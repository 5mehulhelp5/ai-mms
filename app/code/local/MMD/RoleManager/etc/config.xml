<?xml version="1.0"?>
<config>
    <modules>
        <MMD_RoleManager>
            <version>1.3.0</version>
        </MMD_RoleManager>
    </modules>

    <global>
        <models>
            <mmd_rolemanager>
                <class>MMD_RoleManager_Model</class>
                <resourceModel>mmd_rolemanager_mysql4</resourceModel>
            </mmd_rolemanager>
            <mmd_rolemanager_mysql4>
                <class>MMD_RoleManager_Model_Mysql4</class>
                <entities>
                    <role_map>
                        <table>mmd_user_role_map</table>
                    </role_map>
                </entities>
            </mmd_rolemanager_mysql4>
            <!-- WYSIWYG plugin path overrides — OpenMage core points at
                 tinymce/plugins/openmage*.js paths that don't exist; we
                 redirect to the legacy tiny_mce/plugins/magento*.js paths
                 that do. Without this, every WYSIWYG editor 404s on plugin
                 load and silently fails to attach. -->
            <core>
                <rewrite>
                    <variable_config>MMD_RoleManager_Model_Wysiwyg_VariableConfig</variable_config>
                </rewrite>
            </core>
            <widget>
                <rewrite>
                    <widget_config>MMD_RoleManager_Model_Wysiwyg_WidgetConfig</widget_config>
                </rewrite>
            </widget>
        </models>

        <blocks>
            <mmd_rolemanager>
                <class>MMD_RoleManager_Block</class>
            </mmd_rolemanager>
            <adminhtml>
                <rewrite>
                    <page_menu>MMD_RoleManager_Block_Page_Menu</page_menu>
                </rewrite>
            </adminhtml>
        </blocks>

        <helpers>
            <mmd_rolemanager>
                <class>MMD_RoleManager_Helper</class>
            </mmd_rolemanager>
        </helpers>

        <resources>
            <mmd_rolemanager_setup>
                <setup>
                    <module>MMD_RoleManager</module>
                </setup>
                <connection>
                    <use>core_setup</use>
                </connection>
            </mmd_rolemanager_setup>
            <mmd_rolemanager_write>
                <connection>
                    <use>core_write</use>
                </connection>
            </mmd_rolemanager_write>
            <mmd_rolemanager_read>
                <connection>
                    <use>core_read</use>
                </connection>
            </mmd_rolemanager_read>
        </resources>

        <events>
            <admin_session_user_login_success>
                <observers>
                    <mmd_rolemanager_login>
                        <class>mmd_rolemanager/observer</class>
                        <method>onAdminLogin</method>
                    </mmd_rolemanager_login>
                </observers>
            </admin_session_user_login_success>
            <controller_action_predispatch>
                <observers>
                    <mmd_rolemanager_predispatch>
                        <class>mmd_rolemanager/observer</class>
                        <method>onPredispatch</method>
                    </mmd_rolemanager_predispatch>
                </observers>
            </controller_action_predispatch>
            <cms_wysiwyg_config_prepare>
                <observers>
                    <mmd_rolemanager_wysiwyg>
                        <class>mmd_rolemanager/observer</class>
                        <method>onWysiwygConfigPrepare</method>
                    </mmd_rolemanager_wysiwyg>
                </observers>
            </cms_wysiwyg_config_prepare>
        </events>
    </global>

    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <MMD_RoleManager before="Mage_Adminhtml">MMD_RoleManager_Adminhtml</MMD_RoleManager>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>

    <!-- Public frontend route for trainer invitation accept/decline.
         URL: /trainer_invite/respond?token=<hex>&action=accept|decline
         No session or login required — token is the authentication. -->
    <frontend>
        <routers>
            <mmd_rolemanager_trainer>
                <use>standard</use>
                <args>
                    <module>MMD_RoleManager</module>
                    <frontName>trainer_invite</frontName>
                </args>
            </mmd_rolemanager_trainer>
        </routers>
    </frontend>

    <adminhtml>
        <layout>
            <updates>
                <mmd_rolemanager>
                    <file>rolemanager.xml</file>
                </mmd_rolemanager>
            </updates>
        </layout>
    </adminhtml>

    <!-- Class formation cron — backend-only worker that materialises
         course_runs + course_run_enrolments from sales_flat_order. Runs
         every minute. Reads sales tables only; never written by storefront
         code paths. See Model/Cron/ClassFormation.php for the full
         frontend-invariant contract. -->
    <crontab>
        <jobs>
            <mmd_rolemanager_class_formation>
                <schedule><cron_expr>* * * * *</cron_expr></schedule>
                <run><model>mmd_rolemanager/cron_classFormation::run</model></run>
            </mmd_rolemanager_class_formation>
            <!-- Trainer invitation auto-sweep — Mon & Thu at 10:00 SGT.
                 Finds upcoming classes (within 30 days) with enrolled learners
                 but no trainer and no pending invitation, then sends the next
                 eligible trainer an invitation email. -->
            <mmd_rolemanager_trainer_invitation>
                <schedule><cron_expr>0 10 * * 1,4</cron_expr></schedule>
                <run><model>mmd_rolemanager/cron_trainerInvitation::run</model></run>
            </mmd_rolemanager_trainer_invitation>
            <!-- Daily trainer import from LMS — fail-safe gated by
                 mmd/trainer_import/auto_enabled (absent = OFF). 03:30 SGT. -->
            <mmd_rolemanager_trainer_import>
                <schedule><cron_expr>30 3 * * *</cron_expr></schedule>
                <run><model>mmd_rolemanager/cron_trainerImport::run</model></run>
            </mmd_rolemanager_trainer_import>
            <!-- Daily course sync from SG — country instances only, fail-safe
                 gated by mmd/course_sync/auto_enabled (absent = OFF). 03:00 SGT.
                 Silently skips when MMS_MODE != country. -->
            <mmd_rolemanager_course_sync>
                <schedule><cron_expr>0 3 * * *</cron_expr></schedule>
                <run><model>mmd_rolemanager/cron_courseSync::run</model></run>
            </mmd_rolemanager_course_sync>
        </jobs>
    </crontab>
</config>
