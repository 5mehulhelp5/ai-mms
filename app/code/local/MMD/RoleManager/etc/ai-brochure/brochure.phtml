/**
 * Compact A4 brochure — fits a typical course on one page, max two.
 * Two-column body layout mirrors the storefront product page (Ultimo
 * theme) where the Course Information / Skills Framework / Learning
 * Outcomes stack on the left and the title / about / WSQ Funding /
 * CTA stack on the right.
 *
 * Rendered by
 * MMD_RoleManager_Adminhtml_CoursesaveController::generateBrochureAction()
 * via PHP `include` with extract($context).
 *
 * No @page CSS rule — page format and margins are set in the Mpdf
 * constructor. Past experiments showed @page combined with constructor
 * margins ballooned the output to ~9 MB / 17 000 pages.
 */

$paraify = function ($text) {
    $out = '';
    foreach (preg_split('/\n\s*\n/', trim((string) $text)) as $p) {
        $p = trim(preg_replace('/\s+/', ' ', $p));
        if ($p !== '') $out .= '<p>' . htmlspecialchars($p) . '</p>';
    }
    return $out;
};
