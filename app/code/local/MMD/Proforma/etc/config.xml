<?xml version="1.0"?>
<config>
    <modules>
        <MMD_Proforma>
            <version>1.0.0</version>
        </MMD_Proforma>
    </modules>

    <global>
        <models>
            <proforma>
                <class>MMD_Proforma_Model</class>
            </proforma>
            <!-- Expose getIsSelfSponsored() on the order for the email template.
                 No other active module rewrites sales/order. -->
            <sales>
                <rewrite>
                    <order>MMD_Proforma_Model_Order</order>
                </rewrite>
            </sales>
        </models>
        <helpers>
            <proforma>
                <class>MMD_Proforma_Helper</class>
            </proforma>
        </helpers>
    </global>

    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <MMD_Proforma before="Mage_Adminhtml">MMD_Proforma_Adminhtml</MMD_Proforma>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>

    <adminhtml>
        <events>
            <!-- Adds a "Pro Forma Invoice" download button to the order view. -->
            <adminhtml_block_html_before>
                <observers>
                    <mmd_proforma_order_view_button>
                        <class>proforma/observer</class>
                        <method>addOrderViewButton</method>
                    </mmd_proforma_order_view_button>
                </observers>
            </adminhtml_block_html_before>
        </events>
    </adminhtml>

    <frontend>
        <routers>
            <proforma>
                <use>standard</use>
                <args>
                    <module>MMD_Proforma</module>
                    <!-- matches the legacy email link path /pdf/?orderID=... -->
                    <frontName>pdf</frontName>
                </args>
            </proforma>
        </routers>
    </frontend>
</config>
