<?xml version="1.0"?>
<config>
    <modules>
        <MMD_CourseImage>
            <version>1.0.0</version>
        </MMD_CourseImage>
    </modules>

    <global>
        <helpers>
            <mmd_courseimage>
                <class>MMD_CourseImage_Helper</class>
            </mmd_courseimage>
        </helpers>
        <models>
            <mmd_courseimage>
                <class>MMD_CourseImage_Model</class>
            </mmd_courseimage>
            <!--
                Emit category banner URLs straight from Cloudflare R2 instead of
                /media/catalog/category/ (which is absent from the prod image and
                only resolves via the media/.htaccess 302 fallback). Direct R2 URL
                drops the redirect hop and makes the storefront src visibly R2.
            -->
            <catalog>
                <rewrite>
                    <category>MMD_CourseImage_Model_Catalog_Category</category>
                </rewrite>
            </catalog>
        </models>
    </global>

    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <MMD_CourseImage before="Mage_Adminhtml">MMD_CourseImage_Adminhtml</MMD_CourseImage>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
</config>
