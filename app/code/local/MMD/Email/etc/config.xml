<?xml version="1.0"?>
<!--
  MMD_Email — keeps transactional email working without a cron daemon.

  Two responsibilities:

  1. Auto-flush core/email_queue. The Docker image runs Apache only, no
     crond, so Magento's queued mail (order confirmation, invoice,
     shipment, etc.) would otherwise sit in the table forever. We
     rewrite core/email_queue to extend Aschroder_SMTPPro_Model_Email_Queue
     and trigger send() right after a message is queued — same SMTPPro
     transport path that cron would have used.

  2. MX-record validation on customer save. Catches typos like
     @gnail.com / @gmial.com that pass the format-only check.
-->
<config>
    <modules>
        <MMD_Email>
            <version>1.0.0</version>
        </MMD_Email>
    </modules>
    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <mmd_email after="Mage_Adminhtml">MMD_Email_Adminhtml</mmd_email>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
    <global>
        <helpers>
            <mmd_email>
                <class>MMD_Email_Helper</class>
            </mmd_email>
        </helpers>
        <models>
            <mmd_email>
                <class>MMD_Email_Model</class>
            </mmd_email>
            <core>
                <rewrite>
                    <email_queue>MMD_Email_Model_Queue</email_queue>
                </rewrite>
            </core>
        </models>
        <events>
            <customer_save_before>
                <observers>
                    <mmd_email_validate_customer>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>validateCustomerEmail</method>
                    </mmd_email_validate_customer>
                </observers>
            </customer_save_before>
            <sales_order_place_after>
                <observers>
                    <mmd_email_send_course_registration>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>sendCourseRegistrationEmail</method>
                    </mmd_email_send_course_registration>
                </observers>
            </sales_order_place_after>
            <!--
                Install our Gmail OAuth2 transport as Zend_Mail's default
                at the very start of every front-controller request. Every
                Magento email path (orders, invoices, shipments, password
                resets, newsletter, contact form, …) calls $mail->send()
                with no transport argument and so picks up the default.
                One observer, one transport, every email type covered.
            -->
            <controller_front_init_before>
                <observers>
                    <mmd_email_install_default_transport>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>installDefaultTransport</method>
                    </mmd_email_install_default_transport>
                </observers>
            </controller_front_init_before>
            <!--
                Set Reply-To to the per-store sales identity on every
                outbound template. Customers replying to a Gmail-OAuth-
                sent email would otherwise land in the OAuth sender's
                mailbox (sales@tertiarycourses.com.sg) regardless of
                which country store fired the email. This observer
                routes the reply to e.g. sales@tertiarycourses.com.my
                for an MY order.
            -->
            <email_template_send_before>
                <observers>
                    <mmd_email_set_reply_to>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>setReplyTo</method>
                    </mmd_email_set_reply_to>
                </observers>
            </email_template_send_before>
            <!--
                Aschroder SMTPPro rewrites core/email_template and core/email
                and, when enabled, ALWAYS sends via its own SMTP transport
                (passed explicitly to $mail->send($transport), which wins
                over Zend_Mail::getDefaultTransport()). For Singapore we
                must guarantee Gmail OAuth is used for *every* email path —
                including contact-form staff notifications and any other
                Magento mailer that lands in SMTPPro. These two observers
                hand SMTPPro our Gmail transport when the current store is
                SG (or admin), so SG always ships via Gmail and the other
                country stores keep their normal SMTPPro behaviour.
            -->
            <aschroder_smtppro_template_before_send>
                <observers>
                    <mmd_email_force_gmail_sg>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>forceGmailTransportForSg</method>
                    </mmd_email_force_gmail_sg>
                </observers>
            </aschroder_smtppro_template_before_send>
            <aschroder_smtppro_before_send>
                <observers>
                    <mmd_email_force_gmail_sg>
                        <type>singleton</type>
                        <class>mmd_email/observer</class>
                        <method>forceGmailTransportForSg</method>
                    </mmd_email_force_gmail_sg>
                </observers>
            </aschroder_smtppro_before_send>
        </events>
        <template>
            <email>
                <mmd_email_course_registration translate="label" module="mmd_email">
                    <label>Course Registration Confirmation</label>
                    <file>mmd_email/course_registration.html</file>
                    <type>html</type>
                </mmd_email_course_registration>
            </email>
        </template>
    </global>
    <default>
        <mmd_email>
            <course_registration>
                <enabled>1</enabled>
                <template>mmd_email_course_registration</template>
                <identity>sales</identity>
            </course_registration>
        </mmd_email>
    </default>
</config>
