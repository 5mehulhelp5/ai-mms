<config>
    <global>
        <install>
            <date><![CDATA[Wed, 27 Jan 2016 12:46:08 +0000]]></date>
        </install>
        <crypt>
            <key><![CDATA[your_encryption_key_here]]></key>
        </crypt>
        <disable_local_modules>false</disable_local_modules>
        <resources>
            <db>
                <table_prefix><![CDATA[]]></table_prefix>
            </db>
            <default_setup>
                <connection>
                    <host><![CDATA[db_mysql]]></host>
                    <username><![CDATA[your_username]]></username>
                    <password><![CDATA[your_password]]></password>
                    <dbname><![CDATA[your_database]]></dbname>
                    <initStatements><![CDATA[SET NAMES utf8]]></initStatements>
                    <model><![CDATA[mysql4]]></model>
                    <type><![CDATA[pdo_mysql]]></type>
                    <pdoType><![CDATA[]]></pdoType>
                    <active>1</active>
                </connection>
            </default_setup>
        </resources>
        <!-- Sessions stored in the core_session DB table so they survive container
             rebuilds (Coolify replaces the container on every deploy). Migration
             027 ensures the table exists. Do not change to "files" without also
             configuring a persistent volume mount for /var/www/html/var/session. -->
        <session_save><![CDATA[db]]></session_save>
        <!-- MMD Marketing newsletter builder.
             Read by MMD_RoleManager_Helper_Data::getMarketingApiConfig().
             Empty values flip the newsletter controller into stub mode
             (mock Claude responses, MailerLite IDs prefixed STUB-) so the
             admin UI works without real keys. Drop in real keys here when
             ready and the same code paths go live. -->
        <mmd_marketing>
            <api>
                <anthropic_key><![CDATA[]]></anthropic_key>
                <anthropic_model><![CDATA[claude-sonnet-4-6]]></anthropic_model>
                <mailerlite_key><![CDATA[]]></mailerlite_key>
                <from_name><![CDATA[Tertiary Infotech Academy]]></from_name>
                <from_email><![CDATA[noreply@tertiaryinfotech.com]]></from_email>
            </api>
        </mmd_marketing>
    </global>
    <admin>
        <routers>
            <adminhtml>
                <args>
                    <frontName><![CDATA[your_admin_path]]></frontName>
                </args>
            </adminhtml>
        </routers>
    </admin>
</config>
