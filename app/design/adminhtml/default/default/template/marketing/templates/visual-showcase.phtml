/**
 * Email template — Visual Showcase.
 *
 * Image-driven, color-blocked layout. Uploaded reference images are
 * used as backgrounds (with semi-transparent color overlays for text
 * legibility), and when 2+ images are present they overlap in a
 * collage band. Falls back gracefully to color blocks alone when no
 * images are uploaded.
 *
 * Sections (top-to-bottom):
 *   1. Hero — first reference image as full-bleed background, with a
 *      tinted gradient overlay so the course title stays readable in
 *      large knockout type.
 *   2. Tagline bar — bold color strip with body_block_1.
 *   3. Image collage — uses 2nd and 3rd reference images (or repeats
 *      the 1st if only one was uploaded) in an offset/overlapping
 *      pair. On clients that strip absolute positioning the images
 *      stack side-by-side instead.
 *   4. What you'll learn — bold color background with semi-transparent
 *      image watermark behind numbered cards.
 *   5. Pricing band — third reference image as side accent.
 *   6. CTA — full-width image with dark gradient + glowing button.
 *   7. Footer — bold color band with contact info.
 *
 * Expected $vars are the same set the controller passes to every
 * marketing template — see course-promo.phtml for the full list.
 */

$v = function ($k, $default = '') use ($vars) { return isset($vars[$k]) ? $vars[$k] : $default; };

$design  = $v('design', array());
$palette = isset($design['palette']) ? $design['palette'] : array(
    'primary' => '#d4276e', 'dark' => '#7c1741', 'accent' => '#2bc4d4',
    'yellow' => '#ffc83d', 'sub' => '#e63946',
);
$primary = $palette['primary'];
$dark    = $palette['dark'];
$accent  = $palette['accent'];
$yellow  = $palette['yellow'];

// Perceived luminance (ITU-R BT.601 weighting). Used to pick a text
// colour that stays readable on whatever the palette throws at us —
// e.g. the `crimson-cream` palette has a pale accent (#fef3c7), so the
// tagline strip needs DARK text on it, not white.
$luma = function ($hex) {
    $hex = ltrim((string) $hex, '#');
    if (strlen($hex) === 3) {
        $hex = $hex[0] . $hex[0] . $hex[1] . $hex[1] . $hex[2] . $hex[2];
    }
    if (strlen($hex) !== 6) return 0;
    $r = hexdec(substr($hex, 0, 2));
    $g = hexdec(substr($hex, 2, 2));
    $b = hexdec(substr($hex, 4, 2));
    return (int) (0.299 * $r + 0.587 * $g + 0.114 * $b);
};
$onAccent = $luma($accent) > 160 ? $dark    : '#ffffff';
$onYellow = $luma($yellow) > 160 ? $dark    : '#ffffff';
$onPrimary= $luma($primary)> 160 ? $dark    : '#ffffff';

$courses     = $v('courses', array());
$first       = !empty($courses) ? $courses[0] : null;
$courseTitle = $first && !empty($first['name']) ? $first['name'] : $v('title', 'Newsletter');
$courseUrl   = $first && !empty($first['url'])  ? $first['url']  : $v('cta_url', '#');

$courseDates = '';
if ($first) {
    $startTs = !empty($first['start_date']) ? strtotime($first['start_date']) : 0;
    $endTs   = !empty($first['end_date'])   ? strtotime($first['end_date'])   : $startTs;
    if ($startTs && $endTs) {
        if (date('Y-m-d', $startTs) === date('Y-m-d', $endTs)) {
            $courseDates = strtoupper(date('j M Y', $startTs));
        } else {
            $courseDates = strtoupper(date('j', $startTs) . ' &ndash; ' . date('j M Y', $endTs));
        }
    }
}

$tagline = trim((string) $v('body_block_1'));

$bullets = array();
foreach (preg_split('/\R+/', (string) $v('body_block_2')) as $ln) {
    $ln = trim(preg_replace('/^[-*\x{2022}]\s*/u', '', $ln));
    if ($ln !== '') $bullets[] = $ln;
}
$bullets = array_slice($bullets, 0, 4);

$pricing = array();
foreach (preg_split('/\R+/', (string) $v('body_block_3')) as $ln) {
    if (strpos($ln, '|') === false) continue;
    list($lbl, $pr) = array_map('trim', explode('|', $ln, 2));
    if ($lbl !== '' && $pr !== '') $pricing[] = array('label' => $lbl, 'price' => $pr);
}
$pricing = array_slice($pricing, 0, 4);

// Build data-URI image sources from the uploaded reference images so
// the rendered HTML is self-contained (works in inbox without external
// hosting). _renderTemplate already validated media_type + data.
$images = array();
foreach ((array) $v('images', array()) as $img) {
    if (empty($img['data']) || empty($img['media_type'])) continue;
    $images[] = 'data:' . $img['media_type'] . ';base64,' . $img['data'];
}
// Helper — pick the i-th image, repeating the last available one when
// the user uploaded fewer images than the template wants to show.
$imgAt = function ($i) use ($images, $primary, $dark) {
    if (empty($images)) {
        // No image uploaded — return an inline SVG color block so the
        // section still renders without a broken image icon.
        $svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">'
             . '<defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1">'
             . '<stop offset="0%" stop-color="' . $primary . '"/>'
             . '<stop offset="100%" stop-color="' . $dark . '"/>'
             . '</linearGradient></defs>'
             . '<rect width="600" height="400" fill="url(#g)"/></svg>';
        return 'data:image/svg+xml;base64,' . base64_encode($svg);
    }
    return $images[$i % count($images)];
};

$heroImg     = $imgAt(0);
$collageImgA = $imgAt(1);
$collageImgB = $imgAt(2);
$ctaImg      = $imgAt(0); // re-use hero for CTA so the brand stays cohesive

$fromName  = (string) $v('from_name',  'Tertiary Infotech Academy');
$fromEmail = (string) $v('from_email', 'enquiry@tertiaryinfotech.com');
$country   = (string) $v('country',    '');
$ctaLabel  = strtoupper((string) $v('cta_label', 'REGISTER'));

