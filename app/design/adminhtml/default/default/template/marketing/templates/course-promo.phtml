              <?php echo htmlspecialchars($s['label']) ?>
            </span>
          </td>
        <?php endforeach; ?>
        </tr>
      </table>
      <?php endif; ?>
      <h1 style="margin:0;font-size:30px;line-height:1.1;font-weight:900;letter-spacing:.5px;text-transform:uppercase;color:#ffffff;text-shadow:2px 2px 0 <?php echo $palette['dark'] ?>;">
        <?php echo htmlspecialchars(strtoupper($courseTitle)) ?>
      </h1>
    </td></tr>
    <?php else: /* hero variant 1 — headline first, then yellow pill band */ ?>
    <tr><td style="background:<?php echo $palette['dark'] ?>;padding:30px 24px 24px;text-align:center;color:#ffffff;">
      <h1 style="margin:0;font-size:30px;line-height:1.1;font-weight:900;letter-spacing:.5px;text-transform:uppercase;color:#ffffff;">
