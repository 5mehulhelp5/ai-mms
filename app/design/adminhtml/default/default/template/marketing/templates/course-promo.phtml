<?php
/**
 * Email template — Standard Tertiary Infotech Academy newsletter.
 *
 * Layout sections (rendered top-to-bottom):
 *   1. Coloured header band  — italic course title + class date
 *   2. Hero panel            — uses the first uploaded reference image
 *                              when present, otherwise a coloured
 *                              gradient. Subsidy pills + knockout
 *                              headline overlay/underlay depending on
 *                              the hero variant.
 *   3. Yellow tagline strip  — body_block_1 highlighted
 *   4. Two-column body       — "What you'll learn" cards (numbered or
 *                              checkmark style) on the left, pricing
 *                              table + QR code on the right
 *   5. CTA band              — "Elevate Your..." line + REGISTER pill
 *   6. Class-date repeat     — banner reinforcing the date
 *   7. Footer                — social icons, contact block, copyright,
 *                              unsubscribe / preferences, ATO/PEI tag
 *
 * The colour scheme + hero arrangement + card style are picked from
 * `$vars['design']` (computed from a seed by the controller). Each
 * Send-to-AI re-rolls the seed so the design varies every generation.
 *
 * Expected $vars keys:
 *   subject, preview_text, title, body_block_1..3,
 *   country, country_code, from_name, from_email,
 *   cta_label, cta_url,
 *   courses     — [{entity_id, sku, name, start_date, end_date, price, url}],
 *   subsidies   — [{label, color}] (per-country pill list),
 *   images      — [{media_type, data, name}] (uploaded reference images),
 *   design      — {seed, palette:{primary,dark,accent,yellow,sub}, hero:0|1, cards:0|1}
 */

$v = function ($k, $default = '') use ($vars) { return isset($vars[$k]) ? $vars[$k] : $default; };

$design  = $v('design', array());
$palette = isset($design['palette']) ? $design['palette'] : array(
    'primary' => '#d4276e', 'dark' => '#7c1741', 'accent' => '#2bc4d4',
    'yellow' => '#ffc83d', 'sub' => '#e63946',
);
$heroStyle = isset($design['hero'])  ? (int) $design['hero']  : 0;
$cardStyle = isset($design['cards']) ? (int) $design['cards'] : 0;

$courses     = $v('courses', array());
$first       = !empty($courses) ? $courses[0] : null;
$courseTitle = $first && !empty($first['name']) ? $first['name'] : $v('title', 'Newsletter');

$courseDates = '';
if ($first) {
    $startTs = !empty($first['start_date']) ? strtotime($first['start_date']) : 0;
    $endTs   = !empty($first['end_date'])   ? strtotime($first['end_date'])   : $startTs;
    if ($startTs && $endTs) {
        if (date('Y-m-d', $startTs) === date('Y-m-d', $endTs)) {
            $courseDates = date('j M Y', $startTs);
        } elseif (date('Y-m', $startTs) === date('Y-m', $endTs)) {
            $courseDates = date('j', $startTs) . ' &ndash; ' . date('j M Y', $endTs);
        } else {
            $courseDates = date('j M Y', $startTs) . ' &ndash; ' . date('j M Y', $endTs);
        }
    }
}

$tagline = trim((string) $v('body_block_1'));

$bullets = array();
foreach (preg_split('/\R+/', (string) $v('body_block_2')) as $ln) {
    $ln = trim(preg_replace('/^[-*\x{2022}]\s*/u', '', $ln));
    if ($ln !== '') $bullets[] = $ln;
}
$bullets = array_slice($bullets, 0, 4);

$pricing = array();
foreach (preg_split('/\R+/', (string) $v('body_block_3')) as $ln) {
    if (strpos($ln, '|') === false) continue;
    list($lbl, $pr) = array_map('trim', explode('|', $ln, 2));
    if ($lbl !== '' && $pr !== '') $pricing[] = array('label' => $lbl, 'price' => $pr);
}
$pricing = array_slice($pricing, 0, 4);

$subsidies = $v('subsidies', array());
$ctaUrl    = $v('cta_url') ?: 'https://www.tertiarycourses.com.sg/';
$qrUrl     = 'https://quickchart.io/qr?text=' . urlencode($ctaUrl) . '&size=200&margin=2';

// First reference image (if any) becomes the hero photo. Embedded as a
// data: URI which works in iframe srcdoc previews; for production sends
// MailerLite will need hosted URLs.
$images   = $v('images', array());
$heroImg  = '';
if (!empty($images) && !empty($images[0]['data']) && !empty($images[0]['media_type'])) {
    $heroImg = 'data:' . $images[0]['media_type'] . ';base64,' . $images[0]['data'];
}

// Numbered card colours rotate through palette tones so the cards feel
// connected to the rest of the design.
$cardColors = array($palette['accent'], $palette['sub'], $palette['primary'], $palette['yellow']);
