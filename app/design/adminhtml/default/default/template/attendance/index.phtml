<script>
var ATT_LOAD_URL   = '<?php echo $this->jsQuoteEscape($loadUrl) ?>';
var ATT_SAVE_URL   = '<?php echo $this->jsQuoteEscape($saveUrl) ?>';
var ATT_ADD_URL    = '<?php echo $this->jsQuoteEscape($addUrl) ?>';
var ATT_REMOVE_URL = '<?php echo $this->jsQuoteEscape($removeUrl) ?>';
var ATT_SEARCH_URL = '<?php echo $this->jsQuoteEscape($searchLearnersUrl) ?>'; // debounced server search (shared with Assign Learners)
var _attSearchTimer = null;
var _attChosenEmail = '';                          // email of a picked/known-existing learner
var _attEmailKnown  = { email: '', exists: false };// last email-field existence check
var ATT_FORM_KEY   = window.FORM_KEY || '';
var ATT_READONLY   = <?php echo $readonly ? 'true' : 'false' ?>;          // always false now — completed classes stay editable
var ATT_SHOW_KPIS  = <?php echo $isCompleted ? 'true' : 'false' ?>;        // Completed tab still shows the attendance-rate summary cards
var CERT_SEND_URL   = '<?php echo $this->jsQuoteEscape($certSendUrl) ?>';
var CERT_TOGGLE_URL = '<?php echo $this->jsQuoteEscape($certToggleUrl) ?>';
var attRunId = 0;
var attRoster = [];

function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

// ── Certificate: manual send for the selected class ──────────────────────────
function certSendForClass(btn) {
    if (!attRunId) { alert('Select a class first.'); return; }
    if (!confirm('Generate and email a Certificate of Achievement to every learner marked Present in this class who does not already have one?')) return;
    var st = document.getElementById('cert-send-status');
    var orig = btn.textContent;
    btn.disabled = true; btn.textContent = 'Sending…'; if (st) st.textContent = '';
    fetch(CERT_SEND_URL, {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'run_id=' + attRunId + '&form_key=' + encodeURIComponent(ATT_FORM_KEY)
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        btn.disabled = false; btn.textContent = orig;
        if (st) { st.style.color = d.success ? '#22c55e' : '#f87171'; st.textContent = (d.success ? '✓ ' : '✗ ') + (d.message || ''); }
    })
    .catch(function(){ btn.disabled=false; btn.textContent=orig; if(st){st.style.color='#f87171';st.textContent='✗ Network error';} });
}

// ── Certificate: auto-send fail-safe toggle (braille spinner + tick/cross) ────
var _certSpin = null, _certResultTimer = null;
function certSpinStart(){ var el=document.getElementById('cert-spinner'); if(!el)return; if(_certResultTimer){clearTimeout(_certResultTimer);_certResultTimer=null;} el.style.color='#60a5fa'; el.removeAttribute('title'); var f=['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'],i=0; el.textContent=f[0]; _certSpin=setInterval(function(){i=(i+1)%f.length;el.textContent=f[i];},80); }
function certSpinStop(){ if(_certSpin){clearInterval(_certSpin);_certSpin=null;} }
function certResult(ok,msg){ var el=document.getElementById('cert-spinner'); if(!el)return; el.textContent=ok?'✓':'✗'; el.style.color=ok?'#22c55e':'#ef4444'; if(msg)el.setAttribute('title',msg); _certResultTimer=setTimeout(function(){el.textContent='';el.style.color='#60a5fa';el.removeAttribute('title');_certResultTimer=null;},2500); }

function certToggle(cb) {
    var val = cb.checked ? 1 : 0;
    cb.checked = (val === 0); // hold until server confirms
    if (val === 1 && !confirm('Enable automatic certificate emails?\n\nA daily sweep will email certificates to learners marked Present once their class has ended.')) return;
    cb.disabled = true; certSpinStart();
    var fd = new FormData(); fd.append('value', val); fd.append('form_key', ATT_FORM_KEY);
    fetch(CERT_TOGGLE_URL, { method:'POST', body:fd, credentials:'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(d){
            cb.disabled = false; certSpinStop();
            if (!d.success) { certResult(false, d.message || 'Failed'); return; }
            var on = (d.value === 1); cb.checked = on;
            cb.closest('.dcf-toggle-sw').setAttribute('title', on ? 'Auto-send ON' : 'Auto-send OFF');
            var b = document.getElementById('cert-banner');
            if (b) { b.style.borderColor = on?'rgba(34,197,94,.3)':'rgba(100,116,139,.25)'; b.style.background = on?'rgba(34,197,94,.08)':'rgba(100,116,139,.06)'; }
            certResult(true);
        })
        .catch(function(){ cb.disabled=false; certSpinStop(); certResult(false,'Network error'); });
}

function attSelectClass(runId) {
    attRunId = parseInt(runId, 10) || 0;
    var card = document.getElementById('att-roster-card');
    var pills = document.getElementById('att-pills');
    if (!attRunId) { card.style.display = 'none'; pills.innerHTML = ''; return; }

    var opt = document.querySelector('#att-class option[value="' + attRunId + '"]');
    if (opt) {
        var start = opt.getAttribute('data-start'); var end = opt.getAttribute('data-end');
        var fmt = function(d){ if(!d) return '—'; var x=new Date(d); return isNaN(x)? d : x.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}); };
        pills.innerHTML =
            '<span class="att-pill">Class ID <b>' + esc(opt.getAttribute('data-class-id')) + '</b></span>' +
            '<span class="att-pill">Code <b>' + esc(opt.getAttribute('data-sku')) + '</b></span>' +
            '<span class="att-pill">Start <b>' + fmt(start) + '</b></span>' +
            '<span class="att-pill">End <b>' + fmt(end) + '</b></span>' +
            (opt.getAttribute('data-trainer') ? '<span class="att-pill">Trainer <b>' + esc(opt.getAttribute('data-trainer')) + '</b></span>' : '');
    }

    fetch(ATT_LOAD_URL + '?run_id=' + attRunId, { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(d){
            if (!d.success) { alert('Error: ' + (d.message || 'load failed')); return; }
            attRoster = d.roster || [];
            attRender();
            card.style.display = '';
        })
        .catch(function(){ alert('Network error loading roster.'); });
}

function attRender() {
    var tb = document.getElementById('att-tbody');
    var html = '';
    if (!attRoster.length) {
        var cols = ATT_READONLY ? 4 : 6;
        document.getElementById('att-table').style.display = attRoster.length ? '' : 'none';
        tb.innerHTML = '';
        var empty = document.getElementById('att-empty-row');
        document.getElementById('att-roster-card').querySelector('#att-kpis').style.display = 'none';
        tb.innerHTML = '<tr><td colspan="' + cols + '" class="att-empty">No learners enrolled' + (ATT_READONLY ? '' : '. Use “+ Add Learner”.') + '</td></tr>';
        attUpdateCounters();
        return;
    }
    document.getElementById('att-table').style.display = '';
    attRoster.forEach(function(r, i) {
        var present = !!r.is_present;
        var rowCls = r.is_walkin ? ' class="walkin"' : '';
        html += '<tr' + rowCls + ' data-idx="' + i + '">'
            + '<td style="color:#64748b">' + (i + 1) + '</td>'
            + '<td>' + esc(r.learner_name || '—') + (r.is_walkin ? '<span class="att-badge-walkin">Walk-in</span>' : '') + '</td>'
            + '<td style="color:#94a3b8;font-size:12px;">' + esc(r.learner_email) + '</td>';
        if (ATT_READONLY) {
            html += '<td>' + (present
                ? '<span class="att-present-lbl" style="color:#22c55e">✓ Present</span>'
                : '<span class="att-present-lbl" style="color:#f87171">✗ Absent</span>') + '</td>';
        } else {
            html += '<td>'
                + '<label style="display:inline-flex;align-items:center;gap:8px;cursor:pointer;">'
                + '<input type="checkbox" ' + (present ? 'checked' : '') + ' onchange="attToggle(' + i + ', this.checked)" style="width:16px;height:16px;accent-color:#22c55e;">'
                + '<span class="att-present-lbl" id="att-lbl-' + i + '" style="color:' + (present ? '#22c55e' : '#f87171') + '">' + (present ? '✓ Present' : '✗ Absent') + '</span>'
                + '</label></td>'
                + '<td><input type="text" class="att-reason" id="att-reason-' + i + '" placeholder="Enter reason..." value="' + esc(r.reason_of_absence) + '" oninput="attReason(' + i + ', this.value)"' + (present ? ' style="display:none;"' : '') + '></td>'
                + '<td>' + (r.is_walkin ? '<button type="button" class="att-btn att-btn-danger" style="padding:3px 8px;" onclick="attRemove(' + i + ')">Remove</button>' : '') + '</td>';
        }
        html += '</tr>';
    });
    document.getElementById('att-tbody').innerHTML = html;
    attUpdateCounters();
    if (ATT_SHOW_KPIS) attRenderKpis();
}

function attToggle(i, checked) {
    attRoster[i].is_present = checked ? 1 : 0;
    var lbl = document.getElementById('att-lbl-' + i);
    var reason = document.getElementById('att-reason-' + i);
    if (lbl) { lbl.textContent = checked ? '✓ Present' : '✗ Absent'; lbl.style.color = checked ? '#22c55e' : '#f87171'; }
    if (reason) { reason.style.display = checked ? 'none' : ''; if (checked) { reason.value=''; attRoster[i].reason_of_absence=''; } }
    attUpdateCounters();
}
function attReason(i, val) { attRoster[i].reason_of_absence = val; }

function attAllPresent() {
    attRoster.forEach(function(r){ r.is_present = 1; r.reason_of_absence = ''; });
    attRender();
}

function attUpdateCounters() {
    var p = 0; attRoster.forEach(function(r){ if (r.is_present) p++; });
    document.getElementById('att-cnt-present').textContent = p;
    document.getElementById('att-cnt-absent').textContent = attRoster.length - p;
    document.getElementById('att-cnt-total').textContent = attRoster.length;
}

function attRenderKpis() {
    var kp = document.getElementById('att-kpis');
    var total = attRoster.length;
    var present = 0; attRoster.forEach(function(r){ if (r.is_present) present++; });
    var pct = total ? Math.round((present / total) * 100) : 0;
    var col = pct >= 75 ? '#22c55e' : (pct >= 50 ? '#f59e0b' : '#f87171');
    kp.innerHTML =
        '<div class="att-kpi"><div class="att-kpi-num" style="color:#e2e8f0">' + total + '</div><div class="att-kpi-lbl">No. of Learners</div></div>' +
        '<div class="att-kpi"><div class="att-kpi-num" style="color:#22c55e">' + present + '</div><div class="att-kpi-lbl">Present</div></div>' +
        '<div class="att-kpi"><div class="att-kpi-num" style="color:' + col + '">' + pct + '%</div><div class="att-kpi-lbl">Attendance Rate</div></div>';
    kp.style.display = '';
}

function attSave() {
    var btn = document.getElementById('att-save-btn');
    var st = document.getElementById('att-save-status');
    btn.disabled = true; btn.textContent = 'Saving…'; st.textContent = '';
    fetch(ATT_SAVE_URL, {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ run_id: attRunId, form_key: ATT_FORM_KEY, records: attRoster })
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        btn.disabled = false; btn.textContent = 'Save Attendance';
        st.style.color = d.success ? '#22c55e' : '#f87171';
        st.textContent = (d.success ? '✓ ' : '✗ ') + (d.message || '');
        setTimeout(function(){ st.textContent=''; }, 3000);
    })
    .catch(function(){ btn.disabled=false; btn.textContent='Save Attendance'; st.style.color='#f87171'; st.textContent='✗ Network error'; });
}

function attHideAddResults() {
    var box = document.getElementById('att-add-results');
    if (box) box.style.display = 'none';
}

// Braille search spinner + tick/cross (mirrors the cert toggle's certSpin*).
var _attSpin = null, _attSpinResultTimer = null;
function attSpinStart() {
    var el = document.getElementById('att-search-spin'); if (!el) return;
    if (_attSpinResultTimer) { clearTimeout(_attSpinResultTimer); _attSpinResultTimer = null; }
    el.style.display = 'inline-block'; el.style.color = '#60a5fa';
    var f = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'], i = 0; el.textContent = f[0];
    if (_attSpin) clearInterval(_attSpin);
    _attSpin = setInterval(function(){ i = (i+1) % f.length; el.textContent = f[i]; }, 80);
}
function attSpinResult(ok) {
    var el = document.getElementById('att-search-spin'); if (!el) return;
    if (_attSpin) { clearInterval(_attSpin); _attSpin = null; }
    el.style.display = 'inline-block'; el.textContent = ok ? '✓' : '✗';
    el.style.color = ok ? '#22c55e' : '#ef4444';
    _attSpinResultTimer = setTimeout(function(){ el.textContent = ''; el.style.display = 'none'; }, 1500);
}
function attSpinClear() {
    var el = document.getElementById('att-search-spin'); if (!el) return;
    if (_attSpin) { clearInterval(_attSpin); _attSpin = null; }
    if (_attSpinResultTimer) { clearTimeout(_attSpinResultTimer); _attSpinResultTimer = null; }
    el.textContent = ''; el.style.display = 'none';
}

// Typing in name OR email triggers a DEBOUNCED server search (shared with the
// Assign Learners panel). Results show in a dropdown anchored under the active
// field. Searching the EMAIL field doubles as the existing-account check.
function attAddSearch(input) {
    var box = document.getElementById('att-add-results');
    if (!box) return;
    input.parentNode.appendChild(box); // anchor under the active field
    var spin = document.getElementById('att-search-spin');
    if (spin) input.parentNode.appendChild(spin); // move spinner into the active field
    var isEmail = (input.id === 'att-add-email');
    var q = (input.value || '').trim();
    // Manually editing the email away from a picked learner clears the pick.
    if (isEmail && q.toLowerCase() !== _attChosenEmail) _attChosenEmail = '';
    attUpdateAddState();

    if (_attSearchTimer) clearTimeout(_attSearchTimer);
    if (q.length < 2) { box.style.display = 'none'; attSpinClear(); return; }

    attSpinStart();
    _attSearchTimer = setTimeout(function() {
        fetch(ATT_SEARCH_URL + '?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
          .then(function(r){ return r.json(); })
          .then(function(j){
              var list = (j && j.success && j.learners) ? j.learners : [];
              attSpinResult(list.length > 0);
              // Email-field search confirms whether the exact email exists.
              if (isEmail) {
                  var ql = q.toLowerCase();
                  _attEmailKnown = {
                      email: ql,
                      exists: list.some(function(l){ return (l.email || '').toLowerCase() === ql; })
                  };
                  attUpdateAddState();
              }
              box.innerHTML = '';
              if (!list.length) {
                  var n = document.createElement('div');
                  n.style.cssText = 'padding:8px 10px;color:#64748b;font-size:12px;';
                  n.textContent = 'No matches';
                  box.appendChild(n);
                  box.style.display = 'block';
                  return;
              }
              list.forEach(function(l) {
                  var d = document.createElement('div');
                  d.style.cssText = 'padding:8px 10px;cursor:pointer;font-size:12px;border-bottom:1px solid #1e293b;';
                  d.onmouseover = function(){ d.style.background = '#1e293b'; };
                  d.onmouseout  = function(){ d.style.background = 'transparent'; };
                  d.innerHTML = '<span style="color:#e2e8f0;">' + esc(l.name) + '</span> <span style="color:#64748b;">' + esc(l.email) + '</span>';
                  d.onmousedown = function(e){ e.preventDefault(); attPickLearner(l.email, l.name); };
                  box.appendChild(d);
              });
              box.style.display = 'block';
          })
          .catch(function(){ attSpinResult(false); box.style.display = 'none'; });
    }, 200);
}

function attPickLearner(email, name) {
    document.getElementById('att-add-name').value  = name || '';
    document.getElementById('att-add-email').value = email || '';
    _attChosenEmail = (email || '').toLowerCase();
    attHideAddResults();
    attUpdateAddState();
}

// Existing if the learner was picked from the list, or the email-field search
// confirmed an exact match. Otherwise (email present) it's a new account.
function attUpdateAddState() {
    var email  = (document.getElementById('att-add-email').value || '').trim().toLowerCase();
    var note   = document.getElementById('att-add-note');
    var status = document.getElementById('att-add-status');
    var btn    = document.getElementById('att-add-btn');
    var existing = !!email && (email === _attChosenEmail || (_attEmailKnown.email === email && _attEmailKnown.exists));
    if (existing) {
        status.style.display = 'block'; status.style.color = '#22c55e';
        status.textContent = '✓ Existing learner — they will be enrolled into this class (no new account created).';
        if (note) note.textContent = 'This learner already exists. They will be added to this class roster.';
        btn.textContent = 'Add to Class';
    } else if (email) {
        status.style.display = 'block'; status.style.color = '#f59e0b';
        status.textContent = '⚠ No existing learner with this email — submitting will CREATE a new learner account with the name + email above.';
        if (note) note.textContent = 'No match found. A new learner account will be created and added to this class.';
        btn.textContent = 'Create & Add Learner';
    } else {
        status.style.display = 'none';
        if (note) note.textContent = 'Type a name or email. If the learner already exists, pick them from the list; otherwise a new learner account will be created and added to this class.';
        btn.textContent = 'Add Learner';
    }
}

function attOpenAdd() {
    document.getElementById('att-add-name').value = '';
    document.getElementById('att-add-email').value = '';
    document.getElementById('att-add-err').style.display = 'none';
    _attChosenEmail = '';
    _attEmailKnown  = { email: '', exists: false };
    attHideAddResults();
    attUpdateAddState();
    document.getElementById('att-add-modal').style.display = 'flex';
}
document.getElementById('att-add-modal').addEventListener('click', function(e){ if (e.target === this) this.style.display='none'; });
// Dismiss the autocomplete dropdown when clicking outside the inputs/list.
document.addEventListener('click', function(e){
    var box = document.getElementById('att-add-results');
    if (!box || box.style.display === 'none') return;
    if (e.target.id === 'att-add-name' || e.target.id === 'att-add-email' || box.contains(e.target)) return;
    box.style.display = 'none';
});

function attAddLearner() {
    var name = document.getElementById('att-add-name').value.trim();
    var email = document.getElementById('att-add-email').value.trim();
    var err = document.getElementById('att-add-err');
    if (!name || !email) { err.textContent = 'Name and email are required.'; err.style.display='block'; return; }
    if (email.indexOf('@') < 0) { err.textContent = 'Please enter a valid email address.'; err.style.display='block'; return; }
    var btn = document.getElementById('att-add-btn');
    btn.disabled = true; btn.textContent = 'Adding…';
    fetch(ATT_ADD_URL, {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ run_id: attRunId, full_name: name, email: email, form_key: ATT_FORM_KEY })
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        btn.disabled = false; btn.textContent = 'Add Learner';
        if (!d.success) { err.textContent = d.message || 'Failed to add.'; err.style.display='block'; return; }
        document.getElementById('att-add-modal').style.display = 'none';
        attSelectClass(attRunId); // reload roster
    })
    .catch(function(){ btn.disabled=false; btn.textContent='Add Learner'; err.textContent='Network error.'; err.style.display='block'; });
}

function attRemove(i) {
    var r = attRoster[i];
    if (!r || !confirm('Remove walk-in ' + (r.learner_name || r.learner_email) + ' from this class?')) return;
    fetch(ATT_REMOVE_URL, {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ run_id: attRunId, learner_email: r.learner_email, form_key: ATT_FORM_KEY })
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        if (!d.success) { alert('Error: ' + (d.message || 'remove failed')); return; }
        attSelectClass(attRunId);
    })
    .catch(function(){ alert('Network error.'); });
}

// Deep-link / preselect
(function(){
    var sel = document.getElementById('att-class');
    if (sel && sel.value) attSelectClass(sel.value);
})();
</script>
