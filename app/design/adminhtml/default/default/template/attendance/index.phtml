    <script>
    // Force the .att-tab colors as inline styles — the upstream
    // dark-theme.css §190 has a blanket `a { color: var(--blue)
    // !important }` plus several admin-wide tab styles that win
    // against every CSS rule we can write from this inline <style>.
    // Inline `style` has the highest possible specificity, so this
    // is the bulletproof way to nail the colors on every theme.
    (function(){
        var theme = document.documentElement.getAttribute('data-theme') || 'dark';
        var isLight = theme === 'light';
        document.querySelectorAll('.att-tab').forEach(function(a){
            if (a.classList.contains('active')) {
                a.style.setProperty('background', '#2563eb', 'important');
                a.style.setProperty('color', isLight ? '#0f172a' : '#ffffff', 'important');
            } else {
                a.style.setProperty('background', 'transparent', 'important');
                a.style.setProperty('color', isLight ? '#475569' : '#94a3b8', 'important');
            }
        });
    })();
