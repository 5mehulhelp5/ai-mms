<script type="text/javascript">
//<![CDATA[
    (function injectScheduleSearch() {
        function go() {
            var firstCell = document.querySelector('#customoptionsOptionsGrid table.massaction > tbody > tr > td:first-child')
                         || document.querySelector('#customoptionsOptionsGrid table.massaction tr > td:first-child');
            var titleFilter = document.getElementById('customoptionsOptionsGrid_filter_title');
            if (!firstCell || !titleFilter) {
                return setTimeout(go, 100);
            }
            if (document.getElementById('mmd-schedule-search-input')) return;
            var wrap = document.createElement('span');
            wrap.id = 'mmd-schedule-search-wrap';
            wrap.style.cssText = 'display:inline-block;margin-left:24px;vertical-align:middle;';
            var input = document.createElement('input');
            input.type = 'text';
            input.id = 'mmd-schedule-search-input';
            input.className = 'input-text';
            input.placeholder = 'Search title…';
            input.value = titleFilter.value || '';
            input.style.cssText = 'width:320px;height:30px;padding:4px 10px;border-radius:6px;border:1px solid #2a3447;background:#0f172a;color:#e5e7eb;font-size:13px;box-sizing:border-box;vertical-align:middle;';
            input.addEventListener('keydown', function (e) {
                if (e.keyCode === 13) {
                    e.preventDefault();
                    titleFilter.value = input.value;
                    var grid = (typeof customoptionsOptionsGridJsObject !== 'undefined') ? customoptionsOptionsGridJsObject
                             : (typeof customoptionsOptionsGrid !== 'undefined' ? customoptionsOptionsGrid : null);
                    if (grid && grid.doFilter) {
                        grid.doFilter();
                    }
                }
            });
            wrap.appendChild(input);
            firstCell.appendChild(wrap);
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', go);
        } else {
            go();
        }
    })();
//]]>
</script>