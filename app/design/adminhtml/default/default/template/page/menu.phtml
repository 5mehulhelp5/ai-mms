<script type="text/javascript">
(function(){
    function applyRoleSidebar(role) {
        var map = {
            'Learner':     'sidebar-nav-learner',
            'Trainer':     'sidebar-nav-trainer',
            'Admin':       'sidebar-nav-admin-custom',
            'Marketing':   'sidebar-nav-marketing',
            'Super Admin': 'sidebar-nav-superadmin-custom',
            'Developer':   'sidebar-nav-developer'
        };
        var targetId = map[role] || 'sidebar-nav-admin';
        var ids = ['sidebar-nav-admin','sidebar-nav-admin-custom','sidebar-nav-superadmin-custom','sidebar-nav-marketing','sidebar-nav-learner','sidebar-nav-trainer','sidebar-nav-developer'];
        for (var i = 0; i < ids.length; i++) {
            var el = document.getElementById(ids[i]);
            if (el) el.style.display = (ids[i] === targetId) ? '' : 'none';
        }
