    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ applyRoleSidebar(role); });
    else applyRoleSidebar(role);
    window.__applySidebarRole = applyRoleSidebar;
})();
function toggleToolGroup(btn) {
    var group = btn.parentElement;
    var willOpen = !group.classList.contains('open');
    // Accordion: if this group lives inside a container marked
    // `data-accordion="1"` (e.g. Configuration's tab list), close every
    // sibling group on open so only one section is expanded at a time.
    var container = group.parentElement;
    if (willOpen && container && container.getAttribute('data-accordion') === '1') {
        var siblings = container.querySelectorAll(':scope > .tools-group.open');
        for (var i = 0; i < siblings.length; i++) {
            if (siblings[i] !== group) { siblings[i].classList.remove('open'); }
        }
    }
    group.classList.toggle('open');
}
function setTrainerActiveNav(which) {
    var ids = { myclasses:'trainer-nav-myclasses', edtools:'trainer-nav-edtools', problemsolving:'trainer-nav-problemsolving', dataanalytics:'trainer-nav-dataanalytics', finance:'trainer-nav-finance', statistical:'trainer-nav-statistical', doe:'trainer-nav-doe', spc:'trainer-nav-spc', sustainability:'trainer-nav-sustainability', blockchain:'trainer-nav-blockchain', genai:'trainer-nav-genai', agentic:'trainer-nav-agentic', virtual:'trainer-nav-virtual', billing:'learner-nav-billing', certhistory:'learner-nav-certhistory' };
    for (var key in ids) {
        var el = document.getElementById(ids[key]);
        if (el) el.classList.toggle('active', which === key);
    }
}

// Click-to-highlight for all sidebar items. PHP no longer applies any
// active class on render. The active state is derived purely from the
// URL: detectMirrorTabFromUrl() inspects window.location.pathname/hash
// and decides which sidebar item + top tab should be highlighted, and
// that runs on every page-load-shaped moment (DOMContentLoaded, load,
// hashchange, popstate, pageshow). Click handlers add the same class
// immediately for instant visual feedback before navigation completes.
(function () {
    // Wipe any legacy sessionStorage keys from earlier iterations of
    // this script — they're no longer read, but leaving them in place
    // could confuse anyone inspecting state during a debug session.
    try {
        sessionStorage.removeItem('mmd_sidebar_active_href');
        sessionStorage.removeItem('mmd_sidebar_active_v2');
        sessionStorage.removeItem('mmd_sidebar_active_v3');
    } catch (e) {}

    function clearAll() {
        var els = document.querySelectorAll('.lms-nav-item.active, .tools-group-toggle.active, .tools-sub-item.active');
        for (var i = 0; i < els.length; i++) els[i].classList.remove('active');
    }

    // Highlight whichever sub-item's href best matches the current URL
    // (path + query). Best match = longest matching prefix of the link's
    // pathname+query against the current pathname+query.
    function applyActiveSubItemFromUrl() {
        var here = (window.location.pathname || '') + (window.location.search || '');
        var subs = document.querySelectorAll('a.tools-sub-item[href]');
        var best = null, bestLen = 0;
        for (var i = 0; i < subs.length; i++) {
            var h;
            try { h = new URL(subs[i].href, window.location.origin); } catch (e) { continue; }
            var target = h.pathname + h.search;
            // The href must be a prefix of the current URL; pick the longest such match.
            // Skip very short prefixes (e.g. '/') to avoid false positives.
            if (target.length < 8) { continue; }
            if (here.indexOf(target) === 0 && target.length > bestLen) {
                best = subs[i];
                bestLen = target.length;
            }
        }
        if (best) { best.classList.add('active'); }
    }

    function applyByMirrorTab(mt) {
        if (!mt) return false;
        var match = document.querySelector('.lms-nav-item[data-mirror-tab="' + mt + '"], .tools-group-toggle[data-mirror-tab="' + mt + '"]');
        if (!match) return false;
        match.classList.add('active');
        return true;
    }

    // Inspect the URL + hash and decide which mirror-tab key matches
    // the page the user is actually looking at. This is what keeps the
    // sidebar / top bar / main-page content in sync — without it we'd
    // be relying purely on sessionStorage (the last thing clicked),
    // which goes stale the moment the user navigates by URL, browser
    // back/forward, or a deep link.
    function detectMirrorTabFromUrl() {
        var path = (window.location.pathname || '').toLowerCase();
        var hash = (window.location.hash || '').toLowerCase();
        if (path.indexOf('/system_account') >= 0) return 'profile';
        if (path.indexOf('/dashboard') >= 0) {
            if (hash === '#billing')     return 'billing';
            if (hash === '#certhistory') return 'certhistory';
            if (hash === '#edtools')     return 'edtools';
            if (hash === '#genai')       return 'genai';
            // No specific hash → dashboard's default for learner/trainer
            // is the My Classes panel.
            return 'myclasses';
        }
        return '';
    }

    // When a sidebar item carries `data-mirror-tab="X"`, clicking it
    // should also activate the matching top-bar tab (either learner or
    // trainer style) so the two stay visually in sync. Looks up by the
    // tab's own data-* attribute — works for both .header-lnr-tab and
    // .header-trn-tab without needing role-specific logic here.
    function mirrorTopTab(which) {
        if (!which) return;
        var topTabs = document.querySelectorAll('.header-lnr-tab[data-lnr-tab], .header-trn-tab[data-trn-tab]');
        var matched = false;
        for (var i = 0; i < topTabs.length; i++) {
            var t = topTabs[i];
            var key = t.getAttribute('data-lnr-tab') || t.getAttribute('data-trn-tab');
            if (key === which) matched = true;
        }
        if (!matched) return; // no top-bar equivalent — leave top bar alone
        for (var j = 0; j < topTabs.length; j++) {
            var tt = topTabs[j];
            var k = tt.getAttribute('data-lnr-tab') || tt.getAttribute('data-trn-tab');
            tt.classList.toggle('active', k === which);
        }
    }

    function attach() {
        // Click handlers give immediate visual feedback (highlight the
        // clicked item) just before the browser navigates. The actual
        // source of truth is the URL — when the page reloads,
        // detectMirrorTabFromUrl() decides what's active. So we don't
        // need to persist anything across navigations.
        document.querySelectorAll('a.lms-nav-item').forEach(function (a) {
            a.addEventListener('click', function () {
                clearAll();
                a.classList.add('active');
                mirrorTopTab(a.getAttribute('data-mirror-tab') || '');
            });
        });
        document.querySelectorAll('.tools-group-toggle').forEach(function (t) {
            t.addEventListener('click', function () {
                clearAll();
                t.classList.add('active');
                mirrorTopTab(t.getAttribute('data-mirror-tab') || '');
            });
        });
        document.querySelectorAll('a.tools-sub-item').forEach(function (a) {
            a.addEventListener('click', function () {
                clearAll();
                a.classList.add('active');
            });
        });

        // On page load, active state is derived purely from the URL —
        // no sessionStorage to go stale, no "last clicked" memory to
        // disagree with the page the user is actually looking at.
        clearAll();
        var urlMt = detectMirrorTabFromUrl();
        if (urlMt) {
            applyByMirrorTab(urlMt);
            mirrorTopTab(urlMt);
        }
        // Also highlight the matching sub-item (Configuration, Users, etc.).
        applyActiveSubItemFromUrl();
    }

    // Public entry point. The dashboard's top-bar Billing / Certificate /
    // My Classes onclick handlers call showTrainerSubPanel() to swap the
    // visible panel WITHOUT navigating (event.preventDefault is fired),
    // and hsLnrSetActive() to flip the top tab. Without this the sidebar
    // is left out of the loop — it still highlights whatever the last
    // sidebar click pointed at, so sidebar / top bar / main content
    // disagree until the next page load. Exposing this lets the top-bar
    // handlers also push the active state into the sidebar in the same
    // synchronous burst, and updates the URL hash so refresh restores
    // the same view.
    window.mmdSyncActiveNav = function (mirrorTab) {
        if (!mirrorTab) return;
        clearAll();
        applyByMirrorTab(mirrorTab);
        mirrorTopTab(mirrorTab);
        // Mirror the panel choice back into the URL so a refresh on
        // /dashboard/ continues showing the same sub-panel. Skipped
        // for 'profile' which is a separate page (system_account) and
        // doesn't share the dashboard hash space.
        var hashMap = { billing:'#billing', certhistory:'#certhistory',
                        myclasses:'#classes', classes:'#classes',
                        edtools:'#edtools', genai:'#genai' };
        var path = (window.location.pathname || '').toLowerCase();
        if (path.indexOf('/dashboard') >= 0 && hashMap[mirrorTab] !== undefined) {
            try { history.replaceState(null, '', window.location.pathname + hashMap[mirrorTab]); } catch (e) {}
        }
    };

    // Re-run URL-based detection. Called from multiple trigger points
    // so the active state always reflects the page the user is actually
    // looking at, even if a stale click handler or BFCache leaves
    // sessionStorage pointing at the wrong item.
    function syncFromUrl() {
        var urlMt = detectMirrorTabFromUrl();
        if (!urlMt) return;
        clearAll();
        applyByMirrorTab(urlMt);
        mirrorTopTab(urlMt);
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', attach);
    else attach();
    // Belt-and-suspenders: re-sync on every state-change moment that
    // could leave the wrong item highlighted.
    window.addEventListener('load',       syncFromUrl);
    window.addEventListener('hashchange', syncFromUrl);
    window.addEventListener('popstate',   syncFromUrl);
    window.addEventListener('pageshow',   syncFromUrl); // covers BFCache restores
    // CRITICAL: the admin uses instant-nav.js (PJAX) which swaps page
    // content without firing DOMContentLoaded again. The custom
    // `instant-nav:after-swap` event is dispatched after each swap, so
    // we re-run URL detection here too — otherwise clicking sidebar /
    // top-tab links leaves the active highlight stuck on whatever was
    // last visually set by the click handler, even after the URL has
    // moved on to a different page.
    document.addEventListener('instant-nav:after-swap', function () {
        // Click handlers need to be re-attached to the freshly-swapped
        // sidebar DOM, and the URL-derived active state re-applied.
        attach();
    });
})();
</script>

