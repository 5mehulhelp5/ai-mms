            <?php if (!empty($_cfgTabs)): ?>
                <?php foreach ($_cfgTabs as $_cfgTab): ?>
                    <?php $_cfgSections = $_cfgTab->getSections(); ?>
                    <?php if (!$_cfgSections || !count($_cfgSections)) continue; ?>
                    <?php
                        // Some tabs (e.g. MageComp) use an <img> tag as their label
                        // for branding — strip HTML so the sidebar shows a clean text label.
                        $_cfgTabLabel = trim(strip_tags((string)$_cfgTab->getLabel()));
                        if ($_cfgTabLabel === '') {
                            $_cfgTabLabel = ucwords(str_replace(array('_','-'), ' ', (string)$_cfgTab->getId()));
                        }
                    ?>
                    <div class="tools-group tools-subgroup">
                        <div class="tools-group-toggle tools-sub-item" onclick="toggleToolGroup(this)">
                            <span><?php echo htmlspecialchars($_cfgTabLabel) ?></span>
                            <svg class="tools-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                        </div>
                        <div class="tools-group-items">
                            <?php foreach ($_cfgSections as $_cfgSection): ?>
                                <?php
                                    $_cfgSectionLabel = trim(strip_tags((string)$_cfgSection->getLabel()));
                                    if ($_cfgSectionLabel === '') {
                                        $_cfgSectionLabel = ucwords(str_replace(array('_','-'), ' ', (string)$_cfgSection->getId()));
                                    }
                                    // Build an absolute URL to adminhtml/system_config/edit so
                                    // the link works from any controller — the Tabs block's own
                                    // getUrl() uses */*/* which would otherwise route back to
                                    // the current controller (e.g. system_cache).
                                    $_cfgSectionUrl = Mage::helper('adminhtml')->getUrl(
                                        'adminhtml/system_config/edit',
                                        array('section' => $_cfgSection->getId())
                                    );
                                ?>
                                <a href="<?php echo $_cfgSectionUrl ?>" class="tools-sub-item"><span><?php echo htmlspecialchars($_cfgSectionLabel) ?></span></a>
                            <?php endforeach; ?>
                        </div>
                    </div>
