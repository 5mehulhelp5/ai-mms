<script>
(function(){
    var QR = {
        formKey: <?php echo json_encode($_qrFormKey) ?>,
        saveUrl: <?php echo json_encode($_qrSaveUrl) ?>,
        searchUrl: <?php echo json_encode($_qrSearchUrl) ?>,
        infoUrl: <?php echo json_encode($_qrInfoUrl) ?>,
        productId: null,
        searchT: null,
    };
    window.__QR = QR;

    function $(id) { return document.getElementById(id); }

    window.qrOpen = function() {
        $('qr-backdrop').classList.add('open');
        document.body.style.overflow = 'hidden';
        $('qr-err').textContent = '';
        $('qr-firstname').focus();
    };
    window.qrClose = function() {
        $('qr-backdrop').classList.remove('open');
        document.body.style.overflow = '';
    };
    window.qrToast = function(msg, kind) {
        var t = $('qr-toast');
        t.textContent = msg;
        t.className = 'qr-toast ' + (kind || '');
        t.style.display = 'block';
        clearTimeout(window.__qrToastT);
        window.__qrToastT = setTimeout(function(){ t.style.display = 'none'; }, kind === 'err' ? 8000 : 4500);
    };

    // ---- Course search (debounced).
    $('qr-course-search').addEventListener('input', function(e) {
        var q = e.target.value.trim();
        clearTimeout(QR.searchT);
        if (q.length < 2) {
            $('qr-course-list').classList.remove('open');
            return;
        }
        QR.searchT = setTimeout(function(){ qrDoSearch(q); }, 200);
    });

    function qrDoSearch(q) {
        var storeId = $('qr-store').value || 1;
        var url = QR.searchUrl + '?q=' + encodeURIComponent(q) + '&store_id=' + encodeURIComponent(storeId);
        fetch(url, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(j){
                var list = $('qr-course-list');
                list.innerHTML = '';
                if (!j.results || !j.results.length) {
                    list.innerHTML = '<div class="qr-course-item" style="color:#94a3b8;">No matches.</div>';
                    list.classList.add('open');
                    return;
                }
                j.results.forEach(function(r){
                    var div = document.createElement('div');
                    div.className = 'qr-course-item';
                    div.innerHTML = '<div>' + escapeHtml(r.name) + '</div><div class="qr-sku">' + escapeHtml(r.sku) + ' · $' + Number(r.price).toFixed(2) + '</div>';
                    div.onclick = function(){ qrPickCourse(r); };
                    list.appendChild(div);
                });
                list.classList.add('open');
            })
            .catch(function(){ /* silent */ });
    }

    function qrPickCourse(r) {
        QR.productId = r.product_id;
        $('qr-course-list').classList.remove('open');
        $('qr-course-search').value = '';
        $('qr-picked').classList.add('shown');
        $('qr-pick-name').innerHTML = '<strong>' + escapeHtml(r.name) + '</strong>';
        $('qr-pick-meta').textContent = r.sku + ' · $' + Number(r.price).toFixed(2);
        qrLoadCourseInfo(r.product_id);
    }

    window.qrClearCourse = function() {
        QR.productId = null;
        $('qr-picked').classList.remove('shown');
        $('qr-opt-area').classList.remove('shown');
        $('qr-opt-area').innerHTML = '';
        $('qr-start-date').innerHTML = '<option value="">— pick a course first —</option>';
        $('qr-course-search').focus();
    };

    function qrLoadCourseInfo(productId) {
        var storeId = $('qr-store').value || 1;
        var url = QR.infoUrl + '?product_id=' + encodeURIComponent(productId) + '&store_id=' + encodeURIComponent(storeId);
        fetch(url, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(j){
                // Start dates from course_runs.
                var dateSel = $('qr-start-date');
                dateSel.innerHTML = '';
                if (j.runs && j.runs.length) {
                    j.runs.forEach(function(r){
                        var opt = document.createElement('option');
                        opt.value = r.course_start_date;
                        opt.textContent = r.course_start_date + ' → ' + (r.course_end_date || '?') + ' (' + (r.vacancy === 'A' ? 'available' : 'closed') + ')';
                        dateSel.appendChild(opt);
                    });
                } else {
                    dateSel.innerHTML = '<option value="">— no scheduled runs yet —</option>';
                }

                // Custom options.
                var area = $('qr-opt-area');
                area.innerHTML = '';
                if (j.options && j.options.length) {
                    j.options.forEach(function(opt){
                        var row = document.createElement('div');
                        row.className = 'qr-row';
                        var labelTxt = escapeHtml(opt.title) + (opt.required ? ' <span class="req">*</span>' : '');
                        var widget = '';
                        if (['drop_down','radio','multiple'].indexOf(opt.type) >= 0 && opt.values.length) {
                            widget = '<select class="qr-select" data-opt-id="' + opt.option_id + '">';
                            if (!opt.required) widget += '<option value="">— none —</option>';
                            opt.values.forEach(function(v){
                                widget += '<option value="' + v.option_type_id + '">' + escapeHtml(v.title) + (v.price ? ' (+$' + Number(v.price).toFixed(2) + ')' : '') + '</option>';
                            });
                            widget += '</select>';
                        } else {
                            widget = '<input type="text" class="qr-input" data-opt-id="' + opt.option_id + '" />';
                        }
                        row.innerHTML = '<label>' + labelTxt + '</label>' + widget;
                        area.appendChild(row);
                    });
                    area.classList.add('shown');
                } else {
                    area.classList.remove('shown');
                }
            })
            .catch(function(e){ qrToast('Could not load course details', 'err'); });
    }

    function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
            return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
        });
    }

    window.qrSubmit = function() {
        var err = $('qr-err');
        err.textContent = '';
        var btn = $('qr-submit');

        // Client-side checks before round-tripping.
        var missing = [];
        ['firstname','lastname','email','telephone'].forEach(function(f){
            if (!$('qr-' + f).value.trim()) missing.push(f);
        });
        if (!QR.productId) missing.push('course');
        if (missing.length) {
            err.textContent = 'Missing: ' + missing.join(', ');
            return;
        }

        var fd = new FormData();
        fd.append('form_key', QR.formKey);
        fd.append('store_id', $('qr-store').value);
        fd.append('firstname', $('qr-firstname').value.trim());
        fd.append('lastname',  $('qr-lastname').value.trim());
        fd.append('email',     $('qr-email').value.trim());
        fd.append('telephone', $('qr-telephone').value.trim());
        fd.append('product_id', QR.productId);
        fd.append('qty', $('qr-qty').value || 1);
        fd.append('payment_method', $('qr-payment').value);
        fd.append('admin_note', $('qr-note').value.trim());
        // Start date is stored as an admin note line so we don't need a
        // separate column; the run row itself is the source of truth.
        var sd = $('qr-start-date').value;
        if (sd) fd.append('admin_note', 'Start date: ' + sd + ($('qr-note').value ? ' · ' + $('qr-note').value : ''));

        // Collect options.
        $('qr-opt-area').querySelectorAll('[data-opt-id]').forEach(function(el){
            var v = el.value;
            if (v === '' || v == null) return;
            fd.append('options[' + el.dataset.optId + ']', v);
        });

        btn.disabled = true;
        btn.innerHTML = '<span class="qr-spinner"></span>Saving…';

        fetch(QR.saveUrl, { method: 'POST', credentials: 'same-origin', body: fd })
            .then(function(r){ return r.json(); })
            .then(function(j){
                btn.disabled = false;
                btn.textContent = 'Create Registration';
                if (j.ok) {
                    qrToast('Registration #' + j.increment_id + ' created.', 'ok');
                    qrClose();
                    // Refresh the grid by reloading.
                    setTimeout(function(){ window.location.reload(); }, 600);
                } else {
                    err.textContent = j.error || 'Save failed.';
                }
            })
            .catch(function(){
                btn.disabled = false;
                btn.textContent = 'Create Registration';
                err.textContent = 'Network error. Try again.';
            });
    };

    // ---- Wire the toolbar button on the sales order index.
    function wireToolbarButton() {
        if (!document.body.classList.contains('adminhtml-sales-order-index')) return;
        // Magento's toolbar primary button has class .scalable.add (or .add).
        // Walk all buttons and match by label text since the class isn't unique.
        var buttons = document.querySelectorAll('button.scalable.add, button.add, .content-buttons button, .page-actions button');
        buttons.forEach(function(b){
            var label = (b.textContent || '').trim();
            if (label.indexOf('New Registration') !== -1 || label.indexOf('Create New Order') !== -1) {
                b.addEventListener('click', function(e){
                    e.preventDefault();
                    e.stopPropagation();
                    qrOpen();
                    return false;
                }, true);
            }
        });
    }
    if (document.readyState !== 'loading') wireToolbarButton();
    else document.addEventListener('DOMContentLoaded', wireToolbarButton);
    document.addEventListener('instant-nav:after-swap', wireToolbarButton);
})();
</script>
