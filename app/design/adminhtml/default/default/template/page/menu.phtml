<script type="text/javascript">
(function(){
    function applyRoleSidebar(role) {
        var map = {
            'Learner':     'sidebar-nav-learner',
            'Trainer':     'sidebar-nav-trainer',
            'Admin':       'sidebar-nav-admin-custom',
            'Marketing':   'sidebar-nav-marketing',
            'Super Admin': 'sidebar-nav-superadmin-custom',
            'Developer':   'sidebar-nav-developer'
        };
        var targetId = map[role] || 'sidebar-nav-admin';
        var ids = ['sidebar-nav-admin','sidebar-nav-admin-custom','sidebar-nav-superadmin-custom','sidebar-nav-marketing','sidebar-nav-learner','sidebar-nav-trainer','sidebar-nav-developer'];
        for (var i = 0; i < ids.length; i++) {
            var el = document.getElementById(ids[i]);
            if (el) el.style.display = (ids[i] === targetId) ? '' : 'none';
        }
    }
    var role = '<?php echo htmlspecialchars($_activeRoleLabel) ?>';
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ applyRoleSidebar(role); });
    else applyRoleSidebar(role);
    window.__applySidebarRole = applyRoleSidebar;
})();
function toggleToolGroup(btn) {
    var group = btn.parentElement;
    group.classList.toggle('open');
}
function setTrainerActiveNav(which) {
    var ids = { myclasses:'trainer-nav-myclasses', edtools:'trainer-nav-edtools', problemsolving:'trainer-nav-problemsolving', dataanalytics:'trainer-nav-dataanalytics', finance:'trainer-nav-finance', statistical:'trainer-nav-statistical', doe:'trainer-nav-doe', spc:'trainer-nav-spc', sustainability:'trainer-nav-sustainability', blockchain:'trainer-nav-blockchain', genai:'trainer-nav-genai', agentic:'trainer-nav-agentic', virtual:'trainer-nav-virtual', billing:'learner-nav-billing', certhistory:'learner-nav-certhistory' };
    for (var key in ids) {
        var el = document.getElementById(ids[key]);
        if (el) el.classList.toggle('active', which === key);
    }
}

// Click-to-highlight for all sidebar items. The PHP no longer applies
// any active class on render — instead, clicking an item adds the
// .active class (which the CSS paints translucent cyan) and persists
// the choice in sessionStorage so the highlight survives the page
// navigation that the click triggers. We store BOTH the data-mirror-tab
// (when present — most reliable since it doesn't change across page
// renders) AND the href (fallback for items without a mirror tab).
(function () {
    var STORAGE_KEY = 'mmd_sidebar_active_v3';
    // Clean up any legacy storage keys from earlier versions of this
    // script so stale entries can't fight the new logic.
    try {
        sessionStorage.removeItem('mmd_sidebar_active_href');
        sessionStorage.removeItem('mmd_sidebar_active_v2');
    } catch (e) {}

    function clearAll() {
        var els = document.querySelectorAll('.lms-nav-item.active, .tools-group-toggle.active');
        for (var i = 0; i < els.length; i++) els[i].classList.remove('active');
    }

    function applyByHref(href) {
        if (!href) return false;
        var matches = document.querySelectorAll('.lms-nav-item[href="' + href + '"]');
        if (!matches.length) return false;
        for (var i = 0; i < matches.length; i++) matches[i].classList.add('active');
        return true;
    }

    function applyByMirrorTab(mt) {
        if (!mt) return false;
        var match = document.querySelector('.lms-nav-item[data-mirror-tab="' + mt + '"], .tools-group-toggle[data-mirror-tab="' + mt + '"]');
        if (!match) return false;
        match.classList.add('active');
        return true;
    }

    function saveState(mt, href) {
        try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ mt: mt || '', href: href || '' })); } catch (e) {}
    }

    function readState() {
        try { return JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '{}') || {}; } catch (e) { return {}; }
    }

    // Inspect the URL + hash and decide which mirror-tab key matches
    // the page the user is actually looking at. This is what keeps the
    // sidebar / top bar / main-page content in sync — without it we'd
    // be relying purely on sessionStorage (the last thing clicked),
    // which goes stale the moment the user navigates by URL, browser
    // back/forward, or a deep link.
    function detectMirrorTabFromUrl() {
        var path = (window.location.pathname || '').toLowerCase();
        var hash = (window.location.hash || '').toLowerCase();
        if (path.indexOf('/system_account') >= 0) return 'profile';
        if (path.indexOf('/dashboard') >= 0) {
            if (hash === '#billing')     return 'billing';
            if (hash === '#certhistory') return 'certhistory';
            if (hash === '#edtools')     return 'edtools';
            if (hash === '#genai')       return 'genai';
            // No specific hash → dashboard's default for learner/trainer
            // is the My Classes panel.
            return 'myclasses';
        }
        return '';
    }

    // When a sidebar item carries `data-mirror-tab="X"`, clicking it
    // should also activate the matching top-bar tab (either learner or
    // trainer style) so the two stay visually in sync. Looks up by the
    // tab's own data-* attribute — works for both .header-lnr-tab and
    // .header-trn-tab without needing role-specific logic here.
    function mirrorTopTab(which) {
        if (!which) return;
        var topTabs = document.querySelectorAll('.header-lnr-tab[data-lnr-tab], .header-trn-tab[data-trn-tab]');
        var matched = false;
        for (var i = 0; i < topTabs.length; i++) {
            var t = topTabs[i];
            var key = t.getAttribute('data-lnr-tab') || t.getAttribute('data-trn-tab');
            if (key === which) matched = true;
        }
        if (!matched) return; // no top-bar equivalent — leave top bar alone
        for (var j = 0; j < topTabs.length; j++) {
            var tt = topTabs[j];
            var k = tt.getAttribute('data-lnr-tab') || tt.getAttribute('data-trn-tab');
            tt.classList.toggle('active', k === which);
        }
    }

    function attach() {
        // Plain link items: a.lms-nav-item — clicking adds active +
        // saves state before navigation completes.
        document.querySelectorAll('a.lms-nav-item').forEach(function (a) {
            a.addEventListener('click', function () {
                var mt = a.getAttribute('data-mirror-tab') || '';
                saveState(mt, a.getAttribute('href') || '');
                clearAll();
                a.classList.add('active');
                mirrorTopTab(mt);
            });
        });
        // Group toggles (div.tools-group-toggle) — these don't navigate
        // by themselves; they just open the dropdown. Mark them active
        // on click and mirror to top bar if applicable.
        document.querySelectorAll('.tools-group-toggle').forEach(function (t) {
            t.addEventListener('click', function () {
                var mt = t.getAttribute('data-mirror-tab') || '';
                if (mt) saveState(mt, '');
                clearAll();
                t.classList.add('active');
                mirrorTopTab(mt);
            });
        });
        // Sub-items inside an open tools-group also persist the click
        // so the parent group + sub-item read on next page load.
        document.querySelectorAll('a.tools-sub-item').forEach(function (a) {
            a.addEventListener('click', function () {
                saveState('', a.getAttribute('href') || '');
            });
        });

        // On page load, the active state must reflect the page the
        // user is actually looking at — sidebar, top bar, and main
        // content all stay in sync. Detection order:
        //   1. URL/hash (most authoritative — survives navigations,
        //      direct links, browser back/forward).
        //   2. sessionStorage data-mirror-tab (recent click hint).
        //   3. sessionStorage href fallback (for items without a
        //      mirror-tab attribute).
        clearAll();
        var urlMt = detectMirrorTabFromUrl();
        var applied = false;
        if (urlMt) {
            applied = applyByMirrorTab(urlMt) || applied;
            mirrorTopTab(urlMt);
            // URL won — also refresh sessionStorage so future page
            // loads start from the correct baseline.
            saveState(urlMt, '');
        } else {
            var s = readState();
            if (s.mt) {
                applied = applyByMirrorTab(s.mt) || applied;
                mirrorTopTab(s.mt);
            }
            if (!applied && s.href) applyByHref(s.href);
        }
    }

    // Public entry point. The dashboard's top-bar Billing / Certificate /
    // My Classes onclick handlers call showTrainerSubPanel() to swap the
    // visible panel WITHOUT navigating (event.preventDefault is fired),
    // and hsLnrSetActive() to flip the top tab. Without this the sidebar
    // is left out of the loop — it still highlights whatever the last
    // sidebar click pointed at, so sidebar / top bar / main content
    // disagree until the next page load. Exposing this lets the top-bar
    // handlers also push the active state into the sidebar in the same
    // synchronous burst, and updates the URL hash so refresh restores
    // the same view.
    window.mmdSyncActiveNav = function (mirrorTab) {
        if (!mirrorTab) return;
        clearAll();
        applyByMirrorTab(mirrorTab);
        mirrorTopTab(mirrorTab);
        saveState(mirrorTab, '');
        // Mirror the panel choice back into the URL so a refresh on
        // /dashboard/ continues showing the same sub-panel. Skipped
        // for 'profile' which is a separate page (system_account) and
        // doesn't share the dashboard hash space.
        var hashMap = { billing:'#billing', certhistory:'#certhistory',
                        myclasses:'#classes', classes:'#classes',
                        edtools:'#edtools', genai:'#genai' };
        var path = (window.location.pathname || '').toLowerCase();
        if (path.indexOf('/dashboard') >= 0 && hashMap[mirrorTab] !== undefined) {
            try { history.replaceState(null, '', window.location.pathname + hashMap[mirrorTab]); } catch (e) {}
        }
    };

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', attach);
    else attach();
})();
</script>
