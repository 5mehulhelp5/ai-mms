<script type="text/javascript">
function adminToggleTheme() {
    var cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    var next = cur === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('admin-theme', next); } catch(e) {}
    /* Notify any on-page consumers (e.g. the profile page's
       Appearance card) so their visible state matches. The card
       defines refreshAppearanceUI(); call it only if present. */
    if (typeof window.refreshAppearanceUI === 'function') {
        try { window.refreshAppearanceUI(); } catch(e) {}
    }
}
function switchRole(btn) {
    var roleCode = btn.getAttribute('data-role');
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '<?php echo $switchUrl ?>');
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
        try {
            var resp = JSON.parse(xhr.responseText);
            if (resp.success && resp.redirect) {
                // Role switch MUST do a full document reload — the
                // header (role badge / top tabs / brand chrome) and
                // sidebar (role-specific menu items) live OUTSIDE the
                // #anchor-content PJAX swap area, so a PJAX-only nav
                // would leave them showing the previous role. Take the
                // perf hit here in exchange for correct chrome state.
                window.location.href = resp.redirect;
            }
        } catch(e) {
            window.location.reload();
        }
    };
    xhr.send('role_code=' + encodeURIComponent(roleCode) + '&form_key=<?php echo Mage::getSingleton('core/session')->getFormKey() ?>');
}
document.addEventListener('click', function(e) {
    var menu = document.getElementById('user-menu');
    if (menu && !menu.contains(e.target)) menu.classList.remove('open');
    var viewAs = document.getElementById('view-as');
    if (viewAs && !viewAs.contains(e.target)) viewAs.classList.remove('open');
    var bell = document.getElementById('audit-bell');
    if (bell && !bell.contains(e.target)) bell.classList.remove('open');
});
(function(){
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    function pad(n){ return n < 10 ? '0' + n : n; }
    function tick(){
        var now = new Date();
        var dateStr = days[now.getDay()] + ' ' + pad(now.getDate()) + ' ' + months[now.getMonth()];
        var h = now.getHours();
        var ampm = h >= 12 ? 'PM' : 'AM';
        h = h % 12;
        if (h === 0) h = 12;
        var timeStr = pad(h) + ':' + pad(now.getMinutes()) + ' ' + ampm;
        var d = document.getElementById('header-date');
        var t = document.getElementById('header-time');
        if (d) d.textContent = dateStr;
        if (t) t.textContent = timeStr;
    }
    tick();
    setInterval(tick, 1000);
})();
</script>
