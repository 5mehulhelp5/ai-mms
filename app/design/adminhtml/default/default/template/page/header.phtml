    <script type="text/javascript">
    (function(){
        var ENTRIES = <?php echo json_encode(array_values($_hsSearchEntries)) ?>;
        var trigger = document.getElementById('header-search-trigger');
        var overlay = document.getElementById('header-search-overlay');
        var input   = document.getElementById('header-search-q');
        var list    = document.getElementById('header-search-list');
        var count   = document.getElementById('header-search-count');
        var idx     = 0;
        var filtered = ENTRIES.slice();

        function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function(c){
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
            });
        }
        function render() {
            if (!filtered.length) {
                list.innerHTML = '<div class="header-search-empty">No matching functions</div>';
                count.textContent = '0 results';
                return;
            }
            var html = '';
            for (var i = 0; i < filtered.length; i++) {
                var e = filtered[i];
                // No onmouseenter — re-rendering on hover used to destroy
                // the <a> element mid-click and swallowed the navigation.
                // CSS :hover already paints the highlight; keyboard idx
                // navigation just toggles .active via updateActive().
                var cls = 'header-search-item' + (i === idx ? ' active' : '');
                html += '<a href="' + e.url + '" class="' + cls + '" data-i="' + i + '">'
                     +    '<span>' + escapeHtml(e.label) + '</span>'
                     +    '<span class="header-search-group">' + escapeHtml(e.group) + '</span>'
                     +  '</a>';
            }
            list.innerHTML = html;
            count.textContent = filtered.length + ' results';
        }
        function updateActive() {
            var items = list.querySelectorAll('.header-search-item');
            for (var i = 0; i < items.length; i++) {
                if (i === idx) items[i].classList.add('active');
                else items[i].classList.remove('active');
            }
        }
        function applyFilter(q) {
            q = (q || '').toLowerCase().trim();
            if (!q) { filtered = ENTRIES.slice(); }
            else {
                filtered = ENTRIES.filter(function(e){
                    return (e.label.toLowerCase().indexOf(q) >= 0)
                        || (e.kw && e.kw.toLowerCase().indexOf(q) >= 0)
                        || (e.group.toLowerCase().indexOf(q) >= 0);
                });
            }
            idx = 0;
            render();
        }
        window.hsClose = function() { overlay.classList.remove('open'); input.value=''; applyFilter(''); };
        function hsOpen() { overlay.classList.add('open'); setTimeout(function(){ input.focus(); }, 30); }

        trigger.addEventListener('click', hsOpen);
        trigger.addEventListener('focus', hsOpen);
        input.addEventListener('input', function(){ applyFilter(input.value); });
        input.addEventListener('keydown', function(e){
            if (e.key === 'Escape') { hsClose(); }
            else if (e.key === 'ArrowDown') { e.preventDefault(); if (idx < filtered.length - 1) { idx++; updateActive(); } }
            else if (e.key === 'ArrowUp')   { e.preventDefault(); if (idx > 0) { idx--; updateActive(); } }
            else if (e.key === 'Enter')     { e.preventDefault(); if (filtered[idx]) window.location.href = filtered[idx].url; }
        });
        document.addEventListener('keydown', function(e){
            var isK = (e.key === 'k' || e.key === 'K');
            if (isK && (e.metaKey || e.ctrlKey)) { e.preventDefault(); hsOpen(); }
        });
        applyFilter('');
    })();
    </script>
