<?php
/**
 * Currency rate editor — flattened to one row per pair (From → To) instead
 * of the original NxN matrix. Same form field name (`rate[FROM][TO]`) so
 * the controller doesn't need changes.
 */
?>
<?php
$_oldRates = $this->getOldRates();
$_newRates = $this->getNewRates();
$_rates    = ($_newRates) ? $_newRates : $_oldRates;
?>
<form name="rateForm" id="rateForm" method="post" action="<?php echo $this->getRatesFormAction(); ?>">
    <?php echo $this->getBlockHtml('formkey') ?>
    <div class="grid currency-rate-list">
        <table cellspacing="0">
            <thead>
                <tr class="headings">
                    <th class="a-left"><?php echo $this->__('From') ?></th>
                    <th class="a-left"><?php echo $this->__('To') ?></th>
                    <th class="a-left"><?php echo $this->__('Rate') ?></th>
                </tr>
            </thead>
            <tbody>
            <?php foreach ($this->getDefaultCurrencies() as $_currencyCode): ?>
                <?php if (!isset($_rates[$_currencyCode]) || !is_array($_rates[$_currencyCode])) continue; ?>
                <?php foreach ($_rates[$_currencyCode] as $_rate => $_value): ?>
                    <?php $isSelf = ($_currencyCode === $_rate); ?>
                    <tr class="<?php echo $isSelf ? 'is-self' : '' ?>">
                        <td class="a-left"><strong><?php echo $this->escapeHtml($_currencyCode) ?></strong></td>
                        <td class="a-left"><strong><?php echo $this->escapeHtml($_rate) ?></strong></td>
                        <td class="a-left">
                            <input type="text"
                                   name="rate[<?php echo $this->escapeHtml($_currencyCode) ?>][<?php echo $this->escapeHtml($_rate) ?>]"
                                   value="<?php echo $isSelf
                                       ? '1.0000'
                                       : ($_value > 0
                                           ? $_value
                                           : (isset($_oldRates[$_currencyCode][$_rate]) ? $_oldRates[$_currencyCode][$_rate] : '')) ?>"
                                   <?php echo $isSelf ? 'class="input-text input-text-disabled" readonly="true"' : 'class="input-text"' ?> />
                            <?php if (isset($_newRates) && !$isSelf && isset($_oldRates[$_currencyCode][$_rate])): ?>
                                <span class="old-rate"><?php echo $this->__('Old:') ?> <?php echo $_oldRates[$_currencyCode][$_rate] ?></span>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
            <?php endforeach; ?>
            </tbody>
        </table>
    </div>
</form>
<script type="text/javascript">
    currencyForm = new varienForm('rateForm');
</script>
