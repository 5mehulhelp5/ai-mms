.admin-main .theme-mode-switch{width:64px !important;height:32px !important;min-height:32px !important;min-width:64px !important;max-width:64px !important;border-radius:999px !important;background:#4b5563 !important;background-image:none !important;border:0 !important;border-width:0 !important;position:relative !important;cursor:pointer !important;padding:0 !important;margin:0 !important;transition:background 0.2s ease;flex-shrink:0;display:inline-block !important;box-shadow:none !important;color:transparent !important;font-size:0 !important;line-height:1 !important;vertical-align:middle !important;overflow:visible !important}
