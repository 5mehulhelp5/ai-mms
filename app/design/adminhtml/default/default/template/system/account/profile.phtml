<script type="text/javascript">
function toggleEdit() {
    var bio = document.getElementById('bio-section');
    var login = document.getElementById('login-section');
    var edit = document.getElementById('edit-section');
    if (edit.classList.contains('active')) {
        edit.classList.remove('active');
        bio.style.display = '';
        login.style.display = '';
    } else {
        edit.classList.add('active');
        bio.style.display = 'none';
        login.style.display = 'none';
    }
}
function previewImage(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var preview = document.getElementById('avatar-preview');
            preview.innerHTML = '<img src="' + e.target.result + '" alt="" />';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
function refreshAppearanceUI() {
    var t = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    var sub = document.getElementById('appearance-sub');
    var sw  = document.getElementById('theme-mode-switch');
    if (sub) sub.textContent = (t === 'light') ? 'Light theme active' : 'Dark theme active';
    if (sw)  sw.classList.toggle('on', t === 'dark');
}
refreshAppearanceUI();
</script>
