/** @var MMD_Adminhtml_Block_System_Account_Edit $this */
$user = $this->getUser();
$roles = $this->getUserRoles();
$firstName = $this->escapeHtml($user->getFirstname());
$lastName = $this->escapeHtml($user->getLastname());
$fullName = $firstName . ' ' . $lastName;
$email = $this->escapeHtml($user->getEmail());
$initials = strtoupper(substr($firstName, 0, 1) . substr($lastName, 0, 1));
$roleLabels = array();
foreach ($roles as $rc) { $roleLabels[] = $this->getRoleLabel($rc); }
$roleSubtitle = implode(' & ', $roleLabels);
$formKey = Mage::getSingleton('core/session')->getFormKey();
$minPwLen = $this->getMinPasswordLength();

$tel = $this->escapeHtml($user->getData('tel'));
$gender = $this->escapeHtml($user->getData('gender'));
$race = $this->escapeHtml($user->getData('race'));
$dob = $user->getData('dob');
$dobDisplay = $dob ? date('d M Y', strtotime($dob)) : '';
$dobInput = $dob ? date('Y-m-d', strtotime($dob)) : '';
$nricFin = $this->escapeHtml($user->getData('nric_fin'));
$linkedinUrl = $this->escapeHtml($user->getData('linkedin_url'));
$profileImage = $user->getData('profile_image');
$profileImageUrl = $profileImage ? Mage::getBaseUrl('media') . 'admin/profile/' . $profileImage : '';

// Mask NRIC for display
$nricDisplay = '';
if ($nricFin) {
    $nricDisplay = substr($nricFin, 0, 1) . str_repeat('*', max(0, strlen($nricFin) - 2)) . substr($nricFin, -1);
}

$roleColors = array(
    'learner'           => '#22c55e',
    'trainer'           => '#f59e0b',
    'admin'             => '#3b82f6',
    'marketing'         => '#a855f7',
    'training_provider' => '#06b6d4',
    'developer'         => '#ef4444',
    'finance'           => '#64748b',
