<?php
/** @var MMD_Leads_Block_Adminhtml_Leads $this */
$_items  = $this->getSidebarItems();
$_active = $this->getActiveFilter();
?>
<aside class="sidebar-nav sidebar-nav-role dcf-edit-sidebar mmd-leads-sidebar">
    <h3 class="dcf-edit-sidebar-title">Leads</h3>
    <?php foreach ($_items as $_it): ?>
        <a class="lms-nav-item<?php echo $_it['key'] === $_active ? ' active' : '' ?>"
           href="<?php echo htmlspecialchars($this->getFilterUrl($_it['key'])) ?>">
            <span><?php echo htmlspecialchars($_it['label']) ?></span>
            <span class="mmd-leads-nav-count"><?php echo (int) $_it['count'] ?></span>
        </a>
    <?php endforeach; ?>
</aside>

<div class="dcf-wrap mmd-leads-wrap">
<?php if ($_active !== 'all'):
        $_activeLabel = '';
        foreach ($_items as $_it) { if ($_it['key'] === $_active) { $_activeLabel = $_it['label']; break; } }
    ?>
    <div class="dcf-edit-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Filtered: <strong><?php echo htmlspecialchars($_activeLabel) ?></strong>
        <a href="<?php echo $this->getFilterUrl('all') ?>" style="margin-left:auto;color:inherit;text-decoration:underline;">Clear filter</a>
    </div>
    <?php endif; ?>

    <div class="dcf-mag">
        <div class="dcf-mag-bar">
            <span>All Leads</span>
        </div>
        <div class="dcf-mag-body" style="padding:0;">
            <?php echo $this->getGridHtml() ?>
        </div>
    </div>
</div>

