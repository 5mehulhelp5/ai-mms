<?php
/** @var MMD_Leads_Block_Adminhtml_Leads $this */
$_active = $this->getActiveFilter();
$_label  = '';
if ($_active !== 'all') {
    foreach ($this->getSidebarItems() as $_it) {
        if ($_it['key'] === $_active) { $_label = $_it['label']; break; }
    }
}
?>
<div class="dcf-wrap mmd-leads-wrap">
    <?php if ($_active !== 'all'): ?>
    <div class="dcf-edit-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Filtered: <strong><?php echo htmlspecialchars($_label) ?></strong>
        <a href="<?php echo $this->getFilterUrl('all') ?>" style="margin-left:auto;color:inherit;text-decoration:underline;">Clear filter</a>
    </div>
    <?php endif; ?>

    <div class="dcf-mag">
        <div class="dcf-mag-bar">
            <span>All Leads</span>
        </div>
        <div class="dcf-mag-body" style="padding:0;">
            <?php echo $this->getGridHtml() ?>
        </div>
    </div>
</div>

<style>
    /* Grid sits inside .dcf-mag-body — strip the grid's own margin/border
       so the header bar above it reads as the section bar. */
    .mmd-leads-wrap .dcf-mag .grid { margin: 0 !important; }
    .mmd-leads-wrap [id$="_massaction"] {
        padding: 10px 14px !important;
        border-bottom: 1px solid var(--b1, #1f2937) !important;
    }
    /* Suppress the auto-injected Filters toggle + panel on the Leads
       page — Magento's built-in column filters are already enough. */
    .mmd-leads-wrap .advanced-filter-toggle,
    .mmd-leads-wrap .advanced-filter-panel {
        display: none !important;
    }
</style>
