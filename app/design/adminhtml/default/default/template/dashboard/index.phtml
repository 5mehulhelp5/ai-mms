<script type="text/javascript">
window._atTab = 'upcoming';
window._atPage = 1;
window._atPerPage = 10;
// Server-precomputed per-tab KPI numbers. JS reads these on tab
// switch so the three tiles flip to that bucket's totals (and the
// first tile re-labels Upcoming/Ongoing/Completed Classes).
window._atKpiByTab = {
    upcoming:  { count: <?php echo (int)$_atKpi['upcoming']  ?>, assigned: <?php echo (int)$_atKpi['assigned_upcoming']  ?>, missing: <?php echo (int)$_atKpi['missing_upcoming']  ?> },
    ongoing:   { count: <?php echo (int)$_atKpi['ongoing']   ?>, assigned: <?php echo (int)$_atKpi['assigned_ongoing']   ?>, missing: <?php echo (int)$_atKpi['missing_ongoing']   ?> },
    completed: { count: <?php echo (int)$_atKpi['completed'] ?>, assigned: <?php echo (int)$_atKpi['assigned_completed'] ?>, missing: <?php echo (int)$_atKpi['missing_completed'] ?> }
};

window.atSetTab = function(btn) {
    var tabs = document.querySelectorAll('.at-tab');
    for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
    btn.classList.add('active');
    window._atTab = btn.getAttribute('data-tab');
    window._atPage = 1;
    // Swap the KPI tile values + first label to match the active tab.
    var bucket = window._atKpiByTab[window._atTab] || { count:0, assigned:0, missing:0 };
    var lblMap = { upcoming: 'Upcoming Classes', ongoing: 'Ongoing Classes', completed: 'Completed Classes' };
    var elC  = document.getElementById('at-kpi-classes');
    var elA  = document.getElementById('at-kpi-assigned');
    var elM  = document.getElementById('at-kpi-missing');
    var elL  = document.getElementById('at-kpi-classes-lbl');
    if (elC) elC.textContent = bucket.count.toLocaleString();
    if (elA) elA.textContent = bucket.assigned.toLocaleString();
    if (elM) elM.textContent = bucket.missing.toLocaleString();
    if (elL) elL.textContent = lblMap[window._atTab] || 'Classes';
    atRender();
};

window.atRender = function() {
    var rows = document.querySelectorAll('#at-tbody tr');
    var q = (document.getElementById('at-search')||{value:''}).value.toLowerCase().trim();
    var noTrainer = (document.getElementById('at-no-trainer')||{checked:false}).checked;
    var trainerFilter = (document.getElementById('at-filter-trainer')||{value:''}).value.toLowerCase().trim();
    var courseFilter = (document.getElementById('at-filter-course')||{value:''}).value;
    var matched = [];
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        var match = true;
        if (r.getAttribute('data-tab') !== window._atTab) match = false;
        if (match && q) {
            var hay = (r.getAttribute('data-title')||'') + ' ' + (r.getAttribute('data-sku')||'') + ' ' + (r.getAttribute('data-run')||'');
            if (hay.indexOf(q) === -1) match = false;
        }
        if (match && noTrainer && r.getAttribute('data-trainers-empty') !== '1') match = false;
        if (match && trainerFilter && (r.getAttribute('data-trainers')||'').indexOf(trainerFilter) === -1) match = false;
        if (match && courseFilter && r.getAttribute('data-course') !== courseFilter) match = false;
        r.style.display = 'none';
        if (match) matched.push(r);
    }
    var perPage = window._atPerPage;
    var total = matched.length;
    var pages = Math.max(1, Math.ceil(total / perPage));
    if (window._atPage > pages) window._atPage = pages;
    if (window._atPage < 1) window._atPage = 1;
    var startIdx = (window._atPage - 1) * perPage;
    var endIdx = Math.min(startIdx + perPage, total);
    for (var j = startIdx; j < endIdx; j++) matched[j].style.display = '';

    var tabLabel = window._atTab.charAt(0).toUpperCase() + window._atTab.slice(1);
    var counter = document.getElementById('at-counter');
    if (counter) counter.textContent = total === 0 ? 'No ' + tabLabel + ' classes' : 'Showing ' + total + ' of ' + total + ' ' + tabLabel + ' classes';

    var info = document.getElementById('at-pager-info');
    if (info) info.textContent = total === 0 ? '' : 'Page ' + window._atPage + ' of ' + pages + ' (' + total + ' classes)';

    var ne = document.getElementById('at-no-results');
    if (ne) ne.style.display = total === 0 ? '' : 'none';

    var c = document.getElementById('at-pager-ctrls');
    if (c && total > 0) {
        c.innerHTML = '';
        var cur = window._atPage;
        var addBtn = function(label, page, isActive, isDisabled) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'at-pg-btn' + (isActive ? ' active' : '') + (isDisabled ? ' disabled' : '');
            b.textContent = label;
            if (!isDisabled && page) b.onclick = function() { window._atPage = page; atRender(); };
            c.appendChild(b);
        };
        var addEll = function() {
            var s = document.createElement('span');
            s.className = 'at-pg-ell';
            s.textContent = '…';
            c.appendChild(s);
        };

        // Build the list of page numbers to render.
        var nums = [];
        if (pages <= 10) {
            for (var p1 = 1; p1 <= pages; p1++) nums.push(p1);
        } else {
            nums.push(1);
            for (var p2 = cur - 2; p2 <= cur + 2; p2++) {
                if (p2 > 1 && p2 < pages) nums.push(p2);
            }
            nums.push(pages);
            // De-dup (already sorted by construction).
            var dedup = [];
            for (var di = 0; di < nums.length; di++) {
                if (di === 0 || nums[di] !== nums[di - 1]) dedup.push(nums[di]);
            }
            nums = dedup;
        }

        addBtn('Prev', cur - 1, false, cur <= 1);
        var prev = 0;
        for (var k = 0; k < nums.length; k++) {
            var n = nums[k];
            if (prev && n - prev > 1) addEll();
            addBtn(String(n), n, n === cur, false);
            prev = n;
        }
        addBtn('Next', cur + 1, false, cur >= pages);
    } else if (c) {
        c.innerHTML = '';
    }
};
(function(){ if (document.getElementById('at-tbody')) atRender(); })();

// ===== Trainer inline editor =====
// Expansion <tr> is moved beneath whichever row is clicked. State lives
// in window._atmState; rendering uses ids inside the expansion fragment.
window._atmState = { pid: 0, runId: '', courseTitle: '', list: [], mode: 'select' };

window.atOpenTrainerModal = function(btn) {
    var tr = btn.closest('tr');
    if (!tr) return;
    var pid = parseInt(tr.getAttribute('data-pid'), 10) || 0;
    var oidsCsv = tr.getAttribute('data-oids') || '';
    var namesPipe = tr.getAttribute('data-tnames') || '';
    var oids = oidsCsv ? oidsCsv.split(',').map(function(x){ return parseInt(x,10); }).filter(function(x){ return x>0; }) : [];
    var names = namesPipe ? namesPipe.split('|') : [];
    var list = [];
    for (var i = 0; i < oids.length; i++) {
        list.push({ oid: oids[i], name: names[i] || ('#' + oids[i]) });
    }
    if (oids.length === 0 && names.length) {
        for (var j = 0; j < names.length; j++) list.push({ oid: 0, name: names[j] });
    }
    window._atmState = {
        pid: pid,
        runId: tr.getAttribute('data-runid') || '',
        courseTitle: tr.getAttribute('data-course') || '',
        list: list,
        mode: 'select'
    };

    var atmRow = document.getElementById('atm-row');
    if (!atmRow) return;
    // Toggle: if already showing under this row, just hide. Don't
    // detach from the DOM — once removed, document.getElementById
    // can't find it again, which is why "Edit Trainer" only worked
    // on the first click.
    var alreadyOpenHere = atmRow.previousElementSibling === tr
        && atmRow.style.display !== 'none';
    if (alreadyOpenHere) {
        atmRow.style.display = 'none';
        return;
    }
    // insertBefore moves the element if it's already attached
    // elsewhere — no need to removeChild first.
    tr.parentNode.insertBefore(atmRow, tr.nextSibling);
    atmRow.style.display = '';
    atmRender();
};

window.atmClose = function() {
    // Just hide — keep it in the DOM so the next click can find it.
    var atmRow = document.getElementById('atm-row');
    if (atmRow) atmRow.style.display = 'none';
};

window.atmRender = function() {
    var st = window._atmState;
    document.getElementById('atm-count').textContent = st.list.length;

    // Currently-assigned list
    var box = document.getElementById('atm-current-list');
    box.innerHTML = '';
    if (st.list.length === 0) {
        var empty = document.createElement('div');
        empty.className = 'at-trainer-empty';
        empty.style.padding = '8px 4px';
        empty.textContent = '— No trainers assigned —';
        box.appendChild(empty);
    } else {
        for (var i = 0; i < st.list.length; i++) {
            var t = st.list[i];
            var row = document.createElement('div');
            row.className = 'atm-trainer-row';
            var nameSpan = document.createElement('div');
            var n = document.createElement('span');
            n.className = 'atm-trainer-name';
            n.textContent = t.name;
            nameSpan.appendChild(n);
            row.appendChild(nameSpan);
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'atm-trainer-remove';
            rm.textContent = '× Remove';
            (function(idx){ rm.onclick = function(){ window._atmState.list.splice(idx, 1); atmRender(); }; })(i);
            row.appendChild(rm);
            box.appendChild(row);
        }
    }

    // Mode toggle
    document.getElementById('atm-mode-select').classList.toggle('active', st.mode === 'select');
    document.getElementById('atm-mode-manual').classList.toggle('active', st.mode === 'manual');
    document.getElementById('atm-input-select').style.display = st.mode === 'select' ? '' : 'none';
    document.getElementById('atm-input-manual').style.display = st.mode === 'manual' ? '' : 'none';
};

window.atmSetMode = function(mode) {
    window._atmState.mode = mode;
    atmRender();
};

window.atmRemoveAll = function() {
    if (!confirm('Remove all assigned trainers?')) return;
    window._atmState.list = [];
    atmRender();
};

window.atmAdd = function() {
    var st = window._atmState;
    if (st.mode === 'select') {
        var sel = document.getElementById('atm-input-select');
        var oid = parseInt(sel.value, 10) || 0;
        if (!oid) { alert('Pick a trainer first.'); return; }
        for (var i = 0; i < st.list.length; i++) {
            if (st.list[i].oid === oid) { alert('Already assigned.'); return; }
        }
        var name = sel.options[sel.selectedIndex].text;
        st.list.push({ oid: oid, name: name });
        sel.value = '';
    } else {
        var inp = document.getElementById('atm-input-manual');
        var v = (inp.value || '').trim();
        if (v.length < 2) { alert('Enter a trainer name.'); return; }
        st.list.push({ oid: 0, name: v });
        inp.value = '';
    }
    atmRender();
};

window.atmSave = function() {
    var st = window._atmState;
    if (!st.pid) { alert('No course selected.'); return; }
    var btn = document.getElementById('atm-save-btn');
    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    var oids = st.list.filter(function(t){ return t.oid > 0; }).map(function(t){ return t.oid; });
    var names = st.list.filter(function(t){ return t.oid <= 0; }).map(function(t){ return t.name; });
    fd.append('trainer_option_ids', oids.join(','));
    fd.append('new_trainer_names', names.join('|'));

    // Snapshot the row's pre-save state so we can revert if the server
    // rejects the change.
    var rows = document.querySelectorAll('#at-tbody tr[data-pid="' + st.pid + '"]');
    var snapshot = [];
    rows.forEach(function(r){
        snapshot.push({
            row: r,
            oids:    r.getAttribute('data-oids')    || '',
            tnames:  r.getAttribute('data-tnames')  || '',
            trainers:r.getAttribute('data-trainers')|| '',
            empty:   r.getAttribute('data-trainers-empty') || '',
            cellHtml: r.children[5] ? r.children[5].innerHTML : ''
        });
    });

    // Optimistic UX — apply the change to the row + KPIs, close the
    // modal instantly, show a "Saving..." toast. The server reconciles
    // in the background.
    btn.disabled = true; btn.textContent = 'Saving...';
    atmApplyToRow(st.pid, oids, st.list);
    atmRecomputeKpis();
    atmClose();
    atmShowToast('Saving trainer changes...', 'pending');

    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/saveTrainers') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        btn.disabled = false; btn.textContent = 'Save';
        if (j && j.success) {
            // Server may have minted new option_ids for free-text
            // names — re-apply with the canonical list.
            if (j.option_ids) atmApplyToRow(st.pid, j.option_ids, st.list);
            atmShowToast('Trainer assignments saved', 'success');
        } else {
            // Revert the row to its pre-save state.
            snapshot.forEach(function(s){
                s.row.setAttribute('data-oids',     s.oids);
                s.row.setAttribute('data-tnames',   s.tnames);
                s.row.setAttribute('data-trainers', s.trainers);
                s.row.setAttribute('data-trainers-empty', s.empty);
                if (s.row.children[5]) s.row.children[5].innerHTML = s.cellHtml;
            });
            atmRecomputeKpis();
            atmShowToast((j && j.message) || 'Save failed — reverted', 'error');
        }
    }).catch(function(err){
        btn.disabled = false; btn.textContent = 'Save';
        snapshot.forEach(function(s){
            s.row.setAttribute('data-oids',     s.oids);
            s.row.setAttribute('data-tnames',   s.tnames);
            s.row.setAttribute('data-trainers', s.trainers);
            s.row.setAttribute('data-trainers-empty', s.empty);
            if (s.row.children[5]) s.row.children[5].innerHTML = s.cellHtml;
        });
        atmRecomputeKpis();
        atmShowToast('Network error — reverted', 'error');
    });
};

// Floating toast for the Assign Trainer save, separate from the
// View Trainers toast so they can coexist on screen.
window.atmShowToast = function(text, kind) {
    kind = kind || 'pending';
    var t = document.getElementById('atm-toast');
    if (!t) {
        t = document.createElement('div');
        t.id = 'atm-toast';
        t.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:99999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.45);display:none;align-items:center;gap:10px;cursor:pointer;font-family:inherit';
        t.onclick = function(){ t.style.display = 'none'; };
        document.body.appendChild(t);
    }
    var palette = {
        pending: { bg: '#1e293b', color: '#e2e8f0', border: '1px solid #475569', dot: '⏳' },
        success: { bg: '#10b981', color: '#fff',    border: 'none',              dot: '✓'  },
        error:   { bg: '#ef4444', color: '#fff',    border: 'none',              dot: '✗'  }
    }[kind];
    t.style.background = palette.bg;
    t.style.color      = palette.color;
    t.style.border     = palette.border;
    t.innerHTML = '<span style="font-size:14px">' + palette.dot + '</span><span></span>';
    t.lastChild.textContent = text;
    t.style.display = 'inline-flex';
    if (kind === 'success') {
        setTimeout(function(){ if (t) t.style.display = 'none'; }, 1500);
    }
};

// Patch the touched row's data attributes + trainer cell so the table
// reflects the new state without a full reload. List = [{oid,name}…].
window.atmApplyToRow = function(pid, finalOids, list) {
    var rows = document.querySelectorAll('#at-tbody tr[data-pid="' + pid + '"]');
    if (!rows.length) return;
    var nameLookup = {};
    for (var i = 0; i < list.length; i++) nameLookup[list[i].oid] = list[i].name;
    var resolvedNames = [];
    for (var k = 0; k < finalOids.length; k++) {
        var oid = parseInt(finalOids[k], 10);
        if (nameLookup[oid]) resolvedNames.push(nameLookup[oid]);
        else if (nameLookup[0])   { resolvedNames.push(nameLookup[0]); delete nameLookup[0]; }
        else                       resolvedNames.push('#' + oid);
    }
    var oidsCsv  = finalOids.map(function(x){ return parseInt(x,10); }).filter(function(x){ return x>0; }).join(',');
    var namesPipe = resolvedNames.join('|');
    var isEmpty  = resolvedNames.length === 0 ? '1' : '0';

    for (var r = 0; r < rows.length; r++) {
        var row = rows[r];
        row.setAttribute('data-oids', oidsCsv);
        row.setAttribute('data-tnames', namesPipe);
        row.setAttribute('data-trainers', namesPipe.toLowerCase());
        row.setAttribute('data-trainers-empty', isEmpty);
        // Trainer cell is the 6th <td> (Start, Run ID, Code, Title, Status, Trainer, Action).
        var td = row.children[5];
        if (td) {
            td.innerHTML = '';
            if (resolvedNames.length === 0) {
                var em = document.createElement('span');
                em.className = 'at-trainer-empty';
                em.textContent = '— No trainer —';
                td.appendChild(em);
            } else {
                for (var n = 0; n < resolvedNames.length; n++) {
                    var pill = document.createElement('span');
                    pill.className = 'at-trainer-pill';
                    pill.textContent = resolvedNames[n];
                    td.appendChild(pill);
                }
            }
        }
        // Action cell (7th <td>) — flip between Edit/Assign Trainer.
        var act = row.children[6];
        if (act) {
            var btn = act.querySelector('button.at-action-btn');
            if (btn) {
                btn.classList.remove('at-action-edit', 'at-action-assign');
                if (resolvedNames.length === 0) {
                    btn.classList.add('at-action-assign');
                    btn.textContent = 'Assign Trainer';
                } else {
                    btn.classList.add('at-action-edit');
                    btn.textContent = 'Edit Trainer';
                }
            }
        }
    }
};

// Recompute the three KPI numbers from the table's current state. Same
// rules as the PHP-side counters: Upcoming = rows with data-tab="upcoming";
// Trainers Assigned / Missing Trainers split that subset by data-trainers-empty.
window.atmRecomputeKpis = function() {
    var rows = document.querySelectorAll('#at-tbody tr[data-tab]');
    var up = 0, assigned = 0, missing = 0;
    for (var i = 0; i < rows.length; i++) {
        if (rows[i].getAttribute('data-tab') !== 'upcoming') continue;
        up++;
        if (rows[i].getAttribute('data-trainers-empty') === '1') missing++;
        else                                                     assigned++;
    }
    var el = document.querySelector('.at-kpi-num.at-num-up');
    if (el) el.textContent = up.toLocaleString();
    el = document.querySelector('.at-kpi-num.at-num-assigned');
    if (el) el.textContent = assigned.toLocaleString();
    el = document.querySelector('.at-kpi-num.at-num-missing');
    if (el) el.textContent = missing.toLocaleString();
    // Refresh visible row set + counter so a row that just got a trainer
    // doesn't linger on a "no trainer" filter, etc.
    if (typeof atRender === 'function') atRender();
};
