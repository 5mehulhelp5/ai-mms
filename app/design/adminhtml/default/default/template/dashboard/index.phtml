                    </div>
                    <div id="dcf-image-upload-msg" style="margin-top:6px;font-size:12px;color:#94a3b8;display:none;"></div>
                </div>
                <script>
                /* Direct-upload helper for the Image URL Link field. Posts the
                   selected file to adminhtml/courseimage/upload, then writes
                   the returned media URL into the text input and updates the
                   preview. The Save Changes flow remains unchanged — the URL
                   is still persisted via the same `image_url` form field. */
                (function () {
                    var fileInput   = document.getElementById('dcf-image-file');
                    var btn         = document.getElementById('dcf-image-upload-btn');
                    var urlInput    = document.getElementById('dcf-image-url');
                    var preview     = document.getElementById('dcf-image-preview');
                    var previewWrap = document.getElementById('dcf-image-preview-wrap');
                    var msg         = document.getElementById('dcf-image-upload-msg');
                    var lbl         = document.getElementById('dcf-image-upload-lbl');
                    if (!fileInput || !btn || !urlInput) return;

                    var uploadUrl = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/courseimage/upload')) ?>;

                    function showMsg(text, color) {
                        msg.style.display = 'block';
                        msg.style.color = color || '#94a3b8';
                        msg.textContent = text;
                    }
                    function refreshPreview() {
                        if (!preview || !previewWrap) return;
                        var v = (urlInput.value || '').trim();
                        if (!v) { previewWrap.style.display = 'none'; return; }
                        preview.src = v;
                        previewWrap.style.display = '';
                    }
                    urlInput.addEventListener('input', refreshPreview);

                    btn.addEventListener('click', function () { fileInput.click(); });

                    fileInput.addEventListener('change', function () {
                        var f = fileInput.files && fileInput.files[0];
                        if (!f) return;
                        if (!/^image\/(jpe?g|png|gif|webp)$/i.test(f.type)) {
                            showMsg('Only JPG / PNG / GIF / WebP images are accepted.', '#fb7185');
                            fileInput.value = '';
                            return;
                        }
                        var fd = new FormData();
                        fd.append('image', f);
                        fd.append('form_key', (window.FORM_KEY || ''));
                        btn.disabled = true;
                        lbl.textContent = 'Uploading…';
                        showMsg('Uploading ' + f.name + '…');
                        fetch(uploadUrl, {
                            method: 'POST',
                            body: fd,
                            credentials: 'same-origin'
                        }).then(function (r) { return r.json(); })
                          .then(function (data) {
                            if (data && data.success && data.url) {
                                urlInput.value = data.url;
                                refreshPreview();
                                showMsg('Uploaded. Click Save Changes to persist.', '#34d399');
                            } else {
                                showMsg('Upload failed: ' + (data && data.message ? data.message : 'unknown error'), '#fb7185');
                            }
                          })
                          .catch(function (err) {
                            showMsg('Upload error: ' + err.message, '#fb7185');
                          })
                          .then(function () {
                            btn.disabled = false;
                            lbl.textContent = 'Upload';
                            fileInput.value = '';
                          });
                    });
                })();
                </script>
