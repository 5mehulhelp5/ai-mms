<?php
// Data prep — only runs when this panel is the active sub-view.
$_alActive = ($activeRole === 'admin') && (Mage::app()->getRequest()->getParam('panel') === 'assign_learner');
$_alKpi = array('upcoming' => 0, 'ongoing' => 0, 'completed' => 0, 'trainees' => 0, 'no_trainee' => 0);
$_alRows = array();
$_alCourseTitles = array();
if ($_alActive) {
    // Country scope from the logged-in admin (admin.<cc>@…).
    $_alWid = (int) Mage::helper('mmd_rolemanager')->getActiveWebsiteId();
    try {
        // Country-scoped catalog: active + named on the admin's website.
        // Date columns converted from correlated subqueries to LEFT JOINs at
        // store_id=0 (verified equivalent on local DB; ~50% faster).
        $_alProducts = $read->fetchAll(
            "SELECT e.entity_id, e.sku, v.value AS name,
                    sd.value AS news_from_date,
                    ed.value AS news_to_date
             FROM catalog_product_entity e
             INNER JOIN catalog_product_website pw
                ON pw.product_id=e.entity_id AND pw.website_id={$_alWid}
             INNER JOIN catalog_product_entity_varchar v
                ON v.entity_id=e.entity_id AND v.attribute_id=71 AND v.store_id=0
             INNER JOIN catalog_product_entity_int s
                ON s.entity_id=e.entity_id AND s.attribute_id={$statusAid} AND s.store_id=0 AND s.value=1
             LEFT JOIN catalog_product_entity_datetime sd
                ON sd.entity_id=e.entity_id AND sd.attribute_id={$startAid} AND sd.store_id=0
             LEFT JOIN catalog_product_entity_datetime ed
                ON ed.entity_id=e.entity_id AND ed.attribute_id={$endAid}   AND ed.store_id=0
             WHERE v.value IS NOT NULL AND v.value <> ''
             ORDER BY IFNULL(sd.value, '9999-12-31') ASC, e.entity_id ASC
             LIMIT 2000"
        );

        // Latest course_runs row per product (override dates if present).
        $_alRunByPid = array();
        try {
            $_alRunRows = $read->fetchAll(
                "SELECT cr.product_id, cr.run_id, cr.course_start_date, cr.course_end_date
                 FROM course_runs cr
                 JOIN (
                     SELECT product_id, MAX(run_id) AS max_run FROM course_runs GROUP BY product_id
                 ) latest ON latest.product_id=cr.product_id AND latest.max_run=cr.run_id"
            );
            foreach ($_alRunRows as $_rn) $_alRunByPid[(int)$_rn['product_id']] = $_rn;
        } catch (Exception $e) {}

        // Aggregate enrolment counts per product. UNION two sources so
        // admin-driven enrolments via the Assign Learners panel persist
        // across page reloads:
        //   1. sales_flat_order — paying customers (SG website only).
        //   2. course_run_enrolments — admins clicking "Add Learner".
        // Distinct count over the union de-dupes a learner who both
        // ordered AND was admin-assigned to the same course.
        // IMPORTANT: this filter MUST stay in sync with the modal's
        // loadLearnersAction in CoursesaveController.php — otherwise the
        // badge updates with a different number the moment the admin
        // clicks "Add / Edit Learners" (because the JS replaces the
        // initial badge value with the modal's count). Both queries:
        //   - orders: state IN ('complete','processing') only
        //     (paid attendees only; pending / payment_review / holded
        //      shouldn't show as enrolled)
        //   - course_run_enrolments: every row, the admin explicitly
        //     added them
        // UNION-distinct on (product_id, email) so a learner who both
        // ordered AND was admin-assigned to the same product counts once.
        $_alEnrol = array();
        try {
            $_alEnrolRows = $read->fetchAll(
                "SELECT u.product_id, COUNT(DISTINCT u.email) AS c
                 FROM (
                     SELECT oi.product_id, LOWER(o.customer_email) AS email
                     FROM sales_flat_order o
                     JOIN sales_flat_order_item oi ON oi.order_id=o.entity_id
                     JOIN core_store cs ON cs.store_id=o.store_id AND cs.website_id={$_alWid}
                     WHERE o.state IN ('complete','processing')
                       AND o.customer_email IS NOT NULL
                     UNION
                     SELECT product_id, LOWER(learner_email) AS email
                     FROM course_run_enrolments
                     WHERE learner_email IS NOT NULL AND learner_email <> ''
                 ) u
                 GROUP BY u.product_id"
            );
            foreach ($_alEnrolRows as $_er) $_alEnrol[(int)$_er['product_id']] = (int)$_er['c'];
        } catch (Exception $e) {}

        // Bulk-load "Course Date" custom-option titles per product. Many
        // catalog products leave news_from_date empty and store the real
        // schedule as drop-down options like "14 Mar 2026 (Sat)" — the
        // Learner My Classes view already parses these, mirror it here
        // so the Assign Learners table doesn't show "—" for products
        // that genuinely do have a published date.
        $_alCdByPid = array();
        try {
            $_alCdRows = $read->fetchAll(
                "SELECT o.product_id, ott.title
                 FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'"
            );
            foreach ($_alCdRows as $_cd) $_alCdByPid[(int)$_cd['product_id']][] = $_cd['title'];
        } catch (Exception $e) {}

        $_alToday = strtotime(date('Y-m-d'));
        foreach ($_alProducts as $_p) {
            $_pid = (int) $_p['entity_id'];
            $_run = isset($_alRunByPid[$_pid]) ? $_alRunByPid[$_pid] : null;

            $_sd = 0; $_ed = 0;
            if ($_run && !empty($_run['course_start_date'])) $_sd = strtotime($_run['course_start_date']);
            elseif ($_p['news_from_date'])                   $_sd = strtotime($_p['news_from_date']);
            if ($_run && !empty($_run['course_end_date']))   $_ed = strtotime($_run['course_end_date']);
            elseif ($_p['news_to_date'])                     $_ed = strtotime($_p['news_to_date']);

            // Course Date fallback — only when neither course_runs nor
            // news_from_date provided a date. Pick the soonest future
            // date if any exist; otherwise the latest past date so the
            // tab classifier still buckets it correctly.
            if (!$_sd && isset($_alCdByPid[$_pid])) {
                $_bestFuture = null; $_bestFutureEnd = 0;
                $_bestPast   = null; $_bestPastEnd   = 0;
                foreach ($_alCdByPid[$_pid] as $_title) {
                    if (preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_title, $_dm)) {
                        $_stTs = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_dm[4]);
                        $_enTs = !empty($_dm[2]) ? strtotime($_dm[2] . ' ' . $_dm[3] . ' ' . $_dm[4]) : $_stTs;
                        if (!$_stTs) continue;
                        if ($_stTs >= $_alToday) {
                            if ($_bestFuture === null || $_stTs < $_bestFuture) { $_bestFuture = $_stTs; $_bestFutureEnd = $_enTs; }
                        } else {
                            if ($_bestPast === null || $_stTs > $_bestPast)     { $_bestPast   = $_stTs; $_bestPastEnd   = $_enTs; }
                        }
                    }
                }
                if ($_bestFuture !== null)   { $_sd = $_bestFuture; $_ed = $_bestFutureEnd; }
                elseif ($_bestPast !== null) { $_sd = $_bestPast;   $_ed = $_bestPastEnd; }
            }

            $_tab = '';
            if ($_sd && $_ed && $_sd <= $_alToday && $_ed >= $_alToday) $_tab = 'ongoing';
            elseif ($_ed && $_ed < $_alToday)                           $_tab = 'completed';
            elseif ($_sd && $_sd < $_alToday && !$_ed)                  $_tab = 'completed';
            else                                                        $_tab = 'upcoming';

            // Run ID — same pattern as Assign Trainer.
            if ($_run) {
                $_runId = Mage::helper('mmd_rolemanager')->formatRunId($_pid, $_run['run_id']);
            } elseif (isset($_lmcRunMap[$_pid])) {
                $_runId = $_lmcRunMap[$_pid];
            } elseif (isset($_devRankMap[$_pid])) {
                $_runId = $_devPrefix . '-' . (100000 + (int)$_devRankMap[$_pid]);
            } else {
                $_runId = (string) (1000000 + $_pid);
            }

            $_traineeCount = isset($_alEnrol[$_pid]) ? (int)$_alEnrol[$_pid] : 0;

            $_alRows[] = array(
                'pid'        => $_pid,
                'sku'        => $_p['sku'],
                'title'      => $_p['name'] ?: '(No Name)',
                'run_id'     => $_runId,
                'start_date' => $_sd ? date('d/m/Y', $_sd) : '—',
                'start_iso'  => $_sd ? date('Y-m-d', $_sd) : '',
                'tab'        => $_tab,
                'trainees'   => $_traineeCount,
            );
            $_alCourseTitles[$_p['name']] = true;

            if ($_tab === 'upcoming')  $_alKpi['upcoming']++;
            if ($_tab === 'ongoing')   $_alKpi['ongoing']++;
            if ($_tab === 'completed') $_alKpi['completed']++;
            if ($_tab === 'upcoming') {
                if ($_traineeCount === 0) $_alKpi['no_trainee']++;
            }
        }
        ksort($_alCourseTitles);
        $_alCourseTitles = array_keys($_alCourseTitles);

        // Sort rows by effective start date ascending (soonest first),
        // empty dates last. The earlier SQL ORDER BY only sees
        // news_from_date — it can't know about course_runs / Course
        // Date custom-option fallbacks that fill in dates per row in
        // PHP, so without this re-sort the table looks scrambled.
        usort($_alRows, function ($a, $b) {
            $aEmpty = $a['start_iso'] === '';
            $bEmpty = $b['start_iso'] === '';
            if ($aEmpty !== $bEmpty) return $aEmpty ? 1 : -1;
            if ($a['start_iso'] !== $b['start_iso']) return strcmp($a['start_iso'], $b['start_iso']);
            return $a['pid'] - $b['pid'];
        });

        // Distinct trainee count per tab bucket. The Sum-of-counts
        // approach inflated the KPI because a learner enrolled in 5
        // upcoming courses got counted 5×. We instead query distinct
        // emails over the union of products in each bucket so the
        // tile reads "people enrolled in upcoming classes", not
        // "enrolment seats filled".
        $_alPidsByTab = array('upcoming' => array(), 'ongoing' => array(), 'completed' => array());
        $_alNoTraineeByTab = array('upcoming' => 0, 'ongoing' => 0, 'completed' => 0);
        foreach ($_alRows as $_r) {
            $_alPidsByTab[$_r['tab']][] = (int)$_r['pid'];
            if ((int)$_r['trainees'] === 0) $_alNoTraineeByTab[$_r['tab']]++;
        }
        $_alDistinctByTab = array('upcoming' => 0, 'ongoing' => 0, 'completed' => 0);
        foreach ($_alPidsByTab as $_tabName => $_pidsT) {
            if (empty($_pidsT)) continue;
            try {
                $_pidsList = implode(',', $_pidsT);
                // Distinct over UNION of order-based + admin-driven
                // enrolments — same shape as the per-product query.
                // Same filter as the per-product count + the modal's
                // loadLearners action — orders restricted to paid /
                // processing only (state IN complete/processing), plus
                // every admin-added course_run_enrolments row. Keep
                // these three sources in lockstep so the KPI tile
                // matches the row badges and the modal.
                $_alDistinctByTab[$_tabName] = (int) $read->fetchOne(
                    "SELECT COUNT(DISTINCT u.email) FROM (
                         SELECT LOWER(o.customer_email) AS email
                         FROM sales_flat_order o
                         JOIN sales_flat_order_item oi ON oi.order_id=o.entity_id
                         JOIN core_store cs ON cs.store_id=o.store_id AND cs.website_id={$_alWid}
                         WHERE o.state IN ('complete','processing')
                           AND o.customer_email IS NOT NULL
                           AND oi.product_id IN ({$_pidsList})
                         UNION
                         SELECT LOWER(learner_email) AS email
                         FROM course_run_enrolments
                         WHERE learner_email IS NOT NULL AND learner_email <> ''
                           AND product_id IN ({$_pidsList})
                     ) u"
                );
            } catch (Exception $e) {}
        }
        $_alKpi['trainees'] = $_alDistinctByTab['upcoming'];
    } catch (Exception $e) {}
}
if (!isset($_alDistinctByTab))   $_alDistinctByTab   = array('upcoming' => 0, 'ongoing' => 0, 'completed' => 0);
if (!isset($_alNoTraineeByTab))  $_alNoTraineeByTab  = array('upcoming' => 0, 'ongoing' => 0, 'completed' => 0);
