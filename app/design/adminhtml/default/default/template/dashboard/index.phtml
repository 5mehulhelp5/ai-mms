                    window.lsnAddTopic = function(){
                        topics.push({ title: 'Topic ' + (topics.length + 1) + ': New Topic', subsecs: [{ title: '', links: [] }], _open: true });
                        render();
                    };

                    /* Drag-and-drop reordering of topic cards.
                       Event-delegated on the #lsn-topics container so we
                       wire it up exactly once and don't re-attach handlers
                       on every render. Only the hamburger handle starts a
                       drag — clicks inside text inputs / buttons don't. */
                    (function attachTopicDragDrop(){
                        var wrap = document.getElementById('lsn-topics');
                        if (!wrap || wrap._dragWired) return;
                        wrap._dragWired = true;

                        wrap.addEventListener('mousedown', function (e) {
                            var handle = e.target.closest && e.target.closest('.lsn-topic-drag');
                            if (!handle) return;
                            var topic = handle.closest('.lsn-topic');
                            if (topic) topic.setAttribute('draggable', 'true');
                        });
                        wrap.addEventListener('mouseup', function () {
                            wrap.querySelectorAll('.lsn-topic[draggable="true"]').forEach(function (t) {
                                t.removeAttribute('draggable');
                            });
                        });

                        function indexOfTopic(el) {
                            var children = Array.prototype.slice.call(wrap.children);
                            return children.indexOf(el);
                        }

                        wrap.addEventListener('dragstart', function (e) {
                            var topic = e.target.closest && e.target.closest('.lsn-topic');
                            if (!topic || topic.getAttribute('draggable') !== 'true') return;
                            var fromIdx = indexOfTopic(topic);
                            if (fromIdx < 0) return;
                            e.dataTransfer.setData('text/plain', String(fromIdx));
                            e.dataTransfer.effectAllowed = 'move';
                            topic.classList.add('lsn-topic-dragging');
                        });
                        wrap.addEventListener('dragend', function (e) {
                            var topic = e.target.closest && e.target.closest('.lsn-topic');
                            if (topic) topic.classList.remove('lsn-topic-dragging');
                            wrap.querySelectorAll('.lsn-topic-drop-target').forEach(function (t) {
                                t.classList.remove('lsn-topic-drop-target');
                            });
                            wrap.querySelectorAll('.lsn-topic[draggable="true"]').forEach(function (t) {
                                t.removeAttribute('draggable');
                            });
                        });
                        wrap.addEventListener('dragover', function (e) {
                            e.preventDefault();
                            e.dataTransfer.dropEffect = 'move';
                            var topic = e.target.closest && e.target.closest('.lsn-topic');
                            wrap.querySelectorAll('.lsn-topic-drop-target').forEach(function (t) {
                                if (t !== topic) t.classList.remove('lsn-topic-drop-target');
                            });
                            if (topic && !topic.classList.contains('lsn-topic-dragging')) {
                                topic.classList.add('lsn-topic-drop-target');
                            }
                        });
                        wrap.addEventListener('drop', function (e) {
                            e.preventDefault();
                            var target = e.target.closest && e.target.closest('.lsn-topic');
                            if (!target) return;
                            var fromIdx = parseInt(e.dataTransfer.getData('text/plain'), 10);
                            var toIdx = indexOfTopic(target);
                            wrap.querySelectorAll('.lsn-topic-drop-target').forEach(function (t) {
                                t.classList.remove('lsn-topic-drop-target');
                            });
                            if (isNaN(fromIdx) || fromIdx === toIdx || fromIdx < 0 || toIdx < 0) return;
                            var moved = topics.splice(fromIdx, 1)[0];
                            topics.splice(toIdx, 0, moved);
                            render();
                        });
                    })();
                    window.lsnAddSubsec = function(ti){
                        topics[ti].subsecs = topics[ti].subsecs || [];
