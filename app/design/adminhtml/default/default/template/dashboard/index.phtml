);
$_creds = array();
foreach ($_credPaths as $_cp) {
    $_creds[$_cp] = (string) Mage::getStoreConfig($_cp);
}
$_credMask = function ($v) {
    $v = (string) $v;
    if ($v === '') return '';
    $n = strlen($v);
    if ($n <= 8) return str_repeat('•', max($n - 2, 1)) . substr($v, -2);
    return substr($v, 0, 4) . str_repeat('•', 12) . substr($v, -4);
};
