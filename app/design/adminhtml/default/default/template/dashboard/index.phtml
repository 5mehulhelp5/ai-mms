                <script>
                /* Collapse / expand every topic card in one click. The button
                   reflects the next action it would take — when everything is
                   already collapsed it offers to expand (down chevron), and
                   when at least one is open it offers to collapse (up chevron). */
                function lsnUpdateCollapseBtn() {
                    var topics = document.querySelectorAll('#lsn-topics .lsn-topic');
                    var anyOpen = false;
                    for (var i = 0; i < topics.length; i++) {
                        if (topics[i].classList.contains('open')) { anyOpen = true; break; }
                    }
                    var lbl  = document.getElementById('lsn-collapse-all-lbl');
                    var icon = document.getElementById('lsn-collapse-all-icon');
                    if (lbl)  lbl.textContent  = anyOpen ? 'Collapse all topics' : 'Expand all topics';
                    if (icon) icon.style.transform = anyOpen ? 'rotate(180deg)' : '';
                }
                window.lsnToggleAll = function () {
                    var topicEls = document.querySelectorAll('#lsn-topics .lsn-topic');
                    if (!topicEls.length) return;
                    var anyOpen = false;
                    for (var i = 0; i < topicEls.length; i++) {
                        if (topicEls[i].classList.contains('open')) { anyOpen = true; break; }
                    }
                    // Write the desired state into the canonical topics[] array
                    // (via the IIFE-exposed helper) so render() preserves it on
                    // every subsequent edit / add / delete. Falls back to direct
                    // class toggling if the helper isn't ready yet.
                    if (typeof window.lsnSetAllOpen === 'function') {
                        window.lsnSetAllOpen(!anyOpen);
                    } else {
                        for (var j = 0; j < topicEls.length; j++) {
                            if (anyOpen) topicEls[j].classList.remove('open');
                            else         topicEls[j].classList.add('open');
                        }
                    }
                    lsnUpdateCollapseBtn();
                };
                // Sync the button label/arrow on first paint so they match
                // whatever state the topics happened to load in.
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', lsnUpdateCollapseBtn);
                } else {
                    setTimeout(lsnUpdateCollapseBtn, 0);
                }
