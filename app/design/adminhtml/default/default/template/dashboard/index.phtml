    <?php if ($activeRole === 'trainer' || $activeRole === 'learner'): ?>
    <!-- Lesson (visible to trainer + learner). Topics extracted from the
         course's description field (the same source the Developer view
         uses) — looking for <strong>Topic N: ...</strong> markup that
         the dev course editor's Lesson editor saves into the description.
         Previously hardcoded 7 AutoCAD topics, which made trainer/learner
         views show stale data unrelated to the actual course (fixed
         2026-05-07). -->
    <?php
    // Same parser the developer view uses: prefer the LSN_DATA JSON marker
    // for full structure (subsecs + typed links), fall back to flat
    // <strong>...LU N: title...</strong> parse for legacy courses.
    $_sharedLessonTopics = array();
    try {
        $_sharedProd = Mage::getModel('catalog/product')->load($_selectedCourse['id']);
        $_sharedDescRaw = (string)$_sharedProd->getData('description');
        if ($_sharedDescRaw !== '' && preg_match('/<!--\s*LSN_DATA:\s*(\[.*?\])\s*-->/s', $_sharedDescRaw, $_slj)) {
            $_sDecoded = json_decode($_slj[1], true);
            if (is_array($_sDecoded)) {
                foreach ($_sDecoded as $_t) {
                    // Same v1/v2/v3 normaliser as the other two blocks.
                    $_subsecsRaw = isset($_t['subsecs']) && is_array($_t['subsecs']) ? $_t['subsecs']
                                 : (isset($_t['subsec']) && is_string($_t['subsec']) && $_t['subsec'] !== '' ? array($_t['subsec']) : array());
                    $_subTitles = array();
                    $_subLinks  = array();
                    foreach ($_subsecsRaw as $_ss) {
                        if (is_array($_ss)) {
                            $_sst = (string)(isset($_ss['title']) ? $_ss['title'] : '');
                            if ($_sst !== '') $_subTitles[] = $_sst;
                            if (isset($_ss['links']) && is_array($_ss['links'])) {
                                foreach ($_ss['links'] as $_sl) {
                                    if (is_array($_sl)) $_subLinks[] = $_sl;
                                }
                            }
                        } else {
                            $_sst = (string)$_ss;
                            if ($_sst !== '') $_subTitles[] = $_sst;
                        }
                    }
                    $_topicLinks = isset($_t['links']) && is_array($_t['links']) ? $_t['links'] : array();
                    $_sharedLessonTopics[] = array(
                        'title'   => (string)(isset($_t['title']) ? $_t['title'] : ''),
                        'subsecs' => $_subTitles,
                        'links'   => array_merge($_topicLinks, $_subLinks),
                    );
                }
            }
        }
        if (empty($_sharedLessonTopics) && $_sharedDescRaw !== ''
            && preg_match('#<strong>\s*(?:LU|Lesson|Topic|Module)\s*\d+#i', $_sharedDescRaw)) {
            // Split on each LU/Lesson/Topic/Module heading so we also
            // collect the <em>T#: …</em> sub-topic lines that follow it
            // (legacy Course-Topics HTML lists the T#s under each LU).
            // Earlier code only kept the <strong> titles and dropped them.
            $_shParts = preg_split(
                '#<strong>\s*((?:LU|Lesson|Topic|Module)\s*\d+[^<]*?)\s*</strong>#i',
                $_sharedDescRaw, -1, PREG_SPLIT_DELIM_CAPTURE
            );
            for ($_shPi = 1; $_shPi < count($_shParts); $_shPi += 2) {
                $_lt = trim(html_entity_decode($_shParts[$_shPi]), " :\t\n\r\0\x0B");
                if ($_lt === '') continue;
                $_shBody = isset($_shParts[$_shPi + 1]) ? $_shParts[$_shPi + 1] : '';
                $_shSubs = array();
                if (preg_match_all('#<em>(.*?)</em>#is', $_shBody, $_shEm)) {
                    foreach ($_shEm[1] as $_st) {
                        $_st = trim(html_entity_decode(strip_tags($_st)), " :\t\n\r\0\x0B");
                        if ($_st !== '') $_shSubs[] = $_st;
                    }
                } else {
                    foreach (preg_split('#</?(?:p|li|br|div)[^>]*>#i', $_shBody) as $_ln) {
                        $_ln = trim(html_entity_decode(strip_tags($_ln)), " :\t\n\r\0\x0B");
                        if ($_ln !== '') $_shSubs[] = $_ln;
                    }
                }
                $_sharedLessonTopics[] = array('title' => $_lt, 'subsecs' => $_shSubs, 'links' => array());
            }
        }
    } catch (Exception $e) {}
    $_sharedTypeLabels = array('web'=>'Web','doc'=>'Document','yt'=>'YouTube','act'=>'Activity','qz'=>'Quiz');
    $_sharedTypeColors = array('web'=>'#2563eb','doc'=>'#16a34a','yt'=>'#dc2626','act'=>'#f59e0b','qz'=>'#a855f7');
    ?>
    <div class="lcd-section" id="lesson">
        <div class="lcd-section-title" style="padding-bottom:14px;border-bottom:2px solid #22d3ee;margin-bottom:4px;">Lesson</div>
        <?php if (!empty($_sharedLessonTopics)): ?>
        <?php foreach ($_sharedLessonTopics as $_tp):
            $_hasBody = !empty($_tp['subsecs']) || !empty($_tp['links']);
        ?>
        <div class="lcd-shared-topic">
            <div class="lcd-shared-topic-head" onclick="this.parentNode.classList.toggle('open')">
                <div class="lcd-shared-topic-title"><?php echo htmlspecialchars($_tp['title']) ?></div>
                <svg class="lcd-shared-topic-caret" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="lcd-shared-topic-body">
                <?php if (!empty($_tp['subsecs'])): foreach ($_tp['subsecs'] as $_ss): ?>
