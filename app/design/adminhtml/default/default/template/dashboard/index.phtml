<?php /* ===== Role switcher JS ===== */ ?>
<script type="text/javascript">
(function(){
    var COURSE_DETAIL_ACTIVE = <?php echo $_selectedCourse ? 'true' : 'false' ?>;
    var COURSE_EDIT_ACTIVE = <?php echo ($_editMode || $_editingMode) ? 'true' : 'false' ?>;
    function showPanel(role) {
        var panels = {
            'Admin':             'dash-panel-admin',
            'Super Admin':       'dash-panel-superadmin',
            'Marketing':         'dash-panel-marketing-newsletter',
            'Learner':           'dash-panel-learner',
            'Trainer':           'dash-panel-learner',
            'Developer':         'dash-panel-developer'
        };
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-developer','dash-panel-learner','dash-panel-billing','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-course-detail','dash-panel-course-edit','dash-panel-companysetting','dash-panel-cp-coursedetails','dash-panel-cp-aboutcourse','dash-panel-cp-whatlearn','dash-panel-cp-bgparta','dash-panel-cp-bgpartb','dash-panel-cp-learningoutcomes','dash-panel-cp-instructmethods','dash-panel-cp-assessmethods','dash-panel-cp-lusequencing','dash-panel-cp-courseoutline','dash-panel-cp-entryreq','dash-panel-cp-jobroles','dash-panel-cp-lessonplan','dash-panel-cp-cpvalidation'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        // If in edit mode, show the edit panel
        if (COURSE_EDIT_ACTIVE) {
            var edit = document.getElementById('dash-panel-course-edit');
            if (edit) edit.style.display = '';
            return;
        }
        // If a course is selected, show course detail instead of the role panel
        if (COURSE_DETAIL_ACTIVE) {
            var detail = document.getElementById('dash-panel-course-detail');
            if (detail) detail.style.display = '';
            return;
        }
        var target = panels[role] || 'dash-panel-admin';
        var show = document.getElementById(target);
        if (show) show.style.display = '';

        var suffix = document.querySelector('.head-role-suffix');
        if (suffix) suffix.textContent = ' — ' + role;
    }

    // Trainer sub-view switcher (My Classes <-> Ed Tools)
    // Only effective when current role is Learner/Trainer; otherwise no-op.
    function showTrainerSubPanel(name) {
        var current = 'Admin';
        try { var s = localStorage.getItem('adminViewAs'); if (s) current = s; } catch(e) {}
        if (current !== 'Trainer' && current !== 'Learner') return;

        // Hide ALL panels first, then show only the requested sub-panel
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-learner','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-trainers','dash-panel-companysetting','dash-panel-certhistory','dash-panel-billing'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        var subMap = {
            'edtools':        'dash-panel-edtools',
            'problemsolving': 'dash-panel-problemsolving',
            'dataanalytics':  'dash-panel-dataanalytics',
            'finance':        'dash-panel-finance',
            'statistical':    'dash-panel-statistical',
            'doe':            'dash-panel-doe',
            'spc':            'dash-panel-spc',
            'sustainability': 'dash-panel-sustainability',
            'blockchain':     'dash-panel-blockchain',
            'genai':          'dash-panel-genai',
            'agentic':        'dash-panel-agentic',
            'virtual':        'dash-panel-virtual',
            'billing':        'dash-panel-billing',
            'certhistory':    'dash-panel-certhistory'
        };
        var target = subMap[name] || 'dash-panel-learner';
        var show = document.getElementById(target);
        if (show) show.style.display = '';
    }
    window.showTrainerSubPanel = showTrainerSubPanel;

    // Use server-side role (from session) as source of truth, fall back to localStorage.
    var serverRole = <?php echo json_encode((string)$_roleLabel) ?>;
    var role = serverRole || 'Admin';
    try {
        if (serverRole) localStorage.setItem('adminViewAs', serverRole);
        else { var s = localStorage.getItem('adminViewAs'); if (s) role = s; }
    } catch(e) {}

    // Admin/Super Admin sub-view switcher (Dashboard <-> View Trainers)
    function showAdminSubPanel(name, filter) {
        var r = role;
        if (r !== 'Admin' && r !== 'Super Admin' && r !== 'Marketing') return;
        var panelMap = { admin: 'dash-panel-admin', trainers: 'dash-panel-trainers', companysetting: 'dash-panel-companysetting', credentials: 'dash-panel-credentials', createclass: 'dash-panel-createclass', assigntrainer: 'dash-panel-assigntrainer', assignlearner: 'dash-panel-assignlearner', enrolllearner: 'dash-panel-enrolllearner', marketingnewsletter: 'dash-panel-marketing-newsletter', dashboard: (r === 'Admin' ? 'dash-panel-admin' : 'dash-panel-superadmin') };
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-learner','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-trainers','dash-panel-companysetting','dash-panel-createclass','dash-panel-assigntrainer','dash-panel-assignlearner','dash-panel-enrolllearner'];
        for (var i=0; i<all.length; i++) { var el = document.getElementById(all[i]); if (el) el.style.display = 'none'; }
        var t = document.getElementById(panelMap[name] || panelMap.dashboard);
        if (t) t.style.display = '';
        if (window.applyDashTimeFilter) window.applyDashTimeFilter(filter || '');
    }
    window.showAdminSubPanel = showAdminSubPanel;

    // Time-based filter for the admin master class list. Filter is one of:
    // '' (all), 'ongoing', 'upcoming', 'completed'. The page title and
    // KPI tiles are now rendered server-side from the ?dash_filter query
    // param, so JS just stores the filter and defers row pagination to
    // dashFilter().
    window.applyDashTimeFilter = function(filter) {
        window._dashTimeFilter = filter || '';
        if (typeof window.dashFilter === 'function') window.dashFilter();
    };

    // Developer sub-view switcher (CP Generator pages)
    function showDeveloperSubPanel(name) {
        var cpKeys = ['coursedetails','aboutcourse','whatlearn','bgparta','bgpartb','learningoutcomes','instructmethods','assessmethods','lusequencing','courseoutline','entryreq','jobroles','lessonplan','cpvalidation'];
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-developer','dash-panel-learner','dash-panel-course-detail','dash-panel-course-edit','dash-panel-companysetting'];
        for (var i = 0; i < cpKeys.length; i++) all.push('dash-panel-cp-' + cpKeys[i]);
        for (var j = 0; j < all.length; j++) { var el = document.getElementById(all[j]); if (el) el.style.display = 'none'; }
        if (cpKeys.indexOf(name) >= 0) {
            var t = document.getElementById('dash-panel-cp-' + name);
            if (t) { t.style.display = ''; return; }
            console.warn('[CP] Panel not found:', 'dash-panel-cp-' + name);
        }
        var dev = document.getElementById('dash-panel-developer');
        if (dev) dev.style.display = '';
    }
    window.showDeveloperSubPanel = showDeveloperSubPanel;

    function applyInitialPanel() {
        // Sub-panel selection — accept the resolved value from PHP first
        // (covers Magento's default path-arg URL style /panel/<value>/),
        // then fall back to the query string `?panel=` and finally the
        // legacy `#anchor` hash. Resolve sub-panel BEFORE the default
        // showPanel() call so we don't paint the role's main dashboard
        // for a frame and then flip to the requested sub-panel.
        //
        // Without the PHP-source seed, sidebar links like View Trainers
        // (which use getUrl(..., array('panel' => 'trainers')) → emits
        // /panel/trainers/ path args) bypassed the JS switcher entirely
        // because URLSearchParams only sees the query string. Server-side
        // data prep still ran, but the panel never became visible.
        var qsPanel  = <?php echo json_encode((string) Mage::app()->getRequest()->getParam('panel', '')) ?>;
        var qsFilter = <?php echo json_encode((string) Mage::app()->getRequest()->getParam('dash_filter', '')) ?>;
        if (!qsPanel || !qsFilter) {
            try {
                var qs = new URLSearchParams(window.location.search);
                if (!qsPanel)  qsPanel  = qs.get('panel') || '';
                if (!qsFilter) qsFilter = qs.get('dash_filter') || '';
            } catch (e) {}
        }
        var hash = window.location.hash;

        if ((qsPanel === 'companysetting' || hash === '#companysetting')
            && (role === 'Admin' || role === 'Super Admin' || role === 'Marketing')) {
            showAdminSubPanel('companysetting');
            return;
        }
        if ((qsPanel === 'credentials' || hash === '#credentials')
            && (role === 'Admin' || role === 'Super Admin' || role === 'Marketing')) {
            showAdminSubPanel('credentials');
            return;
        }
        if ((qsPanel === 'trainers' || hash === '#trainers')
            && (role === 'Admin' || role === 'Super Admin' || role === 'Marketing')) {
            showAdminSubPanel('trainers');
            return;
        }
        if ((qsPanel === 'create_class' || qsPanel === 'createclass' || hash === '#create-class')
            && (role === 'Admin' || role === 'Super Admin')) {
            showAdminSubPanel('createclass');
            return;
        }
        if ((qsPanel === 'assign_trainer' || qsPanel === 'assigntrainer' || hash === '#assign-trainer')
            && (role === 'Admin' || role === 'Super Admin')) {
            showAdminSubPanel('assigntrainer');
            return;
        }
        if ((qsPanel === 'assign_learner' || qsPanel === 'assignlearner' || hash === '#assign-learner')
            && (role === 'Admin' || role === 'Super Admin')) {
            showAdminSubPanel('assignlearner');
            return;
        }
        if ((qsPanel === 'enroll_learner' || qsPanel === 'enrolllearner' || hash === '#enroll-learner')
            && (role === 'Admin' || role === 'Super Admin')) {
            showAdminSubPanel('enrolllearner');
            return;
        }
        if ((qsPanel === 'marketing_newsletter' || qsPanel === 'marketingnewsletter' || hash === '#marketing-newsletter')
            && (role === 'Marketing' || role === 'Admin' || role === 'Super Admin')) {
            // Marketing newsletter panel — visible to Marketing role and
            // higher. Use the same showAdminSubPanel hide/show machinery.
            var panel = document.getElementById('dash-panel-marketing-newsletter');
            var all = document.querySelectorAll('[id^="dash-panel-"]');
            for (var i = 0; i < all.length; i++) all[i].style.display = 'none';
            if (panel) panel.style.display = '';
            return;
        }
        if (qsFilter && (role === 'Admin' || role === 'Super Admin' || role === 'Marketing')) {
            showAdminSubPanel('admin', qsFilter);
            return;
        }
        if (hash && hash.indexOf('#cp-') === 0 && role === 'Developer') {
            showDeveloperSubPanel(hash.substring(4));
            return;
        }
        if ((qsPanel === 'billing' || hash === '#billing')
            && (role === 'Learner' || role === 'Trainer')) {
            showTrainerSubPanel('billing');
            return;
        }

        // No specific panel requested — show the role's default panel.
        showPanel(role);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyInitialPanel);
    } else {
        applyInitialPanel();
    }
    window.addEventListener('hashchange', applyInitialPanel);
    // PJAX (instant-nav.js) swaps the page body without reloading the
    // <head> scripts, so DOMContentLoaded doesn't re-fire on subsequent
    // navigations. Re-run sub-panel resolution after every swap so links
    // like ?panel=trainers / ?panel=companysetting still take effect.
    document.addEventListener('instant-nav:after-swap', applyInitialPanel);
    // Also handle browser back/forward — popstate fires on history nav
    // even when the URL only differs in its query string.
    window.addEventListener('popstate', applyInitialPanel);

    // Expose for header role switcher
    window.__applyDashboardRole = showPanel;
})();

// Admin panel filter functions
var _dashAdvOpen = false;
window.dashToggleAdv = function() {
    _dashAdvOpen = !_dashAdvOpen;
    var el = document.getElementById('dashAdvFilters');
    if (el) { if (_dashAdvOpen) el.classList.add('is-open'); else el.classList.remove('is-open'); }
};
window.dashClearFilters = function() {
    ['dashSearch','fType','fStatus','fDateFrom','fDateTo'].forEach(function(id){
        var el=document.getElementById(id); if(el) el.value='';
    });
    dashFilter();
};
window._dashPage = 1;
window._dashPerPage = 20;
window._dashMatchedRows = [];

window.dashFilter = function(resetPage) {
    if (resetPage !== false) window._dashPage = 1;
    var q    = (document.getElementById('dashSearch')||{value:''}).value.toLowerCase().trim();
    var type = (document.getElementById('fType')    ||{value:''}).value.toLowerCase().trim();
    var stat = (document.getElementById('fStatus')  ||{value:''}).value.toLowerCase().trim();
    var df   = (document.getElementById('fDateFrom')||{value:''}).value;
    var dt   = (document.getElementById('fDateTo')  ||{value:''}).value;
    var timeFilter = window._dashTimeFilter || '';
    var today = new Date(); today.setHours(0,0,0,0);
    var rows = document.querySelectorAll('#dashTableBody tr');
    window._dashMatchedRows = [];
    for (var i=0; i<rows.length; i++) {
        var r=rows[i], match=true;
        var rt=(r.getAttribute('data-title')||''), rr=(r.getAttribute('data-ref')||'');
        if (q    && rt.indexOf(q)===-1 && rr.indexOf(q)===-1) match=false;
        if (type && (r.getAttribute('data-type')||'').toLowerCase()!==type) match=false;
        if (stat && (r.getAttribute('data-status')||'').toLowerCase()!==stat) match=false;
        var rs=r.getAttribute('data-start')||'';
        var re=r.getAttribute('data-end')||'';
        if (df && rs && rs<df) match=false;
        if (dt && rs && rs>dt) match=false;
        if (match && timeFilter) {
            var sd = rs ? new Date(rs) : null; if (sd) sd.setHours(0,0,0,0);
            var ed = re ? new Date(re) : null; if (ed) ed.setHours(0,0,0,0);
            if (timeFilter === 'ongoing')  match = !!(sd && ed && sd <= today && ed >= today);
            if (timeFilter === 'upcoming') match = !!(sd && sd > today);
            if (timeFilter === 'completed')match = !!(ed && ed < today);
        }
        r.style.display = 'none';
        if (match) window._dashMatchedRows.push(r);
    }
    window.dashRenderPage();
};

window.dashRenderPage = function() {
    var rowsArr = window._dashMatchedRows || [];
    var perPage = window._dashPerPage || 15;
    var total = rowsArr.length;
    var pages = Math.max(1, Math.ceil(total / perPage));
    if (window._dashPage > pages) window._dashPage = pages;
    if (window._dashPage < 1) window._dashPage = 1;

    for (var i=0; i<rowsArr.length; i++) rowsArr[i].style.display = 'none';
    var startIdx = (window._dashPage - 1) * perPage;
    var endIdx   = Math.min(startIdx + perPage, total);
    for (var j=startIdx; j<endIdx; j++) rowsArr[j].style.display = '';

    var nr = document.getElementById('dashNoResults');
    if (nr) nr.style.display = (total === 0) ? '' : 'none';

    var info = document.getElementById('dashPagerInfo');
    if (info) info.textContent = total === 0 ? 'No courses' : ('Showing ' + (startIdx+1) + ' to ' + endIdx + ' of ' + total + ' courses');

    window.dashRenderPager(pages);
};

window.dashRenderPager = function(pages) {
    var c = document.getElementById('dashPagerCtrls');
    if (!c) return;
    c.innerHTML = '';

    function btn(label, page, opts) {
        opts = opts || {};
        var b = document.createElement('button');
        b.className = 'dash-pg-btn' + (opts.active ? ' active' : '') + (opts.disabled ? ' disabled' : '');
        b.textContent = label;
        if (!opts.disabled && page) b.onclick = function(){ window._dashPage = page; window.dashRenderPage(); };
        c.appendChild(b);
    }
    function ellipsis() { var e = document.createElement('span'); e.className = 'dash-pg-ellipsis'; e.textContent = '...'; c.appendChild(e); }

    btn('Prev', window._dashPage - 1, { disabled: window._dashPage <= 1 });

    var maxNumeric = 5;
    var start = Math.max(1, window._dashPage - 2);
    var end   = Math.min(pages, start + maxNumeric - 1);
    if (end - start < maxNumeric - 1) start = Math.max(1, end - maxNumeric + 1);

    if (start > 1) { btn('1', 1); if (start > 2) ellipsis(); }
    for (var p = start; p <= end; p++) btn(String(p), p, { active: p === window._dashPage });
    if (end < pages) { if (end < pages - 1) ellipsis(); btn(String(pages), pages); }

    btn('Next', window._dashPage + 1, { disabled: window._dashPage >= pages });
};

(function(){
    var si=document.getElementById('dashSearch');
    if(si) si.addEventListener('input', function(){ window.dashFilter(); });
    if (typeof window.dashFilter === 'function') window.dashFilter();

    // Restore page from URL hash (e.g. #page3)
    try {
        var hash = window.location.hash;
        var m = hash.match(/^#page(\d+)$/);
        if (m && parseInt(m[1],10) > 1) {
            window._dashPage = parseInt(m[1],10);
            if (typeof window.dashRenderPage === 'function') window.dashRenderPage();
            history.replaceState(null, '', window.location.pathname + window.location.search);
        }
    } catch(e) {}
})();

// ===== Trainers panel: search + pagination =====
window._trnPage = 1;
window._trnPerPage = 10;
window._trnMatched = [];

window.trnFilter = function() {
    window._trnPage = 1;
    var q    = (document.getElementById('trnSearch')||{value:''}).value.toLowerCase().trim();
    var typ  = (document.getElementById('trnFilterType')||{value:''}).value;
    var stat = (document.getElementById('trnFilterStatus')||{value:''}).value;
    var lin  = (document.getElementById('trnFilterLinkedIn')||{value:''}).value;
    var rows = document.querySelectorAll('#trnTableBody tr');
    window._trnMatched = [];
    for (var i=0; i<rows.length; i++) {
        var r = rows[i];
        var n = r.getAttribute('data-name')     || '';
        var e = r.getAttribute('data-email')    || '';
        var p = r.getAttribute('data-phone')    || '';
        var c = r.getAttribute('data-nric')     || '';
        var t = r.getAttribute('data-type')     || '';
        var s = r.getAttribute('data-status')   || '';
        var l = r.getAttribute('data-linkedin') || '';
        r.style.display = 'none';
        // General search matches across name/email/phone/nric
        var matchQ = !q || n.indexOf(q) !== -1 || e.indexOf(q) !== -1 || p.indexOf(q) !== -1 || c.indexOf(q) !== -1;
        var matchT = !typ  || t === typ;
        var matchS = !stat || s === stat;
        var matchL = !lin  || l === lin;
        if (matchQ && matchT && matchS && matchL) window._trnMatched.push(r);
    }
    window.trnRender();
};

window.trnToggleAdv = function() {
    var panel = document.getElementById('trnAdvPanel');
    var btn   = document.getElementById('trnAdvBtn');
    if (!panel) return;
    // "is currently hidden" iff inline style is 'none' OR computed display is 'none'
    var hidden = panel.style.display === 'none'
        || (panel.style.display === '' && getComputedStyle(panel).display === 'none');
    panel.style.display = hidden ? 'block' : 'none';
    if (btn) btn.textContent = hidden ? 'Hide Advanced Filters' : 'Show Advanced Filters';
};

window.trnRender = function() {
    var rows = window._trnMatched;
    var pp = window._trnPerPage;
    var total = rows.length;
    var pages = Math.max(1, Math.ceil(total / pp));
    if (window._trnPage > pages) window._trnPage = pages;
    if (window._trnPage < 1) window._trnPage = 1;
    for (var i=0; i<rows.length; i++) rows[i].style.display = 'none';
    var s = (window._trnPage - 1) * pp;
    var e = Math.min(s + pp, total);
    for (var j=s; j<e; j++) rows[j].style.display = '';

    var info = document.getElementById('trnPagerInfo');
    if (info) info.textContent = total === 0 ? 'No trainers' : ('Showing ' + (s+1) + ' to ' + e + ' of ' + total + ' trainers');

    var c = document.getElementById('trnPagerCtrls');
    if (!c) return;
    c.innerHTML = '';
    function btn(lbl, page, opts) {
        opts = opts || {};
        var b = document.createElement('button');
        b.className = 'dash-pg-btn' + (opts.active ? ' active' : '') + (opts.disabled ? ' disabled' : '');
        b.textContent = lbl;
        if (!opts.disabled && page) b.onclick = function(){ window._trnPage = page; window.trnRender(); };
        c.appendChild(b);
    }
    function dots() { var x=document.createElement('span'); x.className='dash-pg-ellipsis'; x.textContent='...'; c.appendChild(x); }
    btn('Prev', window._trnPage-1, { disabled: window._trnPage<=1 });
    var maxNum = 5;
    var st = Math.max(1, window._trnPage-2);
    var ed = Math.min(pages, st+maxNum-1);
    if (ed-st < maxNum-1) st = Math.max(1, ed-maxNum+1);
    if (st > 1) { btn('1', 1); if (st > 2) dots(); }
    for (var p=st; p<=ed; p++) btn(String(p), p, { active: p === window._trnPage });
    if (ed < pages) { if (ed < pages-1) dots(); btn(String(pages), pages); }
    btn('Next', window._trnPage+1, { disabled: window._trnPage>=pages });
};

window.trnReset = function() {
    var s = document.getElementById('trnSearch'); if (s) s.value = '';
    ['trnFilterType','trnFilterStatus','trnFilterLinkedIn'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) el.value = '';
    });
    window.trnFilter();
};

(function(){
    var si = document.getElementById('trnSearch');
    if (si) si.addEventListener('input', function(){ window.trnFilter(); });
    ['trnFilterType','trnFilterStatus','trnFilterLinkedIn'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) el.addEventListener('change', function(){ window.trnFilter(); });
    });
    if (typeof window.trnFilter === 'function') window.trnFilter();
})();
</script>

