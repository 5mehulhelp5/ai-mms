// Only Learner and Trainer roles render dash-panel-learner (per the JS
// panelMap below) — for everyone else this whole block runs ~5+
// queries against sales_flat_order whose results are never displayed.
// $_learnerCourses, $_billingHistory et al. already have empty/zero
// defaults above so the markup is safe to render either way.
if ($_loggedInEmail && ($activeRole === 'learner' || $activeRole === 'trainer')) {
    $_now = date('Y-m-d');
    $_resource = Mage::getSingleton('core/resource');
    $_read = $_resource->getConnection('core_read');
    $_orderTable = $_resource->getTableName('sales/order');
    $_itemTable  = $_resource->getTableName('sales/order_item');
    $_prodTable  = $_resource->getTableName('catalog/product');
    $_eav_dt     = $_resource->getTableName('catalog_product_entity_datetime');
    $_eav_vc     = $_resource->getTableName('catalog_product_entity_varchar');
    $_eav_tx     = $_resource->getTableName('catalog_product_entity_text');

    // Get attribute IDs
    // Pulled from the batched $_eavAttrIds lookup at the top of file
    // (one query) instead of 4 separate fetchOne calls per page load.
    $_nameAttrId     = isset($_eavAttrIds['name'])           ? $_eavAttrIds['name']           : 71;
    $_startAttrId    = isset($_eavAttrIds['news_from_date']) ? $_eavAttrIds['news_from_date'] : 0;
    $_endAttrId      = isset($_eavAttrIds['news_to_date'])   ? $_eavAttrIds['news_to_date']   : 0;
    $_trainersAttrId = isset($_eavAttrIds['trainers'])       ? $_eavAttrIds['trainers']       : 0;

    $_rows = array();

    // TRAINER view: show courses where the logged-in trainer (matched by email) is assigned
    if ($activeRole === 'trainer' && $_trainersAttrId) {
        $_userEmail = strtolower(trim((string)$_loggedInUser->getEmail()));
        $_fn = trim((string)$_loggedInUser->getFirstname());
        $_ln = trim((string)$_loggedInUser->getLastname());
        $_fullName = trim($_fn . ' ' . $_ln);

        // Match trainer options to this user. Two strategies:
        // 1. Name-based: admin user's full name appears in trainer option value
        // 2. Email-slug: auto-generated email from trainer name matches admin user's email
        $_optMatches = array();
        $_matchedTrainerNames = array(); // lowercase trainer names for trainerprofile fallback
        $_opts = $_read->fetchAll(
            "SELECT o.option_id, v.value FROM eav_attribute_option o
             JOIN eav_attribute_option_value v ON o.option_id=v.option_id
             WHERE o.attribute_id=? AND v.store_id=0",
            array($_trainersAttrId)
        );
        // Tokens for "full-name equal OR full-name-with-prefix" matching.
        // Substring matching is unsafe — "Alfred Ang" must NOT match "Alfred Angelo".
        $_fullNameLc = strtolower($_fullName);
        $_fullNameRegex = $_fullName !== '' ? '/\b' . preg_quote($_fullName, '/') . '\b/i' : '';
        foreach ($_opts as $_o) {
            $_optName = trim(preg_replace('/^ACTA\s+/i', '', $_o['value']));
            if ($_optName === '') continue;
            $_isMatch = false;

            // Strategy 1: full name as a whole word inside the option value.
            // Word-boundary regex prevents "Alfred Ang" matching "Alfred Angelo".
            if ($_fullNameRegex !== '' && preg_match($_fullNameRegex, $_optName)) {
                $_isMatch = true;
            }

            // Strategy 2: auto-generated email slug matches user's email prefix
            if (!$_isMatch && $_userEmail !== '') {
                $_slug = trim(preg_replace('/[^a-z0-9]+/', '.', strtolower($_optName)), '.');
                $_genEmail = $_slug . '@tertiaryinfotech.com';
                if ($_genEmail === $_userEmail) $_isMatch = true;
                // Also match if the user's email local-part equals the slug
                $_userLocal = strstr($_userEmail, '@', true);
                if ($_userLocal !== false && $_slug === $_userLocal) $_isMatch = true;
            }

            if ($_isMatch) {
                $_optMatches[] = (int)$_o['option_id'];
                $_matchedTrainerNames[] = strtolower($_optName);
            }
        }

        // Build the product query: match via multiselect option IDs OR via trainerprofile HTML
        if (!empty($_optMatches) || $_fullName !== '') {
            $_tpAttrId = isset($_eavAttrIds['trainerprofile']) ? $_eavAttrIds['trainerprofile'] : 0;
            $_conditions = array();
            $_params = array();

            if (!empty($_optMatches)) {
                foreach ($_optMatches as $_mid) {
                    $_conditions[] = "(tm.value IS NOT NULL AND FIND_IN_SET(?, REPLACE(tm.value, ' ', ''))>0)";
                    $_params[] = $_mid;
                }
            }
            // Trainerprofile HTML fallback. Only considered when NO
            // multiselect row exists for the product yet (`tm.value_id
            // IS NULL`). Once an admin saves the trainers multiselect —
            // even to clear it — the multiselect becomes the source of
            // truth and we stop falling back to bio text. Without that
            // gate, removing a trainer from the multiselect via the
            // Assign Trainer modal would leave them stuck on their My
            // Assigned Classes view because their name still appears in
            // <strong>Name:</strong> in the course bio.
            if ($_tpAttrId && $_fullName !== '') {
                $_conditions[] = "(tm.value_id IS NULL AND (tp.value LIKE ? OR tp.value LIKE ? OR tp.value LIKE ?))";
                $_params[] = '%<strong>' . $_fullName . ':%';
                $_params[] = '%<strong>' . $_fullName . '</strong>%';
                $_params[] = '%<strong>Dr ' . $_fullName . ':%';
            }

            $_whereSql = !empty($_conditions) ? '(' . implode(' OR ', $_conditions) . ')' : '1=0';
            $_tpJoin  = $_tpAttrId ? "LEFT JOIN {$_eav_tx} tp ON p.entity_id=tp.entity_id AND tp.attribute_id={$_tpAttrId}" : '';

            $_sqlTrainer = "SELECT DISTINCT p.entity_id AS product_id, p.sku,
                                pn.value AS product_name, pn.value AS item_name,
                                'complete' AS order_state,
                                sd.value AS start_date, ed.value AS end_date
                            FROM {$_prodTable} p
                            LEFT JOIN {$_eav_tx} tm ON p.entity_id=tm.entity_id AND tm.attribute_id={$_trainersAttrId}
                            {$_tpJoin}
                            LEFT JOIN {$_eav_vc} pn ON p.entity_id=pn.entity_id AND pn.attribute_id={$_nameAttrId} AND pn.store_id=0
                            LEFT JOIN {$_eav_dt} sd ON p.entity_id=sd.entity_id AND sd.attribute_id={$_startAttrId} AND sd.store_id=0
                            LEFT JOIN {$_eav_dt} ed ON p.entity_id=ed.entity_id AND ed.attribute_id={$_endAttrId} AND ed.store_id=0
                            WHERE {$_whereSql}
                            ORDER BY sd.value DESC
                            LIMIT 200";
            $_rows = $_read->fetchAll($_sqlTrainer, $_params);

            // Resolve real course dates from "Course Date" custom-option dropdown titles.
            // ALWAYS prefer Course Date custom options over news_from_date — many courses
            // have stale news_from_date values from 2014 that should not be displayed.
            //
            // Perf: bulk-load all Course Date titles for every product_id in
            // $_rows in ONE query, group by product_id, then loop in PHP.
            // Previously this ran a fetchAll per row inside the foreach
            // (N+1 — ~200ms on a typical trainer load with 50 rows).
            $_courseDateTitles = _dashLoadCourseDateTitles($_read, $_rows);
            if (!empty($_rows)) {
                $_todayTs = time();
                foreach ($_rows as &$_r) {
                    $_cdDates = isset($_courseDateTitles[(int)$_r['product_id']]) ? $_courseDateTitles[(int)$_r['product_id']] : array();
                    $_bestFuture = null;
                    $_bestEnd = null;
                    $_bestAny = null;
                    foreach ($_cdDates as $_cdTitle) {
                        // Extract date from title like "26 Mar 2026 (Thu)" or "23/24 Jul 2026 Evening (Thu/Fri)"
                        if (preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_cdTitle, $_dm)) {
                            $_startTs = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_dm[4]);
                            $_endTs = !empty($_dm[2]) ? strtotime($_dm[2] . ' ' . $_dm[3] . ' ' . $_dm[4]) : $_startTs;
                            if (!$_startTs) continue;
                            if ($_startTs >= $_todayTs) {
                                if ($_bestFuture === null || $_startTs < $_bestFuture) {
                                    $_bestFuture = $_startTs;
                                    $_bestEnd = $_endTs;
                                }
                            }
                            if ($_bestAny === null || $_startTs > $_bestAny) {
                                $_bestAny = $_startTs;
                                if ($_bestFuture === null) $_bestEnd = $_endTs;
                            }
                        }
                    }
                    if ($_bestFuture !== null) {
                        $_r['start_date'] = date('Y-m-d 00:00:00', $_bestFuture);
                        $_r['end_date']   = date('Y-m-d 23:59:59', $_bestEnd);
                    } elseif ($_bestAny !== null) {
                        $_r['start_date'] = date('Y-m-d 00:00:00', $_bestAny);
                        $_r['end_date']   = date('Y-m-d 23:59:59', $_bestEnd);
                    } else {
                        // No custom-option dates — use news_from_date only if it's recent (last 2 years or future)
                        $_sdTs = $_r['start_date'] ? strtotime($_r['start_date']) : 0;
                        if ($_sdTs > 0 && $_sdTs < ($_todayTs - 63072000)) {
                            // older than 2 years — discard as stale
                            $_r['start_date'] = null;
                            $_r['end_date'] = null;
                        }
                    }
                }
                unset($_r);
            }
        }
    } else {
        // LEARNER view: show courses from order history
        $_sql = "SELECT DISTINCT oi.product_id, oi.sku, oi.name as item_name,
                    o.state as order_state,
                    pn.value as product_name,
                    sd.value as start_date,
                    ed.value as end_date
                 FROM {$_orderTable} o
                 JOIN {$_itemTable} oi ON o.entity_id = oi.order_id
                 LEFT JOIN {$_eav_vc} pn ON oi.product_id = pn.entity_id AND pn.attribute_id = {$_nameAttrId} AND pn.store_id = 0
                 LEFT JOIN {$_eav_dt} sd ON oi.product_id = sd.entity_id AND sd.attribute_id = {$_startAttrId} AND sd.store_id = 0
                 LEFT JOIN {$_eav_dt} ed ON oi.product_id = ed.entity_id AND ed.attribute_id = {$_endAttrId} AND ed.store_id = 0
                 WHERE LOWER(o.customer_email) = ?
                 AND o.state NOT IN ('canceled','closed')
                 ORDER BY sd.value DESC";

        $_rows = $_read->fetchAll($_sql, array($_loggedInEmail));

        // Layer in admin-driven enrolments from course_run_enrolments —
        // these don't have an order behind them but should still show
        // in the learner's My Classes view as "Confirmed" classes.
        // De-duped against $_rows so a learner who both ordered AND was
        // admin-assigned to the same course doesn't get a duplicate card.
        try {
            $_adminEnrolRows = $_read->fetchAll(
                "SELECT cre.product_id, p.sku, pn.value AS item_name,
                        'complete' AS order_state,
                        pn.value AS product_name,
                        sd.value AS start_date,
                        ed.value AS end_date
                 FROM " . $_resource->getTableName('course_run_enrolments') . " cre
                 JOIN {$_prodTable} p ON p.entity_id = cre.product_id
                 LEFT JOIN {$_eav_vc} pn ON pn.entity_id = cre.product_id AND pn.attribute_id = {$_nameAttrId} AND pn.store_id = 0
                 LEFT JOIN {$_eav_dt} sd ON sd.entity_id = cre.product_id AND sd.attribute_id = {$_startAttrId} AND sd.store_id = 0
                 LEFT JOIN {$_eav_dt} ed ON ed.entity_id = cre.product_id AND ed.attribute_id = {$_endAttrId} AND ed.store_id = 0
                 WHERE LOWER(cre.learner_email) = ?",
                array($_loggedInEmail)
            );
            $_existingPids = array();
            foreach ($_rows as $_exr) $_existingPids[(int)$_exr['product_id']] = true;
            foreach ($_adminEnrolRows as $_aer) {
                if (!isset($_existingPids[(int)$_aer['product_id']])) {
                    $_rows[] = $_aer;
                    $_existingPids[(int)$_aer['product_id']] = true;
                }
            }
        } catch (Exception $e) {}

        // Resolve real course dates from "Course Date" custom-option dropdown titles
        // for the learner view too. news_from_date on many courses is either empty
        // or stale (2014-era); the authoritative schedule lives in Course Date options.
        // Same bulk-load optimisation as the trainer branch above — one
        // query for all product_ids, grouped in PHP.
        $_courseDateTitles = _dashLoadCourseDateTitles($_read, $_rows);
        if (!empty($_rows)) {
            $_todayTs = time();
            foreach ($_rows as &$_r) {
                $_cdDates = isset($_courseDateTitles[(int)$_r['product_id']]) ? $_courseDateTitles[(int)$_r['product_id']] : array();
                $_bestFuture = null; $_bestEnd = null; $_bestAny = null;
                foreach ($_cdDates as $_cdTitle) {
                    if (preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_cdTitle, $_dm)) {
                        $_startTs = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_dm[4]);
                        $_endTs = !empty($_dm[2]) ? strtotime($_dm[2] . ' ' . $_dm[3] . ' ' . $_dm[4]) : $_startTs;
                        if (!$_startTs) continue;
                        if ($_startTs >= $_todayTs) {
                            if ($_bestFuture === null || $_startTs < $_bestFuture) {
                                $_bestFuture = $_startTs; $_bestEnd = $_endTs;
                            }
                        }
                        if ($_bestAny === null || $_startTs > $_bestAny) {
                            $_bestAny = $_startTs;
                            if ($_bestFuture === null) $_bestEnd = $_endTs;
                        }
                    }
                }
                if ($_bestFuture !== null) {
                    $_r['start_date'] = date('Y-m-d 00:00:00', $_bestFuture);
                    $_r['end_date']   = date('Y-m-d 23:59:59', $_bestEnd);
                } elseif ($_bestAny !== null) {
                    $_r['start_date'] = date('Y-m-d 00:00:00', $_bestAny);
                    $_r['end_date']   = date('Y-m-d 23:59:59', $_bestEnd);
                } else {
                    $_sdTs = $_r['start_date'] ? strtotime($_r['start_date']) : 0;
                    if ($_sdTs > 0 && $_sdTs < ($_todayTs - 63072000)) {
                        $_r['start_date'] = null; $_r['end_date'] = null;
                    }
                }
            }
            unset($_r);
        }
    }
    foreach ($_rows as $_r) {
        $_start = $_r['start_date'] ? date('Y-m-d', strtotime($_r['start_date'])) : null;
        $_end = $_r['end_date'] ? date('Y-m-d', strtotime($_r['end_date'])) : null;
        // Self-paced products (Practice Exams, voucher-only SKUs) have no
        // Course Date sessions and no news_from_date. Synthesize a stable
        // upcoming window from the product entity_id so the Learner card
        // always shows dates instead of "—".
        if (!$_start) {
            $_offset    = ((int)$_r['product_id'] % 120) + 1;
            $_synthTs   = strtotime('+' . $_offset . ' days');
            $_start     = date('Y-m-d', $_synthTs);
            $_end       = date('Y-m-d', strtotime('+1 day', $_synthTs));
        } elseif (!$_end) {
            $_end = $_start;
        }

        $_status = 'Confirmed';
        if (in_array($_r['order_state'], array('pending','holded','new'))) $_status = 'Pending';

        $_timeStatus = 'current';
        if ($_start && $_end) {
            if ($_now >= $_start && $_now <= $_end) { $_timeStatus = 'current'; $_learnerCurrent++; }
            elseif ($_now < $_start) { $_timeStatus = 'upcoming'; $_learnerUpcoming++; }
            else { $_timeStatus = 'past'; $_learnerPast++; }
        } else {
            // No dates known: trainer view → upcoming (scheduled but not yet running);
            // learner view → past (historical order)
            if ($activeRole === 'trainer') {
                $_timeStatus = 'upcoming';
                $_learnerUpcoming++;
            } else {
                $_timeStatus = 'past';
                $_learnerPast++;
            }
        }

        // Get product image + real attributes from DB
        $_imgUrl = '';
        $_lcDuration = 0;
        $_lcType = '';
        try {
            $_prod = Mage::getModel('catalog/product')->load($_r['product_id']);
            $_courseImgUrl = trim((string) $_prod->getData('course_image_url'));
            if ($_courseImgUrl !== '') {
                $_imgUrl = $_courseImgUrl;
            } elseif ($_prod->getImage() && $_prod->getImage() !== 'no_selection') {
                $_imgUrl = (string) Mage::helper('catalog/image')->init($_prod, 'image')->resize(400, 250);
            }
            $_lcDuration = (float)$_prod->getData('duration');
            $_lcType = $_prod->getAttributeText('software') ?: '';
        } catch (Exception $e) {}

        $_detailUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('course_id' => $_r['product_id']));
        $_learnerCourses[] = array(
            'id'          => $_r['product_id'],
            'name'        => $_r['product_name'] ?: $_r['item_name'],
            'sku'         => $_r['sku'],
            'start_date'  => $_start ? date('j M Y', strtotime($_start)) : '—',
            'end_date'    => $_end ? date('j M Y', strtotime($_end)) : '—',
            'status'      => $_status,
            'time_status' => $_timeStatus,
            'image'       => $_imgUrl,
            'order_state' => $_r['order_state'],
            'detail_url'  => $_detailUrl,
            'duration'    => $_lcDuration,
            'course_type' => $_lcType,
        );
    }

    // Course-runs expansion: each row in course_runs is one scheduled
    // class instance (admin-created via Create New Class). The trainer
    // view needs one card per row — admin scheduling course X three
    // times with the same trainer should produce three distinct cards
    // with their own dates and Run IDs.
    //
    // Strategy: for each existing $_learnerCourses entry, look up all
    // matching course_runs rows. If any exist, REPLACE that single
    // entry with N entries (one per run), each carrying the run's
    // start/end dates plus a unique 'run_id' override. If no rows
    // exist, leave the legacy order-based entry untouched.
    //
    // For trainer role, also additionally include any course_runs
    // rows targeted at the logged-in trainer that aren't already in
    // $_learnerCourses (e.g. a class scheduled before any learner
    // enrolled in it).
    try {
        $_lcProductIds = array_unique(array_map(function ($c) { return (int)$c['id']; }, $_learnerCourses));
        $_runsByPid = array();
        if (!empty($_lcProductIds)) {
            $_runRows = $read->fetchAll(
                "SELECT * FROM course_runs WHERE product_id IN (" . implode(',', $_lcProductIds) . ") ORDER BY run_id ASC"
            );
            foreach ($_runRows as $_rr) {
                $_runsByPid[(int)$_rr['product_id']][] = $_rr;
            }
        }
        if (!empty($_runsByPid)) {
            $_expanded = array();
            foreach ($_learnerCourses as $_lc) {
                $_pid = (int)$_lc['id'];
                if (!isset($_runsByPid[$_pid])) {
                    $_expanded[] = $_lc;
                    continue;
                }
                foreach ($_runsByPid[$_pid] as $_run) {
                    $_card = $_lc;
                    if (!empty($_run['course_start_date'])) $_card['start_date'] = date('j M Y', strtotime($_run['course_start_date']));
                    if (!empty($_run['course_end_date']))   $_card['end_date']   = date('j M Y', strtotime($_run['course_end_date']));
                    $_card['run_id']    = Mage::helper('mmd_rolemanager')->formatRunId($_pid, $_run['run_id']);
                    $_card['venue']     = trim(implode(' ', array_filter(array($_run['venue_block'], $_run['venue_street'], $_run['venue_building']))));
                    $_card['room']      = $_run['room'];
                    $_card['postal']    = $_run['postal_code'];
                    $_card['vacancy']   = $_run['vacancy'];
                    $_card['mode']      = (int)$_run['mode_of_training'];
                    $_card['scheduled'] = true;
                    $_card['cr_run_id'] = (int)$_run['run_id'];
                    $_card['detail_url']= Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('course_id' => $_pid, '_query' => array('run' => (int)$_run['run_id'])));
                    $_expanded[] = $_card;
                }
            }
            $_learnerCourses = $_expanded;
        }

        // Trainer-only: pull in course_runs that target this trainer
        // but whose source product isn't yet in $_learnerCourses.
        if ($activeRole === 'trainer' && !empty($_optMatches)) {
            $_lcSeenRunIds = array();
            foreach ($_learnerCourses as $_lc) {
                if (isset($_lc['cr_run_id'])) $_lcSeenRunIds[(int)$_lc['cr_run_id']] = true;
            }
            $_optList = implode(',', array_map('intval', $_optMatches));
            $_extraRuns = $read->fetchAll(
                "SELECT cr.*, p.sku,
                        (SELECT v.value FROM " . $_resource->getTableName('catalog_product_entity_varchar') . " v
                         WHERE v.entity_id=cr.product_id AND v.attribute_id=71 ORDER BY v.store_id LIMIT 1) AS course_name
                 FROM course_runs cr
                 JOIN " . $_resource->getTableName('catalog_product_entity') . " p ON p.entity_id=cr.product_id
                 WHERE cr.trainer_option_id IN ({$_optList})
                 ORDER BY cr.run_id ASC"
            );
            foreach ($_extraRuns as $_run) {
                if (isset($_lcSeenRunIds[(int)$_run['run_id']])) continue;
                $_pid = (int)$_run['product_id'];
                $_imgUrl = '';
                try {
                    $_p = Mage::getModel('catalog/product')->load($_pid);
                    $_courseImgUrl = trim((string) $_p->getData('course_image_url'));
                    if ($_courseImgUrl !== '') $_imgUrl = $_courseImgUrl;
                    elseif ($_p->getImage() && $_p->getImage() !== 'no_selection') {
                        $_imgUrl = (string) Mage::helper('catalog/image')->init($_p, 'image')->resize(400, 250);
                    }
                    $_dur = (float)$_p->getData('duration');
                    $_typ = $_p->getAttributeText('software') ?: '';
                } catch (Exception $e) { $_dur = 0; $_typ = ''; }
                $_today  = strtotime(date('Y-m-d'));
                $_st     = $_run['course_start_date'] ? strtotime($_run['course_start_date']) : 0;
                $_en     = $_run['course_end_date']   ? strtotime($_run['course_end_date'])   : 0;
                $_tStat  = ($_st && $_st > $_today) ? 'upcoming' : (($_en && $_en < $_today) ? 'past' : 'current');
                $_learnerCourses[] = array(
                    'id'          => $_pid,
                    'name'        => $_run['course_name'] ?: $_run['sku'],
                    'sku'         => $_run['sku'],
                    'start_date'  => $_st ? date('j M Y', $_st) : '—',
                    'end_date'    => $_en ? date('j M Y', $_en) : '—',
                    'status'      => 'Confirmed',
                    'time_status' => $_tStat,
                    'image'       => $_imgUrl,
                    'order_state' => 'complete',
                    'detail_url'  => Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('course_id' => $_pid, '_query' => array('run' => (int)$_run['run_id']))),
                    'duration'    => $_dur,
                    'course_type' => $_typ,
                    'run_id'      => Mage::helper('mmd_rolemanager')->formatRunId($_pid, $_run['run_id']),
                    'venue'       => trim(implode(' ', array_filter(array($_run['venue_block'], $_run['venue_street'], $_run['venue_building'])))),
                    'room'        => $_run['room'],
                    'postal'      => $_run['postal_code'],
                    'vacancy'     => $_run['vacancy'],
                    'mode'        => (int)$_run['mode_of_training'],
                    'scheduled'   => true,
                    'cr_run_id'   => (int)$_run['run_id'],
                );
            }
        }
    } catch (Exception $e) {}

    // Re-classify each card's time_status from its displayed dates and
    // recount the three KPIs so they match the cards 1:1. Without this,
    // run-expansion (one product → N runs) and trainer-extra runs would
    // produce more cards than $_rows-based counters reported, leaving
    // the KPI tiles out of sync with the grid below.
    $_learnerCurrent = 0; $_learnerUpcoming = 0; $_learnerPast = 0;
    $_kpiToday = strtotime(date('Y-m-d'));
    foreach ($_learnerCourses as &$_lcRef) {
        $_lcSt = (!empty($_lcRef['start_date']) && $_lcRef['start_date'] !== '—') ? strtotime($_lcRef['start_date']) : 0;
        $_lcEn = (!empty($_lcRef['end_date'])   && $_lcRef['end_date']   !== '—') ? strtotime($_lcRef['end_date'])   : 0;
        if ($_lcSt && $_lcEn && $_lcSt <= $_kpiToday && $_lcEn >= $_kpiToday) {
            $_lcRef['time_status'] = 'current';
            $_learnerCurrent++;
        } elseif ($_lcSt && $_lcSt > $_kpiToday) {
            $_lcRef['time_status'] = 'upcoming';
            $_learnerUpcoming++;
        } elseif ($_lcEn && $_lcEn < $_kpiToday) {
            $_lcRef['time_status'] = 'past';
            $_learnerPast++;
        } else {
            // No usable date pair: keep prior classification but ensure
            // it lands in some bucket so card count = sum of KPIs.
            $_lcExisting = isset($_lcRef['time_status']) ? $_lcRef['time_status'] : '';
            if ($_lcExisting === 'current')      $_learnerCurrent++;
            elseif ($_lcExisting === 'past')     $_learnerPast++;
            else { $_lcRef['time_status'] = 'upcoming'; $_learnerUpcoming++; }
        }
    }
    unset($_lcRef);

    // Sort My Classes / My Assigned Classes by date (per product request
    // 2026-05-06, reaffirmed 2026-05-07). Group upcoming → current → past
    // so the next-up class is at the top of the grid, then within each
    // group order ascending by start_date. Undated rows fall to the very
    // end. We parse "j M Y" explicitly because that's what we render with
    // — strtotime usually handles it but DateTime::createFromFormat is
    // bullet-proof.
    $_lcParseTs = function ($val) {
        if (empty($val) || $val === '—') return 0;
        $dt = DateTime::createFromFormat('!j M Y', (string)$val);
        if ($dt instanceof DateTime) return (int)$dt->getTimestamp();
        $ts = strtotime((string)$val);
        return $ts ? (int)$ts : 0;
    };
    $_lcStatusOrder = array('upcoming' => 0, 'current' => 1, 'past' => 2);
    usort($_learnerCourses, function ($a, $b) use ($_lcParseTs, $_lcStatusOrder) {
        $aBucket = isset($_lcStatusOrder[$a['time_status']]) ? $_lcStatusOrder[$a['time_status']] : 3;
        $bBucket = isset($_lcStatusOrder[$b['time_status']]) ? $_lcStatusOrder[$b['time_status']] : 3;
        if ($aBucket !== $bBucket) return $aBucket - $bBucket;
        $aSt = $_lcParseTs(isset($a['start_date']) ? $a['start_date'] : '');
        $bSt = $_lcParseTs(isset($b['start_date']) ? $b['start_date'] : '');
        if ($aSt === 0 && $bSt === 0) return 0;
        if ($aSt === 0) return 1;
        if ($bSt === 0) return -1;
        return $aSt - $bSt;
    });

    // Query billing history for this learner (one row per order item)
    $_billSql = "SELECT o.increment_id, o.created_at, o.grand_total, o.status, o.state,
                        oi.name as item_name, oi.sku as item_sku, oi.product_type,
                        (SELECT GROUP_CONCAT(inv.increment_id) FROM {$_resource->getTableName('sales/invoice')} inv WHERE inv.order_id = o.entity_id) as invoice_no
                 FROM {$_orderTable} o
                 JOIN {$_itemTable} oi ON o.entity_id = oi.order_id
                 WHERE LOWER(o.customer_email) = ?
                 ORDER BY o.created_at DESC";
    $_billRows = $_read->fetchAll($_billSql, array($_loggedInEmail));
    foreach ($_billRows as $_b) {
        $_isPaid = in_array($_b['state'], array('complete', 'processing'));
        // Extract course ref code (TGS-XXXXXXXXX) from item name or SKU
        $_refCode = '—';
        if (preg_match('/\b(TGS-\d+)\b/', $_b['item_name'], $_m)) {
            $_refCode = $_m[1];
        } elseif (preg_match('/\b(TGS-\d+)\b/', $_b['item_sku'], $_m)) {
            $_refCode = $_m[1];
        }
        // Generate a deterministic enrollment ID from order + item
        $_enrollId = substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 0, 8) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 8, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 12, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 16, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 20, 12);
        // Determine type from product_type
        $_type = '—';
        if ($_b['product_type'] === 'virtual') $_type = 'Virtual';
        elseif ($_b['product_type'] === 'simple') $_type = 'Physical';
        elseif ($_b['product_type'] === 'downloadable') $_type = 'Download';
        $_billingHistory[] = array(
            'course_title' => $_b['item_name'],
            'ref_code'     => $_refCode,
            'type'         => $_type,
            'invoice_no'   => $_b['invoice_no'] ?: '—',
            'enrollment_id'=> $_enrollId,
            'date'         => date('d M Y', strtotime($_b['created_at'])),
            'status'       => ucfirst($_b['status']),
            'is_paid'      => $_isPaid,
            'amount'       => (float)$_b['grand_total'],
        );
        $_billingTotal += (float)$_b['grand_total'];
        if ($_isPaid) $_billingPaid += (float)$_b['grand_total'];
        else $_billingPending += (float)$_b['grand_total'];
    }
}

// Course Run IDs (SG-100000, SG-100001, ...) sourced from course_run_registry —
// a course gets registered the first time an admin schedules it,
// and keeps its sequential number thereafter. Courses that haven't been
// scheduled don't get a Course Run ID row on the card.
$_lmcCountryPrefix = array(1=>'SG', 2=>'MY', 3=>'GH', 4=>'NG', 5=>'BUT', 6=>'IND', 7=>'INF');
$_lmcRunMap        = array(); // product_id => "SG-100000"
try {
    $_lmcRead = Mage::getSingleton('core/resource')->getConnection('core_read');
    $_registryRows = $_lmcRead->fetchAll(
        "SELECT product_id, website_id, run_seq FROM course_run_registry"
    );
    foreach ($_registryRows as $_rr) {
        $_wid    = (int) $_rr['website_id'];
        $_prefix = isset($_lmcCountryPrefix[$_wid]) ? $_lmcCountryPrefix[$_wid] : 'SG';
        $_num    = 100000 + (int) $_rr['run_seq'];
        $_lmcRunMap[(int) $_rr['product_id']] = $_prefix . '-' . str_pad((string)$_num, 6, '0', STR_PAD_LEFT);
    }
} catch (Exception $e) {
    // course_run_registry migration not yet applied
}

// Selected course detail (if course_id param)
$_selectedCourseId = (int) Mage::app()->getRequest()->getParam('course_id');
$_selectedCourse = null;
if ($_selectedCourseId) {
    // First check learner courses
    foreach ($_learnerCourses as $_c) {
        if ((int)$_c['id'] === $_selectedCourseId) {
            $_selectedCourse = $_c;
            break;
        }
    }
    // If not found (e.g. Admin/Super Admin view), load product directly
    if (!$_selectedCourse) {
        try {
            $_prod = Mage::getModel('catalog/product')->load($_selectedCourseId);
            if ($_prod->getId()) {
                $_pName = $_prod->getName();
                $_pSku  = $_prod->getSku();
                $_pStart = $_prod->getData('news_from_date');
                $_pEnd   = $_prod->getData('news_to_date');
                $_pStatus = ((int)$_prod->getStatus() === 1) ? 'Confirmed' : 'Pending';
                $_pImg = '';
                $_courseImgUrl = trim((string) $_prod->getData('course_image_url'));
                if ($_courseImgUrl !== '') {
                    $_pImg = $_courseImgUrl;
                } elseif ($_prod->getImage() && $_prod->getImage() !== 'no_selection') {
                    try { $_pImg = (string) Mage::helper('catalog/image')->init($_prod, 'image')->resize(400, 250); } catch (Exception $e) {}
                }
                // Determine software/class type
                $_swAttr = $_prod->getAttributeText('software');
                $_selectedCourse = array(
                    'id'          => $_selectedCourseId,
                    'name'        => $_pName ?: '(No Name)',
                    'sku'         => $_pSku,
                    'start_date'  => $_pStart ? date('j M Y', strtotime($_pStart)) : '—',
                    'end_date'    => $_pEnd ? date('j M Y', strtotime($_pEnd)) : '—',
                    'status'      => $_pStatus,
                    'time_status' => 'current',
                    'image'       => $_pImg,
                    'order_state' => 'complete',
                    'detail_url'  => '',
                    'class_type'  => $_swAttr ?: '',
                    'duration'    => (float)$_prod->getData('duration'),
                );
            }
        } catch (Exception $e) {}
    }
}
$_backUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard');

// Edit mode for developer course detail
$_courseMode = Mage::app()->getRequest()->getParam('mode');
$_editMode = ($_courseMode === 'edit' || $_courseMode === 'editing') && $_selectedCourse && $activeRole === 'developer';
$_editingMode = ($_courseMode === 'editing') && $_selectedCourse && $activeRole === 'developer';
// Back-state — preserved across View → Edit → Save/Cancel so the editor can
// drop the user back on the exact filtered page they came from.
$_devBack = trim((string) Mage::app()->getRequest()->getParam('dev_back', ''));
$_devBackUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard') . ($_devBack !== '' ? '?' . $_devBack : '') . '#courses';
$_devBackSuffix = $_devBack !== '' ? '?dev_back=' . urlencode($_devBack) : '';
$_editCourseData = array();
if ($_editMode) {
    try {
        $_editProd = Mage::getModel('catalog/product')->load($_selectedCourseId);
        // Explicitly load multiselect/text attributes (default 0 store_id + fallback to any
        // other store where the value is actually populated — some courses store trainerprofile
        // under a specific store_view instead of the admin scope)
        try {
            $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
            $_trVal = $_read->fetchOne("SELECT value FROM catalog_product_entity_text WHERE entity_id=? AND attribute_id=170 AND value IS NOT NULL AND value != '' ORDER BY store_id LIMIT 1", array((int)$_selectedCourseId));
            if ($_trVal !== false && $_trVal !== null) $_editProd->setData('trainers', $_trVal);
            $_tpAttrId = isset($_eavAttrIds['trainerprofile']) ? $_eavAttrIds['trainerprofile'] : 0;
            if ($_tpAttrId) {
                $_tpVal = $_read->fetchOne("SELECT value FROM catalog_product_entity_text WHERE entity_id=? AND attribute_id=? AND value IS NOT NULL AND value != '' ORDER BY store_id LIMIT 1", array((int)$_selectedCourseId, $_tpAttrId));
                if ($_tpVal !== false && $_tpVal !== null) $_editProd->setData('trainerprofile', $_tpVal);
            }
        } catch (Exception $e) {}
        if ($_editProd->getId()) {
            // Build full image URL: prefer course_image_url, fall back to Magento catalog image
            $_imgUrlRaw = trim((string)$_editProd->getData('course_image_url'));
            if ($_imgUrlRaw === '') {
                $_rawImg = $_editProd->getImage();
                if ($_rawImg && $_rawImg !== 'no_selection') {
                    $_imgUrlRaw = Mage::getBaseUrl('media') . 'catalog/product' . $_rawImg;
                }
            }

            // Extract brochure URL: prefer course_brochure_url attribute, else parse from short_description HTML
            $_brochureUrl = trim((string)$_editProd->getData('course_brochure_url'));
            if ($_brochureUrl === '') {
                $_sd = (string)$_editProd->getData('short_description');
                if ($_sd !== '' && preg_match('#Course Brochure.*?<a[^>]+href=(["\'])(.+?)\1#si', $_sd, $_m)) {
                    $_brochureUrl = html_entity_decode($_m[2]);
                }
            }

            // Load ALL trainer options from the `trainers` multiselect attribute
            // Also try to match each trainer's name to an admin_user record to pull an email
            $_allTrainers = array();      // option_id => name
            $_allTrainerEmails = array(); // option_id => email (may be empty)
            try {
                $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
                $_tblOV = $_read->getTableName('eav_attribute_option_value');
                $_tblO  = $_read->getTableName('eav_attribute_option');
                $_rowsAll = $_read->fetchAll(
                    "SELECT o.option_id, v.value FROM {$_tblO} o JOIN {$_tblOV} v ON o.option_id=v.option_id WHERE o.attribute_id=170 AND v.store_id=0 ORDER BY v.value"
                );

                // Load admin users once: full_name_lower => email
                $_adminUsers = array();
                try {
                    $_auRows = $_read->fetchAll("SELECT firstname, lastname, email FROM " . $_read->getTableName('admin_user') . " WHERE email IS NOT NULL AND email != ''");
                    foreach ($_auRows as $_au) {
                        $_fn = trim((string)$_au['firstname']);
                        $_ln = trim((string)$_au['lastname']);
                        if ($_fn !== '' || $_ln !== '') {
                            $_key = strtolower(trim($_fn . ' ' . $_ln));
                            $_adminUsers[$_key] = $_au['email'];
                        }
                    }
                } catch (Exception $e) {}

                foreach ($_rowsAll as $_r) {
                    $_nm = trim(preg_replace('/^ACTA\s+/i', '', $_r['value']));
                    if ($_nm === '') continue;
                    $_allTrainers[(int)$_r['option_id']] = $_nm;
                    // Try to match an admin user by name (case-insensitive)
                    $_low = strtolower($_nm);
                    $_email = '';
                    if (isset($_adminUsers[$_low])) {
                        $_email = $_adminUsers[$_low];
                    } else {
                        foreach ($_adminUsers as $_aukey => $_auemail) {
                            if ($_aukey !== '' && stripos($_nm, $_aukey) !== false) { $_email = $_auemail; break; }
                        }
                    }
                    // Fallback: generate a placeholder email from the name
                    if ($_email === '') {
                        $_slug = preg_replace('/[^a-z0-9]+/', '.', strtolower($_nm));
                        $_slug = trim($_slug, '.');
                        if ($_slug !== '') $_email = $_slug . '@tertiaryinfotech.com';
                    }
                    $_allTrainerEmails[(int)$_r['option_id']] = $_email;
                }
            } catch (Exception $e) {}

            // Currently assigned trainer IDs for this course
            $_assignedIds = array();
            $_trainerIds = (string)$_editProd->getData('trainers');
            if ($_trainerIds !== '') {
                foreach (array_filter(array_map('intval', explode(',', $_trainerIds))) as $_id) {
                    $_assignedIds[] = $_id;
                }
            }

            // Build display list: multiselect names first, then HTML fallback names (deduped)
            $_trainerNames = array();
            $_seenNames = array(); // lowercased for dedup
            foreach ($_assignedIds as $_id) {
                if (isset($_allTrainers[$_id])) {
                    $_nm = $_allTrainers[$_id];
                    $_k = strtolower(trim($_nm));
                    if (!isset($_seenNames[$_k])) {
                        $_trainerNames[] = $_nm;
                        $_seenNames[$_k] = true;
                    }
                }
            }

            // Always also parse trainerprofile HTML so legacy names survive next to multiselect
            $_legacyTrainerNames = array(); // Names that don't exist as options in the master list
            $_tpRaw = (string)$_editProd->getData('trainerprofile');
            if ($_tpRaw !== '' && preg_match_all('#<strong>([^<:]+?):</strong>#si', $_tpRaw, $_tm)) {
                // Build lookup for matching fallback names to option IDs (pre-select in editor)
                $_nameToId = array();
                foreach ($_allTrainers as $_tid => $_tnm) {
                    $_nameToId[strtolower(trim($_tnm))] = $_tid;
                }
                foreach ($_tm[1] as $_n) {
                    $_n = trim(html_entity_decode($_n));
                    if ($_n === '') continue;
                    $_low = strtolower($_n);
                    if (!isset($_seenNames[$_low])) {
                        $_trainerNames[] = $_n;
                        $_seenNames[$_low] = true;
                    }
                    // Try to match the name to a master-list option ID
                    $_matched = false;
                    if (isset($_nameToId[$_low])) {
                        $_mid = $_nameToId[$_low];
                        if (!in_array($_mid, $_assignedIds)) $_assignedIds[] = $_mid;
                        $_matched = true;
                    } else {
                        foreach ($_allTrainers as $_tid => $_tnm) {
                            if (stripos($_tnm, $_n) !== false || stripos($_n, $_tnm) !== false) {
                                if (!in_array($_tid, $_assignedIds)) $_assignedIds[] = $_tid;
                                $_matched = true;
                                break;
                            }
                        }
                    }
                    if (!$_matched) $_legacyTrainerNames[] = $_n;
                }
            }

            $_editCourseData = array(
                'name'        => $_editProd->getName() ?: '',
                'sku'         => $_editProd->getSku() ?: '',
                'status'      => (int) $_editProd->getStatus(),
                'url_key'     => (string) $_editProd->getData('url_key'),
                'image'       => $_selectedCourse['image'],
                'image_url'   => $_imgUrlRaw,
                'description' => $_editProd->getData('description') ?: '',
                'short_desc'  => $_editProd->getData('short_description') ?: '',
                'start_date'  => $_editProd->getData('news_from_date') ? date('M d, Y', strtotime($_editProd->getData('news_from_date'))) : '',
                'end_date'    => $_editProd->getData('news_to_date') ? date('M d, Y', strtotime($_editProd->getData('news_to_date'))) : '',
                'course_type' => $_editProd->getAttributeText('software') ?: '',
                'price'       => (float)$_editProd->getData('price'),
                'duration'    => (float)$_editProd->getData('duration'),
                'sessions'    => $_editProd->getAttributeText('sessions') ?: '',
                'level'       => $_editProd->getAttributeText('level') ?: '',
                'meta_title'       => $_editProd->getData('meta_title') ?: '',
                'meta_description' => $_editProd->getData('meta_description') ?: '',
                'meta_keyword'     => $_editProd->getData('meta_keyword') ?: '',
                'who_should_attend' => $_editProd->getData('whoshouldattend') ?: '',
                'prerequisite'     => $_editProd->getData('prerequisite') ?: '',
                'trainer_profile'  => $_editProd->getData('trainerprofile') ?: '',
                'trainer_names'    => $_trainerNames,
                'all_trainers'     => $_allTrainers,
                'all_trainer_emails' => $_allTrainerEmails,
                'assigned_ids'     => $_assignedIds,
                'legacy_trainers'  => $_legacyTrainerNames,
                'learning_outcomes' => $_editProd->getData('description') ?: '',
                'brochure_url'      => $_brochureUrl,
            );
        }
    } catch (Exception $e) {}
}

// ---- Courseware URLs (Courseware section on Developer course edit page) ----
$_courseware = array(
    'lesson_plan_url'        => '',
    'learner_guide_url'      => '',
    'facilitator_guide_url'  => '',
    'assessment_plan_url'    => '',
    'learner_slides_url'     => '',
    'trainer_slides_url'     => '',
    'courseware_link'        => '',
    'brochure_link'          => '',
    'assessment_record_link' => '',
    'assessment_summary_url' => '',
    'google_meet_url'        => '',
    'certificate_url'        => '',
);
if ($_selectedCourseId) {
    try {
        $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_cwRow = $_read->fetchRow(
            "SELECT * FROM course_courseware WHERE product_id = ? LIMIT 1",
            array((int) $_selectedCourseId)
        );
        if ($_cwRow) {
            foreach ($_courseware as $_k => $_v) {
                if (isset($_cwRow[$_k])) $_courseware[$_k] = (string)$_cwRow[$_k];
            }
        }
    } catch (Exception $e) { /* table may not exist yet on fresh DB */ }
}

// Per-course Additional Documents list (Trainer/Learner course detail
// renders these instead of the previous hardcoded sample row).
$_courseDocuments = array();
if ($_selectedCourseId) {
    try {
        $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_courseDocuments = $_read->fetchAll(
            "SELECT id, filename, file_url, uploaded_by, created_at
             FROM course_documents WHERE product_id = ?
             ORDER BY created_at DESC, id DESC",
            array((int) $_selectedCourseId)
        );
    } catch (Exception $e) { /* table may not exist yet on fresh DB */ }
}

// ---- Course Date sessions (Course Sessions UI) ----
// Query existing "Course Date" custom option values for the currently selected course.
// Used by the Course Sessions section on the Developer course detail page to list
// scheduled sessions and allow adding/removing them.
$_courseSessions = array();
if ($_selectedCourseId) {
    try {
        $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_courseSessions = $_read->fetchAll(
            "SELECT ov.option_type_id, ott.title,
                    COALESCE(otp.price, 0) AS price
             FROM catalog_product_option o
             JOIN catalog_product_option_title ot        ON ot.option_id = o.option_id  AND ot.store_id = 0
             JOIN catalog_product_option_type_value ov   ON ov.option_id = o.option_id
             JOIN catalog_product_option_type_title ott  ON ott.option_type_id = ov.option_type_id AND ott.store_id = 0
             LEFT JOIN catalog_product_option_type_price otp
                    ON otp.option_type_id = ov.option_type_id AND otp.store_id = 0
             WHERE o.product_id = ? AND (ot.title = 'Course Date' OR ot.title LIKE '%Date%')
             ORDER BY ott.title",
            array((int) $_selectedCourseId)
        );
    } catch (Exception $e) { $_courseSessions = array(); }
}
?>

