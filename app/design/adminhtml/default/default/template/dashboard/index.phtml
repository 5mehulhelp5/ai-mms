<script type="text/javascript">
window._alTab = 'upcoming';
window._alPage = 1;
window._alPerPage = 10;
// Server-precomputed per-tab KPI numbers — distinct learner count and
// "no trainee" class count for each bucket. JS reads these on tab
// switch so we don't double-count multi-enrolment learners on the
// client side.
window._alKpiByTab = {
    upcoming:  { trainees: <?php echo (int)$_alDistinctByTab['upcoming']  ?>, noTrainee: <?php echo (int)$_alNoTraineeByTab['upcoming']  ?> },
    ongoing:   { trainees: <?php echo (int)$_alDistinctByTab['ongoing']   ?>, noTrainee: <?php echo (int)$_alNoTraineeByTab['ongoing']   ?> },
    completed: { trainees: <?php echo (int)$_alDistinctByTab['completed'] ?>, noTrainee: <?php echo (int)$_alNoTraineeByTab['completed'] ?> }
};

window.alSetTab = function(btn) {
    var tabs = document.querySelectorAll('.al-tab');
    for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
    btn.classList.add('active');
    window._alTab = btn.getAttribute('data-tab');
    window._alPage = 1;
    alRender();
};

window.alRender = function() {
    var rows = document.querySelectorAll('#al-tbody tr');
    var q = (document.getElementById('al-search')||{value:''}).value.toLowerCase().trim();
    var matched = [];
    // Class count comes from a row walk so it tracks DOM mutations
    // (e.g. a future inline editor that adds/removes rows). Trainees +
    // no-trainee come from server-precomputed per-tab numbers since
    // distinct learner counting can't be done on the client without
    // emails — see _alKpiByTab.
    var kpiClasses = 0;
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        var inTab = r.getAttribute('data-tab') === window._alTab;
        if (inTab) kpiClasses++;
        var match = inTab;
        if (match && q) {
            var hay = (r.getAttribute('data-title')||'') + ' ' + (r.getAttribute('data-sku')||'') + ' ' + (r.getAttribute('data-run')||'');
            if (hay.indexOf(q) === -1) match = false;
        }
        r.style.display = 'none';
        if (match) matched.push(r);
    }
    var kpiBucket = window._alKpiByTab[window._alTab] || { trainees: 0, noTrainee: 0 };
    var kpiTrainees  = kpiBucket.trainees;
    var kpiNoTrainee = kpiBucket.noTrainee;
    // Update KPI tiles + first-tile label so it reads
    // "Upcoming/Ongoing/Completed Classes" depending on the active tab.
    var fmt = function(n){ return n.toLocaleString(); };
    var lblMap = { upcoming: 'Upcoming Classes', ongoing: 'Ongoing Classes', completed: 'Completed Classes' };
    var elClasses  = document.getElementById('al-kpi-classes');
    var elTrainees = document.getElementById('al-kpi-trainees');
    var elEmpty    = document.getElementById('al-kpi-empty');
    var elLbl      = document.getElementById('al-kpi-classes-lbl');
    if (elClasses)  elClasses.textContent  = fmt(kpiClasses);
    if (elTrainees) elTrainees.textContent = fmt(kpiTrainees);
    if (elEmpty)    elEmpty.textContent    = fmt(kpiNoTrainee);
    if (elLbl)      elLbl.textContent      = lblMap[window._alTab] || 'Classes';
    var perPage = window._alPerPage;
    var total = matched.length;
    var pages = Math.max(1, Math.ceil(total / perPage));
    if (window._alPage > pages) window._alPage = pages;
    if (window._alPage < 1) window._alPage = 1;
    var startIdx = (window._alPage - 1) * perPage;
    var endIdx = Math.min(startIdx + perPage, total);
    for (var j = startIdx; j < endIdx; j++) matched[j].style.display = '';

    var info = document.getElementById('al-pager-info');
    if (info) info.textContent = total === 0 ? '' : 'Showing ' + (startIdx + 1) + '–' + endIdx + ' of ' + total + ' classes';

    var ne = document.getElementById('al-no-results');
    if (ne) ne.style.display = total === 0 ? '' : 'none';

    var c = document.getElementById('al-pager-ctrls');
    if (c && total > 0) {
        c.innerHTML = '';
        var cur = window._alPage;
        var addBtn = function(label, page, isActive, isDisabled) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'al-pg-btn' + (isActive ? ' active' : '') + (isDisabled ? ' disabled' : '');
            b.textContent = label;
            if (!isDisabled && page) b.onclick = function() { window._alPage = page; alRender(); };
            c.appendChild(b);
        };
        var addEll = function() {
            var s = document.createElement('span');
            s.className = 'al-pg-ell';
            s.textContent = '…';
            c.appendChild(s);
        };
        var nums = [];
        if (pages <= 10) {
            for (var p1 = 1; p1 <= pages; p1++) nums.push(p1);
        } else {
            nums.push(1);
            for (var p2 = cur - 2; p2 <= cur + 2; p2++) {
                if (p2 > 1 && p2 < pages) nums.push(p2);
            }
            nums.push(pages);
            var dedup = [];
            for (var di = 0; di < nums.length; di++) {
                if (di === 0 || nums[di] !== nums[di - 1]) dedup.push(nums[di]);
            }
            nums = dedup;
        }
        addBtn('Prev', cur - 1, false, cur <= 1);
        var prev = 0;
        for (var k = 0; k < nums.length; k++) {
            var n = nums[k];
            if (prev && n - prev > 1) addEll();
            addBtn(String(n), n, n === cur, false);
            prev = n;
        }
        addBtn('Next', cur + 1, false, cur >= pages);
    } else if (c) {
        c.innerHTML = '';
    }
};
(function(){ if (document.getElementById('al-tbody')) alRender(); })();

// ===== Inline learner editor (alm-) =====
window._almState = { pid: 0, list: [], mode: 'add', selectMode: 'select', selectEmail: '', selectName: '' };

window.almOpen = function(btn) {
    var tr = btn.closest('tr');
    if (!tr) return;
    var almRow = document.getElementById('alm-row');
    if (!almRow) return;

    // Toggle: if already showing under this row, just hide. Don't
    // detach from the DOM — once removed, getElementById can't find
    // it again, which made the button silently no-op on every click
    // after the first.
    var alreadyHere = almRow.previousElementSibling === tr
        && almRow.style.display !== 'none';
    if (alreadyHere) {
        almClose();
        return;
    }
    // insertBefore moves the element if it's already attached
    // elsewhere — no removeChild needed.
    tr.parentNode.insertBefore(almRow, tr.nextSibling);
    almRow.style.display = '';

    window._almState.pid = parseInt(tr.getAttribute('data-pid'), 10) || 0;
    window._almState.list = [];
    window._almState.mode = 'add';
    window._almState.selectMode = 'select';
    window._almState.selectEmail = '';
    window._almState.selectName = '';
    window._almOpenerBtn = btn;
    btn.textContent = 'Close';
    btn.classList.add('al-action-close');

    almRender();
    almLoadCurrent();
};

window.almClose = function() {
    // Just hide — keep it in the DOM so the next click can find it.
    var almRow = document.getElementById('alm-row');
    if (almRow) almRow.style.display = 'none';
    if (window._almOpenerBtn) {
        window._almOpenerBtn.textContent = 'Add / Edit Learners';
        window._almOpenerBtn.classList.remove('al-action-close');
        window._almOpenerBtn = null;
    }
};

window.almSetTab = function(mode) {
    window._almState.mode = mode;
    almRender();
};

window.almSetSelectMode = function(mode) {
    window._almState.selectMode = mode;
    window._almState.selectEmail = '';
    window._almState.selectName = '';
    almRender();
};

window.almRender = function() {
    var st = window._almState;
    document.getElementById('alm-count').textContent = st.list.length;
    document.getElementById('alm-tab-add').classList.toggle('active', st.mode === 'add');
    document.getElementById('alm-tab-view').classList.toggle('active', st.mode === 'view');
    document.getElementById('alm-panel-add').style.display  = st.mode === 'add'  ? '' : 'none';
    document.getElementById('alm-panel-view').style.display = st.mode === 'view' ? '' : 'none';

    document.getElementById('alm-mode-select').classList.toggle('active', st.selectMode === 'select');
    document.getElementById('alm-mode-manual').classList.toggle('active', st.selectMode === 'manual');
    document.getElementById('alm-input-select-wrap').style.display = st.selectMode === 'select' ? '' : 'none';
    document.getElementById('alm-input-manual-wrap').style.display = st.selectMode === 'manual' ? '' : 'none';

    var box = document.getElementById('alm-current-list');
    box.innerHTML = '';
    if (st.list.length === 0) {
        var empty = document.createElement('div');
        empty.className = 'alm-empty';
        empty.textContent = '— No learners enrolled yet —';
        box.appendChild(empty);
    } else {
        for (var i = 0; i < st.list.length; i++) {
            var t = st.list[i];
            var row = document.createElement('div');
            row.className = 'alm-trainer-row';
            var info = document.createElement('div'); info.className = 'alm-trainer-info';
            var n = document.createElement('div'); n.className = 'alm-trainer-name'; n.textContent = t.name;
            info.appendChild(n);
            if (t.email && t.email !== t.name) {
                var em = document.createElement('div');
                em.className = 'alm-trainer-email';
                em.textContent = t.email;
                info.appendChild(em);
            }
            row.appendChild(info);
            // Remove works for both order-sourced and manual rows. Order
            // rows go to the suppression list (course_learner_excludes);
            // manual rows are deleted from course_run_enrolments.
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'alm-trainer-remove';
            rm.textContent = 'Remove';
            (function(em){ rm.onclick = function(){ almRemove(em); }; })(t.email);
            row.appendChild(rm);
            box.appendChild(row);
        }
    }
};

window.almLoadCurrent = function() {
    var pid = window._almState.pid;
    if (!pid) return;
    var fd = new FormData(); fd.append('product_id', String(pid));
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/loadLearners') ?>?product_id=' + pid, { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(j){
          if (j && j.success) { window._almState.list = j.learners || []; almRender(); almSyncRow(0); }
      })
      .catch(function(){});
};

window.almAdd = function() {
    var st = window._almState;
    var email = '', name = '';
    if (st.selectMode === 'select') {
        email = (st.selectEmail || '').toLowerCase().trim();
        name  = st.selectName || '';
        if (!email) { alert('Pick a learner from the list first.'); return; }
    } else {
        email = (document.getElementById('alm-input-manual').value || '').toLowerCase().trim();
        if (!email || email.indexOf('@') === -1) { alert('Enter a valid email.'); return; }
    }
    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    fd.append('learner_email', email);
    fd.append('learner_name',  name);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/addLearner') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        if (j && j.success) {
            // Insert into local list if not already there.
            var exists = false;
            for (var i = 0; i < st.list.length; i++) if (st.list[i].email === j.email) exists = true;
            if (!exists) st.list.push({ email: j.email, name: j.name, source: 'manual', enrol_id: 0 });
            st.selectMode = 'select'; st.selectEmail = ''; st.selectName = '';
            document.getElementById('alm-input-manual').value = '';
            document.getElementById('alm-input-select').value = '';
            almRender();
            almSyncRow(exists ? 0 : 1);
        } else {
            alert((j && j.message) || 'Could not add learner.');
        }
    }).catch(function(err){ alert('Network error: ' + err); });
};

window.almRemove = function(email) {
    var st = window._almState;
    if (!confirm('Remove ' + email + '?')) return;
    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    fd.append('learner_email', email);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/removeLearner') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        if (j && j.success) {
            var removed = 0;
            for (var i = st.list.length - 1; i >= 0; i--) {
                if (st.list[i].email === email && st.list[i].source !== 'order') { st.list.splice(i, 1); removed = 1; }
            }
            almRender();
            almSyncRow(-removed);
        } else {
            alert((j && j.message) || 'Could not remove learner.');
        }
    }).catch(function(err){ alert('Network error: ' + err); });
};

// Patch the originating row's Trainees badge from current list length,
// and recompute the KPI tiles. delta = +1 when a learner was just
// added, -1 when removed, 0 on initial load. The trainees tile is a
// distinct-people count that we can't recompute precisely on the
// client (we'd need every email globally) so we shift it optimistically
// — over-counts if the added learner already had another upcoming
// enrolment, under-counts on remove if they're still elsewhere; the
// drift resets on the next page load when the server recomputes.
window.almSyncRow = function(delta) {
    var st = window._almState;
    var rows = document.querySelectorAll('#al-tbody tr[data-pid="' + st.pid + '"]');
    for (var r = 0; r < rows.length; r++) {
        rows[r].setAttribute('data-trainees', String(st.list.length));
        // Columns: 0=Start, 1=Run ID, 2=Title, 3=Code, 4=Trainees, 5=Action
        var traineesTd = rows[r].children[4];
        if (traineesTd) {
            traineesTd.innerHTML = '';
            var b = document.createElement('span');
            if (st.list.length > 0) {
                b.className = 'al-badge al-badge-enrolled';
                b.textContent = st.list.length + ' enrolled';
            } else {
                b.className = 'al-badge al-badge-empty';
                b.textContent = 'No trainees';
            }
            traineesTd.appendChild(b);
        }
    }
    // Recompute "Classes with No Trainee" from current rows in the active tab.
    var rowsAll = document.querySelectorAll('#al-tbody tr[data-tab]');
    var noT = 0;
    for (var i = 0; i < rowsAll.length; i++) {
        if (rowsAll[i].getAttribute('data-tab') !== window._alTab) continue;
        if ((parseInt(rowsAll[i].getAttribute('data-trainees'), 10) || 0) === 0) noT++;
    }
    var elE = document.getElementById('al-kpi-empty');
    if (elE) elE.textContent = noT.toLocaleString();

    // Bump per-tab trainees count on add/remove.
    if (typeof delta === 'number' && delta !== 0 && window._alKpiByTab) {
        var tab = window._alTab;
        var rowTab = (rows[0] && rows[0].getAttribute('data-tab')) || tab;
        if (window._alKpiByTab[rowTab]) {
            window._alKpiByTab[rowTab].trainees = Math.max(0, (window._alKpiByTab[rowTab].trainees || 0) + delta);
            if (rowTab === tab) {
                var elT = document.getElementById('al-kpi-trainees');
                if (elT) elT.textContent = window._alKpiByTab[rowTab].trainees.toLocaleString();
            }
        }
    }
};

// Autocomplete for the Select-from-list dropdown. Debounced fetch to
// the searchLearners endpoint, populates a <select> with up to 30 matches.
var _almSearchTimer = null;
window.almOnSearchInput = function(input) {
    if (_almSearchTimer) clearTimeout(_almSearchTimer);
    var q = (input.value || '').trim();
    if (q.length < 2) {
        document.getElementById('alm-results').innerHTML = '';
        return;
    }
    _almSearchTimer = setTimeout(function() {
        fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/searchLearners') ?>?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
          .then(function(r){ return r.json(); })
          .then(function(j){
              var box = document.getElementById('alm-results');
              box.innerHTML = '';
              if (!j || !j.success || !j.learners.length) {
                  var n = document.createElement('div');
                  n.className = 'alm-result-empty';
                  n.textContent = 'No matches';
                  box.appendChild(n);
                  return;
              }
              for (var i = 0; i < j.learners.length; i++) {
                  var l = j.learners[i];
                  var d = document.createElement('div');
                  d.className = 'alm-result-row';
                  d.textContent = l.name + '  (' + l.email + ')';
                  (function(email, name){
                      d.onclick = function() {
                          window._almState.selectEmail = email;
                          window._almState.selectName  = name;
                          input.value = name + ' (' + email + ')';
                          box.innerHTML = '';
                      };
                  })(l.email, l.name);
                  box.appendChild(d);
              }
          })
          .catch(function(){});
    }, 200);
};
</script>

