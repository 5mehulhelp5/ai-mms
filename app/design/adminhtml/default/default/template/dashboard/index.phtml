   an unchanged masked value leaves the DB row alone. */
$_credPaths = array(
    'mmd_marketing/api/anthropic_key',
    'mmd_marketing/api/anthropic_model',
    'mmd_marketing/api/mailerlite_key',
    'mmd_marketing/api/from_name',
