<script type="text/javascript">
window.cpAddItem = function(panelKey, placeholder) {
    var list = document.getElementById('cp-list-' + panelKey);
    if (!list) return;
    var count = list.children.length + 1;
    var item = document.createElement('div');
    item.className = 'cp-list-item';
    item.innerHTML = '<span class="cp-list-num">' + count + '.</span>' +
                     '<input type="text" placeholder="' + placeholder + '"/>' +
                     '<button class="cp-remove" onclick="cpRemoveItem(this)" title="Remove">&times;</button>';
    list.appendChild(item);
};
window.cpRemoveItem = function(btn) {
    var item = btn.parentElement;
    var list = item.parentElement;
    item.remove();
    // renumber
    var items = list.children;
    for (var i = 0; i < items.length; i++) {
        var num = items[i].querySelector('.cp-list-num');
        if (num) num.textContent = (i + 1) + '.';
    }
};
window.cpSaveDraft = function(key) {
    alert('Draft saved for ' + key + '. (Coming soon: persist to database)');
};
window.cpSaveAndNext = function(key) {
    var order = ['coursedetails','aboutcourse','whatlearn','bgparta','bgpartb','learningoutcomes','instructmethods','assessmethods','lusequencing','courseoutline','entryreq','jobroles','lessonplan','cpvalidation'];
    var idx = order.indexOf(key);
    if (idx >= 0 && idx < order.length - 1) {
        showDeveloperSubPanel(order[idx + 1]);
        window.scrollTo(0, 0);
    }
};
window.cpSubmitCP = function() {
    if (confirm('Submit this Course Proposal for approval?')) {
        alert('Course Proposal submitted successfully. (Coming soon: actual submission workflow)');
    }
};
</script>

