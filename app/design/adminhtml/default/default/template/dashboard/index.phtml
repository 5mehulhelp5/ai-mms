<script>
function lcdOpenDrawer(){
    document.getElementById('lcd-drawer').classList.add('open');
    document.getElementById('lcd-drawer-backdrop').classList.add('open');
    document.body.classList.add('lcd-drawer-open');
}
function lcdCloseDrawer(){
    document.getElementById('lcd-drawer').classList.remove('open');
    document.getElementById('lcd-drawer-backdrop').classList.remove('open');
    document.body.classList.remove('lcd-drawer-open');
}
function lcdNavTo(link, sectionId){
    // Mark clicked item active
    var items = document.querySelectorAll('.lcd-nav-item');
    for (var i = 0; i < items.length; i++) items[i].classList.remove('active');
    link.classList.add('active');
    // Close drawer and smooth-scroll to section
    lcdCloseDrawer();
    setTimeout(function(){
        var el = document.getElementById(sectionId);
        if (el) el.scrollIntoView({behavior:'smooth', block:'start'});
    }, 260);
    return false;
}
</script>
