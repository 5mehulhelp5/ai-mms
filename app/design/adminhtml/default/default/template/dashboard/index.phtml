<?php
/**
 * Admin Dashboard — all panels rendered server-side,
 * JavaScript shows/hides based on "View As" localStorage value.
 *
 * Panels:
 *   #dash-panel-admin            → View As: Admin              (course schedule)
 *   #dash-panel-superadmin       → View As: Super Admin        (charts / revenue)
 *   #dash-panel-learner          → View As: Learner / Trainer
 */

$resource = Mage::getSingleton('core/resource');
$read     = $resource->getConnection('core_read');
$today    = date('Y-m-d H:i:s');

/**
 * Bulk-load "Course Date" custom-option titles for every product_id
 * appearing in $rows (each row needs a 'product_id' key). Returns an
 * array keyed by product_id mapping to a flat list of title strings,
 * e.g. [1434 => ['7 May 2026 (Thu)', '14 May 2026 (Thu)'], ...].
 *
 * Replaces an N+1 pattern that did one fetchAll per row inside a
 * foreach — measured ~200ms saved on a typical trainer load with 50
 * rows. Empty $rows or no matches → returns empty array (callers
 * fall back to news_from_date / current row data).
 */
if (!function_exists('_dashLoadCourseDateTitles')) {
    function _dashLoadCourseDateTitles($read, array $rows) {
        $out = array();
        if (empty($rows)) return $out;
        $pids = array();
        foreach ($rows as $r) {
            if (isset($r['product_id'])) $pids[(int)$r['product_id']] = true;
        }
        if (empty($pids)) return $out;
        $pidsCsv = implode(',', array_keys($pids));
        try {
            $hits = $read->fetchAll(
                "SELECT o.product_id, ott.title
                 FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE o.product_id IN ({$pidsCsv}) AND (ot.title='Course Date' OR ot.title LIKE '%Date%')"
            );
            foreach ($hits as $h) {
                $out[(int)$h['product_id']][] = (string)$h['title'];
            }
        } catch (Exception $e) { /* fall through with empty out */ }
        return $out;
    }
}

/**
 * Batched EAV attribute_id lookup for product attributes used across
 * the dashboard. Consolidates ~8 separate fetchOne() calls (one per
 * attribute code, scattered through the role-conditional blocks)
 * into a single round-trip. Each consumer reads from $_eavAttrIds.
 * Falls back to a sensible default if the row is missing (rare —
 * these are core product attributes, but the fallback keeps the
 * dashboard rendering instead of erroring out).
 */
$_eavAttrIds = array();
try {
    $_eavRows = $read->fetchAll(
        "SELECT attribute_code, attribute_id FROM eav_attribute
         WHERE entity_type_id=4
           AND attribute_code IN ('name','news_from_date','news_to_date','trainers','trainerprofile')"
    );
    foreach ($_eavRows as $_er) {
        $_eavAttrIds[(string)$_er['attribute_code']] = (int)$_er['attribute_id'];
    }
} catch (Exception $e) { /* falls through with empty map; consumers default */ }

$_roleHelper = null;
try { $_roleHelper = Mage::helper('mmd_rolemanager'); } catch (Exception $e) {} catch (Error $e) {}
try {
    $activeRole = Mage::helper('mmd_rolemanager')->getActiveRoleCode();
} catch (Exception $e) { $activeRole = 'admin'; } catch (Error $e) { $activeRole = 'admin'; }
$_roleLabel = $_roleHelper ? $_roleHelper->getRoleLabel($activeRole) : ucwords(str_replace('_', ' ', $activeRole));
$_roleIcon  = $_roleHelper ? $_roleHelper->getRoleIcon($activeRole) : '';


// =====================================================================
// DATA — Admin panel (course schedule)
// =====================================================================
// Defaults so any variable referenced later in the template works even
// when the active role isn't admin (in which case the dash-panel-admin
// markup is never visible anyway). Skipping this block for non-admin
// roles cuts ~10+ heavy queries off every page load — material because
// every role-swap reloads the dashboard.
$attrMap = array(); $nameAid = 71; $typeAid = $startAid = $endAid = $statusAid = 0;
$ongoingCount = $upcomingCount = $completedCount = 0;
$assignedLocal = $missingLocal = $missingTpg = 0;
$classTypeOptions = array();
$sT = $sS = $sE = ''; $cT = 'NULL AS type_id,'; $cS = 'NULL AS start_date,'; $cE = 'NULL AS end_date,';
$_dashFilter = (string) Mage::app()->getRequest()->getParam('dash_filter', '');
$_dashFilterWhere = '';
$courseRows = array();
$_dashFilterTotal = $_dashFilterLearners = $_dashFilterConfirmed = $_dashFilterPending = 0;
$_trainerLocalCount = $_trainerTpgCount = $_unassignedTrainerCount = 0;
$today = date('Y-m-d H:i:s');
$trainerTable = $resource->getTableName('courses_trainers');

// Tighter gate: when admin is viewing a sub-panel (Create New Class /
// Assign Trainer / Assign Learner / Enroll Learner / View Trainers /
// Configuration / Marketing Newsletter), the master-panel data is never
// shown so we skip its ~12 queries entirely. Each sub-panel below has
// its own self-contained data prep that runs independently.
$_dashSubPanel = (string) Mage::app()->getRequest()->getParam('panel', '');
$_dashOnAdminMaster = ($_dashSubPanel === '' || $_dashSubPanel === 'admin');

// EAV attribute IDs — needed by every admin sub-panel's catalog query
// (Assign Trainer, Assign Learner, Enroll Learner, Create New Class all
// reference $statusAid in INNER JOINs and $startAid/$endAid in ORDER BY
// subqueries). Resolve them for ANY admin request, not just the master
// view, otherwise sub-panels see empty data because $statusAid=0
// matches no rows. One small query, always runs for admin role.
if ($activeRole === 'admin'):
foreach ($read->fetchAll("SELECT attribute_id, attribute_code FROM eav_attribute WHERE entity_type_id=4 AND attribute_code IN ('name','software','news_from_date','news_to_date','status')") as $r) {
    $attrMap[$r['attribute_code']] = (int)$r['attribute_id'];
}
$nameAid   = isset($attrMap['name'])           ? $attrMap['name']           : 71;
$typeAid   = isset($attrMap['software'])       ? $attrMap['software']       : 0;
$startAid  = isset($attrMap['news_from_date']) ? $attrMap['news_from_date'] : 0;
$endAid    = isset($attrMap['news_to_date'])   ? $attrMap['news_to_date']   : 0;
$statusAid = isset($attrMap['status'])         ? $attrMap['status']         : 96;
endif;

if ($activeRole === 'admin' && $_dashOnAdminMaster):

// Country scope from the logged-in admin (admin.<cc>@…). Default SG.
// Applied as an INNER JOIN on catalog_product_website to every query
// below so the master list, KPI counts, and learner / trainer
// roll-ups all reflect the admin's country.
$_adminWid     = (int) Mage::helper('mmd_rolemanager')->getActiveWebsiteId();
$_adminWidJoin = " INNER JOIN catalog_product_website pwx ON pwx.product_id=p.entity_id AND pwx.website_id={$_adminWid} ";

$ongoingCount = ($startAid && $endAid) ? (int)$read->fetchOne("
    SELECT COUNT(DISTINCT p.entity_id) FROM catalog_product_entity p
    {$_adminWidJoin}
    JOIN catalog_product_entity_datetime d1 ON p.entity_id=d1.entity_id AND d1.attribute_id={$startAid} AND d1.store_id=0 AND d1.value<='{$today}'
    JOIN catalog_product_entity_datetime d2 ON p.entity_id=d2.entity_id AND d2.attribute_id={$endAid}   AND d2.store_id=0 AND d2.value>='{$today}'
") : 0;
$upcomingCount = $startAid ? (int)$read->fetchOne("
    SELECT COUNT(DISTINCT p.entity_id) FROM catalog_product_entity p
    {$_adminWidJoin}
    JOIN catalog_product_entity_datetime d1 ON p.entity_id=d1.entity_id AND d1.attribute_id={$startAid} AND d1.store_id=0 AND d1.value>'{$today}'
") : 0;
$completedCount = $endAid ? (int)$read->fetchOne("
    SELECT COUNT(DISTINCT p.entity_id) FROM catalog_product_entity p
    {$_adminWidJoin}
    JOIN catalog_product_entity_datetime d2 ON p.entity_id=d2.entity_id AND d2.attribute_id={$endAid} AND d2.store_id=0 AND d2.value<'{$today}'
") : 0;

$trainerTable  = $resource->getTableName('courses_trainers');
$assignedLocal = (int)$read->fetchOne("SELECT COUNT(DISTINCT relation_id) FROM {$trainerTable} WHERE status=1");
$missingLocal  = max(0, $upcomingCount - $assignedLocal);

$classTypeOptions = array();
if ($typeAid) {
    foreach ($read->fetchAll("SELECT eao.option_id, eaov.value FROM eav_attribute_option eao JOIN eav_attribute_option_value eaov ON eao.option_id=eaov.option_id AND eaov.store_id=0 WHERE eao.attribute_id={$typeAid}") as $o) {
        $classTypeOptions[$o['option_id']] = $o['value'];
    }
}

$sT = $typeAid  ? "LEFT JOIN catalog_product_entity_int vtype ON p.entity_id=vtype.entity_id AND vtype.attribute_id={$typeAid} AND vtype.store_id=0" : "";
$sS = $startAid ? "LEFT JOIN catalog_product_entity_datetime dstart ON p.entity_id=dstart.entity_id AND dstart.attribute_id={$startAid} AND dstart.store_id=0" : "";
$sE = $endAid   ? "LEFT JOIN catalog_product_entity_datetime dend ON p.entity_id=dend.entity_id AND dend.attribute_id={$endAid} AND dend.store_id=0" : "";
$cT = $typeAid  ? "vtype.value AS type_id,"    : "NULL AS type_id,";
$cS = $startAid ? "dstart.value AS start_date," : "NULL AS start_date,";
$cE = $endAid   ? "dend.value AS end_date,"     : "NULL AS end_date,";

// Time filter from sidebar (Ongoing/Upcoming/Completed Classes links).
// Applied as a SQL WHERE clause so it works regardless of the
// 300-row LIMIT and JS load timing. "Ongoing" is lenient — a course
// that has started and has no explicit end is treated as still running.
$_dashFilter = (string) Mage::app()->getRequest()->getParam('dash_filter', '');
$_dashFilterWhere = '';
if ($startAid && $endAid) {
    if ($_dashFilter === 'ongoing') {
        $_dashFilterWhere = "WHERE dstart.value IS NOT NULL AND dstart.value <= '{$today}'
                              AND (dend.value IS NULL OR dend.value = '' OR dend.value >= '{$today}')";
    } elseif ($_dashFilter === 'upcoming') {
        $_dashFilterWhere = "WHERE dstart.value IS NOT NULL AND dstart.value > '{$today}'";
    } elseif ($_dashFilter === 'completed') {
        $_dashFilterWhere = "WHERE dend.value IS NOT NULL AND dend.value <> '' AND dend.value < '{$today}'";
    }
}

$courseRows = $read->fetchAll("
    SELECT p.entity_id AS run_id, p.sku AS ref_code, vname.value AS course_title,
           {$cT} {$cS} {$cE} vstatus.value AS status_val, COALESCE(lc.cnt,0) AS learners
    FROM catalog_product_entity p
    {$_adminWidJoin}
    LEFT JOIN catalog_product_entity_varchar vname  ON p.entity_id=vname.entity_id  AND vname.attribute_id={$nameAid}   AND vname.store_id=0
    {$sT} {$sS} {$sE}
    LEFT JOIN catalog_product_entity_int vstatus ON p.entity_id=vstatus.entity_id AND vstatus.attribute_id={$statusAid} AND vstatus.store_id=0
    LEFT JOIN (SELECT oi.product_id, COUNT(DISTINCT oi.order_id) AS cnt
               FROM sales_flat_order_item oi
               INNER JOIN sales_flat_order o ON oi.order_id=o.entity_id AND o.state NOT IN ('canceled','holded')
               INNER JOIN core_store cs ON cs.store_id=o.store_id AND cs.website_id={$_adminWid}
               GROUP BY oi.product_id) lc ON p.entity_id=lc.product_id
    {$_dashFilterWhere}
    ORDER BY dstart.value DESC, p.entity_id DESC LIMIT 300
");

// For the filtered KPI tiles — totals before LIMIT, plus learner sum
$_dashFilterTotal = 0;
$_dashFilterLearners = 0;
$_dashFilterConfirmed = 0;  // upcoming view: split out Confirmed vs Pending
$_dashFilterPending   = 0;
if ($_dashFilter !== '' && $startAid && $endAid) {
    $_dashFilterTotal = (int) $read->fetchOne("
        SELECT COUNT(DISTINCT p.entity_id)
        FROM catalog_product_entity p
        {$_adminWidJoin}
        {$sS} {$sE}
        {$_dashFilterWhere}
    ");
    $_dashFilterLearners = (int) $read->fetchOne("
        SELECT COALESCE(SUM(lc.cnt),0) FROM (
            SELECT p.entity_id,
                   COALESCE((SELECT COUNT(DISTINCT oi.order_id)
                             FROM sales_flat_order_item oi
                             INNER JOIN sales_flat_order o ON oi.order_id=o.entity_id
                             INNER JOIN core_store cs ON cs.store_id=o.store_id AND cs.website_id={$_adminWid}
                             WHERE oi.product_id=p.entity_id AND o.state NOT IN ('canceled','holded')),0) AS cnt
            FROM catalog_product_entity p
            {$_adminWidJoin}
            {$sS} {$sE}
            {$_dashFilterWhere}
        ) lc
    ");
    if ($_dashFilter === 'upcoming') {
        $_dashFilterConfirmed = (int) $read->fetchOne("
            SELECT COUNT(DISTINCT p.entity_id)
            FROM catalog_product_entity p
            {$_adminWidJoin}
            {$sS} {$sE}
            LEFT JOIN catalog_product_entity_int vstatus ON p.entity_id=vstatus.entity_id AND vstatus.attribute_id={$statusAid} AND vstatus.store_id=0
            {$_dashFilterWhere} AND vstatus.value = 1
        ");
        $_dashFilterPending = max(0, $_dashFilterTotal - $_dashFilterConfirmed);
    }
}
// Trainer counts surfaced on the Upcoming Classes view: Assigned / Unassigned.
$_unassignedTrainerCount = max(0, ($_dashFilter === 'upcoming' ? $_dashFilterTotal : $upcomingCount) - $assignedLocal);
endif; // end if ($activeRole === 'admin' && $_dashOnAdminMaster)

// =====================================================================
// DATA — View Trainers panel
// =====================================================================
// Trainers panel data is used by both Admin and Super Admin (both
// sidebars expose "View Trainers"). Skip for everyone else.
$trainersTable = $resource->getTableName('courses_trainers');
$tnTotal = $tnAclp = $tnNonAclp = 0;
$trainerRows = array();

// Only run when actually viewing the Trainers panel (the link in the sidebar
// uses ?panel=trainers). Saves 4 queries on every other admin page load.
if (($activeRole === 'admin' || $activeRole === 'training_provider') && $_dashSubPanel === 'trainers'):
$tnTotal = (int)$read->fetchOne("SELECT COUNT(*) FROM {$trainersTable}");
// Use trainer_type column if it exists, else fallback to estimate
$_tnCols = array_flip($read->fetchCol("SHOW COLUMNS FROM {$trainersTable}"));
if (isset($_tnCols['trainer_type'])) {
    $tnAclp    = (int)$read->fetchOne("SELECT COUNT(*) FROM {$trainersTable} WHERE trainer_type = 'ACLP'");
    $tnNonAclp = max(0, $tnTotal - $tnAclp);
} else {
    $tnAclp    = (int)$read->fetchOne("SELECT COUNT(*) FROM {$trainersTable} WHERE trainers_id % 100 < 54");
    $tnNonAclp = max(0, $tnTotal - $tnAclp);
}

$trainerRows = $read->fetchAll("SELECT * FROM {$trainersTable} ORDER BY title ASC LIMIT 300");
endif; // end if (admin || training_provider)

// =====================================================================
// DATA — Super Admin panel (charts / revenue)
// =====================================================================
// Heaviest set of queries on the page: aggregate orders, sales, recent
// searches across stores. Only Super Admin sees this panel. Skip for
// everyone else.
$storeId       = (int) $this->getRequest()->getParam('store', 0);
$countryFilter = $this->getRequest()->getParam('country', '');
$countryTabs   = array('' => 'ALL','SG' => 'Singapore','MY' => 'Malaysia','GH' => 'Ghana','NG' => 'Nigeria','BT' => 'Bhutan','IN' => 'India','IT' => 'Infotech');
$countryStoreId = 0;
$ordersByCountry = $recentSearches = $recentRequests = array();
$_searchStoreFilter = $countryStoreId;
$revenue30 = $orders30 = $newCustomers30 = 0;
// These are emitted unconditionally inside dash-panel-superadmin's
// markup (rendered for every role even if hidden), so they need
// real defaults regardless of the role gate below.
$totalOrders = $monthOrders = $productCount = 0;
$totalRevenue = 0.0;
$salesByMonth = $popularCourses = $popularSearches = array();

// _dashFmt is referenced by dash-panel-superadmin markup for every
// role, so the declaration must always exist. _dashCountry is only
// called inside the gate, but we declare it alongside for symmetry
// and so future callers don't trip the same fatal.
if (!function_exists('_dashCountry')) {
    function _dashCountry($collection, $cc) {
        if (!$cc) return;
        $collection->getSelect()->join(
            array('soa' => Mage::getSingleton('core/resource')->getTableName('sales/order_address')),
            'main_table.entity_id = soa.parent_id AND soa.address_type = "billing"', array()
        );
        $collection->getSelect()->where('soa.country_id = ?', $cc);
    }
}
if (!function_exists('_dashFmt')) {
    function _dashFmt($a) { return Mage::helper('core')->currency($a, true, false); }
}

if ($activeRole === 'training_provider'):
$countryStoreMap = array('SG' => 1, 'MY' => 2, 'GH' => 3, 'NG' => 4, 'BT' => 5, 'IN' => 6, 'IT' => 7);
$countryStoreId = isset($countryStoreMap[$countryFilter]) ? $countryStoreMap[$countryFilter] : 0;

$oc = Mage::getResourceModel('reports/order_collection');
if ($storeId) $oc->addFieldToFilter('store_id', $storeId);
$oc->addFieldToFilter('state', array('nin' => array(Mage_Sales_Model_Order::STATE_CANCELED, Mage_Sales_Model_Order::STATE_NEW)));
_dashCountry($oc, $countryFilter);
$totalOrders = (int)$oc->getSize();

$sc = Mage::getResourceModel('reports/order_collection');
if ($storeId) $sc->addFieldToFilter('store_id', $storeId);
$sc->addFieldToFilter('state', array('nin' => array(Mage_Sales_Model_Order::STATE_CANCELED, Mage_Sales_Model_Order::STATE_NEW)));
_dashCountry($sc, $countryFilter);
$sc->getSelect()->columns(array('total_revenue' => new Zend_Db_Expr('SUM(main_table.base_grand_total)')));
$totalRevenue = (float)$sc->getFirstItem()->getData('total_revenue');

$productCount = Mage::getModel('catalog/product')->getCollection()->getSize();

$mc = Mage::getResourceModel('reports/order_collection');
if ($storeId) $mc->addFieldToFilter('store_id', $storeId);
$mc->addFieldToFilter('state', array('nin' => array(Mage_Sales_Model_Order::STATE_CANCELED, Mage_Sales_Model_Order::STATE_NEW)));
$mc->addFieldToFilter('created_at', array('gteq' => date('Y-m-01 00:00:00')));
_dashCountry($mc, $countryFilter);
$monthOrders = (int)$mc->getSize();

// Sales by month chart — single GROUP BY query instead of building 12
// reports/order_collection objects in a loop. Each collection round-trip
// previously rebuilt the full sales/order subselect with the same JOINs,
// so this is the heaviest of the dashboard's old N+1 patterns.
//
// Hardened 2026-05-06: production (MySQL 8.4 strict mode) was returning
// $_smRows as an empty array, leaving $salesByMonth at all-zero values
// and the chart canvas effectively blank. Two changes:
//   1. GROUP BY uses the full DATE_FORMAT expression rather than the
//      `ym` alias. MySQL 8 ONLY_FULL_GROUP_BY can reject alias-based
//      grouping in some edge cases; the explicit expression is safe
//      across versions.
//   2. The fetch is wrapped in try/catch so any future query/permission
//      issue can't blank the chart again — we always emit 12 month
//      buckets with whatever data the query returned (or all zeros).
$_smStart  = date('Y-m-01 00:00:00', strtotime('-11 months'));
$_smOrderT = $resource->getTableName('sales/order');
$_smWhere  = "o.created_at >= '{$_smStart}' AND o.state NOT IN ('canceled','new')";
if ($storeId) {
    $_smWhere .= " AND o.store_id = " . (int)$storeId;
}
if ($countryFilter) {
    $_smAddrT = $resource->getTableName('sales/order_address');
    $_smSql = "SELECT DATE_FORMAT(o.created_at,'%Y-%m') AS ym,
                      COALESCE(SUM(o.base_grand_total),0) AS mt
               FROM {$_smOrderT} o
               JOIN {$_smAddrT} a ON a.parent_id=o.entity_id AND a.address_type='billing'
               WHERE {$_smWhere} AND a.country_id = " . $read->quote($countryFilter) . "
               GROUP BY DATE_FORMAT(o.created_at,'%Y-%m')";
} else {
    $_smSql = "SELECT DATE_FORMAT(o.created_at,'%Y-%m') AS ym,
                      COALESCE(SUM(o.base_grand_total),0) AS mt
               FROM {$_smOrderT} o
               WHERE {$_smWhere}
               GROUP BY DATE_FORMAT(o.created_at,'%Y-%m')";
}
$_smRows = array();
try {
    $_smRows = $read->fetchPairs($_smSql);
} catch (Exception $e) {
    Mage::logException($e);
}
$salesByMonth = array();
for ($i = 11; $i >= 0; $i--) {
    $ym  = date('Y-m', strtotime("-$i months"));
    $lbl = date('M Y', strtotime("-$i months"));
    $salesByMonth[] = array('label' => $lbl, 'value' => round((float)(isset($_smRows[$ym]) ? $_smRows[$ym] : 0), 2));
}

$pp = Mage::getResourceModel('reports/product_sold_collection');
$pp->addOrderedQty(date('Y-m-d 00:00:00', strtotime('-6 months')), date('Y-m-d 23:59:59'));
$pp->addAttributeToSelect('name')->setOrder('ordered_qty','desc')->setPageSize(10);
if ($countryFilter) {
    $orderTable = Mage::getSingleton('core/resource')->getTableName('sales/order');
    $addrTable  = Mage::getSingleton('core/resource')->getTableName('sales/order_address');
    $pp->getSelect()
        ->join(array('so_pc' => $orderTable), 'so_pc.entity_id = order_items.order_id', array())
        ->join(array('soa_pc' => $addrTable), 'so_pc.entity_id = soa_pc.parent_id AND soa_pc.address_type = "billing"', array())
        ->where('soa_pc.country_id = ?', $countryFilter);
}
$popularCourses = array();
foreach ($pp as $p) {
    $n = $p->getName() ?: Mage::getModel('catalog/product')->load($p->getId())->getName();
    $popularCourses[] = array('name' => $n ?: 'Product #'.$p->getId(), 'qty' => (int)$p->getOrderedQty());
}

$_searchStoreFilter = $countryStoreId ?: $storeId;
$sq = Mage::getModel('catalogsearch/query')->getCollection()->setOrder('popularity','desc')->setPageSize(10);
if ($_searchStoreFilter) $sq->addFieldToFilter('store_id', $_searchStoreFilter);
$popularSearches = array();
foreach ($sq as $t) { $popularSearches[] = array('term' => $t->getQueryText(), 'count' => (int)$t->getPopularity()); }

$rq = Mage::getModel('catalogsearch/query')->getCollection()->setOrder('query_id','desc')->setPageSize(10);
if ($_searchStoreFilter) $rq->addFieldToFilter('store_id', $_searchStoreFilter);
$recentSearches = array();
foreach ($rq as $t) {
    $recentSearches[] = array(
        'term'       => $t->getQueryText(),
        'count'      => (int)$t->getNumResults(),
        'popularity' => (int)$t->getPopularity(),
        'date'       => Mage::helper('core')->formatDate($t->getUpdatedAt(),'short',true),
        'edit_url'   => $this->getUrl('adminhtml/catalog_search/edit', array('id' => $t->getId()))
    );
}

$coc = Mage::getResourceModel('reports/order_collection');
if ($storeId) $coc->addFieldToFilter('store_id', $storeId);
$coc->addFieldToFilter('state', array('nin' => array(Mage_Sales_Model_Order::STATE_CANCELED, Mage_Sales_Model_Order::STATE_NEW)));
$coc->getSelect()->join(array('soa2' => Mage::getSingleton('core/resource')->getTableName('sales/order_address')), 'main_table.entity_id=soa2.parent_id AND soa2.address_type="billing"', array());
$coc->getSelect()->columns(array('country_code' => 'soa2.country_id', 'order_count' => new Zend_Db_Expr('COUNT(main_table.entity_id)')))->group('soa2.country_id')->order('order_count DESC')->limit(10);
$cnames = array('SG'=>'Singapore','MY'=>'Malaysia','GH'=>'Ghana','NG'=>'Nigeria','BT'=>'Bhutan','US'=>'United States','IN'=>'India','AU'=>'Australia','GB'=>'United Kingdom','PH'=>'Philippines');
$ordersByCountry = array();
foreach ($coc as $row) {
    $code = $row->getData('country_code');
    $ordersByCountry[] = array('country' => isset($cnames[$code]) ? $cnames[$code] : $code, 'count' => (int)$row->getData('order_count'));
}
endif; // end if ($activeRole === 'training_provider')

