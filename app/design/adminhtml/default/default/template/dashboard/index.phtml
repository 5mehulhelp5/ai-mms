    $_smSql = "SELECT DATE_FORMAT(o.created_at,'%Y-%m') AS ym,
                      COALESCE(SUM(o.base_grand_total),0) AS mt
               FROM {$_smOrderT} o
               WHERE {$_smWhere}
               GROUP BY DATE_FORMAT(o.created_at,'%Y-%m')";
}
