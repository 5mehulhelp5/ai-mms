// ---- Course Date sessions (Course Sessions UI) ----
// Query existing "Course Date" custom option values for the currently selected course.
// Used by the Course Sessions section on the Developer course detail page to list
// scheduled sessions and allow adding/removing them.
$_courseSessions = array();
if ($_selectedCourseId) {
    try {
        $_read = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_courseSessions = $_read->fetchAll(
            "SELECT ov.option_type_id, ott.title,
                    COALESCE(otp.price, 0) AS price
             FROM catalog_product_option o
             JOIN catalog_product_option_title ot        ON ot.option_id = o.option_id  AND ot.store_id = 0
             JOIN catalog_product_option_type_value ov   ON ov.option_id = o.option_id
             JOIN catalog_product_option_type_title ott  ON ott.option_type_id = ov.option_type_id AND ott.store_id = 0
             LEFT JOIN catalog_product_option_type_price otp
                    ON otp.option_type_id = ov.option_type_id AND otp.store_id = 0
             WHERE o.product_id = ? AND (ot.title = 'Course Date' OR ot.title LIKE '%Date%')
             ORDER BY ott.title",
            array((int) $_selectedCourseId)
        );
    } catch (Exception $e) { $_courseSessions = array(); }
}
