$_csUrl = Mage::helper('adminhtml')->getUrl('adminhtml/companysetting/save');
$_csLoadUrl = Mage::helper('adminhtml')->getUrl('adminhtml/companysetting/load');

// Load saved Company Setting values from core_config_data so the panel
// renders real saved values instead of the hardcoded HTML defaults.
// CompanysettingController::saveAction has been writing here for a
// while, but the panel never read back, so saves persisted in the DB
// while the UI kept showing the old defaults. Wired up 2026-05-07.
$_cs = array();
try {
    $_csRead = Mage::getSingleton('core/resource')->getConnection('core_read');
    $_csTbl  = Mage::getSingleton('core/resource')->getTableName('core/config_data');
    $_csRows = $_csRead->fetchAll(
        "SELECT path, value FROM {$_csTbl} WHERE path LIKE 'mmd_company/%' AND scope = 'default' AND scope_id = 0"
    );
    foreach ($_csRows as $_csR) {
        $_cs[$_csR['path']] = (string)$_csR['value'];
    }
} catch (Exception $e) { /* core_config_data table is fundamental — this should never fail in practice */ }

// Tiny helper closure: return htmlspecialchars'd saved value, falling
// back to the second arg when no DB row exists. Empty-string DB values
// also fall through to the default so a field can be "reset" by saving
// blank without rendering blank to users.
$_csv = function ($path, $default = '') use ($_cs) {
    $v = isset($_cs[$path]) ? $_cs[$path] : '';
    return htmlspecialchars($v !== '' ? $v : $default, ENT_QUOTES);
};
