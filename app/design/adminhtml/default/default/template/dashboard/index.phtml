            <svg class="lcd-caret" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition:transform .2s"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div>
            <div style="border-top:1px solid #334155;margin-top:14px;padding-top:14px;">
                <?php if (!empty($_devLessonTopics)): ?>
                <?php foreach ($_devLessonTopics as $_idx => $_tp):
                    $_hasBody = !empty($_tp['subsecs']) || !empty($_tp['links']);
                ?>
                <div class="lcd-topic-card" data-lesson-card>
                    <div class="lcd-topic-card-head" onclick="this.parentNode.classList.toggle('open')">
                        <div class="lcd-topic-card-title"><?php echo htmlspecialchars($_tp['title']) ?></div>
                        <svg class="lcd-topic-card-caret" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <div class="lcd-topic-card-body">
                        <?php if (!empty($_tp['subsecs'])): foreach ($_tp['subsecs'] as $_ss): ?>
                        <div class="lcd-topic-subsec">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            <span><?php echo htmlspecialchars($_ss) ?></span>
                        </div>
                        <?php endforeach; endif; ?>
                        <?php if (!empty($_tp['links'])): foreach ($_tp['links'] as $_lnk):
                            $_lt = isset($_lnk['type'])  ? strtolower((string)$_lnk['type']) : 'web';
                            $_lh = isset($_lnk['url'])   ? (string)$_lnk['url']   : '';
