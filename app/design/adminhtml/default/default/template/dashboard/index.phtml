<script type="text/javascript">
window._mnState = {
    cc: <?php echo json_encode($_mnCC) ?>,
    country: <?php echo json_encode($_mnCountry) ?>,
    newsletterId: 0,
    template: 'course_promo',
    pids: [],
    pidNames: {},
    chatHistory: [],
    bodyBlocks: { body_block_1: '', body_block_2: '', body_block_3: '' },
    images: [] // [{name, type, dataUrl}] — base64 data URLs, sent on next AI call
};

window.mnPickTpl = function(btn) {
    var all = document.querySelectorAll('.mn-tpl');
    for (var i = 0; i < all.length; i++) all[i].classList.remove('active');
    btn.classList.add('active');
    window._mnState.template = btn.getAttribute('data-tpl');
    mnRefreshPreview();
};

window.mnNewDraft = function() {
    if (window._mnState.newsletterId && !confirm('Discard the current draft?')) return;
    window._mnState.newsletterId = 0;
    window._mnState.pids = [];
    window._mnState.pidNames = {};
    window._mnState.chatHistory = [];
    window._mnState.bodyBlocks = { body_block_1: '', body_block_2: '', body_block_3: '' };
    window._mnState.images = [];
    document.getElementById('mn-course-search').value = '';
    var comp = document.getElementById('mn-composer-input');
    if (comp) { comp.value = ''; mnComposerAutoSize(comp); }
    document.getElementById('mn-prompt').value = '';
    document.getElementById('mn-search-results').innerHTML = '';
    document.getElementById('mn-images').value = '';
    var draftBtns = document.querySelectorAll('.mn-draft');
    for (var i = 0; i < draftBtns.length; i++) draftBtns[i].classList.remove('active');
    mnRenderPids();
    mnRenderChat();
    mnRenderImageThumbs();
    if (typeof mnUpdateComposerHint === 'function') mnUpdateComposerHint();
    var stage = document.getElementById('mn-preview-stage');
    if (stage) stage.style.display = 'none';
    var empty = document.getElementById('mn-preview-empty');
    if (empty) empty.style.display = 'flex';
    var status = document.getElementById('mn-preview-status');
    if (status) status.textContent = 'No content yet';
    var ifr = document.getElementById('mn-iframe');
    if (ifr) ifr.srcdoc = '';
};

// --- Reference images (max 3) ----------------------------------------
window.mnHandleImages = function(input) {
    var files = Array.prototype.slice.call(input.files || []);
    var room = 3 - window._mnState.images.length;
    if (files.length > room) {
        alert('Only ' + room + ' more image(s) allowed (max 3 total).');
        files = files.slice(0, Math.max(0, room));
    }
    files.forEach(function (f) {
        if (f.size > 5 * 1024 * 1024) { alert('"' + f.name + '" is over 5MB and was skipped.'); return; }
        var reader = new FileReader();
        reader.onload = function (e) {
            window._mnState.images.push({ name: f.name, type: f.type, dataUrl: e.target.result });
            mnRenderImageThumbs();
            mnRefreshPreview();
        };
        reader.readAsDataURL(f);
    });
    // Reset the input so re-selecting the same file fires onchange.
    input.value = '';
};
window.mnRemoveImage = function(idx) {
    window._mnState.images.splice(idx, 1);
    mnRenderImageThumbs();
    mnRefreshPreview();
};
window.mnRenderImageThumbs = function() {
    var box = document.getElementById('mn-image-thumbs');
    box.innerHTML = '';
    window._mnState.images.forEach(function (img, idx) {
        var d = document.createElement('div');
        d.className = 'mn-image-thumb';
        var i = document.createElement('img');
        i.src = img.dataUrl;
        i.alt = img.name;
        d.appendChild(i);
        var rm = document.createElement('button');
        rm.type = 'button';
        rm.textContent = '×';
        rm.title = 'Remove ' + img.name;
        rm.onclick = function () { mnRemoveImage(idx); };
        d.appendChild(rm);
        box.appendChild(d);
    });
};

// --- Course picker autocomplete --------------------------------------
var _mnSearchTimer = null;
window.mnSearchCourses = function(inp) {
    if (_mnSearchTimer) clearTimeout(_mnSearchTimer);
    var q = (inp.value || '').trim();
    var box = document.getElementById('mn-search-results');
    if (q.length < 2) { box.innerHTML = ''; return; }
    _mnSearchTimer = setTimeout(function () {
        fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/searchCourses') ?>?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (j) {
              box.innerHTML = '';
              if (!j || !j.success || !j.courses || !j.courses.length) {
                  var n = document.createElement('div');
                  n.className = 'mn-result-empty';
                  n.textContent = 'No matches.';
                  box.appendChild(n);
                  return;
              }
              j.courses.forEach(function (c) {
                  var d = document.createElement('div');
                  d.className = 'mn-result';
                  d.textContent = c.sku + ' — ' + c.name;
                  d.onclick = function () { mnAddPid(c.id, c.sku, c.name); inp.value = ''; box.innerHTML = ''; };
                  box.appendChild(d);
              });
          });
    }, 200);
};
window.mnAddPid = function(id, sku, name) {
    id = parseInt(id, 10);
    if (!id || window._mnState.pids.indexOf(id) >= 0) return;
    window._mnState.pids.push(id);
    window._mnState.pidNames[id] = sku + ' — ' + name;
    mnRenderPids();
    mnRefreshPreview();
};
window.mnRemovePid = function(id) {
    id = parseInt(id, 10);
    var i = window._mnState.pids.indexOf(id);
    if (i >= 0) window._mnState.pids.splice(i, 1);
    delete window._mnState.pidNames[id];
    mnRenderPids();
    mnRefreshPreview();
};
window.mnRenderPids = function() {
    var box = document.getElementById('mn-pids');
    box.innerHTML = '';
    window._mnState.pids.forEach(function (id) {
        var c = document.createElement('span');
        c.className = 'mn-pid-chip';
        c.textContent = window._mnState.pidNames[id] || ('#' + id);
        var x = document.createElement('button');
        x.type = 'button';
        x.textContent = '×';
        x.onclick = function () { mnRemovePid(id); };
        c.appendChild(x);
        box.appendChild(c);
    });
};

// --- Claude chat -----------------------------------------------------
window.mnRenderChat = function() {
    var box = document.getElementById('mn-chat');
    var hist = window._mnState.chatHistory;
    if (!hist.length) {
        box.innerHTML = '<div class="mn-empty-chat">Tell Claude what to draft. Subsequent messages refine it.</div>';
        return;
    }
    box.innerHTML = '';
    hist.forEach(function (m) {
        var d = document.createElement('div');
        d.className = 'mn-msg ' + m.role;
        var role = document.createElement('div');
        role.className = 'mn-msg-role';
        role.textContent = m.role === 'user' ? 'You' : 'Claude';
        d.appendChild(role);
        var body = document.createElement('div');
        // Assistant messages contain the full response — chat ack on
        // top, then `===NEWSLETTER===` marker, then the structured
        // body. The chat pane only shows the ack so it reads like a
        // chatbot conversation. Older messages without the marker fall
        // back to showing the whole content.
        var content = m.content || '';
        if (m.role === 'assistant') {
            var idx = content.indexOf('===NEWSLETTER===');
            if (idx >= 0) content = content.substring(0, idx).trim();
        }
        body.textContent = content;
        d.appendChild(body);
        box.appendChild(d);
    });
    box.scrollTop = box.scrollHeight;
};
// Progress bar driver — Claude responses don't stream into the page so
// we simulate progress with an asymptotic curve that ticks up while we
// wait, then snap to 100% when the response actually lands. The label
// switches phases ("Sending" → "Drafting" → "Polishing") as the bar
// climbs, so it reads as informative rather than a fake spinner.
window._mnProg = { timer: null, value: 0, target: 0 };
window.mnProgressStart = function() {
    var box = document.getElementById('mn-progress');
    if (!box) return;
    box.style.display = '';
    window._mnProg.value = 0;
    window._mnProg.target = 8;
    mnProgressRender();
    if (window._mnProg.timer) clearInterval(window._mnProg.timer);
    window._mnProg.timer = setInterval(function () {
        // Ease toward target; raise the ceiling so the bar never stalls.
        var p = window._mnProg;
        p.value += Math.max(0.4, (p.target - p.value) * 0.08);
        if (p.value > 92) p.value = 92;
        // Climb the ceiling slowly so we don't sit at 92% for ages.
        if (p.target < 90) p.target += 1.2;
        mnProgressRender();
    }, 250);
};
window.mnProgressFinish = function() {
    if (window._mnProg.timer) clearInterval(window._mnProg.timer);
    window._mnProg.timer = null;
    window._mnProg.value = 100;
    mnProgressRender();
    setTimeout(function () {
        var box = document.getElementById('mn-progress');
        if (box) box.style.display = 'none';
        window._mnProg.value = 0;
        mnProgressRender();
    }, 600);
};
window.mnProgressRender = function() {
    var pct = Math.round(window._mnProg.value);
    var bar = document.getElementById('mn-progress-bar');
    var lbl = document.getElementById('mn-progress-pct');
    var phase = document.getElementById('mn-progress-label');
    if (bar) bar.style.width = pct + '%';
    if (lbl) lbl.textContent = pct + '%';
    if (phase) {
        phase.textContent = pct < 25 ? 'Sending brief to Claude'
            : pct < 65 ? 'Drafting newsletter copy'
            : pct < 100 ? 'Polishing'
            : 'Done';
    }
};

// --- Chat composer (chatbot-style follow-up input) -------------------
window.mnComposerKey = function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        mnSend();
    }
};
window.mnComposerAutoSize = function(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(140, el.scrollHeight) + 'px';
};

window.mnSend = function() {
    var promptEl   = document.getElementById('mn-prompt');
    var composerEl = document.getElementById('mn-composer-input');
    var briefText    = (promptEl.value || '').trim();
    var composerText = (composerEl.value || '').trim();
    // Composer wins when it has text (so follow-up turns use the chat
    // input, not whatever's still sitting in the brief textarea).
    // Otherwise fall back to the brief — covers the very first turn.
    var prompt;
    var clearComposer = false, clearBrief = false;
    if (composerText) { prompt = composerText; clearComposer = true; }
    else if (briefText) { prompt = briefText; clearBrief = true; }
    else { alert('Type a message in the chat box, or fill the brief above.'); return; }
    var btn = document.getElementById('mn-send-btn');
    btn.disabled = true;
    btn.classList.add('mn-loading');
    mnProgressStart();
    var fd = new FormData();
    fd.append('newsletter_id', String(window._mnState.newsletterId || 0));
    fd.append('prompt', prompt);
    fd.append('template_key', window._mnState.template);
    fd.append('country_code', window._mnState.cc);
    fd.append('course_pids', window._mnState.pids.join(','));
    fd.append('mode', window._mnState.chatHistory.length ? 'revise' : 'initial');
    // Attach reference images (data URLs) — controller decodes them
    // server-side and passes through to Claude as image content blocks.
    // Only sent on the turn the admin attached them; cleared after to
    // avoid re-sending the same images on every revise turn.
    fd.append('images_json', JSON.stringify(window._mnState.images));
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/generate') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (j) {
        btn.disabled = false; btn.classList.remove('mn-loading');
        mnProgressFinish();
        if (!j || !j.success) { alert((j && j.message) || 'Generate failed.'); return; }
        window._mnState.chatHistory = j.chat_history || [];
        // has_body=false means the assistant returned a chat-only
        // reply (e.g. "pick a course first"). In that case keep the
        // existing newsletter body untouched — only the chat updates.
        if (j.has_body !== false) {
            window._mnState.bodyBlocks = j.body_blocks || window._mnState.bodyBlocks;
            mnRefreshPreview();
        }
        if (clearComposer) {
            composerEl.value = '';
            mnComposerAutoSize(composerEl);
        }
        if (clearBrief) promptEl.value = '';
        mnRenderChat();
        mnUpdateComposerHint();
        composerEl.focus();
    })
    .catch(function (e) {
        btn.disabled = false; btn.classList.remove('mn-loading');
        mnProgressFinish();
        alert('Network: ' + e);
    });
};

// Hint text below the composer flips once the conversation has started:
// "First message uses the brief above" → "Press Enter to send".
window.mnUpdateComposerHint = function() {
    var h = document.getElementById('mn-composer-hint');
    if (!h) return;
    var hasTurns = window._mnState.chatHistory.length > 0;
    h.innerHTML = hasTurns
        ? 'Press <kbd>Enter</kbd> to send, <kbd>Shift</kbd>+<kbd>Enter</kbd> for a new line.'
        : 'First message uses the brief above. Press <kbd>Enter</kbd> to send, <kbd>Shift</kbd>+<kbd>Enter</kbd> for a new line.';
};

// --- Preview (re-renders on every body / pid / template / Claude turn) -
var _mnPreviewTimer = null;
window.mnRefreshPreview = function() {
    if (_mnPreviewTimer) clearTimeout(_mnPreviewTimer);
    _mnPreviewTimer = setTimeout(function () {
        // Source of truth is _mnState.bodyBlocks — populated by Claude
        // on every Send. The admin no longer hand-edits the body, so
        // there's no textarea to read from.
        var blocks = window._mnState.bodyBlocks || {
            body_block_1: '', body_block_2: '', body_block_3: ''
        };
        var fd = new FormData();
        fd.append('template_key', window._mnState.template);
        fd.append('course_pids', window._mnState.pids.join(','));
        fd.append('body_blocks', JSON.stringify(blocks));
        // Reference images flow through every preview call so the
        // hero photo updates immediately as the admin uploads/removes.
        fd.append('images_json', JSON.stringify(window._mnState.images || []));
        fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/preview') ?>', {
            method: 'POST', body: fd, credentials: 'same-origin'
        })
        .then(function (r) { return r.json(); })
        .then(function (j) {
            if (!j || !j.success) return;
            var ifr = document.getElementById('mn-iframe');
            ifr.srcdoc = j.html;
            ifr.style.display = '';
            document.getElementById('mn-preview-stage').style.display = 'flex';
            document.getElementById('mn-preview-empty').style.display = 'none';
            document.getElementById('mn-preview-status').textContent = 'Updated ' + new Date().toLocaleTimeString();
            // Push button gates on a real preview.
            var pushBtn = document.getElementById('mn-push-btn');
            if (window._mnState.chatHistory.length || (blocks.body_block_1 || '').trim()) {
                pushBtn.removeAttribute('disabled');
            }
        });
    }, 250);
};

// --- Save + Push -----------------------------------------------------
window.mnSave = function() {
    var fd = new FormData();
    fd.append('newsletter_id', String(window._mnState.newsletterId || 0));
    fd.append('country_code', window._mnState.cc);
    fd.append('template_key', window._mnState.template);
    fd.append('course_pids', window._mnState.pids.join(','));
    fd.append('body_blocks', JSON.stringify(window._mnState.bodyBlocks));
    fd.append('chat_history', JSON.stringify(window._mnState.chatHistory));
    fd.append('images_json', JSON.stringify(window._mnState.images || []));
    var lastPrompt = '';
    for (var i = window._mnState.chatHistory.length - 1; i >= 0; i--) {
        if (window._mnState.chatHistory[i].role === 'user') { lastPrompt = window._mnState.chatHistory[i].content; break; }
    }
    fd.append('ai_prompt', lastPrompt);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/saveDraft') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (j) {
        if (!j || !j.success) { alert((j && j.message) || 'Save failed.'); return; }
        window._mnState.newsletterId = j.newsletter_id;
        alert('Draft saved.');
    });
};
window.mnPush = function() {
    if (!window._mnState.newsletterId) {
        alert('Save the draft first.');
        return;
    }
    if (!confirm('Push this newsletter to MailerLite as a draft campaign?')) return;
    var btn = document.getElementById('mn-push-btn');
    btn.disabled = true; btn.textContent = 'Pushing...';
    var fd = new FormData();
    fd.append('newsletter_id', String(window._mnState.newsletterId));
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/push') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (j) {
        btn.disabled = false; btn.textContent = 'Push to MailerLite';
        if (!j || !j.success) { alert((j && j.message) || 'Push failed.'); return; }
        var note = j.stubbed
            ? '\n\nDemo mode: drop a real MailerLite key into local.xml to push live.'
            : '\n\nGo to MailerLite to schedule the send.';
        alert('Pushed as MailerLite campaign ' + j.mailerlite_id + '.' + note);
        location.reload();
    })
    .catch(function (err) {
        btn.disabled = false; btn.textContent = 'Push to MailerLite';
        alert('Network error — please try again: ' + (err && err.message ? err.message : err));
    });
};

// --- Viewport toggle (Desktop / Mobile) -------------------------------
window.mnSetViewport = function(mode) {
    var stage = document.getElementById('mn-preview-stage');
    if (!stage) return;
    if (mode !== 'mobile') mode = 'desktop';
    stage.dataset.vp = mode;
    var d = document.getElementById('mn-vp-desktop');
    var m = document.getElementById('mn-vp-mobile');
    if (d) { d.classList.toggle('active', mode === 'desktop'); d.setAttribute('aria-selected', mode === 'desktop' ? 'true' : 'false'); }
    if (m) { m.classList.toggle('active', mode === 'mobile');  m.setAttribute('aria-selected', mode === 'mobile' ? 'true' : 'false'); }
};

window.mnDeleteDraft = function(id, title) {
    title = title || 'this draft';
    if (!confirm('Delete "' + title + '"?\n\nThis cannot be undone.')) return;
    var fd = new FormData();
    fd.append('newsletter_id', String(id));
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/deleteDraft') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (j) {
        if (!j || !j.success) { alert((j && j.message) || 'Delete failed.'); return; }
        // Drop the row from the DOM and update the count.
        var row = document.querySelector('.mn-draft[data-id="' + id + '"]');
        if (row) row.remove();
        var listEl = document.getElementById('mn-drafts-list');
        if (listEl && !listEl.querySelector('.mn-draft')) {
            listEl.innerHTML = '<div class="mn-result-empty">No drafts yet.</div>';
        }
        var head = document.querySelector('.mn-drafts h3');
        if (head) {
            var n = document.querySelectorAll('.mn-draft').length;
            head.textContent = 'Drafts (' + n + ')';
        }
        // If the draft being edited is the one we just deleted, reset.
        if (window._mnState && Number(window._mnState.newsletterId) === Number(id)) {
            window._mnState.newsletterId = 0;
        }
    })
    .catch(function (e) { alert('Network: ' + e); });
};
window.mnLoadDraft = function(id) {
    var modal = document.getElementById('mn-draft-modal');
    var ifr   = document.getElementById('mn-draft-modal-iframe');
    var load  = document.getElementById('mn-draft-modal-loading');
    var titleEl = document.getElementById('mn-draft-modal-title');
    var metaEl  = document.getElementById('mn-draft-modal-meta');
    if (!modal || !ifr) return;
    // Lift the modal out of the panel container so position:fixed is
    // measured against the viewport, not a transformed ancestor.
    if (modal.parentNode !== document.body) document.body.appendChild(modal);

    var btn = document.querySelector('.mn-draft[data-id="' + id + '"]');
    if (btn) {
        var t = btn.querySelector('.mn-draft-title');
        var m = btn.querySelector('.mn-draft-meta');
        if (t && titleEl) titleEl.textContent = t.textContent;
        if (m && metaEl)  metaEl.textContent  = m.textContent.replace(/\s+/g, ' ').trim();
    }

    ifr.style.display = 'none';
    ifr.srcdoc = '';
    load.style.display = '';
    load.textContent = 'Loading preview…';
    mnSetDraftViewport('desktop');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    var fd = new FormData();
    fd.append('newsletter_id', String(id));
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/marketingnewsletter/preview') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    })
    .then(function (r) { return r.json(); })
    .then(function (j) {
        if (!j || !j.success) {
            load.textContent = 'Could not load preview' + (j && j.message ? ': ' + j.message : '.');
            return;
        }
        ifr.srcdoc = j.html;
        ifr.style.display = '';
        load.style.display = 'none';
    })
    .catch(function (e) {
        load.textContent = 'Network error — ' + e;
    });
};
window.mnCloseDraftModal = function(e) {
    if (e && e.target && e.target.id !== 'mn-draft-modal' && !(e.target.tagName === 'BUTTON' && e.target.getAttribute('aria-label') === 'Close')) return;
    var modal = document.getElementById('mn-draft-modal');
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
    var ifr = document.getElementById('mn-draft-modal-iframe');
    if (ifr) ifr.srcdoc = '';
};
window.mnSetDraftViewport = function(mode) {
    var stage = document.getElementById('mn-draft-modal-stage');
    if (!stage) return;
    if (mode !== 'mobile') mode = 'desktop';
    stage.dataset.vp = mode;
    var d = document.getElementById('mn-draft-vp-desktop');
    var m = document.getElementById('mn-draft-vp-mobile');
    if (d) d.classList.toggle('active', mode === 'desktop');
    if (m) m.classList.toggle('active', mode === 'mobile');
};
// Close on Escape
document.addEventListener('keydown', function (ev) {
    if (ev.key === 'Escape') {
        var modal = document.getElementById('mn-draft-modal');
        if (modal && modal.style.display !== 'none') mnCloseDraftModal({ target: modal });
    }
});

(function init() {
    mnRenderPids();
    mnRenderChat();
    mnRenderImageThumbs();
    mnUpdateComposerHint();
})();
</script>

