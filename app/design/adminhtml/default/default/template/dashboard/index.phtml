<script>
(function(){
    // Tab switcher — rail now lives outside the form in .dcf-edit-sidebar.
    // Panels stay in the form so submit semantics work; we just toggle visibility.
    var rail = document.querySelector('.dcf-edit-sidebar');
    if (!rail) return;
    rail.addEventListener('click', function(e){
        var btn = e.target.closest('.lms-nav-item[data-tab]');
        if (!btn) return;
        var key = btn.getAttribute('data-tab');
        rail.querySelectorAll('.lms-nav-item[data-tab]').forEach(function(b){ b.classList.toggle('active', b === btn); });
        document.querySelectorAll('#dcf-form .dcf-tab-panel').forEach(function(p){
            p.classList.toggle('active', p.getAttribute('data-tab') === key);
        });
        try { sessionStorage.setItem('dcfActiveTab', key); } catch(_) {}
    });
    try {
        var saved = sessionStorage.getItem('dcfActiveTab');
        if (saved) {
            var savedBtn = rail.querySelector('.lms-nav-item[data-tab="' + saved + '"]');
            if (savedBtn) savedBtn.click();
        }
    } catch(_) {}

    // Two-way sync between Name/Code in the General tab and Course Details tab.
    // The two tabs render the same product attribute as separate inputs; if we
    // didn't sync, editing one would leave the other with the stale old value
    // and last-write-wins on submit could clobber the user's change.
    function bind(aName, bName) {
        var a = document.querySelector('#dcf-form input[name="' + aName + '"]');
        var b = document.querySelector('#dcf-form input[name="' + bName + '"]');
        if (!a || !b) return;
        a.addEventListener('input', function(){ if (b.value !== a.value) b.value = a.value; });
        b.addEventListener('input', function(){ if (a.value !== b.value) a.value = b.value; });
    }
    bind('course_name', 'general_course_name');
    bind('course_code', 'general_course_code');
})();

// Group / Tier price row builders. Build one HTML template each from PHP
// data (websites + customer groups already rendered above) so we don't
// have to round-trip to the server when the user clicks +Add.
(function(){
    var WS = <?php echo json_encode($_priceWebsites) ?>;
    var CG = <?php echo json_encode($_priceCustGroups) ?>;
    function wsOpts() {
        var s = ''; for (var k in WS) s += '<option value="' + k + '">' + WS[k] + '</option>'; return s;
    }
    function cgOpts() {
        var s = ''; for (var k in CG) s += '<option value="' + k + '">' + CG[k] + '</option>'; return s;
    }
    window.dcfAddGroupPriceRow = function() {
        var body = document.getElementById('dcf-grouppx-body');
        var empty = document.getElementById('dcf-grouppx-empty'); if (empty) empty.remove();
        var i = body.querySelectorAll('tr').length;
        var tr = document.createElement('tr');
        tr.style.borderTop = '1px solid #384a60';
        tr.innerHTML =
            '<td style="padding:8px 12px;"><select class="dcf-select" name="group_price[' + i + '][website_id]">' + wsOpts() + '</select></td>' +
            '<td style="padding:8px 12px;"><select class="dcf-select" name="group_price[' + i + '][cust_group]">' + cgOpts() + '</select></td>' +
            '<td style="padding:8px 12px;"><input type="number" step="0.01" class="dcf-input" name="group_price[' + i + '][price]" value="0.00" /></td>' +
            '<td style="padding:8px 12px;text-align:right;"><button type="button" onclick="this.closest(\'tr\').remove()" style="background:#7f1d1d;color:#fecaca;border:none;padding:4px 10px;border-radius:4px;font-size:12px;cursor:pointer;">Remove</button></td>';
        body.appendChild(tr);
    };
    window.dcfAddTierPriceRow = function() {
        var body = document.getElementById('dcf-tierpx-body');
        var empty = document.getElementById('dcf-tierpx-empty'); if (empty) empty.remove();
        var i = body.querySelectorAll('tr').length;
        var tr = document.createElement('tr');
        tr.style.borderTop = '1px solid #384a60';
        tr.innerHTML =
            '<td style="padding:8px 12px;"><select class="dcf-select" name="tier_price[' + i + '][website_id]">' + wsOpts() + '</select></td>' +
            '<td style="padding:8px 12px;"><select class="dcf-select" name="tier_price[' + i + '][cust_group]">' + cgOpts() + '</select></td>' +
            '<td style="padding:8px 12px;"><input type="number" step="1" min="1" class="dcf-input" name="tier_price[' + i + '][price_qty]" value="1" style="width:80px;" /></td>' +
            '<td style="padding:8px 12px;"><input type="number" step="0.01" class="dcf-input" name="tier_price[' + i + '][price]" value="0.00" /></td>' +
            '<td style="padding:8px 12px;text-align:right;"><button type="button" onclick="this.closest(\'tr\').remove()" style="background:#7f1d1d;color:#fecaca;border:none;padding:4px 10px;border-radius:4px;font-size:12px;cursor:pointer;">Remove</button></td>';
        body.appendChild(tr);
    };
})();
</script>
