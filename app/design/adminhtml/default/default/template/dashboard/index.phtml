<script type="text/javascript">
function devSetCountry(btn) {
    var all = document.querySelectorAll('.dev-country-btn');
    for (var i = 0; i < all.length; i++) all[i].classList.remove('active');
    btn.classList.add('active');
}
function devToggleFilters() {
    var row = document.getElementById('dev-filter-row');
    var btn = document.getElementById('dev-filter-toggle');
    if (row.style.display === 'none') {
        row.style.display = '';
        btn.textContent = 'Hide Filters';
        btn.style.borderColor = '#60a5fa';
        btn.style.color = '#fff';
    } else {
        row.style.display = 'none';
        btn.textContent = 'Show Filters';
        btn.style.borderColor = '#475569';
        btn.style.color = '#e2e8f0';
    }
}
function devApplyFilters() {
    var base = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/dashboard')) ?>;
    var country = <?php echo json_encode($_devCountry) ?>;
    var curPage = <?php echo json_encode($_devCurPage) ?>;
    var typeEl = document.getElementById('dev-filter-type');
    var qEl = document.getElementById('dev-search-input');
    var cwEl = document.getElementById('dev-filter-courseware');
    var params = ['dev_country=' + encodeURIComponent(country)];
    // Carry current page across filter changes so changing a dropdown doesn't
    // bounce the user back to page 1. The server clamps if the page no longer
    // exists in the new result set.
    if (curPage > 1) params.push('dev_page=' + curPage);
    if (typeEl && typeEl.value) params.push('dev_type=' + encodeURIComponent(typeEl.value));
    if (qEl && qEl.value.trim() !== '') params.push('dev_q=' + encodeURIComponent(qEl.value.trim()));
    if (cwEl && cwEl.value) params.push('dev_courseware=' + encodeURIComponent(cwEl.value));
    window.location.href = base + '?' + params.join('&') + '#courses';
}
function devResetFilters() {
    var base = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/dashboard')) ?>;
    var country = <?php echo json_encode($_devCountry) ?>;
    window.location.href = base + '?dev_country=' + encodeURIComponent(country) + '#courses';
}
function devSetView(view) {
    var grid = document.getElementById('dev-grid');
    var header = document.getElementById('dev-list-header');
    var gridBtn = document.getElementById('dev-grid-btn');
    var listBtn = document.getElementById('dev-list-btn');
    var wrap = grid.parentNode;
    if (view === 'list') {
        grid.classList.add('dev-grid-list');
        wrap.classList.add('dev-list-active');
        if (header) header.style.display = 'grid';
        gridBtn.classList.remove('active');
        gridBtn.style.background = '';
        gridBtn.style.color = '';
        listBtn.classList.add('active');
        listBtn.style.background = '#374151';
        listBtn.style.color = '#fff';
    } else {
        grid.classList.remove('dev-grid-list');
        wrap.classList.remove('dev-list-active');
        if (header) header.style.display = 'none';
        listBtn.classList.remove('active');
        listBtn.style.background = '';
        listBtn.style.color = '';
        gridBtn.classList.add('active');
        gridBtn.style.background = '#374151';
        gridBtn.style.color = '#fff';
    }
}
</script>
