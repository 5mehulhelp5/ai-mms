         the dev course editor's Lesson editor saves into the description.
         Previously hardcoded 7 AutoCAD topics, which made trainer/learner
         views show stale data unrelated to the actual course (fixed
         2026-05-07). -->
    <?php
    // Same parser the developer view uses: prefer the LSN_DATA JSON marker
    // for full structure (subsecs + typed links), fall back to flat
    // <strong>...LU N: title...</strong> parse for legacy courses.
    $_sharedLessonTopics = array();
    try {
        $_sharedProd = Mage::getModel('catalog/product')->load($_selectedCourse['id']);
        $_sharedDescRaw = (string)$_sharedProd->getData('description');
        if ($_sharedDescRaw !== '' && preg_match('/<!--\s*LSN_DATA:\s*(\[.*?\])\s*-->/s', $_sharedDescRaw, $_slj)) {
            $_sDecoded = json_decode($_slj[1], true);
            if (is_array($_sDecoded)) {
                foreach ($_sDecoded as $_t) {
                    $_sharedLessonTopics[] = array(
                        'title'   => (string)(isset($_t['title']) ? $_t['title'] : ''),
                        'subsecs' => isset($_t['subsecs']) && is_array($_t['subsecs']) ? array_values(array_filter($_t['subsecs'], 'strlen'))
                                   : (isset($_t['subsec']) && $_t['subsec'] !== ''   ? array($_t['subsec']) : array()),
                        'links'   => isset($_t['links']) && is_array($_t['links']) ? $_t['links'] : array(),
                    );
                }
            }
        }
        if (empty($_sharedLessonTopics) && $_sharedDescRaw !== ''
            && preg_match_all('#<strong>\s*((?:LU|Lesson|Topic|Module)\s*\d+[^<]*?)\s*</strong>#i', $_sharedDescRaw, $_sltm)) {
            foreach ($_sltm[1] as $_lt) {
                $_lt = trim(html_entity_decode($_lt), " :\t\n\r\0\x0B");
                if ($_lt !== '') {
                    $_sharedLessonTopics[] = array('title' => $_lt, 'subsecs' => array(), 'links' => array());
                }
            }
        }
    } catch (Exception $e) {}
    $_sharedTypeLabels = array('web'=>'Web','doc'=>'Document','yt'=>'YouTube','act'=>'Activity','qz'=>'Quiz');
