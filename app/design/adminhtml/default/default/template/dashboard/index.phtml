                        <span style="display:inline-flex;align-items:center;gap:5px;color:#f59e0b;font-size:12px;font-weight:500;"><span style="width:6px;height:6px;border-radius:50%;background:#f59e0b;display:inline-block;"></span> Pending</span>
                        <?php endif; ?>
                    </td>
                    <td style="padding:10px 16px;text-align:center;">
                        <?php if ($_isIssued): ?>
                        <a href="<?php echo htmlspecialchars($_cr['detail_url']) ?>#certificate" style="color:#22d3ee;text-decoration:none;font-size:12px;font-weight:500;">View</a>
