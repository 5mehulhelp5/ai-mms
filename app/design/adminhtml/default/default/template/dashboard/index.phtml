                    <script>
                    (function(){
                        window.csToggleOpt = function(headBtn) {
                            var opt = headBtn.closest('.cs-opt');
                            if (!opt) return;
                            var open = opt.classList.toggle('cs-collapsed');
                            // toggle returns true if class is now present, i.e. collapsed
                            headBtn.setAttribute('aria-expanded', open ? 'false' : 'true');
                        };
                        var newCounter = {};  // per-option_id new-row counter
                        window.csAddRow = function(optionId) {
                            newCounter[optionId] = (newCounter[optionId] || 0) + 1;
                            var n = newCounter[optionId];
                            var tbody = document.getElementById('cs-rows-' + optionId);
                            if (!tbody) return;
                            var tr = document.createElement('tr');
                            tr.setAttribute('data-new', n);
                            tr.innerHTML =
                                '<td class="cs-id" style="color:#22d3ee;">new</td>' +
                                '<td><input type="text" class="cs-input" name="schedule_new[' + optionId + '][' + n + '][title]" placeholder="e.g. 27 May 2026 (Tue)" /></td>' +
                                '<td><input type="date" class="cs-input" name="schedule_new[' + optionId + '][' + n + '][reg_course]" /></td>' +
                                '<td><input type="number" step="0.01" class="cs-input cs-w-price" name="schedule_new[' + optionId + '][' + n + '][price]" placeholder="0.00" /></td>' +
                                '<td><input type="number" step="1" class="cs-input cs-w-sort" name="schedule_new[' + optionId + '][' + n + '][sort]" value="0" /></td>' +
                                '<td><button type="button" class="cs-rm-btn" title="Cancel" aria-label="Cancel" onclick="this.closest(\'tr\').remove()"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></td>';
                            tbody.appendChild(tr);
                            tr.querySelector('input').focus();
                        };
                        window.csToggleRemove = function(btn, valueId) {
                            var tr = btn.closest('tr');
                            var hidden = tr.querySelector('input[name="schedule_remove[' + valueId + ']"]');
                            if (!hidden) return;
                            var marked = hidden.value === '1';
                            hidden.value = marked ? '0' : '1';
                            tr.classList.toggle('cs-marked-remove', !marked);
                            btn.classList.toggle('active', !marked);
                            var _trash = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
                            var _undo = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-15-6.7L3 13"/></svg>';
                            btn.title = marked ? 'Remove' : 'Undo';
                            btn.setAttribute('aria-label', btn.title);
                            btn.innerHTML = marked ? _trash : _undo;
                            // Disable inputs in marked-for-remove rows so they don't waste a save round-trip
                            tr.querySelectorAll('input.cs-input').forEach(function(el){ el.disabled = !marked; });
                        };
                    })();
                    </script>
                </div>
            </div>
        </div>

