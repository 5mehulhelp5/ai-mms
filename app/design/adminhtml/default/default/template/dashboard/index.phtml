<?php
/**
 * Admin Dashboard — all panels rendered server-side,
 * JavaScript shows/hides based on "View As" localStorage value.
 *
 * Panels:
 *   #dash-panel-admin            → View As: Admin              (course schedule)
 *   #dash-panel-superadmin       → View As: Super Admin        (charts / revenue)
 *   #dash-panel-learner          → View As: Learner / Trainer
 */

$resource = Mage::getSingleton('core/resource');
$read     = $resource->getConnection('core_read');
$today    = date('Y-m-d H:i:s');

/**
 * Bulk-load "Course Date" custom-option titles for every product_id
 * appearing in $rows (each row needs a 'product_id' key). Returns an
 * array keyed by product_id mapping to a flat list of title strings,
 * e.g. [1434 => ['7 May 2026 (Thu)', '14 May 2026 (Thu)'], ...].
 *
 * Replaces an N+1 pattern that did one fetchAll per row inside a
 * foreach — measured ~200ms saved on a typical trainer load with 50
 * rows. Empty $rows or no matches → returns empty array (callers
 * fall back to news_from_date / current row data).
 */
if (!function_exists('_dashLoadCourseDateTitles')) {
    function _dashLoadCourseDateTitles($read, array $rows) {
        $out = array();
        if (empty($rows)) return $out;
        $pids = array();
        foreach ($rows as $r) {
            if (isset($r['product_id'])) $pids[(int)$r['product_id']] = true;
        }
        if (empty($pids)) return $out;
        $pidsCsv = implode(',', array_keys($pids));
        try {
            $hits = $read->fetchAll(
                "SELECT o.product_id, ott.title
                 FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE o.product_id IN ({$pidsCsv}) AND (ot.title='Course Date' OR ot.title LIKE '%Date%')"
            );
            foreach ($hits as $h) {
                $out[(int)$h['product_id']][] = (string)$h['title'];
            }
        } catch (Exception $e) { /* fall through with empty out */ }
        return $out;
    }
}

/**
 * Batched EAV attribute_id lookup for product attributes used across
 * the dashboard. Consolidates ~8 separate fetchOne() calls (one per
 * attribute code, scattered through the role-conditional blocks)
 * into a single round-trip. Each consumer reads from $_eavAttrIds.
 * Falls back to a sensible default if the row is missing (rare —
 * these are core product attributes, but the fallback keeps the
 * dashboard rendering instead of erroring out).
 */
$_eavAttrIds = array();
try {
    $_eavRows = $read->fetchAll(
        "SELECT attribute_code, attribute_id FROM eav_attribute
         WHERE entity_type_id=4
           AND attribute_code IN ('name','news_from_date','news_to_date','trainers','trainerprofile')"
    );
    foreach ($_eavRows as $_er) {
        $_eavAttrIds[(string)$_er['attribute_code']] = (int)$_er['attribute_id'];
    }
} catch (Exception $e) { /* falls through with empty map; consumers default */ }

$_roleHelper = null;
try { $_roleHelper = Mage::helper('mmd_rolemanager'); } catch (Exception $e) {} catch (Error $e) {}
try {
    $activeRole = Mage::helper('mmd_rolemanager')->getActiveRoleCode();
} catch (Exception $e) { $activeRole = 'admin'; } catch (Error $e) { $activeRole = 'admin'; }
$_roleLabel = $_roleHelper ? $_roleHelper->getRoleLabel($activeRole) : ucwords(str_replace('_', ' ', $activeRole));
$_roleIcon  = $_roleHelper ? $_roleHelper->getRoleIcon($activeRole) : '';


// =====================================================================
// DATA — Admin panel (course schedule)
// =====================================================================
// Defaults so any variable referenced later in the template works even
// when the active role isn't admin (in which case the dash-panel-admin
// markup is never visible anyway). Skipping this block for non-admin
// roles cuts ~10+ heavy queries off every page load — material because
// every role-swap reloads the dashboard.
$attrMap = array(); $nameAid = 71; $typeAid = $startAid = $endAid = $statusAid = 0;
$ongoingCount = $upcomingCount = $completedCount = 0;
$assignedLocal = $missingLocal = $missingTpg = 0;
$classTypeOptions = array();
$sT = $sS = $sE = ''; $cT = 'NULL AS type_id,'; $cS = 'NULL AS start_date,'; $cE = 'NULL AS end_date,';
$_dashFilter = (string) Mage::app()->getRequest()->getParam('dash_filter', '');
$_dashFilterWhere = '';
$courseRows = array();
$_dashFilterTotal = $_dashFilterLearners = $_dashFilterConfirmed = $_dashFilterPending = 0;
$_trainerLocalCount = $_trainerTpgCount = $_unassignedTrainerCount = 0;
$today = date('Y-m-d H:i:s');
$trainerTable = $resource->getTableName('courses_trainers');

// Tighter gate: when admin is viewing a sub-panel (Create New Class /
// Assign Trainer / Assign Learner / Enroll Learner / View Trainers /
// Configuration / Marketing Newsletter), the master-panel data is never
// shown so we skip its ~12 queries entirely. Each sub-panel below has
// its own self-contained data prep that runs independently.
$_dashSubPanel = (string) Mage::app()->getRequest()->getParam('panel', '');
// "Course Manager" view (Manage Courses listing + edit) — natively the developer
// role's main page, but admin can opt into it too via the sidebar link
// (?panel=courses). Once entered, follow-up navigation carries course_id /
// dev_back / dev_country params, so any of those keeps the mode sticky.
$_req = Mage::app()->getRequest();
$_courseManagerActive = ($activeRole === 'developer') || (
    $activeRole === 'admin' && (
        $_dashSubPanel === 'courses'
        || $_req->getParam('course_id')
        || $_req->getParam('dev_back')
        || $_req->getParam('dev_country')
    )
);
// When admin is in course-manager mode, skip the heavy admin-KPI/schedule query
// below — that panel is hidden and we render the developer panel instead.
$_dashOnAdminMaster = ($_dashSubPanel === '' || $_dashSubPanel === 'admin') && !$_courseManagerActive;

// EAV attribute IDs — needed by every admin sub-panel's catalog query
// (Assign Trainer, Assign Learner, Enroll Learner, Create New Class all
// reference $statusAid in INNER JOINs and $startAid/$endAid in ORDER BY
// subqueries). Resolve them for ANY admin request, not just the master
// view, otherwise sub-panels see empty data because $statusAid=0
// matches no rows. One small query, always runs for admin role.
if ($activeRole === 'admin'):
foreach ($read->fetchAll("SELECT attribute_id, attribute_code FROM eav_attribute WHERE entity_type_id=4 AND attribute_code IN ('name','software','news_from_date','news_to_date','status','trainers')") as $r) {
    $attrMap[$r['attribute_code']] = (int)$r['attribute_id'];
}
$nameAid   = isset($attrMap['name'])           ? $attrMap['name']           : 71;
$typeAid   = isset($attrMap['software'])       ? $attrMap['software']       : 0;
$startAid  = isset($attrMap['news_from_date']) ? $attrMap['news_from_date'] : 0;
$endAid    = isset($attrMap['news_to_date'])   ? $attrMap['news_to_date']   : 0;
$statusAid = isset($attrMap['status'])         ? $attrMap['status']         : 96;
endif;

if ($activeRole === 'admin' && $_dashOnAdminMaster):

// Country scope from the **Branchscope pill strip** (All / Singapore /
// Malaysia / …). 0 = All Stores → no website filter applied; KPIs and
// the master list aggregate across every website. Each store_id maps
// 1:1 to its website_id in this install (core_store rows 1–7), so we
// pass the same integer straight through as the website filter.
$_adminWid = (int) Mage::helper('branchscope')->getActiveStoreId();
if ($_adminWid > 0) {
    $_adminWidJoin   = " INNER JOIN catalog_product_website pwx ON pwx.product_id=p.entity_id AND pwx.website_id={$_adminWid} ";
    $_adminWidJoinCo = " INNER JOIN catalog_product_website pwx ON pwx.product_id=cpo.product_id AND pwx.website_id={$_adminWid} ";
    $_adminWidOrder  = " AND cs.website_id={$_adminWid} ";
} else {
    // "All Stores" — drop every per-website filter so counts and rows
    // aggregate across SG/MY/GH/NG/BT/IN/Infotech.
    $_adminWidJoin   = '';
    $_adminWidJoinCo = '';
    $_adminWidOrder  = '';
}

// KPI counts driven by **Course Date custom options** scoped to this
// website (not news_from_date — which is empty for ~all courses).
// Same parsing logic as the master $courseRows build below.
$ongoingCount = $upcomingCount = $completedCount = 0;
$_kpiSessions = $read->fetchAll("
    SELECT cpo.product_id, ott.title AS date_label
    FROM catalog_product_option cpo
    {$_adminWidJoinCo}
    JOIN catalog_product_option_title ot ON ot.option_id=cpo.option_id AND ot.store_id=0
    JOIN catalog_product_option_type_value ov ON ov.option_id=cpo.option_id
    JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
    WHERE ot.title='Course Date'
");
$_kpiTodayTs    = strtotime('today');
$_kpiLast90Ts   = strtotime('-90 days', $_kpiTodayTs);
$_kpiUpcomingPids = array();
foreach ($_kpiSessions as $_ks) {
    if (!preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_ks['date_label'], $_m)) continue;
    $_startTs = strtotime($_m[1] . ' ' . $_m[3] . ' ' . $_m[4]);
    if (!$_startTs) continue;
    $_endTs = !empty($_m[2]) ? strtotime($_m[2] . ' ' . $_m[3] . ' ' . $_m[4]) : $_startTs;
    if ($_startTs <= $_kpiTodayTs && $_endTs >= $_kpiTodayTs) {
        $ongoingCount++;
    } elseif ($_startTs > $_kpiTodayTs) {
        $upcomingCount++;
        $_kpiUpcomingPids[(int)$_ks['product_id']] = true;
    } elseif ($_startTs >= $_kpiLast90Ts) {
        // Cap "completed" to the last 90 days so the count stays
        // meaningful instead of accumulating years of legacy sessions.
        $completedCount++;
    }
}

// Trainer roll-up scoped to products with upcoming sessions on this
// website. Trainers are linked to a course via the `trainers` EAV text
// attribute (attribute_id 170) storing a comma-separated list of
// courses_trainers IDs. A product counts as "assigned" if the value is
// non-empty.
$trainerTable  = $resource->getTableName('courses_trainers');
$assignedLocal = 0;
if (!empty($_kpiUpcomingPids)) {
    $_upcPidsCsv      = implode(',', array_keys($_kpiUpcomingPids));
    $_trainersAttrId  = isset($attrMap['trainers']) ? (int)$attrMap['trainers'] : 170;
    $assignedLocal = (int) $read->fetchOne("
        SELECT COUNT(DISTINCT entity_id) FROM catalog_product_entity_text
         WHERE attribute_id={$_trainersAttrId}
           AND entity_id IN ({$_upcPidsCsv})
           AND value IS NOT NULL AND value <> ''
    ");
}
$missingLocal = max(0, count($_kpiUpcomingPids) - $assignedLocal);

$classTypeOptions = array();
if ($typeAid) {
    foreach ($read->fetchAll("SELECT eao.option_id, eaov.value FROM eav_attribute_option eao JOIN eav_attribute_option_value eaov ON eao.option_id=eaov.option_id AND eaov.store_id=0 WHERE eao.attribute_id={$typeAid}") as $o) {
        $classTypeOptions[$o['option_id']] = $o['value'];
    }
}

/**
 * Course Type display bucket. Since migration 093 the underlying EAV
 * options are already collapsed to "Funded" / "Non-funded", but this
 * helper keeps the dashboard safe against any legacy value that might
 * sneak back in (e.g. from imports).
 */
function _mmd_classTypeBucket($rawLabel) {
    $s = strtolower((string)$rawLabel);
    if ($s === '') return '';
    if (strpos($s, 'non') !== false) return 'Non-funded';
    return 'Funded';
}

$sT = $typeAid  ? "LEFT JOIN catalog_product_entity_int vtype ON p.entity_id=vtype.entity_id AND vtype.attribute_id={$typeAid} AND vtype.store_id=0" : "";
$sS = $startAid ? "LEFT JOIN catalog_product_entity_datetime dstart ON p.entity_id=dstart.entity_id AND dstart.attribute_id={$startAid} AND dstart.store_id=0" : "";
$sE = $endAid   ? "LEFT JOIN catalog_product_entity_datetime dend ON p.entity_id=dend.entity_id AND dend.attribute_id={$endAid} AND dend.store_id=0" : "";
$cT = $typeAid  ? "vtype.value AS type_id,"    : "NULL AS type_id,";
$cS = $startAid ? "dstart.value AS start_date," : "NULL AS start_date,";
$cE = $endAid   ? "dend.value AS end_date,"     : "NULL AS end_date,";

// Time filter from sidebar (Ongoing/Upcoming/Completed Classes links).
// Applied as a SQL WHERE clause so it works regardless of the
// 300-row LIMIT and JS load timing. "Ongoing" is lenient — a course
// that has started and has no explicit end is treated as still running.
$_dashFilter = (string) Mage::app()->getRequest()->getParam('dash_filter', '');

// Build the master upcoming-classes table from **Course Date custom options**
// (the real per-session schedule that learners book against), not from the
// product-level news_from_date attribute — which is empty for ~all courses.
// One row per session; pax counts come from sales_flat_order_item by
// matching the chosen Course Date option_value in product_options.
$courseRows     = array();
$_learnerMap    = array();   // session_key => list of {name,email,phone,order,date}
$_classTrainers = array();   // product_id => list of {name,email,phone}
$_dashFilterWhere = ''; // kept for the legacy ongoing/upcoming/completed sidebar filters below
if (in_array($_dashFilter, array('', 'ongoing', 'upcoming', 'completed'), true) && $statusAid) {
    $_todayTs   = strtotime('today');
    // Date window per filter — applied to the parsed Course Date label below.
    // master (no filter): next 90 days (excluding today)
    // ongoing:            today only
    // upcoming:           any future date (cap 365 days)
    // completed:          past 365 days
    if ($_dashFilter === 'ongoing') {
        $_winFromTs = $_todayTs;                        $_winToTs = strtotime('+1 day', $_todayTs) - 1;
    } elseif ($_dashFilter === 'upcoming') {
        $_winFromTs = strtotime('+1 day', $_todayTs);   $_winToTs = strtotime('+365 days', $_todayTs);
    } elseif ($_dashFilter === 'completed') {
        $_winFromTs = strtotime('-365 days', $_todayTs); $_winToTs = $_todayTs - 1;
    } else {
        $_winFromTs = strtotime('+1 day', $_todayTs);   $_winToTs = strtotime('+90 days', $_todayTs);
    }

    // 1. All Course Date option_type_values for products on this website.
    $_sessionsRaw = $read->fetchAll("
        SELECT cpo.product_id, ov.option_type_id, ott.title AS date_label
        FROM catalog_product_option cpo
        {$_adminWidJoinCo}
        JOIN catalog_product_option_title ot ON ot.option_id=cpo.option_id AND ot.store_id=0
        JOIN catalog_product_option_type_value ov ON ov.option_id=cpo.option_id
        JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
        WHERE ot.title='Course Date'
    ");

    // 2. Parse the date label. Build maps so that multiple option_type_id
    //    rows sharing the same (product_id, course-date-label) collapse into
    //    a single session — orders booked against any of them roll up to one
    //    pax total. Keep only sessions whose first date is in (today, today+90d].
    $_sessions    = array();    // session_key => ['product_id'=>..,'ts'=>..,'label'=>..]
    $_otidToKey   = array();    // option_type_id => session_key (ALL otids, even out-of-window)
    $_sessionPids = array();
    foreach ($_sessionsRaw as $s) {
        $label = trim((string) $s['date_label']);
        if (!preg_match('#(\d{1,2})(?:/\d{1,2})?\s+([A-Za-z]{3,})\s+(\d{4})#', $label, $m)) continue;
        $ts = strtotime($m[1] . ' ' . $m[2] . ' ' . $m[3]);
        if (!$ts) continue;
        // Bucket by parsed date (Y-m-d) — not the raw label — so two slightly
        // different label spellings for the same date (e.g. "20 May 2026" and
        // "20/21 May 2026 Evening") collapse into a single class row.
        $key = (int)$s['product_id'] . '|' . date('Y-m-d', $ts);
        $_otidToKey[(int)$s['option_type_id']] = $key;
        if ($ts >= $_winFromTs && $ts <= $_winToTs && !isset($_sessions[$key])) {
            $_sessions[$key] = array(
                'product_id' => (int)$s['product_id'],
                'ts'         => $ts,
                'label'      => $label,
            );
            $_sessionPids[(int)$s['product_id']] = true;
        }
    }

    if (!empty($_sessions)) {
        // 3. Bulk-fetch product attributes (name, sku, class type, status).
        $_pidsCsv = implode(',', array_keys($_sessionPids));
        $_typeJoin = $typeAid
            ? "LEFT JOIN catalog_product_entity_int vtype ON p.entity_id=vtype.entity_id AND vtype.attribute_id={$typeAid} AND vtype.store_id=0"
            : '';
        $_typeCol  = $typeAid ? "vtype.value" : "NULL";
        $_prodRows = $read->fetchAll("
            SELECT p.entity_id, p.sku,
                   vname.value AS name,
                   {$_typeCol} AS type_id,
                   vstatus.value AS status_val
            FROM catalog_product_entity p
            LEFT JOIN catalog_product_entity_varchar vname ON p.entity_id=vname.entity_id AND vname.attribute_id={$nameAid} AND vname.store_id=0
            {$_typeJoin}
            LEFT JOIN catalog_product_entity_int vstatus ON p.entity_id=vstatus.entity_id AND vstatus.attribute_id={$statusAid} AND vstatus.store_id=0
            WHERE p.entity_id IN ({$_pidsCsv})
        ");
        $_prodById = array();
        foreach ($_prodRows as $pr) $_prodById[(int)$pr['entity_id']] = $pr;

        // 4. Aggregate # of Pax by parsing product_options on each order item.
        //    sales_flat_order_item.product_options is a serialized PHP array
        //    containing the chosen Course Date option_value (= option_type_id).
        //    We bucket by session_key = product_id + lowercased date label so
        //    duplicate option_type_id rows (same date label) roll up together.
        $_paxMap      = array(); // session_key => qty_sum
        $_orderItems = $read->fetchAll("
            SELECT oi.product_id, oi.qty_ordered, oi.product_options,
                   o.entity_id AS order_id, o.increment_id, o.customer_email,
                   o.customer_firstname, o.customer_lastname, o.created_at,
                   o.store_id AS order_store_id,
                   ba.firstname AS bf, ba.lastname AS bl, ba.telephone AS btel
            FROM sales_flat_order_item oi
            INNER JOIN sales_flat_order o ON oi.order_id=o.entity_id AND o.state NOT IN ('canceled','holded')
            INNER JOIN core_store cs ON cs.store_id=o.store_id {$_adminWidOrder}
            LEFT  JOIN sales_flat_order_address ba ON ba.entity_id=o.billing_address_id
            WHERE oi.product_id IN ({$_pidsCsv})
              AND oi.product_options LIKE '%Course Date%'
            ORDER BY o.created_at ASC
        ");
        $_sessStore = array(); // session_key => store_id (first registration wins)
        foreach ($_orderItems as $oi) {
            $opts = @unserialize($oi['product_options']);
            if (!is_array($opts) || empty($opts['options'])) continue;
            foreach ($opts['options'] as $opt) {
                if (!isset($opt['label']) || $opt['label'] !== 'Course Date') continue;
                $key = null;
                if (isset($opt['option_value']) && isset($_otidToKey[(int)$opt['option_value']])) {
                    $key = $_otidToKey[(int)$opt['option_value']];
                } elseif (isset($opt['print_value'])
                       && preg_match('#(\d{1,2})(?:/\d{1,2})?\s+([A-Za-z]{3,})\s+(\d{4})#', (string)$opt['print_value'], $_pvm)) {
                    // Fallback: parse the printed date text when option_value
                    // doesn't resolve (e.g. option row deleted/recreated).
                    $_pvTs = strtotime($_pvm[1] . ' ' . $_pvm[2] . ' ' . $_pvm[3]);
                    if ($_pvTs) $key = (int)$oi['product_id'] . '|' . date('Y-m-d', $_pvTs);
                }
                if ($key !== null && isset($_sessions[$key])) {
                    if (!isset($_paxMap[$key]))     $_paxMap[$key]     = 0.0;
                    if (!isset($_learnerMap[$key])) $_learnerMap[$key] = array();
                    if (!isset($_sessStore[$key]))  $_sessStore[$key]  = (int)$oi['order_store_id'];
                    $_paxMap[$key] += (float)$oi['qty_ordered'];
                    $_name = trim(trim((string)$oi['bf']) . ' ' . trim((string)$oi['bl']));
                    if ($_name === '') $_name = trim(trim((string)$oi['customer_firstname']) . ' ' . trim((string)$oi['customer_lastname']));
                    $_learnerMap[$key][] = array(
                        'name'     => $_name ?: '(guest)',
                        'email'    => (string)$oi['customer_email'],
                        'phone'    => (string)$oi['btel'],
                        'order'    => (string)$oi['increment_id'],
                        'order_id' => (int)$oi['order_id'],
                        'date'     => $oi['created_at'] ? date('d/m/Y', strtotime($oi['created_at'])) : '',
                    );
                }
            }
        }

        // Per-product trainer list for the View/Edit Details modal.
        // Read the `trainers` attribute (CSV of courses_trainers.trainers_id)
        // off each course product, then look up name/email/telephone.
        $_trainersAid   = isset($attrMap['trainers']) ? (int)$attrMap['trainers'] : 170;
        $_trainerCsv    = $read->fetchPairs("
            SELECT entity_id, value
              FROM catalog_product_entity_text
             WHERE attribute_id={$_trainersAid}
               AND entity_id IN ({$_pidsCsv})
               AND value IS NOT NULL AND value <> ''
        ");
        $_allTids = array();
        foreach ($_trainerCsv as $_csv) {
            foreach (preg_split('/[\s,]+/', (string)$_csv) as $_tid) {
                $_tid = (int)$_tid;
                if ($_tid > 0) $_allTids[$_tid] = true;
            }
        }
        $_tnTbl = $resource->getTableName('courses_trainers');
        $_tnById = array();
        if (!empty($_allTids)) {
            $_tnIdsCsv = implode(',', array_keys($_allTids));
            foreach ($read->fetchAll("SELECT trainers_id, title, email, telephone FROM {$_tnTbl} WHERE trainers_id IN ({$_tnIdsCsv})") as $_tn) {
                $_tnById[(int)$_tn['trainers_id']] = $_tn;
            }
        }
        foreach ($_trainerCsv as $_pid => $_csv) {
            $_list = array();
            foreach (preg_split('/[\s,]+/', (string)$_csv) as $_tid) {
                $_tid = (int)$_tid;
                if ($_tid > 0 && isset($_tnById[$_tid])) {
                    $_list[] = array(
                        'name'  => (string)$_tnById[$_tid]['title'],
                        'email' => (string)$_tnById[$_tid]['email'],
                        'phone' => (string)$_tnById[$_tid]['telephone'],
                    );
                }
            }
            if ($_list) $_classTrainers[(int)$_pid] = $_list;
        }

        // 5. Build one $courseRows entry per session — only sessions with at
        //    least one registration are shown (the table is driven by the
        //    Sales Registration data, so empty sessions are hidden).
        //    SG (website_id=1) hides WSQ class types; other websites show all.
        foreach ($_sessions as $sessKey => $sess) {
            $pid = $sess['product_id'];
            if (!isset($_prodById[$pid])) continue;
            if (empty($_paxMap[$sessKey])) continue;
            $pi  = $_prodById[$pid];
            $tid = (int)$pi['type_id'];
            // SG (website_id=1) shows only Unfunded courses; other websites show all.
            if ($_adminWid === 1 && $tid && isset($classTypeOptions[$tid])
                && _mmd_classTypeBucket($classTypeOptions[$tid]) === 'Funded') {
                continue;
            }
            $courseRows[] = array(
                'run_id'       => $pid,                                   // product entity_id for edit links
                'ref_code'     => $pi['sku'],
                'course_title' => $pi['name'],
                'type_id'      => $tid,
                'start_date'   => date('Y-m-d H:i:s', $sess['ts']),
                'end_date'     => null,
                'status_val'   => (int)$pi['status_val'],
                'learners'     => isset($_paxMap[$sessKey]) ? (int) round($_paxMap[$sessKey]) : 0,
                'session_label'=> $sess['label'],
                'session_key'  => $sessKey,
            );
        }
        usort($courseRows, function ($a, $b) {
            return strcmp($a['start_date'], $b['start_date']);
        });
        if (count($courseRows) > 300) $courseRows = array_slice($courseRows, 0, 300);

        // Assign / look up the formatted Class ID (e.g. SG000001) for each
        // displayed row. IDs are persisted in mmd_class_id_map so they stay
        // stable across page loads; the running number is per store_id.
        $_classIdTbl = $resource->getTableName('mmd_class_id_map');
        $_write      = $resource->getConnection('core_write');
        // store_id → 2-letter code used for the Class ID prefix and the
        // Branch column. India is "ID" (not "IN") to avoid clashing with the
        // Infotech store, which keeps "IN".
        $_storeToCc2 = array(1 => 'SG', 2 => 'MY', 3 => 'GH', 4 => 'NG', 5 => 'BT', 6 => 'ID', 7 => 'IN');
        $_needAlloc  = array(); // tuples to look up: store_id|pid|date => [store_id,pid,date]
        foreach ($courseRows as $_r) {
            $_sid = isset($_sessStore[$_r['session_key']]) ? (int)$_sessStore[$_r['session_key']] : 0;
            if ($_sid <= 0) $_sid = $_adminWid > 0 ? $_adminWid : 1; // ALL Stores → fall back to SG
            $_dt  = date('Y-m-d', strtotime($_r['start_date']));
            $_needAlloc[$_sid . '|' . (int)$_r['run_id'] . '|' . $_dt] = array($_sid, (int)$_r['run_id'], $_dt);
        }
        // Bulk-fetch existing mappings.
        $_existing = array();
        if (!empty($_needAlloc)) {
            $_orParts = array();
            foreach ($_needAlloc as $tup) {
                $_orParts[] = '(store_id=' . $tup[0] . ' AND product_id=' . $tup[1] . " AND course_date='" . $tup[2] . "')";
            }
            foreach ($_write->fetchAll("SELECT store_id, product_id, course_date, class_no FROM {$_classIdTbl} WHERE " . implode(' OR ', $_orParts)) as $_em) {
                $_existing[$_em['store_id'] . '|' . $_em['product_id'] . '|' . $_em['course_date']] = (int)$_em['class_no'];
            }
        }
        // Insert any missing mappings — next class_no per store_id.
        foreach ($_needAlloc as $key => $tup) {
            if (isset($_existing[$key])) continue;
            $_maxNo = (int)$_write->fetchOne("SELECT COALESCE(MAX(class_no),0) FROM {$_classIdTbl} WHERE store_id={$tup[0]}");
            $_next  = $_maxNo + 1;
            try {
                $_write->insert($_classIdTbl, array(
                    'store_id'    => $tup[0],
                    'product_id'  => $tup[1],
                    'course_date' => $tup[2],
                    'class_no'    => $_next,
                ));
                $_existing[$key] = $_next;
            } catch (Exception $e) {
                // Race condition — another request inserted first; re-read.
                $_cn = (int)$_write->fetchOne(
                    "SELECT class_no FROM {$_classIdTbl} WHERE store_id={$tup[0]} AND product_id={$tup[1]} AND course_date='{$tup[2]}'"
                );
                if ($_cn) $_existing[$key] = $_cn;
            }
        }
        // Apply to courseRows.
        foreach ($courseRows as &$_r) {
            $_sid = isset($_sessStore[$_r['session_key']]) ? (int)$_sessStore[$_r['session_key']] : 0;
            if ($_sid <= 0) $_sid = $_adminWid > 0 ? $_adminWid : 1;
            $_dt  = date('Y-m-d', strtotime($_r['start_date']));
            $_no  = isset($_existing[$_sid . '|' . (int)$_r['run_id'] . '|' . $_dt]) ? $_existing[$_sid . '|' . (int)$_r['run_id'] . '|' . $_dt] : 0;
            $_cc  = isset($_storeToCc2[$_sid]) ? $_storeToCc2[$_sid] : '??';
            $_r['class_code'] = $_no ? ($_cc . str_pad($_no, 6, '0', STR_PAD_LEFT)) : '';
            $_r['branch']     = $_cc;
        }
        unset($_r);
    }
}

