<script>
function crdToast(msg, kind) {
    var t = document.getElementById('crd-toast');
    t.textContent = msg;
    t.className = 'crd-toast ' + (kind || 'ok');
    t.style.display = 'block';
    clearTimeout(window._crdToastT);
    window._crdToastT = setTimeout(function(){ t.style.display = 'none'; }, kind === 'err' ? 6000 : 3500);
}
function crdSubmit(e) {
    e.preventDefault();
    var form = document.getElementById('crd-form');
    var data = new FormData();
    form.querySelectorAll('input').forEach(function(inp) {
        // If the field's value is unchanged from the masked placeholder,
        // skip it — server keeps the existing DB row untouched.
        if (inp.dataset.original === '__MASKED__' && inp.value.indexOf('•') !== -1) {
            return;
        }
        data.append(inp.name, inp.value);
    });
    data.append('form_key', '<?php echo Mage::getSingleton('core/session')->getFormKey() ?>');
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '<?php echo Mage::helper("adminhtml")->getUrl("adminhtml/maildiagnose/savecreds") ?>', true);
    xhr.onload = function() {
        try {
            var r = JSON.parse(xhr.responseText);
            if (r.ok) {
                crdToast('Credentials saved.', 'ok');
                setTimeout(function(){ window.location.reload(); }, 800);
            } else {
                crdToast('Error: ' + (r.error || 'unknown'), 'err');
            }
        } catch (ex) {
            crdToast('Save failed (' + xhr.status + ')', 'err');
        }
    };
    xhr.send(data);
    return false;
}
</script>
