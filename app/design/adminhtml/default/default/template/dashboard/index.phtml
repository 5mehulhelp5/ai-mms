// ---- Toggle trainer status (Deactivate / Activate) ----
window.trnToggleStatus = function(id, name, currentActive) {
    var action = currentActive ? 'deactivate' : 'activate';
    if (!confirm('Are you sure you want to ' + action + ' "' + name + '"?')) return;

    var fd = new FormData();
    fd.append('trainer_id', id);
    fd.append('form_key', window.__trnFormKey);

    fetch(window.__trnToggleUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(data){
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to ' + action + ' trainer');
            }
        })
        .catch(function(err){ alert('Network error: ' + err.message); });
};

