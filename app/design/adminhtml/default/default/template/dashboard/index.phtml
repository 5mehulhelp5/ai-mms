        <script>
        // Mint a cryptographically random API key of the form
        // "kael_rv_<2-digit year>_<28 url-safe random chars>" using
        // crypto.getRandomValues. Populates the input and clears the
        // mask sentinel so Save sends it as a real change.
        window.kaelGenerateKey = function () {
            var year = String(new Date().getFullYear()).slice(-2);
            var alpha = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            var buf = new Uint32Array(28);
            (window.crypto || window.msCrypto).getRandomValues(buf);
            var rand = '';
            for (var i = 0; i < buf.length; i++) {
                rand += alpha.charAt(buf[i] % alpha.length);
            }
            var key = 'kael_rv_' + year + '_' + rand;
            var input = document.getElementById('kael-review-key-input');
            input.value = key;
            input.removeAttribute('data-original');
            input.focus();
            input.select();
            crdToast('New API key generated — click Save Credentials to persist.', 'ok');
        };
        </script>

