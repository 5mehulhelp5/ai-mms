<script type="text/javascript">
window.cncPickCourse = function(sel) {
    var ref = document.getElementById('cnc-ref');
    if (sel.value && ref && !ref.value) ref.value = sel.value;
};
window.cncToggleTrainer = function(cb) {
    var section = document.getElementById('cnc-trainer-section');
    var input = document.getElementById('cnc-trainer-id');
    if (!section) return;
    section.style.display = cb.checked ? '' : 'none';
    if (input) {
        if (cb.checked) input.setAttribute('required', 'required');
        else { input.removeAttribute('required'); input.value = ''; }
    }
};
window.cncSubmit = function(ev) {
    ev.preventDefault();
    var sku       = (document.getElementById('cnc-ref')||{value:''}).value.trim();
    var startDate = (document.getElementById('cnc-start')||{value:''}).value;
    var endDate   = (document.getElementById('cnc-end')||{value:''}).value;
    var trainerOp = '';
    var optChecked = (document.getElementById('cnc-opt-trainer')||{checked:false}).checked;
    if (optChecked) {
        trainerOp = (document.getElementById('cnc-trainer-id')||{value:''}).value;
        if (!trainerOp) { alert('Please pick a trainer or untick "Assign Trainer".'); return false; }
    }
    if (!sku) { alert('Please fill in the Course Reference Number first.'); return false; }

    function val(id) { var el = document.getElementById(id); return el ? el.value : ''; }
    var fd = new FormData();
    fd.append('course_sku',        sku);
    fd.append('trainer_option_id', trainerOp);
    fd.append('start_date',        startDate);
    fd.append('end_date',          endDate);
    fd.append('reg_open_date',     val('cnc-reg-open'));
    fd.append('reg_close_date',    val('cnc-reg-close'));
    fd.append('venue_block',       val('cnc-venue-block'));
    fd.append('venue_street',      val('cnc-venue-street'));
    fd.append('venue_building',    val('cnc-venue-building'));
    fd.append('venue_floor',       val('cnc-floor'));
    fd.append('venue_unit',        val('cnc-unit'));
    fd.append('postal_code',       val('cnc-postal'));
    fd.append('room',              val('cnc-room'));
    fd.append('wheelchair',        val('cnc-wheelchair'));
    fd.append('mode_of_training',  val('cnc-mode'));
    fd.append('admin_email',       val('cnc-admin-email'));
    fd.append('vacancy',           val('cnc-vacancy'));

    var btn = ev.target.querySelector('.cnc-btn-primary');
    if (btn) { btn.disabled = true; btn.textContent = 'Creating...'; }

    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/createNewClass') ?>', {
        method:'POST', body: fd, credentials:'same-origin'
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
        if (data && data.success) {
            alert(data.message || 'Class created.');
            window.location.href = '<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/dashboard') ?>';
        } else {
            alert('Could not create class: ' + (data && data.message ? data.message : 'unknown error'));
            if (btn) { btn.disabled = false; btn.textContent = 'Create Class'; }
        }
    })
    .catch(function(err){
        alert('Network error: ' + err);
        if (btn) { btn.disabled = false; btn.textContent = 'Create Class'; }
    });
    return false;
};
</script>
