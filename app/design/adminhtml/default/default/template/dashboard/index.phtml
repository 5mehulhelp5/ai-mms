                                $_sdSubs = array();
                                if (preg_match_all('#<em>(.*?)</em>#is', $_sdBody, $_sdEm)) {
                                    foreach ($_sdEm[1] as $_st) {
                                        $_st = trim(html_entity_decode(strip_tags($_st)), " :\t\n\r\0\x0B");
                                        if ($_st !== '') $_sdSubs[] = $_st;
                                    }
                                } else {
                                    foreach (preg_split('#</?(?:p|li|br|div)[^>]*>#i', $_sdBody) as $_ln) {
