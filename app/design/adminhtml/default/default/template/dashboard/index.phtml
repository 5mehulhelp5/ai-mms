    // Real-data certificate status. We don't have an attendance/cert
    // tracking schema yet, so the previous static "Minimum Attendance
    // Not Fulfilled" message lied — it showed regardless of whether the
    // viewing learner had even ordered the course. Drive the message
    // from the existing data we DO have:
    //   no order found                                     -> Not Enrolled
    //   order exists, course end date in future or unset   -> In Progress
    //   order exists, course end date passed               -> Course Completed
    // For Developer / Super Admin who have no learner identity, fall back
    // to a generic note that certs are per-learner.
    $_certState = 'unenrolled';
    $_certEnd   = null;
    try {
        $_certViewerEmail = isset($_loggedInEmail) ? (string)$_loggedInEmail : '';
        if ($_certViewerEmail !== '' && !empty($_selectedCourseId) && $activeRole === 'learner') {
            $_certResource = Mage::getSingleton('core/resource');
            $_certRead     = $_certResource->getConnection('core_read');
            $_certOrderId  = (int) $_certRead->fetchOne(
                "SELECT o.entity_id FROM " . $_certResource->getTableName('sales/order') . " o
                 JOIN " . $_certResource->getTableName('sales/order_item') . " oi ON oi.order_id=o.entity_id
                 WHERE oi.product_id = ? AND LOWER(o.customer_email) = ? AND o.state NOT IN ('canceled')
                 ORDER BY o.created_at DESC LIMIT 1",
                array((int)$_selectedCourseId, strtolower($_certViewerEmail))
            );
            if ($_certOrderId > 0) {
                $_certEndProd = isset($_devProd) ? $_devProd : Mage::getModel('catalog/product')->load($_selectedCourseId);
                $_certEnd     = $_certEndProd->getData('news_to_date');
                if ($_certEnd && strtotime($_certEnd) < strtotime(date('Y-m-d'))) {
                    $_certState = 'completed';
                } else {
                    $_certState = 'in_progress';
                }
            }
        }
    } catch (Exception $e) {}
    ?>
