    <!-- DEVELOPER: Courseware -->
    <?php
    // Same field map as the edit form (line ~2732). Defined here too so the
    // view can render only the URLs that are actually saved against this
    // course, with the same labels and tile order. Previous version of this
    // section hardcoded 6 generic titles ("Courseware Link", "Lesson Plan",
    // ...) with no actual hrefs and no tie to saved data, which is what the
    // user reported: "view doesn't reflect the edit's saved courseware".
    // The Courseware section on the developer course detail surfaces
    // these tiles — the hardcoded list that the section was designed
    // around (Courseware Link as the umbrella "folder", then the
    // teaching artifacts: Lesson Plan, Learner Guide, Facilitator
    // Guide, Learner Slides, Trainer Slides, Assessment Plan).
    // Learner Slides was added 2026-05-07 — previously it was hidden
    // here and only available via the edit form, so a course that had
    // 3 saved URLs (Courseware Link + Trainer Slides + Learner Slides)
    // would only render 2 tiles. Now all stored URLs render even if
    // they're identical to another field — duplicates intentionally
    // surface so the user can see exactly what was saved per slot.
    // assessment_record_link / assessment_summary_url stay out — each
    // has its own dedicated section below. Empty URLs are skipped by
    // the foreach so the section may render fewer tiles depending on
    // what's saved.
    $_devCwLabels = array(
        'courseware_link'        => 'Courseware Link',
        'lesson_plan_url'        => 'Lesson Plan',
        'learner_guide_url'      => 'Learner Guide',
        'facilitator_guide_url'  => 'Facilitator Guide',
        'learner_slides_url'     => 'Learner Slides',
        'trainer_slides_url'     => 'Trainer Slides',
        'assessment_plan_url'    => 'Assessment Plan',
    );
    $_devCwSaved = array();
    foreach ($_devCwLabels as $_k => $_lbl) {
        $_url = isset($_courseware[$_k]) ? trim((string) $_courseware[$_k]) : '';
        if ($_url !== '') {
            $_devCwSaved[$_k] = array('label' => $_lbl, 'url' => $_url);
        }
    }
    ?>
    <div class="lcd-section" id="courseware">
        <div class="lcd-section-title">Courseware</div>
        <?php if (empty($_devCwSaved)): ?>
        <div style="color:#64748b;font-size:13px;font-style:italic;padding:8px 0;">No courseware URLs saved yet.</div>
        <?php else: ?>
        <?php foreach ($_devCwSaved as $_dcw): ?>
        <a href="<?php echo htmlspecialchars($_dcw['url']) ?>" target="_blank" rel="noopener" class="lcd-tile" style="margin-bottom:8px;text-decoration:none;color:inherit;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            <div class="lcd-tile-body">
                <div class="lcd-tile-title"><?php echo htmlspecialchars($_dcw['label']) ?></div>
                <div class="lcd-tile-sub">Click to open</div>
            </div>
        </a>
        <?php endforeach; ?>
        <?php endif; ?>
    </div>

    <!-- DEVELOPER: Lesson (collapsible topic cards driven by the LSN_DATA
         JSON marker the editor writes; falls back to <strong>-only parse
         for courses last edited before that marker existed) -->
    <?php
    $_devLessonTopics = array();
    try {
        $_devProd = Mage::getModel('catalog/product')->load($_selectedCourse['id']);
        $_descRaw = (string)$_devProd->getData('description');
        if ($_descRaw !== '' && preg_match('/<!--\s*LSN_DATA:\s*(\[.*?\])\s*-->/s', $_descRaw, $_lj)) {
            $_decoded = json_decode($_lj[1], true);
            if (is_array($_decoded)) {
                foreach ($_decoded as $_t) {
