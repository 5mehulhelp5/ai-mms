                <div id="lsn-topics"></div>
                <input type="hidden" name="lesson_topics" id="lsn-topics-json" value="" />
                <button type="button" class="lsn-add-topic" onclick="lsnAddTopic()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Topic
                </button>
                <script>
                (function(){
                    // Seed topics. Prefer the canonical JSON marker we wrote on
                    // the previous save (lossless round-trip of subsec / text /
                    // typed links), falling back to the legacy <strong> parser
                    // for courses last edited before the visual editor learned
                    // to persist itself.
                    var topics = <?php
                        $_loRaw = (string)$_editCourseData['learning_outcomes'];
                        $_seed = array();
                        if (preg_match('/<!--\s*LSN_DATA:\s*(\[.*?\])\s*-->/s', $_loRaw, $_lj)) {
                            $_decoded = json_decode($_lj[1], true);
                            if (is_array($_decoded)) {
                                $_seed = $_decoded;
                            }
                        }
                        if (empty($_seed) && $_loRaw !== ''
                            && preg_match_all('#<strong>\s*((?:LU|Lesson|Topic|Module)\s*\d+[^<]*?)\s*</strong>#i', $_loRaw, $_lm)) {
                            foreach ($_lm[1] as $_t) {
                                $_seed[] = array(
                                    'title'  => trim(html_entity_decode($_t), " :\t\n\r\0\x0B"),
                                    'subsec' => '',
                                    'links'  => array(),
                                );
                            }
                        }
                        echo json_encode($_seed);
                    ?>;

                    function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
                    function syncJson(){ document.getElementById('lsn-topics-json').value = JSON.stringify(topics); }

                    function render(){
                        var wrap = document.getElementById('lsn-topics');
                        wrap.innerHTML = '';
                        topics.forEach(function(t, ti){
                            var box = document.createElement('div');
                            box.className = 'lsn-topic' + (t._open ? ' open' : '');
                            var linksHtml = '';
                            (t.links || []).forEach(function(l, li){
                                var cls = 'lsn-tag-' + (l.type || 'web').toLowerCase();
                                var tag = (l.type || 'web').toUpperCase();
                                linksHtml += '<div class="lsn-link">' +
                                    '<div class="lsn-link-drag"><span></span><span></span><span></span></div>' +
                                    '<span class="lsn-tag ' + cls + '">' + tag + '</span>' +
                                    '<input type="text" class="lsn-link-title" value="' + esc(l.title) + '" placeholder="Title" onchange="lsnEditLink(' + ti + ',' + li + ',\'title\',this.value)" />' +
                                    '<input type="text" class="lsn-link-url" value="' + esc(l.url) + '" placeholder="URL" onchange="lsnEditLink(' + ti + ',' + li + ',\'url\',this.value)" />' +
                                    '<button type="button" class="lsn-link-del" onclick="lsnDeleteLink(' + ti + ',' + li + ')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></button>' +
                                '</div>';
                            });
                            box.innerHTML =
                                '<div class="lsn-topic-head">' +
                                    '<div class="lsn-topic-drag"><span></span><span></span><span></span></div>' +
                                    '<input type="text" class="lsn-topic-title" value="' + esc(t.title) + '" onchange="lsnEditTopic(' + ti + ',\'title\',this.value)" />' +
                                    '<button type="button" class="lsn-topic-btn" onclick="lsnToggleTopic(' + ti + ')"><svg class="lsn-caret-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></button>' +
                                    '<button type="button" class="lsn-topic-btn lsn-del" onclick="lsnDeleteTopic(' + ti + ')"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M10 11v6M14 11v6"/></svg></button>' +
                                '</div>' +
                                '<div class="lsn-topic-body">' +
                                    (t.subsecs || []).map(function(s, si){
                                        return '<div class="lsn-subsec">' +
                                            '<div class="lsn-subsec-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>' +
                                            '<input type="text" class="lsn-subsec-title" value="' + esc(s) + '" placeholder="Section name" onchange="lsnEditSubsec(' + ti + ',' + si + ',this.value)" />' +
                                            ((t.subsecs || []).length > 1
                                                ? '<button type="button" class="lsn-subsec-del" onclick="lsnDeleteSubsec(' + ti + ',' + si + ')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></button>'
                                                : '') +
                                        '</div>';
                                    }).join('') +
                                    '<button type="button" class="lsn-add-subsec" onclick="lsnAddSubsec(' + ti + ')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Section name</button>' +
                                    linksHtml +
                                    '<div class="lsn-add-row">' +
                                        '<button type="button" onclick="lsnAddLink(' + ti + ',\'web\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Web</button>' +
                                        '<button type="button" onclick="lsnAddLink(' + ti + ',\'doc\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Document</button>' +
                                        '<button type="button" onclick="lsnAddLink(' + ti + ',\'yt\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> YouTube</button>' +
                                        '<button type="button" onclick="lsnAddLink(' + ti + ',\'act\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Activity</button>' +
                                        '<button type="button" onclick="lsnAddLink(' + ti + ',\'qz\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Quiz</button>' +
                                    '</div>' +
                                '</div>';
                            wrap.appendChild(box);
                        });
                        syncJson();
                    }

                    // Normalize seed: legacy entries used a single subsec
                    // string. Convert to subsecs[] so render only has one path.
                    topics.forEach(function(t){
                        if (!Array.isArray(t.subsecs)) {
                            t.subsecs = (t.subsec && String(t.subsec).trim() !== '') ? [t.subsec] : [''];
                        }
                        if (t.subsecs.length === 0) t.subsecs = [''];
                        delete t.subsec;
                    });

                    window.lsnAddTopic = function(){
                        topics.push({ title: 'Topic ' + (topics.length + 1) + ': New Topic', subsecs: [''], links: [], _open: true });
                        render();
                    };
                    window.lsnAddSubsec = function(ti){
                        topics[ti].subsecs = topics[ti].subsecs || [''];
                        topics[ti].subsecs.push('');
                        render();
                    };
                    window.lsnDeleteSubsec = function(ti, si){
                        topics[ti].subsecs.splice(si, 1);
                        if (topics[ti].subsecs.length === 0) topics[ti].subsecs = [''];
                        render();
                    };
                    window.lsnEditSubsec = function(ti, si, val){
                        topics[ti].subsecs[si] = val;
                        syncJson();
                    };
                    window.lsnDeleteTopic = function(ti){
                        topics.splice(ti, 1);
                        render();
                    };
                    window.lsnToggleTopic = function(ti){
                        topics[ti]._open = !topics[ti]._open;
                        render();
                    };
                    window.lsnEditTopic = function(ti, field, val){
                        topics[ti][field] = val;
                        syncJson();
                    };
                    window.lsnAddLink = function(ti, type){
                        topics[ti].links = topics[ti].links || [];
                        topics[ti].links.push({ type: type, title: '', url: '' });
                        render();
                    };
                    window.lsnDeleteLink = function(ti, li){
                        topics[ti].links.splice(li, 1);
                        render();
                    };
                    window.lsnEditLink = function(ti, li, field, val){
                        topics[ti].links[li][field] = val;
                        syncJson();
                    };

                    // Persistence: serialise topics into the description field
                    // before the form submits. The HTML body stays human-readable
                    // (so anyone editing description directly still sees the
                    // structure), and a hidden JSON comment lets us round-trip
                    // exactly on next load.
                    function serializeTopicsToHtml() {
                        var typeLabels = { web:'Web', doc:'Document', yt:'YouTube', act:'Activity', qz:'Quiz' };
                        // Strip transient fields (_open) and any empty subsec
                        // strings before persisting.
                        var clean = topics.map(function(t){
                            return {
                                title:   t.title || '',
                                subsecs: (t.subsecs || []).map(function(s){ return String(s || ''); }).filter(function(s){ return s !== ''; }),
                                links:   (t.links || []).map(function(l){
                                    return { type: l.type || 'web', title: l.title || '', url: l.url || '' };
                                })
                            };
                        });
                        var marker = '<!-- LSN_DATA: ' + JSON.stringify(clean).replace(/-->/g, '--&gt;') + ' -->';
                        var html = marker + '\n';
                        clean.forEach(function(t){
                            html += '<p><strong>' + esc(t.title || 'Topic') + '</strong></p>\n';
                            t.subsecs.forEach(function(s){
                                html += '<p><em>' + esc(s) + '</em></p>\n';
                            });
                            if (t.links.length) {
                                html += '<ul>\n';
                                t.links.forEach(function(l){
                                    var lbl = typeLabels[l.type] || (l.type || '').toUpperCase();
                                    var titleText = l.title || l.url || '';
                                    if (l.url) {
                                        html += '  <li><a href="' + esc(l.url) + '" target="_blank" rel="noopener">'
                                              + esc(titleText) + '</a> <em>[' + lbl + ']</em></li>\n';
                                    } else {
                                        html += '  <li>' + esc(titleText) + ' <em>[' + lbl + ']</em></li>\n';
                                    }
                                });
                                html += '</ul>\n';
                            }
                        });
                        return html;
                    }

                    var dcfForm = document.getElementById('dcf-form');
                    if (dcfForm) {
                        // Empty topics list means the user cleared the editor;
                        // leave whatever they typed in the description textarea
                        // alone instead of blanking it.
                        function flushTopicsToTextarea(){
                            if (!topics.length) return;
                            var ta = dcfForm.querySelector('textarea[name="learning_outcomes"]');
                            if (ta) ta.value = serializeTopicsToHtml();
                        }

                        // Three paths cover every way this form can submit:
                        //
                        // 1. Native submit event — fires for the type=submit
                        //    "Save Changes" button and for Enter-in-a-field.
                        dcfForm.addEventListener('submit', flushTopicsToTextarea, false);
                        // 2. Programmatic form.submit() — used by the
                        //    "Save & Continue" button. By HTML spec this does
                        //    NOT dispatch the submit event, so we shadow the
                        //    prototype method on this instance.
                        try {
                            var nativeSubmit = HTMLFormElement.prototype.submit.bind(dcfForm);
                            dcfForm.submit = function(){
                                flushTopicsToTextarea();
                                return nativeSubmit();
                            };
                        } catch (e) { /* some browsers refuse the override */ }
                        // 3. Belt-and-suspenders — attach capture-phase click
                        //    listeners directly on every save button so even
                        //    if the prototype shadow above silently fails,
                        //    serialization still runs before the click's own
                        //    inline-onclick handler fires.
                        var saveBtns = document.querySelectorAll(
                            '.dcf-btn-save, .dcf-btn-save-cont, button[type="submit"].dcf-btn'
                        );
                        saveBtns.forEach(function(btn){
                            btn.addEventListener('click', flushTopicsToTextarea, true);
                        });
                    }

                    render();
                })();
                </script>
