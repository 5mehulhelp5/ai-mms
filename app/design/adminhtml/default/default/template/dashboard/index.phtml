            $_roReviews = $_roRead->fetchAll(
                "SELECT r.review_id, r.created_at, r.status_id, rd.title, rd.nickname, rd.detail, rd.store_id
                 FROM review r
                 LEFT JOIN review_detail rd ON rd.review_id = r.review_id
                 WHERE r.entity_pk_value = ?
                 ORDER BY r.created_at DESC",
                array($_selectedCourseId)
            );
            $_roReviewStatusMap = array(1 => 'Approved', 2 => 'Pending', 3 => 'Not Approved');
            // Tags — distinct tags + how many customers have used them on this course
            $_roTags = $_roRead->fetchAll(
                "SELECT t.tag_id, t.name, t.status, COUNT(DISTINCT tr.customer_id) AS use_count
                 FROM tag t
                 INNER JOIN tag_relation tr ON tr.tag_id = t.tag_id
                 WHERE tr.product_id = ?
                 GROUP BY t.tag_id, t.name, t.status
                 ORDER BY t.name ASC",
                array($_selectedCourseId)
            );
            $_roTagStatusMap = array(0 => 'Disabled', 1 => 'Pending', 2 => 'Approved');
            // Customers who tagged this course — first/last name pulled via EAV
            $_fnAttr = (int) $_roRead->fetchOne("SELECT attribute_id FROM eav_attribute WHERE entity_type_id=1 AND attribute_code='firstname'");
            $_lnAttr = (int) $_roRead->fetchOne("SELECT attribute_id FROM eav_attribute WHERE entity_type_id=1 AND attribute_code='lastname'");
            $_roTagCustomers = $_roRead->fetchAll(
                "SELECT DISTINCT ce.entity_id, ce.email,
                        fn.value AS firstname, ln.value AS lastname,
                        t.name AS subject_name
                 FROM tag_relation tr
                 INNER JOIN customer_entity ce ON ce.entity_id = tr.customer_id
                 INNER JOIN tag t ON t.tag_id = tr.tag_id
                 LEFT JOIN customer_entity_varchar fn ON fn.entity_id = ce.entity_id AND fn.attribute_id = ?
                 LEFT JOIN customer_entity_varchar ln ON ln.entity_id = ce.entity_id AND ln.attribute_id = ?
                 WHERE tr.product_id = ?
                 ORDER BY ln.value ASC, fn.value ASC",
                array($_fnAttr, $_lnAttr, $_selectedCourseId)
            );
