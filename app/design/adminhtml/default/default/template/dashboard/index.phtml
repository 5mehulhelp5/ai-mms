$_elActive = ($activeRole === 'admin') && (Mage::app()->getRequest()->getParam('panel') === 'enroll_learner');
$_elCourses = array();
$_elRunsByPid = array();
if ($_elActive) {
    // Country scope from the logged-in admin (admin.<cc>@…). Default SG.
    $_elWid    = (int) Mage::helper('mmd_rolemanager')->getActiveWebsiteId();
    $_elPrefix = Mage::helper('mmd_rolemanager')->getActiveCountryRunPrefix();
    $_elCC     = Mage::helper('mmd_rolemanager')->getActiveCountryCode();

    // Per-country defaults for the Add New Learner Profile form. Each
    // market uses its own ID format, calling code, and example name so
    // testers / admins see input cues that look right in context.
    $_elNpDefaults = array(
        'SG' => array(
            'idTypes' => array('NRIC' => 'NRIC', 'FIN' => 'FIN', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., S7020587D',
            'namePh'  => 'e.g., Aileen Chong',
            'cc'      => '+65',
            'phonePh' => '98765432',
        ),
        'MY' => array(
            'idTypes' => array('IC' => 'IC (NRIC)', 'PASSPORT' => 'Passport', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., 850123-14-5678',
            'namePh'  => 'e.g., Ahmad bin Abdullah',
            'cc'      => '+60',
            'phonePh' => '123456789',
        ),
        'GH' => array(
            'idTypes' => array('GHANA_CARD' => 'Ghana Card', 'PASSPORT' => 'Passport', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., GHA-123456789-1',
            'namePh'  => 'e.g., Kwame Asante',
            'cc'      => '+233',
            'phonePh' => '244123456',
        ),
        'NG' => array(
            'idTypes' => array('NIN' => 'NIN', 'BVN' => 'BVN', 'PASSPORT' => 'Passport', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., 12345678901',
            'namePh'  => 'e.g., Adebayo Okonkwo',
            'cc'      => '+234',
            'phonePh' => '8012345678',
        ),
        'BT' => array(
            'idTypes' => array('CID' => 'CID', 'PASSPORT' => 'Passport', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., 11801001234',
            'namePh'  => 'e.g., Tashi Wangmo',
            'cc'      => '+975',
            'phonePh' => '17123456',
        ),
        'IN' => array(
            'idTypes' => array('AADHAAR' => 'Aadhaar', 'PAN' => 'PAN', 'PASSPORT' => 'Passport', 'OTHERS' => 'Others'),
            'idPh'    => 'e.g., 1234 5678 9012',
            'namePh'  => 'e.g., Priya Sharma',
            'cc'      => '+91',
            'phonePh' => '9876543210',
        ),
    );
    $_elNp = isset($_elNpDefaults[$_elCC]) ? $_elNpDefaults[$_elCC] : $_elNpDefaults['SG'];
    try {
        // Build the rank map from EVERY product on the admin's website
        // (no status / name filter), ordered by entity_id ASC. Matches
        // the developer dashboard's Run ID convention exactly.
        $_elRankByPid = array();
        try {
            $_allSgPids = $read->fetchCol(
                "SELECT DISTINCT product_id FROM catalog_product_website WHERE website_id={$_elWid} ORDER BY product_id ASC"
            );
            foreach ($_allSgPids as $_idx => $_pid) {
                $_elRankByPid[(int)$_pid] = (int)$_idx;
            }
        } catch (Exception $e) {}

        // Visible courses — admin's country website, active, named.
        // Each option's Run ID is looked up from the rank map above.
        $_elCoursesRaw = $read->fetchAll(
            "SELECT e.entity_id, e.sku, v.value AS name
             FROM catalog_product_entity e
             INNER JOIN catalog_product_website pw ON pw.product_id=e.entity_id AND pw.website_id={$_elWid}
             INNER JOIN catalog_product_entity_varchar v ON v.entity_id=e.entity_id AND v.attribute_id=71 AND v.store_id=0 AND v.value <> ''
             INNER JOIN catalog_product_entity_int s ON s.entity_id=e.entity_id AND s.attribute_id={$statusAid} AND s.store_id=0 AND s.value=1
             ORDER BY e.entity_id ASC LIMIT 5000"
        );
        // Courses dropdown sorted alphabetically for usability.
        $_elCourses = $_elCoursesRaw;
        usort($_elCourses, function ($a, $b) {
            return strcasecmp($a['name'], $b['name']);
        });
        // All course_runs grouped by product so the "Course Run" dropdown
        // narrows after the admin picks a course. We also keep the flat
        // list ($_elAllRuns) for the initial dropdown render so admins
        // see something useful before they've picked a course.
        $_elAllRuns = $read->fetchAll(
            "SELECT cr.run_id, cr.product_id, cr.course_start_date, cr.course_end_date,
                    e.sku, v.value AS name
             FROM course_runs cr
             JOIN catalog_product_entity e ON e.entity_id=cr.product_id
             LEFT JOIN catalog_product_entity_varchar v ON v.entity_id=cr.product_id AND v.attribute_id=71 AND v.store_id=0
             ORDER BY cr.run_id ASC"
        );
        foreach ($_elAllRuns as $_rn) {
            $_elRunsByPid[(int)$_rn['product_id']][] = $_rn;
        }

        // Course Date custom-option titles per product as fallback runs.
        // Most catalog products don't have an explicit course_runs row
        // yet — their schedule lives as <option> rows like "14 Mar 2026
        // (Sat)" on a "Course Date" custom option. The Enroll panel
        // surfaces those as synthetic runs so admins can still pick a
        // session even before someone runs Create New Class.
        $_elCdByPid = array();
        try {
            $_elCdRows = $read->fetchAll(
                "SELECT o.product_id, ott.title
                 FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'"
            );
            foreach ($_elCdRows as $_cd) {
                $_elCdByPid[(int)$_cd['product_id']][] = $_cd['title'];
            }
        } catch (Exception $e) {}

        // Build a flat sorted list of EVERY upcoming session across the
        // catalog so admins can pick a run without having to first pick
        // the course. Combines real course_runs rows + synthetic Course
        // Date entries, parses dates, drops past ones, sorts ascending.
        $_elFlatRuns = array();
        $_elNowTs = strtotime(date('Y-m-d'));
        // Course name lookup for nice labels.
        $_elNameByPid = array();
        foreach ($_elCourses as $_c) {
            $_elNameByPid[(int)$_c['entity_id']] = array('sku' => $_c['sku'], 'name' => $_c['name']);
        }
        // Real course_runs first.
        foreach ($_elAllRuns as $_rn) {
            $_pid = (int)$_rn['product_id'];
            $_st  = $_rn['course_start_date'] ? strtotime($_rn['course_start_date']) : 0;
            if ($_st && $_st < $_elNowTs) continue; // past
            $_lbl = $_elPrefix . '-' . str_pad((string)(99999 + (int)$_rn['run_id']), 6, '0', STR_PAD_LEFT);
            if (!empty($_rn['course_start_date'])) {
                $_lbl .= '  (' . $_rn['course_start_date'] . ')';
            }
            if (!empty($_rn['name'])) {
                $_nm = strlen($_rn['name']) > 50 ? substr($_rn['name'], 0, 47) . '...' : $_rn['name'];
                $_lbl .= '  —  ' . $_nm;
            }
            $_elFlatRuns[] = array(
                'value'  => (string)$_rn['run_id'],
                'pid'    => $_pid,
                'sortTs' => $_st ?: PHP_INT_MAX,
                'label'  => $_lbl,
            );
        }
        // Synthetic Course Date sessions.
        foreach ($_elCdByPid as $_pid => $_titles) {
            $_meta = isset($_elNameByPid[$_pid]) ? $_elNameByPid[$_pid] : null;
            if (!$_meta) continue; // skip products outside the SG-active scope
            $_courseLabel = $_meta['sku'] . ' — ' . (strlen($_meta['name']) > 50 ? substr($_meta['name'], 0, 47) . '...' : $_meta['name']);
            $_seenTitles = array();
            foreach ($_titles as $_t) {
                if (isset($_seenTitles[$_t])) continue;
                $_seenTitles[$_t] = 1;
                if (preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_t, $_dm)) {
                    $_st = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_dm[4]);
                    if ($_st && $_st >= $_elNowTs) {
                        $_elFlatRuns[] = array(
                            'value'  => 'cd:' . $_t,
                            'pid'    => $_pid,
                            'sortTs' => $_st,
                            'label'  => $_courseLabel . '  —  ' . $_t,
                        );
                    }
                }
            }
        }
        usort($_elFlatRuns, function ($a, $b) {
            if ($a['sortTs'] !== $b['sortTs']) return $a['sortTs'] - $b['sortTs'];
            return strcmp($a['label'], $b['label']);
        });
    } catch (Exception $e) {}
}
if (!isset($_elCdByPid)) $_elCdByPid = array();
?>
