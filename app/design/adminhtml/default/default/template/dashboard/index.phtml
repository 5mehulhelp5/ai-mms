// Data prep is gated behind ?panel=create_class so we don't pay the
// course-catalog + trainer-EAV query cost on every dashboard request.
// The panel <div> still gets rendered (just empty dropdowns) so the
// JS panel switcher has a target — but the heavy queries only fire
// when this is the page the user actually asked for.
$_cncActive = ($activeRole === 'admin')
    && (Mage::app()->getRequest()->getParam('panel') === 'create_class');
$_cncTrainers = array();
$_cncCourses = array();
if ($_cncActive) {
    // Country scope from the logged-in admin (admin.<cc>@…). Default SG.
    $_cncWid = (int) Mage::helper('mmd_rolemanager')->getActiveWebsiteId();
    $_cncCC  = Mage::helper('mmd_rolemanager')->getActiveCountryCode();

    // Per-country venue field labels + placeholders. The seven inputs
    // (block/street/building/floor/unit/postal/room) keep the same IDs
    // so the JS save logic is untouched; only the labels in front
    // change to match each market's address convention. SG is the
    // default and matches the original form.
    $_cncVenue = array(
        'SG' => array(
            // Tertiary Infotech Academy — Woods Square Tower 1, Woodlands.
            // Address: 12 Woodlands Square, #07-85/86/87, Woods Square Tower 1,
            // Singapore 737715 (Disabled-Friendly).
            'block'    => array('label' => 'Block',         'ph' => '12',                        'required' => false),
            'street'   => array('label' => 'Street',        'ph' => 'Woodlands Square'),
            'building' => array('label' => 'Building',      'ph' => 'Woods Square Tower 1'),
            'floor'    => array('label' => 'Floor',         'ph' => '#07',                       'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => '85',                        'required' => true),
            'postal'   => array('label' => 'Postal Code',   'ph' => '737715',                    'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Training Centre',           'required' => true),
        ),
        'MY' => array(
            'block'    => array('label' => 'City',          'ph' => 'Kuala Lumpur'),
            'street'   => array('label' => 'Address Line 1','ph' => 'No 7-1 Jalan Damai Niaga'),
            'building' => array('label' => 'Address Line 2','ph' => 'Taman Alam Damai, Cheras'),
            'floor'    => array('label' => 'State',         'ph' => 'Selangor',      'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => '7-1',           'required' => true),
            'postal'   => array('label' => 'Postcode',      'ph' => '56000',         'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Training Room A','required' => true),
        ),
        'GH' => array(
            'block'    => array('label' => 'House Number',  'ph' => 'GA-123-4567'),
            'street'   => array('label' => 'Street',        'ph' => 'Independence Avenue'),
            'building' => array('label' => 'Locality',      'ph' => 'Osu, Accra'),
            'floor'    => array('label' => 'Region',        'ph' => 'Greater Accra', 'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => 'Suite 4',       'required' => true),
            'postal'   => array('label' => 'GhanaPost GPS', 'ph' => 'GA-123-4567',   'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Hall 1',        'required' => true),
        ),
        'NG' => array(
            'block'    => array('label' => 'House Number',  'ph' => '12'),
            'street'   => array('label' => 'Street',        'ph' => 'Adeola Odeku Street'),
            'building' => array('label' => 'Area',          'ph' => 'Victoria Island, Lagos'),
            'floor'    => array('label' => 'State',         'ph' => 'Lagos',         'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => 'Suite 3B',      'required' => true),
            'postal'   => array('label' => 'Postcode',      'ph' => '101241',        'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Conference 2',  'required' => true),
        ),
        'BT' => array(
            'block'    => array('label' => 'Building',      'ph' => 'Norzin Lam Building'),
            'street'   => array('label' => 'Locality',      'ph' => 'Norzin Lam'),
            'building' => array('label' => 'Dzongkhag',     'ph' => 'Thimphu'),
            'floor'    => array('label' => 'Floor',         'ph' => '3rd Floor',     'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => 'Suite 12',      'required' => true),
            'postal'   => array('label' => 'Postal Code',   'ph' => '11001',         'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Training Hall', 'required' => true),
        ),
        'IN' => array(
            'block'    => array('label' => 'Flat / House',  'ph' => '4B'),
            'street'   => array('label' => 'Building / Street','ph' => 'Hiranandani Gardens, Powai'),
            'building' => array('label' => 'Area / Locality','ph' => 'Bandra West'),
            'floor'    => array('label' => 'State',         'ph' => 'Maharashtra',   'required' => true),
            'unit'     => array('label' => 'Unit',          'ph' => '4B',            'required' => true),
            'postal'   => array('label' => 'PIN Code',      'ph' => '400050',        'required' => true),
            'room'     => array('label' => 'Room',          'ph' => 'Training Room', 'required' => true),
        ),
    );
    $_cncV = isset($_cncVenue[$_cncCC]) ? $_cncVenue[$_cncCC] : $_cncVenue['SG'];
    try {
        $_cncTrAttrId = isset($_eavAttrIds['trainers']) ? $_eavAttrIds['trainers'] : 0;
        if ($_cncTrAttrId) {
            $_cncTrainers = $read->fetchPairs(
                "SELECT eaov.option_id, eaov.value
                 FROM eav_attribute_option eao
                 JOIN eav_attribute_option_value eaov ON eao.option_id=eaov.option_id AND eaov.store_id=0
                 WHERE eao.attribute_id=?
                 ORDER BY eaov.value",
                array($_cncTrAttrId)
            );
        }
        // Available-courses dropdown — every named product on the
        // admin's country website. INNER JOIN catalog_product_website
        // scopes the list to the logged-in admin's market (SG / MY /
        // GH / NG / BT / IN). LIMIT 5000 covers any market's full
        // catalog (largest is SG at ~1,300).
        $_cncCourses = $read->fetchAll(
            "SELECT e.entity_id, e.sku, v.value AS name
             FROM catalog_product_entity e
             INNER JOIN catalog_product_website pw
               ON pw.product_id=e.entity_id AND pw.website_id={$_cncWid}
             INNER JOIN catalog_product_entity_varchar v
               ON v.entity_id=e.entity_id AND v.attribute_id=71 AND v.store_id=0
             WHERE v.value IS NOT NULL AND v.value <> ''
             ORDER BY e.sku ASC LIMIT 5000"
        );
    } catch (Exception $e) {}
}
