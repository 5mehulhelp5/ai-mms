<script type="text/javascript">
window._elState = { pid: 0, sku: '', runId: '', list: [] };
window._elRunsByPid = <?php echo json_encode($_elRunsByPid) ?>;
window._elCdByPid   = <?php echo json_encode($_elCdByPid) ?>;
window._elPrefix    = <?php echo json_encode(isset($_elPrefix) ? $_elPrefix : 'SG') ?>;

window.elPickCourse = function(pid) {
    pid = parseInt(pid, 10) || 0;
    var sel = document.getElementById('el-course-select');
    var opt = sel.options[sel.selectedIndex];
    var sku = opt ? opt.getAttribute('data-sku') : '';
    window._elState.pid = pid;
    window._elState.sku = sku || '';
    document.getElementById('el-course-code').value = sku || '';

    // Clear any stale "Pick a course first" message and re-run the
    // search if the input already has a query.
    var searchInput = document.getElementById('el-search');
    if (pid && searchInput) {
        var resultsBox = document.getElementById('el-results');
        if (resultsBox) resultsBox.innerHTML = '';
        if ((searchInput.value || '').trim().length >= 2) elOnSearchInput(searchInput);
    }

    // Repopulate runs dropdown for this product. Two sources are
    // merged so admins always see something to pick:
    //   1. Real course_runs rows  → "SG-100001 (2026-05-07)"
    //   2. Course Date custom-options → the title verbatim, prefixed
    //      "cd:" in the value so save logic can tell them apart later.
    var runSel = document.getElementById('el-run-select');
    runSel.innerHTML = '<option value="">Select a course run...</option>';
    var runs = window._elRunsByPid[pid] || [];
    for (var i = 0; i < runs.length; i++) {
        var r = runs[i];
        var label = window._elPrefix + '-' + String(99999 + parseInt(r.run_id, 10)).padStart(6, '0');
        if (r.course_start_date) label += '  (' + r.course_start_date + (r.course_end_date && r.course_end_date !== r.course_start_date ? ' → ' + r.course_end_date : '') + ')';
        var o = document.createElement('option');
        o.value = String(r.run_id);
        o.textContent = label;
        runSel.appendChild(o);
    }
    var cdTitles = window._elCdByPid[pid] || [];
    if (cdTitles.length) {
        // Visual divider so the synthetic entries are distinguishable.
        var divider = document.createElement('option');
        divider.disabled = true;
        divider.textContent = runs.length ? '── Course Date sessions ──' : '── Available sessions ──';
        runSel.appendChild(divider);
        for (var k = 0; k < cdTitles.length; k++) {
            var t = cdTitles[k];
            var op = document.createElement('option');
            op.value = 'cd:' + t;
            op.textContent = t;
            runSel.appendChild(op);
        }
    }
    window._elState.runId = '';
    document.getElementById('el-run-id').value = '';
    elLoadCurrent();
    elUpdatePreview();
};

window.elPickRun = function(runId) {
    window._elState.runId = runId || '';
    var runSel = document.getElementById('el-run-select');
    var opt = runSel.options[runSel.selectedIndex];
    if (runId) {
        if (runId.indexOf('rank:') === 0) {
            // Catalog-rank-based Run ID. The pre-computed display value
            // is on data-runid; surface it directly.
            document.getElementById('el-run-id').value = opt ? (opt.getAttribute('data-runid') || '') : '';
        } else if (runId.indexOf('cd:') === 0) {
            // Synthetic Course Date entry — surface the title verbatim.
            document.getElementById('el-run-id').value = runId.substring(3);
        } else {
            document.getElementById('el-run-id').value = window._elPrefix + '-' + String(99999 + parseInt(runId, 10)).padStart(6, '0');
        }
        // Auto-select the matching course so Currently Enrolled + JSON
        // preview sync to the chosen session's product. State is updated
        // manually instead of calling elPickCourse() so the user's run
        // selection isn't clobbered by the runs dropdown rebuild.
        var pidFromOpt = opt ? parseInt(opt.getAttribute('data-pid'), 10) : 0;
        if (pidFromOpt && pidFromOpt !== window._elState.pid) {
            document.getElementById('el-course-select').value = String(pidFromOpt);
            var courseSel = document.getElementById('el-course-select');
            var copt = courseSel.options[courseSel.selectedIndex];
            window._elState.pid = pidFromOpt;
            window._elState.sku = copt ? (copt.getAttribute('data-sku') || '') : '';
            document.getElementById('el-course-code').value = window._elState.sku;
        }
        // Clear stale "Pick a course first" message + re-run any
        // pending search now that pid is set.
        var searchInput = document.getElementById('el-search');
        if (window._elState.pid && searchInput) {
            var resultsBox = document.getElementById('el-results');
            if (resultsBox) resultsBox.innerHTML = '';
            if ((searchInput.value || '').trim().length >= 2) elOnSearchInput(searchInput);
        }
    }
    elLoadCurrent();
    elUpdatePreview();
};

window.elLoadCurrent = function() {
    var pid = window._elState.pid;
    var box = document.getElementById('el-current-list');
    var countEl = document.getElementById('el-count');
    if (!pid) {
        box.innerHTML = '<div class="el-empty-state">Select a course to see enrolled learners.</div>';
        countEl.textContent = '0';
        return;
    }
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/loadLearners') ?>?product_id=' + pid, { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(j){
          if (j && j.success) {
              window._elState.list = j.learners || [];
              elRenderCurrent();
          }
      });
};

window.elRenderCurrent = function() {
    var box = document.getElementById('el-current-list');
    var countEl = document.getElementById('el-count');
    var list = window._elState.list;
    countEl.textContent = String(list.length);
    elUpdatePreview();
    box.innerHTML = '';
    if (list.length === 0) {
        var em = document.createElement('div');
        em.className = 'el-empty-state';
        em.textContent = '— No learners enrolled yet —';
        box.appendChild(em);
        return;
    }
    for (var i = 0; i < list.length; i++) {
        var t = list[i];
        var row = document.createElement('div');
        row.className = 'el-trainer-row';
        var info = document.createElement('div');
        var n = document.createElement('span'); n.className = 'el-trainer-name'; n.textContent = t.name;
        info.appendChild(n);
        if (t.email && t.email !== t.name) {
            var em2 = document.createElement('span');
            em2.className = 'el-trainer-email';
            em2.textContent = ' (' + t.email + ')';
            info.appendChild(em2);
        }
        row.appendChild(info);
        if (t.source === 'order') {
            var lock = document.createElement('span');
            lock.className = 'el-trainer-locked';
            lock.textContent = 'from order';
            row.appendChild(lock);
        } else {
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'el-trainer-remove';
            rm.textContent = '× Remove';
            (function(em){ rm.onclick = function(){ elRemove(em); }; })(t.email);
            row.appendChild(rm);
        }
        box.appendChild(row);
    }
};

var _elSearchTimer = null;
window.elOnSearchInput = function(input) {
    if (!window._elState.pid) {
        document.getElementById('el-results').innerHTML = '<div class="el-result-empty">Pick a course first.</div>';
        return;
    }
    if (_elSearchTimer) clearTimeout(_elSearchTimer);
    var q = (input.value || '').trim();
    if (q.length < 2) { document.getElementById('el-results').innerHTML = ''; return; }
    _elSearchTimer = setTimeout(function() {
        fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/searchLearners') ?>?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
          .then(function(r){ return r.json(); })
          .then(function(j){
              var box = document.getElementById('el-results');
              box.innerHTML = '';
              if (!j || !j.success || !j.learners.length) {
                  var n = document.createElement('div');
                  n.className = 'el-result-empty';
                  n.textContent = 'No matches';
                  box.appendChild(n);
                  return;
              }
              for (var i = 0; i < j.learners.length; i++) {
                  var l = j.learners[i];
                  var d = document.createElement('div');
                  d.className = 'el-result-row';
                  d.textContent = l.name + '  (' + l.email + ')';
                  (function(email, name){
                      d.onclick = function() { elEnrol(email, name); };
                  })(l.email, l.name);
                  box.appendChild(d);
              }
          });
    }, 200);
};

window.elEnrol = function(email, name) {
    var st = window._elState;
    if (!st.pid) { alert('Pick a course first.'); return; }
    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    fd.append('learner_email', email);
    fd.append('learner_name',  name);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/addLearner') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        if (j && j.success) {
            // Refresh the enrolled list + clear the search box.
            document.getElementById('el-search').value = '';
            document.getElementById('el-results').innerHTML = '';
            elLoadCurrent();
        } else {
            alert((j && j.message) || 'Could not enrol learner.');
        }
    });
};

window.elRemove = function(email) {
    var st = window._elState;
    if (!confirm('Remove ' + email + '?')) return;
    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    fd.append('learner_email', email);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/removeLearner') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        if (j && j.success) elLoadCurrent();
        else alert((j && j.message) || 'Could not remove learner.');
    });
};

// Preview-builder removed alongside the Training Partner / Preview
// Request Body sections. Kept as a no-op so existing callsites
// (elPickRun, elPickCourse, elRenderCurrent, elClearForm, etc.)
// don't need editing.
window.elUpdatePreview = function() {};

window.elClearForm = function() {
    if (!confirm('Clear all fields?')) return;
    document.getElementById('el-course-code').value = '';
    document.getElementById('el-run-id').value = '';
    document.getElementById('el-course-select').value = '';
    document.getElementById('el-run-select').innerHTML = '<option value="">Select a course run...</option>';
    document.getElementById('el-search').value = '';
    document.getElementById('el-results').innerHTML = '';
    window._elState = { pid: 0, sku: '', runId: '', list: [] };
    elRenderCurrent();
    elUpdatePreview();
};

window.elCreateEnrolment = function() {
    var st = window._elState;
    if (!st.pid)            { alert('Pick a course first.'); return; }
    if (st.list.length === 0) { alert('Add at least one learner before creating the enrolment.'); return; }
    // Each learner add already persists to course_run_enrolments — this
    // button confirms the batch is committed and reloads the panel so
    // the form returns to a clean, empty state for the next enrolment.
    alert('Enrolment created. ' + st.list.length + ' learner(s) attached to this class.');
    window.location.href = '<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('_query' => array('panel' => 'enroll_learner'))) ?>';
};

// Toggle between the search/enrolled view and the new-learner-profile form.
window.elShowAddProfile = function() {
    document.getElementById('el-search-mode').style.display = 'none';
    document.getElementById('el-add-profile-mode').style.display = '';
};
window.elHideAddProfile = function() {
    document.getElementById('el-add-profile-mode').style.display = 'none';
    document.getElementById('el-search-mode').style.display = '';
};

// "Specify ___" checkboxes reveal their input only when ticked.
window.elToggleNp = function(key) {
    var wrap = document.getElementById('el-np-' + key + '-wrap');
    var cb   = document.getElementById('el-np-spec-' + key);
    if (wrap && cb) wrap.style.display = cb.checked ? '' : 'none';
};
(function() {
    var spec = document.getElementById('el-np-spec-enrol');
    if (spec) spec.addEventListener('change', function(){
        document.getElementById('el-np-enrol-wrap').style.display = spec.checked ? '' : 'none';
    });
})();

// Save the new learner: persist to course_run_enrolments via the
// existing addLearner endpoint, then return to search view. Other
// fields (NRIC, DOB, phone, employer info) populate the JSON preview
// but aren't persisted yet — the local schema only stores email + name.
window.elSaveNewLearner = function() {
    var st = window._elState;
    if (!st.pid) { alert('Pick a course first.'); return; }
    var name  = (document.getElementById('el-np-name').value || '').trim();
    var email = (document.getElementById('el-np-email').value || '').trim().toLowerCase();
    if (!name)  { alert('Enter the trainee\'s full name.'); return; }
    if (!email || email.indexOf('@') === -1) { alert('Enter a valid email.'); return; }

    var fd = new FormData();
    fd.append('product_id', String(st.pid));
    fd.append('learner_email', email);
    fd.append('learner_name',  name);
    fetch('<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/addLearner') ?>', {
        method: 'POST', body: fd, credentials: 'same-origin'
    }).then(function(r){ return r.json(); }).then(function(j){
        if (j && j.success) {
            // Stash extended fields on state so the JSON preview shows them.
            window._elState.lastNewProfile = {
                idType: document.getElementById('el-np-id-type').value,
                id:     document.getElementById('el-np-id').value,
                dob:    document.getElementById('el-np-dob').value,
                cc:     document.getElementById('el-np-cc').value || '+65',
                phone:  document.getElementById('el-np-phone').value
            };
            // Reset form fields, return to search, refresh enrolled list.
            ['el-np-id','el-np-name','el-np-dob','el-np-email','el-np-phone'].forEach(function(id){
                var e = document.getElementById(id); if (e) e.value = '';
            });
            elHideAddProfile();
            elLoadCurrent();
        } else {
            alert((j && j.message) || 'Could not save learner.');
        }
    });
};

// Manual Course Code / Run ID typing — match against the dropdown
// options and treat as a pick when the input is an exact match. Also
// clears the picked course if the input is empty.
(function() {
    // Build SKU → pid + Run ID → pid lookups from the rendered options.
    var skuMap = {}, runMap = {};
    var courseSel = document.getElementById('el-course-select');
    if (courseSel) {
        for (var i = 0; i < courseSel.options.length; i++) {
            var o = courseSel.options[i];
            var sku = (o.getAttribute('data-sku') || '').trim().toUpperCase();
            if (sku) skuMap[sku] = parseInt(o.value, 10) || 0;
        }
    }
    var runSel = document.getElementById('el-run-select');
    if (runSel) {
        for (var j = 0; j < runSel.options.length; j++) {
            var ro = runSel.options[j];
            var rid = (ro.getAttribute('data-runid') || '').trim().toUpperCase();
            if (rid) runMap[rid] = { value: ro.value, pid: parseInt(ro.getAttribute('data-pid'), 10) || 0 };
        }
    }

    var codeInput  = document.getElementById('el-course-code');
    var runInput   = document.getElementById('el-run-id');

    function applyManualCode() {
        var key = (codeInput.value || '').trim().toUpperCase();
        if (!key) {
            window._elState.pid = 0;
            window._elState.sku = '';
            if (courseSel) courseSel.value = '';
            elLoadCurrent();
            elUpdatePreview();
            return;
        }
        if (skuMap[key]) {
            var pid = skuMap[key];
            if (pid !== window._elState.pid) {
                window._elState.pid = pid;
                window._elState.sku = key;
                if (courseSel) courseSel.value = String(pid);
                elLoadCurrent();
                var search = document.getElementById('el-search');
                if (search && (search.value || '').trim().length >= 2) elOnSearchInput(search);
            }
        }
        elUpdatePreview();
    }
    function applyManualRun() {
        var key = (runInput.value || '').trim().toUpperCase();
        if (!key) {
            window._elState.runId = '';
            if (runSel) runSel.value = '';
            elUpdatePreview();
            return;
        }
        if (runMap[key]) {
            var hit = runMap[key];
            window._elState.runId = hit.value;
            if (runSel) runSel.value = hit.value;
            // If course wasn't already set, infer it from the run.
            if (hit.pid && hit.pid !== window._elState.pid) {
                window._elState.pid = hit.pid;
                if (courseSel) {
                    courseSel.value = String(hit.pid);
                    var copt = courseSel.options[courseSel.selectedIndex];
                    window._elState.sku = copt ? (copt.getAttribute('data-sku') || '') : '';
                    if (codeInput && !codeInput.value) codeInput.value = window._elState.sku;
                }
                elLoadCurrent();
                var search = document.getElementById('el-search');
                if (search && (search.value || '').trim().length >= 2) elOnSearchInput(search);
            }
        }
        elUpdatePreview();
    }

    if (codeInput) codeInput.addEventListener('input', applyManualCode);
    if (runInput)  runInput.addEventListener('input',  applyManualRun);
    elUpdatePreview();
})();
</script>
