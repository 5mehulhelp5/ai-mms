<script>
function dashCloseDetails(){var m=document.getElementById('dashDetailModal');if(m)m.style.display='none';}
function dashOpenDetails(d){
    var esc=function(s){return (s==null?'':String(s)).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});};
    document.getElementById('ddmTitle').textContent = d.title || '(No Name)';
    document.getElementById('ddmSub').textContent   = (d.code||'') + ' · ' + (d.date||'');
    var rows = [
        ['Class ID',    d.classId],
        ['Course Code', d.code || '—'],
        ['Course Date', d.date || '—'],
        ['MOT',         d.mot  || '—'],
        ['Course Type', d.type || '—'],
        ['Status',      d.status || '—'],
        ['# of Pax',    d.pax]
    ];
    var info = '';
    rows.forEach(function(r){info += '<div class="dash-detail-cell"><div class="dash-detail-lbl">'+esc(r[0])+'</div><div class="dash-detail-val">'+esc(r[1])+'</div></div>';});
    document.getElementById('ddmInfo').innerHTML = info;

    var removeIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/></svg>';

    var tns = d.trainers || [];
    document.getElementById('ddmTrainerCount').textContent = '(' + tns.length + ')';
    var tnTbody = document.querySelector('#ddmTrainers tbody');
    tnTbody.innerHTML = tns.length
        ? tns.map(function(t){return '<tr><td>'+esc(t.name)+'</td><td>'+esc(t.email)+'</td><td>'+esc(t.phone)+'</td><td style="text-align:center;"><a href="'+esc(d.editUrl)+'#trainers" title="Remove Trainer" class="dash-detail-rm" onclick="return confirm(\'Remove this trainer from the class?\');">'+removeIcon+'</a></td></tr>';}).join('')
        : '<tr><td colspan="4" class="dash-detail-empty">No trainer assigned.</td></tr>';

    var lns = d.learners || [];
    document.getElementById('ddmLearnerCount').textContent = '(' + lns.length + ')';
    var lnTbody = document.querySelector('#ddmLearners tbody');
    lnTbody.innerHTML = lns.length
        ? lns.map(function(l){return '<tr><td>'+esc(l.name)+'</td><td>'+esc(l.email)+'</td><td>'+esc(l.phone)+'</td><td>'+esc(l.order)+'</td><td>'+esc(l.date)+'</td><td style="text-align:center;"><a href="'+esc(l.cancelUrl||'#')+'" title="Cancel Registration" class="dash-detail-rm" onclick="return confirm(\'Cancel this registration?\');">'+removeIcon+'</a></td></tr>';}).join('')
        : '<tr><td colspan="6" class="dash-detail-empty">No learners registered yet.</td></tr>';

    document.getElementById('ddmAddTrainer').href = (d.editUrl || '#') + '#trainers';
    document.getElementById('ddmAddLearner').href = d.addLearnerUrl || '#';
    document.getElementById('dashDetailModal').style.display = 'flex';
}
document.addEventListener('keydown', function(e){if(e.key==='Escape')dashCloseDetails();});
</script>

