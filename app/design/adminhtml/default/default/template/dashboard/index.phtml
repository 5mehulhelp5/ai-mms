                <script>
                (function(){
                    var hidden = document.getElementById('trainer-ids');
                    window.trFilterList = function(q) {
                        q = q.toLowerCase();
                        var items = document.querySelectorAll('#trainer-list .tr-picker-item');
                        for (var i = 0; i < items.length; i++) {
                            var hay = items[i].getAttribute('data-search') || items[i].getAttribute('data-name').toLowerCase();
                            items[i].classList.toggle('hidden', q && hay.indexOf(q) === -1);
                        }
                    };
                    function rebuildTags() {
                        var ids = (hidden.value || '').split(',').filter(Boolean);
                        var tags = document.getElementById('trainer-tags');
                        var legacyTags = Array.prototype.slice.call(tags.querySelectorAll('.tr-picker-tag[data-legacy]'));
                        var count = document.getElementById('trainer-count');
                        tags.innerHTML = '';
                        ids.forEach(function(id){
                            var item = document.querySelector('#trainer-list .tr-picker-item[data-id="' + id + '"]');
                            if (!item) return;
                            var span = document.createElement('span');
                            span.className = 'tr-picker-tag';
                            span.setAttribute('data-id', id);
                            span.innerHTML = (item.querySelector('.tr-picker-name') || item).textContent.trim() + ' <span class="tr-picker-tag-x">&times;</span>';
                            span.querySelector('.tr-picker-tag-x').onclick = function(){ trRemove(parseInt(id, 10)); };
                            tags.appendChild(span);
                        });
                        legacyTags.forEach(function(t){ tags.appendChild(t); });
                        var total = ids.length + legacyTags.length;
                        count.textContent = total + ' assigned trainer' + (total === 1 ? '' : 's');
                    }
                    window.trToggle = function(el) {
                        var id = el.getAttribute('data-id');
                        var ids = (hidden.value || '').split(',').filter(Boolean);
                        var idx = ids.indexOf(id);
                        if (idx >= 0) {
                            ids.splice(idx, 1);
                            el.classList.remove('selected');
                            var check = el.querySelector('svg');
                            if (check) check.remove();
                        } else {
                            ids.push(id);
                            el.classList.add('selected');
                            if (!el.querySelector('svg')) {
                                el.insertAdjacentHTML('beforeend', '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>');
                            }
                        }
                        hidden.value = ids.join(',');
                        rebuildTags();
                    };
                    window.trRemove = function(id) {
                        var el = document.querySelector('#trainer-list .tr-picker-item[data-id="' + id + '"]');
                        if (el) trToggle(el);
                    };
                    window.trRemoveLegacy = function(name, el) {
                        var rm = document.getElementById('legacy-trainer-remove');
                        var cur = (rm.value || '').split('|').filter(Boolean);
                        cur.push(name);
                        rm.value = cur.join('|');
                        var tag = el.closest('.tr-picker-tag');
                        if (tag) tag.remove();
                        var count = document.getElementById('trainer-count');
                        var ids = (document.getElementById('trainer-ids').value || '').split(',').filter(Boolean);
                        var legacyCount = document.querySelectorAll('.tr-picker-tag[data-legacy]').length;
                        var total = ids.length + legacyCount;
                        count.textContent = total + ' assigned trainer' + (total === 1 ? '' : 's');
                    };
                })();
                </script>
