    <!-- DEVELOPER: Lesson (collapsible topic cards driven by the LSN_DATA
         JSON marker the editor writes; falls back to <strong>-only parse
         for courses last edited before that marker existed) -->
    <?php
    $_devLessonTopics = array();
    try {
        $_devProd = Mage::getModel('catalog/product')->load($_selectedCourse['id']);
        $_descRaw = (string)$_devProd->getData('description');
        if ($_descRaw !== '' && preg_match('/<!--\s*LSN_DATA:\s*(\[.*?\])\s*-->/s', $_descRaw, $_lj)) {
            $_decoded = json_decode($_lj[1], true);
            if (is_array($_decoded)) {
                foreach ($_decoded as $_t) {
                    // Normalise v1/v2/v3 subsec shapes (see comment in the
                    // EDIT-mode block — same data model). Flatten any
                    // per-subsec links onto the topic so the simple
                    // view-mode template only sees one list.
                    $_subsecsRaw = isset($_t['subsecs']) && is_array($_t['subsecs']) ? $_t['subsecs']
                                 : (isset($_t['subsec']) && is_string($_t['subsec']) && $_t['subsec'] !== '' ? array($_t['subsec']) : array());
                    $_subTitles = array();
                    $_subLinks  = array();
                    foreach ($_subsecsRaw as $_ss) {
                        if (is_array($_ss)) {
                            $_sst = (string)(isset($_ss['title']) ? $_ss['title'] : '');
                            if ($_sst !== '') $_subTitles[] = $_sst;
                            if (isset($_ss['links']) && is_array($_ss['links'])) {
                                foreach ($_ss['links'] as $_sl) {
                                    if (is_array($_sl)) $_subLinks[] = $_sl;
                                }
                            }
                        } else {
                            $_sst = (string)$_ss;
                            if ($_sst !== '') $_subTitles[] = $_sst;
                        }
                    }
                    $_topicLinks = isset($_t['links']) && is_array($_t['links']) ? $_t['links'] : array();
                    $_devLessonTopics[] = array(
                        'title'   => (string)(isset($_t['title'])   ? $_t['title']   : ''),
                        'subsecs' => $_subTitles,
                        'links'   => array_merge($_topicLinks, $_subLinks),
                    );
                }
            }
        }
        if (empty($_devLessonTopics) && $_descRaw !== ''
            && preg_match('#<strong>\s*(?:LU|Lesson|Topic|Module)\s*\d+#i', $_descRaw)) {
            // Split on each LU heading so we also collect the
            // <em>T#: …</em> sub-topic lines that follow it (legacy
            // Course-Topics HTML lists the T#s under each LU).
            $_dvParts = preg_split(
                '#<strong>\s*((?:LU|Lesson|Topic|Module)\s*\d+[^<]*?)\s*</strong>#i',
                $_descRaw, -1, PREG_SPLIT_DELIM_CAPTURE
            );
            for ($_dvPi = 1; $_dvPi < count($_dvParts); $_dvPi += 2) {
                $_lt = trim(html_entity_decode($_dvParts[$_dvPi]), " :\t\n\r\0\x0B");
                if ($_lt === '') continue;
                $_dvBody = isset($_dvParts[$_dvPi + 1]) ? $_dvParts[$_dvPi + 1] : '';
                $_dvSubs = array();
                if (preg_match_all('#<em>(.*?)</em>#is', $_dvBody, $_dvEm)) {
                    foreach ($_dvEm[1] as $_st) {
                        $_st = trim(html_entity_decode(strip_tags($_st)), " :\t\n\r\0\x0B");
                        if ($_st !== '') $_dvSubs[] = $_st;
                    }
                } else {
                    foreach (preg_split('#</?(?:p|li|br|div)[^>]*>#i', $_dvBody) as $_ln) {
                        $_ln = trim(html_entity_decode(strip_tags($_ln)), " :\t\n\r\0\x0B");
                        if ($_ln !== '') $_dvSubs[] = $_ln;
                    }
                }
                $_devLessonTopics[] = array('title' => $_lt, 'subsecs' => $_dvSubs, 'links' => array());
            }
        }
    } catch (Exception $e) {}
    $_lessonTypeLabels = array('web'=>'Web','doc'=>'Document','yt'=>'YouTube','act'=>'Activity','qz'=>'Quiz');
    $_lessonTypeColors = array('web'=>'#2563eb','doc'=>'#16a34a','yt'=>'#dc2626','act'=>'#f59e0b','qz'=>'#a855f7');
