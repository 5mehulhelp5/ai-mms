                    <script>
                    (function(){
                        var newCounter = {};  // per-option_id new-row counter
                        window.csAddRow = function(optionId) {
                            newCounter[optionId] = (newCounter[optionId] || 0) + 1;
                            var n = newCounter[optionId];
                            var tbody = document.getElementById('cs-rows-' + optionId);
                            if (!tbody) return;
                            var tr = document.createElement('tr');
                            tr.setAttribute('data-new', n);
                            tr.innerHTML =
                                '<td class="cs-id" style="color:#22d3ee;">new</td>' +
                                '<td><input type="text" class="cs-input" name="schedule_new[' + optionId + '][' + n + '][title]" placeholder="e.g. 27 May 2026 (Tue)" /></td>' +
                                '<td><input type="number" step="0.01" class="cs-input cs-w-price" name="schedule_new[' + optionId + '][' + n + '][price]" placeholder="0.00" /></td>' +
                                '<td><input type="number" step="1" class="cs-input cs-w-sort" name="schedule_new[' + optionId + '][' + n + '][sort]" value="0" /></td>' +
                                '<td><button type="button" class="cs-rm-btn" onclick="this.closest(\'tr\').remove()">Cancel</button></td>';
                            tbody.appendChild(tr);
                            tr.querySelector('input').focus();
                        };
                        window.csToggleRemove = function(btn, valueId) {
                            var tr = btn.closest('tr');
                            var hidden = tr.querySelector('input[name="schedule_remove[' + valueId + ']"]');
                            if (!hidden) return;
                            var marked = hidden.value === '1';
                            hidden.value = marked ? '0' : '1';
                            tr.classList.toggle('cs-marked-remove', !marked);
                            btn.classList.toggle('active', !marked);
                            btn.textContent = marked ? 'Remove' : 'Undo';
                            // Disable inputs in marked-for-remove rows so they don't waste a save round-trip
                            tr.querySelectorAll('input.cs-input').forEach(function(el){ el.disabled = !marked; });
                        };
                    })();
                    </script>
                </div>
