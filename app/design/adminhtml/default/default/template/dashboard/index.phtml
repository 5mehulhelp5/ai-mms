<?php /* ===== PANEL: Developer — Course Management ===== */ ?>
<?php
// Count IBF, Unfunded courses
$_devIbf = 0; $_devUnfunded = 0;
$_devCourses = array();
$_devPageSize = 12;
$_devCurPage = max(1, (int) Mage::app()->getRequest()->getParam('dev_page', 1));
// The dashboard's "branch" is now driven by the global branch tabs
// (MMD_Branchscope) which use ?store=N. We translate the active store
// back into a country NAME so the existing 80+ SQL queries below that
// key off $_devCountry keep working untouched.
//
// Legacy ?dev_country=Singapore bookmarks are still honoured: if the
// URL has dev_country= but no store=, we map it back to a store id and
// stash it on the session so navigation away picks up the same branch.
$_devStoreToCountry = array(
    0 => 'All',
    1 => 'Singapore',
    2 => 'Malaysia',
    3 => 'Ghana',
    4 => 'Nigeria',
    5 => 'Bhutan',
    6 => 'India',
    7 => 'Infotech',
);
$_devCountryToStore = array_flip($_devStoreToCountry);

$_devReq           = Mage::app()->getRequest();
$_devLegacyCountry = (string) $_devReq->getParam('dev_country', '');
if ($_devLegacyCountry !== '' && $_devReq->getParam('store', null) === null
        && isset($_devCountryToStore[$_devLegacyCountry])) {
    // Sync the legacy param into the canonical ?store= for the helper +
    // session, so subsequent navigation respects the user's choice.
    $_devReq->setParam('store', $_devCountryToStore[$_devLegacyCountry]);
    Mage::helper('branchscope')->persistFromRequest();
}

$_devActiveStoreId = (int) Mage::helper('branchscope')->getActiveStoreId();
$_devCountry       = isset($_devStoreToCountry[$_devActiveStoreId])
    ? $_devStoreToCountry[$_devActiveStoreId]
    : 'All';
$_devFilterType = (string) Mage::app()->getRequest()->getParam('dev_type', '');
$_devFilterQuery = trim((string) Mage::app()->getRequest()->getParam('dev_q', ''));
// Courseware filter:
//   ''        = all
//   'missing' = no row in course_courseware, OR all 5 URL columns empty
//   'partial' = row exists and between 1 and 4 URLs are filled
//   'all'     = row exists and all 5 URLs are filled
$_devFilterCourseware = (string) Mage::app()->getRequest()->getParam('dev_courseware', '');
$_devCwCount = array(); // product_id => count of non-empty URLs (0..5)
$_devCwTotal = 5;       // number of URL columns we care about — must match the SUM-over-CASE in the count query below + the $_cwFields array in the edit form
$_devTotalCount = 0;
$_devTotalPages = 1;
$_devTotalAll = 0;

// Courseware-URL counts are only used by the Developer panel's filter
// chips, so skip the SUM-over-CASE query for every other role.
if ($_courseManagerActive && in_array($_devFilterCourseware, array('missing','partial','all'), true)) {
    try {
        $_cwRead = Mage::getSingleton('core/resource')->getConnection('core_read');
        // Count non-empty URLs per product. (col != '') casts to 0/1, summed.
        $_cwRows = $_cwRead->fetchAll(
            "SELECT product_id,
                ((COALESCE(lesson_plan_url,'')        != '') +
                 (COALESCE(learner_slides_url,'')     != '') +
                 (COALESCE(trainer_slides_url,'')     != '') +
                 (COALESCE(courseware_link,'')        != '') +
                 (COALESCE(brochure_link,'')          != '')
                ) AS filled
             FROM course_courseware"
        );
        foreach ($_cwRows as $_cwR) $_devCwCount[(int)$_cwR['product_id']] = (int)$_cwR['filled'];
    } catch (Exception $_cwEx) { /* table may not exist yet — fall through */ }
}

// Build a single "back" query string from the active filter/page state.
// Threaded through View / Edit / Save / Cancel as ?dev_back=… so the editor
// can return the user to the exact list state they were on.
$_devBackParams = array('dev_country' => $_devCountry);
if ($_devCurPage > 1)             $_devBackParams['dev_page']       = $_devCurPage;
if ($_devFilterType !== '')       $_devBackParams['dev_type']       = $_devFilterType;
if ($_devFilterQuery !== '')      $_devBackParams['dev_q']          = $_devFilterQuery;
if ($_devFilterCourseware !== '') $_devBackParams['dev_courseware'] = $_devFilterCourseware;
$_devBackQs = http_build_query($_devBackParams);
// "All" → website_id 0 (treated as "no country filter" everywhere below)
// Canonical branch order across the admin (matches store_id ordering):
// All → Singapore (1) → Malaysia (2) → Ghana (3) → Nigeria (4) →
// Bhutan (5) → India (6) → Infotech (7).
$_devCountryMap = array(
    'All'       => 0,
    'Singapore' => 1,
    'Malaysia'  => 2,
    'Ghana'     => 3,
    'Nigeria'   => 4,
    'Bhutan'    => 5,
    'India'     => 6,
    'Infotech'  => 7,
);
$_devCountryPrefix = array(
    0 => 'ALL',
    1 => 'SG',
    2 => 'MY',
    3 => 'GH',
    4 => 'NG',
    5 => 'BUT',
    6 => 'IND',
    7 => 'INF',
);
$_devAllowedCountries = array_keys($_devCountryMap);
if (!in_array($_devCountry, $_devAllowedCountries)) $_devCountry = 'All';
$_devWebsiteId = $_devCountryMap[$_devCountry];
$_devPrefix = isset($_devCountryPrefix[$_devWebsiteId]) ? $_devCountryPrefix[$_devWebsiteId] : 'SG';

// Build a stable rank map for the current scope so we can generate
// Course Run IDs (SG-100000, SG-100001, ...) that stay consistent across
// pages. For a country tab, rank = position of the product's entity_id
// among products on that country's website (sorted ascending). For the
// "All" tab, rank is computed across every catalog product.
$_devRankMap = array();
try {
    $_rRead = Mage::getSingleton('core/resource')->getConnection('core_read');
    if ($_devWebsiteId > 0) {
        $_pwTbl = $_rRead->getTableName('catalog_product_website');
        $_allCountryIds = $_rRead->fetchCol(
            "SELECT DISTINCT product_id FROM {$_pwTbl} WHERE website_id=? ORDER BY product_id ASC",
            array($_devWebsiteId)
        );
    } else {
        $_allCountryIds = $_rRead->fetchCol(
            "SELECT entity_id FROM " . $_rRead->getTableName('catalog_product_entity') . " ORDER BY entity_id ASC"
        );
    }
    foreach ($_allCountryIds as $_idx => $_pid) {
        $_devRankMap[(int)$_pid] = $_idx;
    }
} catch (Exception $e) {}
$_devTotalCount = 0;
// Heavy block — paginated catalog product collection with multiple EAV
// attributes selected, plus filtering, plus an iteration that resolves
// thumbnail images per row. Only the Developer panel renders this; for
// every other role the result ($_devCourses) is never displayed.
if ($_courseManagerActive):
try {
    // For "All", disable the flat-catalog at runtime so the collection
    // reads from catalog_product_entity (EAV) instead of catalog_product_flat_1.
    // The flat table bakes in WHERE status=1, which would otherwise hide
    // disabled products even when we don't add a status filter ourselves.
    if ($_devWebsiteId === 0) {
        Mage::app()->getStore()->setConfig('catalog/frontend/flat_catalog_product', 0);
    }
    $_devCollection = Mage::getModel('catalog/product')->getCollection()
        ->addAttributeToSelect(array('name','image','status','news_from_date','news_to_date','course_image_url','software','duration','sessions','level','price'))
        ->setOrder('entity_id', 'DESC');
    if ($_devWebsiteId > 0) {
        $_devCollection
            ->addAttributeToFilter('status', 1)
            ->addWebsiteFilter($_devWebsiteId);
    }

    // Server-side filter by course type (software attribute)
    if ($_devFilterType !== '') {
        $_typeMap = array('nonfunded'=>'Non-funded');
        $_typeKey = strtolower($_devFilterType);
        if (isset($_typeMap[$_typeKey])) {
            $_optId = Mage::getSingleton('eav/config')->getAttribute('catalog_product', 'software')->getSource()->getOptionId($_typeMap[$_typeKey]);
            if ($_optId) {
                $_devCollection->addAttributeToFilter('software', $_optId);
            }
        }
    }

    // Server-side search by course name or SKU
    if ($_devFilterQuery !== '') {
        $_devCollection->addFieldToFilter(array(
            array('attribute'=>'name','like'=>'%' . $_devFilterQuery . '%'),
            array('attribute'=>'sku','like'=>'%' . $_devFilterQuery . '%'),
        ));
    }

    $_devTotalCount = $_devCollection->getSize();
    $_devCollection->setPageSize($_devPageSize)->setCurPage($_devCurPage);
    foreach ($_devCollection as $_dp) {
        // Apply courseware filter — skip rows that don't match the chosen state
        if (in_array($_devFilterCourseware, array('missing','partial','all'), true)) {
            $_pid = (int)$_dp->getId();
            $_filled = isset($_devCwCount[$_pid]) ? $_devCwCount[$_pid] : 0;
            if ($_devFilterCourseware === 'missing' && $_filled !== 0)            continue;
            if ($_devFilterCourseware === 'partial' && ($_filled === 0 || $_filled === $_devCwTotal)) continue;
            if ($_devFilterCourseware === 'all'     && $_filled !== $_devCwTotal) continue;
        }

        $_dName = $_dp->getName();
        $_dSoftware = $_dp->getAttributeText('software');
        $_devUnfunded++;
        $_dImgUrl = '';
        $_dExtImg = trim((string) $_dp->getData('course_image_url'));
        if ($_dExtImg !== '') {
            $_dImgUrl = $_dExtImg;
        } else {
            try { if ($_dp->getImage() && $_dp->getImage() !== 'no_selection') $_dImgUrl = (string)Mage::helper('catalog/image')->init($_dp, 'image')->resize(400, 250); } catch (Exception $e) {}
        }
        $_devCourses[] = array(
            'id'          => $_dp->getId(),
            'name'        => $_dName,
            'sku'         => $_dp->getSku(),
            'image'       => $_dImgUrl,
            'funding_date'=> $_dp->getNewsFromDate(),
            'funding_end' => $_dp->getNewsToDate(),
            'duration'    => (float)$_dp->getData('duration'),
            'sessions'    => $_dp->getAttributeText('sessions'),
            'level'       => $_dp->getAttributeText('level'),
            'price'       => (float)$_dp->getData('price'),
            'course_type' => $_dSoftware ?: '',
        );
    }
} catch (Exception $e) {}
$_devTotalPages = max(1, (int) ceil($_devTotalCount / $_devPageSize));
// "Total Courses" header value. Stable per-tab count, independent of
// search / type / courseware filters.
//
// "All" tab: every course in the catalog (regardless of status). Magento's
// flat-catalog collection bakes in WHERE status=1, so we go to the raw
// catalog_product_entity table to get a true total.
//
// Country tabs: active courses on that country's website (uses the flat
// collection's implicit status filter + addWebsiteFilter).
if ($_devWebsiteId > 0) {
    $_devTotalAll = Mage::getModel('catalog/product')->getCollection()
        ->addAttributeToFilter('status', 1)
        ->addWebsiteFilter($_devWebsiteId)
        ->getSize();
} else {
    $_devTotalAll = (int) Mage::getSingleton('core/resource')
        ->getConnection('core_read')
        ->fetchOne("SELECT COUNT(*) FROM " . Mage::getSingleton('core/resource')->getTableName('catalog_product_entity'));
}
endif; // end if ($_courseManagerActive) — closes the $_devCollection block
?>
