<?php /* ===== PANEL: Assign Trainer (Admin only) ===== */ ?>
<?php
// Data prep — only runs when this panel is the active sub-view, otherwise
// the page pays for ~3 extra queries on every dashboard load.
$_atActive = ($activeRole === 'admin') && (Mage::app()->getRequest()->getParam('panel') === 'assign_trainer');
$_atKpi = array(
    'upcoming' => 0, 'ongoing' => 0, 'completed' => 0,
    'assigned' => 0, 'missing' => 0,
    'assigned_upcoming'  => 0, 'missing_upcoming'  => 0,
    'assigned_ongoing'   => 0, 'missing_ongoing'   => 0,
    'assigned_completed' => 0, 'missing_completed' => 0,
);
$_atRows = array();
$_atTrainerOpts = array();
$_atCourseTitles = array();
if ($_atActive) {
    // Country scope from the logged-in admin's email (admin.<cc>@…).
    // Defaults to Singapore for accounts that don't match the pattern.
    $_atWid       = (int) Mage::helper('mmd_rolemanager')->getActiveWebsiteId();
    $_atCountry   = Mage::helper('mmd_rolemanager')->getActiveCountryName();
    $_atSelfLabel = $_atCountry . ' Admin'; // e.g. "Malaysia Admin"
    $_atTrainerOptsScoped = array();
    try {
        $_atTrainersAttrId = isset($_eavAttrIds['trainers']) ? $_eavAttrIds['trainers'] : 0;
        // Trainer option_id → name. Full list is used by the inline
        // editor (admin can pick any trainer to assign). The filter
        // dropdown below uses a country-scoped subset built later.
        if ($_atTrainersAttrId) {
            $_atTrainerOpts = $read->fetchPairs(
                "SELECT eaov.option_id, eaov.value
                 FROM eav_attribute_option eao
                 JOIN eav_attribute_option_value eaov ON eao.option_id=eaov.option_id AND eaov.store_id=0
                 WHERE eao.attribute_id=?
                 ORDER BY eaov.value",
                array($_atTrainersAttrId)
            );

            // Country-scoped trainer subset — anyone whose option_id
            // appears in the trainers multiselect of any product on
            // this country's catalog OR in any course_runs row whose
            // product is on this country's catalog. Plus the matching
            // "<Country> Admin" option, always included so admins can
            // filter to their own self-assigned classes.
            $_atScopedOids = array();
            try {
                $rows = $read->fetchAll(
                    "SELECT t.value FROM catalog_product_entity_text t
                     JOIN catalog_product_website pw ON pw.product_id = t.entity_id AND pw.website_id = ?
                     WHERE t.attribute_id = ? AND t.value <> ''",
                    array($_atWid, $_atTrainersAttrId)
                );
                foreach ($rows as $r) {
                    foreach (explode(',', $r['value']) as $_oid) {
                        $_oid = (int) trim($_oid);
                        if ($_oid) $_atScopedOids[$_oid] = true;
                    }
                }
                $crOids = $read->fetchCol(
                    "SELECT DISTINCT cr.trainer_option_id FROM course_runs cr
                     JOIN catalog_product_website pw ON pw.product_id = cr.product_id AND pw.website_id = ?
                     WHERE cr.trainer_option_id IS NOT NULL",
                    array($_atWid)
                );
                foreach ($crOids as $_oid) $_atScopedOids[(int)$_oid] = true;
                foreach ($_atTrainerOpts as $_oid => $_name) {
                    if (strcasecmp(trim($_name), $_atSelfLabel) === 0) {
                        $_atScopedOids[(int)$_oid] = true;
                    }
                }
                foreach ($_atTrainerOpts as $_oid => $_name) {
                    if (isset($_atScopedOids[(int)$_oid])) $_atTrainerOptsScoped[(int)$_oid] = $_name;
                }
            } catch (Exception $e) {}
        }
        // Source the list from the catalog. Each catalog product is one
        // row — that's the universe of courses admins can assign
        // trainers to. course_runs entries (admin-scheduled instances)
        // are layered on top below: their dates / trainer override the
        // catalog defaults so the "scheduled" version of a class wins.
        // Singapore-only, currently active courses. Joins:
        //   - catalog_product_website (website_id=1) — Singapore scope,
        //     mirrors the dev dashboard's addWebsiteFilter(1).
        //   - catalog_product_entity_varchar (name) — drops untitled
        //     catalog rows that would render as "(No Name)".
        //   - catalog_product_entity_int (status=1) — active products
        //     only, so disabled / archived courses don't pad the list.
        // LIMIT 2000 covers the SG catalog with comfortable headroom.
        // Replaced 5 correlated subqueries with set-based JOINs.
        //
        // Date columns: simple LEFT JOIN at store_id=0. Verified via
        // diff query against local DB — every news_from_date / news_to_date
        // value matches the old "ORDER BY store_id LIMIT 1" subquery.
        //
        // Text columns (trainers_csv, trainer_profile_html): the old
        // subquery used "ORDER BY store_id LIMIT 1" which means it preferred
        // store_id=0 but FELL BACK to the lowest non-zero store_id when no
        // store_id=0 row existed. 4 SG rows actually rely on this fallback,
        // so a naive store_id=0 join would silently drop their trainer.
        // Solved with a MIN(store_id) sub-join per (entity_id, attribute_id),
        // then the value JOIN matches that exact store_id. Two extra
        // LEFT JOINs per text attribute, but each is set-based and cheap
        // compared to the original per-row correlated subquery.
        $_atTrainersJoinAid = $_atTrainersAttrId ? (int)$_atTrainersAttrId : 0;
        $_atProducts = $read->fetchAll(
            "SELECT e.entity_id, e.sku, v.value AS name,
                    s.value AS status_val,
                    sd.value AS news_from_date,
                    ed.value AS news_to_date,
                    " . ($_atTrainersAttrId ? "trc.value" : "NULL") . " AS trainers_csv,
                    tp.value AS trainer_profile_html
             FROM catalog_product_entity e
             INNER JOIN catalog_product_website pw
                ON pw.product_id=e.entity_id AND pw.website_id={$_atWid}
             INNER JOIN catalog_product_entity_varchar v
                ON v.entity_id=e.entity_id AND v.attribute_id=71 AND v.store_id=0
             INNER JOIN catalog_product_entity_int s
                ON s.entity_id=e.entity_id AND s.attribute_id={$statusAid} AND s.store_id=0 AND s.value=1
             LEFT JOIN catalog_product_entity_datetime sd
                ON sd.entity_id=e.entity_id AND sd.attribute_id={$startAid} AND sd.store_id=0
             LEFT JOIN catalog_product_entity_datetime ed
                ON ed.entity_id=e.entity_id AND ed.attribute_id={$endAid}   AND ed.store_id=0
             LEFT JOIN (
                 SELECT entity_id, MIN(store_id) AS min_sid
                 FROM catalog_product_entity_text
                 WHERE attribute_id={$_atTrainersJoinAid} AND value IS NOT NULL AND value <> ''
                 GROUP BY entity_id
             ) trc_min ON trc_min.entity_id=e.entity_id
             LEFT JOIN catalog_product_entity_text trc
                ON trc.entity_id=e.entity_id AND trc.attribute_id={$_atTrainersJoinAid} AND trc.store_id=trc_min.min_sid
             LEFT JOIN (
                 SELECT entity_id, MIN(store_id) AS min_sid
                 FROM catalog_product_entity_text
                 WHERE attribute_id=153 AND value IS NOT NULL AND value <> ''
                 GROUP BY entity_id
             ) tp_min ON tp_min.entity_id=e.entity_id
             LEFT JOIN catalog_product_entity_text tp
                ON tp.entity_id=e.entity_id AND tp.attribute_id=153 AND tp.store_id=tp_min.min_sid
             WHERE v.value IS NOT NULL AND v.value <> ''
             ORDER BY IFNULL(sd.value, '9999-12-31') ASC, e.entity_id ASC
             LIMIT 2000"
        );
        // Pull the latest course_runs row per product so a scheduled
        // class's dates / trainer override the product's attributes.
        $_atRunByPid = array();
        try {
            $_atRunRows = $read->fetchAll(
                "SELECT cr.product_id, cr.run_id, cr.trainer_option_id, cr.course_start_date, cr.course_end_date
                 FROM course_runs cr
                 JOIN (
                     SELECT product_id, MAX(run_id) AS max_run FROM course_runs GROUP BY product_id
                 ) latest ON latest.product_id=cr.product_id AND latest.max_run=cr.run_id"
            );
            foreach ($_atRunRows as $_rn) $_atRunByPid[(int)$_rn['product_id']] = $_rn;
        } catch (Exception $e) {}

        // Bulk-load Course Date custom-option titles per product so the
        // bucket logic below can fall back to them when news_from_date
        // is empty. Same approach Assign Learner uses — keeps the two
        // panels' KPIs consistent.
        $_atCdByPid = array();
        try {
            foreach ($read->fetchAll(
                "SELECT o.product_id, ott.title
                 FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'"
            ) as $_cd) {
                $_atCdByPid[(int)$_cd['product_id']][] = $_cd['title'];
            }
        } catch (Exception $e) {}

        $_atToday = strtotime(date('Y-m-d'));
        foreach ($_atProducts as $_p) {
            $_pid = (int) $_p['entity_id'];
            $_run = isset($_atRunByPid[$_pid]) ? $_atRunByPid[$_pid] : null;

            // Dates: course_runs wins, else news_from/to_date, else
            // parse from Course Date custom-options (the canonical
            // source many catalog products actually use).
            $_sd = 0; $_ed = 0;
            if ($_run && !empty($_run['course_start_date'])) $_sd = strtotime($_run['course_start_date']);
            elseif ($_p['news_from_date'])                   $_sd = strtotime($_p['news_from_date']);
            if ($_run && !empty($_run['course_end_date']))   $_ed = strtotime($_run['course_end_date']);
            elseif ($_p['news_to_date'])                     $_ed = strtotime($_p['news_to_date']);

            if (!$_sd && isset($_atCdByPid[$_pid])) {
                $_bestFuture = null; $_bestFutureEnd = 0;
                $_bestPast   = null; $_bestPastEnd   = 0;
                foreach ($_atCdByPid[$_pid] as $_title) {
                    if (preg_match('#(\d{1,2})(?:/(\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{4})#', $_title, $_dm)) {
                        $_stTs = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_dm[4]);
                        $_enTs = !empty($_dm[2]) ? strtotime($_dm[2] . ' ' . $_dm[3] . ' ' . $_dm[4]) : $_stTs;
                        if (!$_stTs) continue;
                        if ($_stTs >= $_atToday) {
                            if ($_bestFuture === null || $_stTs < $_bestFuture) { $_bestFuture = $_stTs; $_bestFutureEnd = $_enTs; }
                        } else {
                            if ($_bestPast === null || $_stTs > $_bestPast)     { $_bestPast   = $_stTs; $_bestPastEnd   = $_enTs; }
                        }
                    }
                }
                if ($_bestFuture !== null)   { $_sd = $_bestFuture; $_ed = $_bestFutureEnd; }
                elseif ($_bestPast !== null) { $_sd = $_bestPast;   $_ed = $_bestPastEnd; }
            }

            $_sv = (int) $_p['status_val'];
            // Bucket by date.
            //   Ongoing  : start <= today <= end.
            //   Completed: end is past, OR start is past with no end set
            //              (legacy products whose schedule already lapsed
            //              and was never updated — they shouldn't crowd
            //              the Upcoming list).
            //   Upcoming : future start, OR no dates at all (Pending —
            //              awaiting scheduling, the admin's to-do).
            if ($_sd && $_ed && $_sd <= $_atToday && $_ed >= $_atToday) $_tab = 'ongoing';
            elseif ($_ed && $_ed < $_atToday)                           $_tab = 'completed';
            elseif ($_sd && $_sd < $_atToday && !$_ed)                  $_tab = 'completed';
            else                                                        $_tab = 'upcoming';
            // Status label
            if ($_sv !== 1) { $_lbl = 'Cancelled'; $_cls = 'at-badge-cancelled'; }
            elseif (!$_sd) { $_lbl = 'Pending';   $_cls = 'at-badge-pending'; }
            else           { $_lbl = 'Confirmed'; $_cls = 'at-badge-confirmed'; }

            // Trainer names: course_runs.trainer_option_id wins; else
            // pull from the product's `trainers` multiselect CSV; else
            // fall back to parsing names out of `trainerprofile` HTML
            // (attr 153) — that's the bio field where names live as
            // <strong>Name:</strong>… and it covers ~250 more SG courses
            // than the multiselect alone.
            $_tnames = array();
            $_toids  = array();
            if ($_run && (int)$_run['trainer_option_id'] > 0) {
                $_tOpt = (int)$_run['trainer_option_id'];
                if (isset($_atTrainerOpts[$_tOpt])) {
                    $_tnames[] = $_atTrainerOpts[$_tOpt];
                    $_toids[]  = $_tOpt;
                }
            } else {
                $_tcsv = trim((string) $_p['trainers_csv']);
                if ($_tcsv !== '') {
                    foreach (explode(',', $_tcsv) as $_oid) {
                        $_oid = (int) trim($_oid);
                        if ($_oid && isset($_atTrainerOpts[$_oid])) {
                            $_tnames[] = $_atTrainerOpts[$_oid];
                            $_toids[]  = $_oid;
                        }
                    }
                }
            }
            if (empty($_tnames)) {
                $_profile = (string) $_p['trainer_profile_html'];
                if ($_profile !== '' && preg_match_all('/<strong[^>]*>\s*([^<:]{2,80}?)\s*:\s*(?:&nbsp;)?\s*<\/strong>/i', $_profile, $_pm)) {
                    $_seen = array();
                    foreach ($_pm[1] as $_pn) {
                        $_pn = trim(html_entity_decode(strip_tags($_pn), ENT_QUOTES, 'UTF-8'));
                        if ($_pn === '' || isset($_seen[$_pn])) continue;
                        $_seen[$_pn] = 1;
                        $_tnames[] = $_pn;
                        if (count($_tnames) >= 5) break;
                    }
                }
            }

            // Run ID — country prefix follows the product's website
            // (SG-/MY-/GH-/NG-/BUT-/IND-). Scheduled runs use course_runs
            // numbering, unscheduled fall back to catalog-rank.
            if ($_run) {
                $_runId = Mage::helper('mmd_rolemanager')->formatRunId($_pid, $_run['run_id']);
            } elseif (isset($_lmcRunMap[$_pid])) {
                $_runId = $_lmcRunMap[$_pid];
            } elseif (isset($_devRankMap[$_pid])) {
                $_runId = $_devPrefix . '-' . (100000 + (int)$_devRankMap[$_pid]);
            } else {
                $_runId = (string) (1000000 + $_pid);
            }

            $_atRows[] = array(
                'pid'        => $_pid,
                'sku'        => $_p['sku'],
                'title'      => $_p['name'] ?: '(No Name)',
                'run_id'     => $_runId,
                'start_date' => $_sd ? date('d/m/Y', $_sd) : '—',
                'start_iso'  => $_sd ? date('Y-m-d', $_sd) : '',
                'tab'        => $_tab,
                'status'     => $_lbl,
                'status_cls' => $_cls,
                'trainers'   => $_tnames,
                'trainer_oids' => $_toids,
            );
            $_atCourseTitles[$_p['name']] = true;
            if ($_tab === 'upcoming') $_atKpi['upcoming']++;
            if ($_tab === 'ongoing')  $_atKpi['ongoing']++;
            if ($_tab === 'completed')$_atKpi['completed']++;
            // Per-tab assigned / missing so the KPI tiles can swap on
            // tab click without a page reload.
            $_kpiKey = 'assigned_' . $_tab;
            $_kpiKey2 = 'missing_' . $_tab;
            if (!isset($_atKpi[$_kpiKey]))  $_atKpi[$_kpiKey] = 0;
            if (!isset($_atKpi[$_kpiKey2])) $_atKpi[$_kpiKey2] = 0;
            if (!empty($_tnames)) $_atKpi[$_kpiKey]++;
            else                  $_atKpi[$_kpiKey2]++;
            // Backwards-compat aliases used by the initial render.
            if ($_tab === 'upcoming') {
                if (!empty($_tnames)) $_atKpi['assigned']++;
                else                  $_atKpi['missing']++;
            }
        }
        ksort($_atCourseTitles);
        $_atCourseTitles = array_keys($_atCourseTitles);
    } catch (Exception $e) {}
    foreach (array('upcoming','ongoing','completed') as $_tk) {
        if (!isset($_atKpi['assigned_' . $_tk])) $_atKpi['assigned_' . $_tk] = 0;
        if (!isset($_atKpi['missing_' . $_tk]))  $_atKpi['missing_' . $_tk]  = 0;
    }
}
