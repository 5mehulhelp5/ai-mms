    <script type="text/javascript">
    (function(){
        window.__sessAddUrl = <?php echo json_encode($_sessAddUrl) ?>;
        window.__sessDelUrl = <?php echo json_encode($_sessDelUrl) ?>;
        window.__sessCourseId = <?php echo (int)$_selectedCourseId ?>;
    })();
    window.sessToggleAddForm = function() {
        var f = document.getElementById('sessAddForm');
        if (!f) return;
        f.style.display = (f.style.display === 'none' || !f.style.display) ? 'block' : 'none';
    };
    window.sessSubmitAdd = function() {
        var dateEl  = document.getElementById('sessAddDate');
        var labelEl = document.getElementById('sessAddLabel');
        var priceEl = document.getElementById('sessAddPrice');
        var btn     = document.getElementById('sessAddSubmitBtn');
        var rs      = document.getElementById('sessAddResult');
        if (!dateEl.value) {
            rs.style.display = '';
            rs.innerHTML = '<span style="color:#ef4444;">Please pick a session date.</span>';
            return;
        }
        btn.disabled = true; btn.textContent = 'Saving…';
        rs.style.display = '';
        rs.innerHTML = '<span style="color:#94a3b8;">Saving…</span>';

        var fd = new FormData();
        fd.append('course_id', window.__sessCourseId);
        fd.append('session_date', dateEl.value);
        if (labelEl.value) fd.append('session_label', labelEl.value);
        if (priceEl.value) fd.append('session_price', priceEl.value);

        fetch(window.__sessAddUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                btn.disabled = false; btn.textContent = 'Save';
                if (d.success) {
                    rs.innerHTML = '<span style="color:#10b981;">Session added: ' + d.label + '. Reloading…</span>';
                    setTimeout(function(){ window.location.reload(); }, 800);
                } else {
                    rs.innerHTML = '<span style="color:#ef4444;">' + (d.message || 'Failed to add session') + '</span>';
                }
            })
            .catch(function(err){
                btn.disabled = false; btn.textContent = 'Save';
                rs.innerHTML = '<span style="color:#ef4444;">Network error: ' + err.message + '</span>';
            });
    };
    window.sessDelete = function(optionTypeId, btnEl) {
        if (!confirm('Remove this session?')) return;
        btnEl.disabled = true;
        var fd = new FormData();
        fd.append('course_id', window.__sessCourseId);
        fd.append('option_type_id', optionTypeId);
        fetch(window.__sessDelUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (d.success) {
                    var row = btnEl.closest('.sess-row');
                    if (row) row.remove();
                } else {
                    btnEl.disabled = false;
                    alert(d.message || 'Failed to delete session');
                }
            })
            .catch(function(err){
                btnEl.disabled = false;
                alert('Network error: ' + err.message);
            });
    };
    </script>

