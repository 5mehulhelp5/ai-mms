<script type="text/javascript">
// Company Setting panel JS
window.csToggleSection = function(headEl) {
    var body = headEl.nextElementSibling;
    var caret = headEl.querySelector('.cs-caret');
    var willOpen = !body.classList.contains('open');
    if (willOpen) {
        // Accordion: close every other section first.
        var section = headEl.closest ? headEl.closest('.cs-section') : null;
        var openBodies = document.querySelectorAll('.cs-section-body.open');
        for (var i = 0; i < openBodies.length; i++) {
            var ob = openBodies[i];
            if (section && ob.parentNode === section) { continue; }
            ob.classList.remove('open');
            var prevHead = ob.previousElementSibling;
            if (prevHead) {
                var c = prevHead.querySelector('.cs-caret');
                if (c) { c.classList.remove('open'); }
            }
        }
        body.classList.add('open');
        if (caret) caret.classList.add('open');
    } else {
        body.classList.remove('open');
        if (caret) caret.classList.remove('open');
    }
};

// On initial load, expand every section so all features are visible.
// First user click switches into accordion mode (one-at-a-time).
(function () {
    function csExpandAll() {
        var bodies = document.querySelectorAll('.cs-section-body');
        for (var i = 0; i < bodies.length; i++) {
            bodies[i].classList.add('open');
            var head = bodies[i].previousElementSibling;
            if (head) {
                var caret = head.querySelector('.cs-caret');
                if (caret) { caret.classList.add('open'); }
            }
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', csExpandAll);
    } else {
        csExpandAll();
    }
})();
window.csToggleApp = function(headerEl) {
    var body = headerEl.nextElementSibling;
    var caret = headerEl.querySelector('.cs-caret');
    if (body.classList.contains('open')) {
        body.classList.remove('open');
        if (caret) caret.classList.remove('open');
    } else {
        body.classList.add('open');
        if (caret) caret.classList.add('open');
    }
};
/* Eye-toggle icons. The button starts as a plain open-eye 👁 in
   the HTML and gets swapped to a clean SVG pair the first time the
   user interacts. SVGs render consistently across browsers / fonts. */
var CS_EYE_OPEN  = '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
var CS_EYE_OFF   = '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
function csSetEyeIcon(btn, revealed) {
    if (btn) btn.innerHTML = revealed ? CS_EYE_OFF : CS_EYE_OPEN;
}
/* Eye-toggle on the edit-mode password input. Pair with .cs-secret-edit
   wrapper so the button stays positioned next to the input. */
window.csTogglePasswordInput = function (btn) {
    var box = btn.closest('.cs-secret-edit');
    if (!box) return;
    var input = box.querySelector('input');
    if (!input) return;
    input.type = (input.type === 'password') ? 'text' : 'password';
    csSetEyeIcon(btn, input.type === 'text');
    input.focus();
};
window.csToggleEye = function(btn) {
    var box = btn.closest('.cs-input-masked');
    if (!box) return;
    var nowRevealed = false;
    var span = box.querySelector('span[data-cs-masked]');
    if (span) {
        var revealed = span.getAttribute('data-cs-revealed') === '1';
        if (revealed) {
            span.textContent = span.getAttribute('data-cs-masked') || '';
            span.setAttribute('data-cs-revealed', '0');
            nowRevealed = false;
        } else {
            var plain = span.getAttribute('data-cs-plain') || '';
            span.textContent = plain;
            span.setAttribute('data-cs-revealed', '1');
            nowRevealed = true;
        }
    }
    var field = btn.closest('.cs-field');
    if (field) {
        var input = field.querySelector('input[type="password"], input[data-cs-secret]');
        if (input) {
            if (input.type === 'password') {
                input.type = 'text';
                input.setAttribute('data-cs-secret', '1');
            } else if (input.getAttribute('data-cs-secret') === '1') {
                input.type = 'password';
            }
        }
    }
    csSetEyeIcon(btn, nowRevealed);
};
window.csEditSection = function(section) {
    var body = document.getElementById('cs-body-' + section);
    if (!body) return;
    var fields = body.querySelectorAll('.cs-field[data-path]');
    for (var i = 0; i < fields.length; i++) fields[i].classList.add('editing');
    var actions = document.getElementById('cs-actions-' + section);
    if (actions) actions.style.display = 'inline-flex';
    // When the actions pair lives in the header (next to Edit), hide
    // the Edit button so Save / Cancel take its slot.
    var editBtn = document.getElementById('cs-edit-' + section);
    if (editBtn) editBtn.style.display = 'none';
};
window.csCancelSection = function(section) {
    var body = document.getElementById('cs-body-' + section);
    if (!body) return;
    var fields = body.querySelectorAll('.cs-field[data-path]');
    for (var i = 0; i < fields.length; i++) fields[i].classList.remove('editing');
    var actions = document.getElementById('cs-actions-' + section);
    if (actions) actions.style.display = 'none';
    var editBtn = document.getElementById('cs-edit-' + section);
    if (editBtn) editBtn.style.display = '';
    // Re-mask any secret fields the user revealed during this edit
    // session: snap display-mode masked spans back to their bullet
    // form, flip edit-mode password inputs back to type=password, and
    // reset every eye button to the open-eye (masked) icon.
    body.querySelectorAll('.cs-input-masked span[data-cs-masked]').forEach(function (span) {
        if (span.getAttribute('data-cs-revealed') === '1') {
            span.textContent = span.getAttribute('data-cs-masked') || '';
            span.setAttribute('data-cs-revealed', '0');
        }
    });
    body.querySelectorAll('.cs-secret-edit input').forEach(function (input) {
        input.type = 'password';
    });
    body.querySelectorAll('.cs-eye-btn').forEach(function (btn) {
        csSetEyeIcon(btn, false);
    });
};
window.csSaveSection = function(section) {
    var body = document.getElementById('cs-body-' + section);
    if (!body) return;
    var fields = body.querySelectorAll('.cs-field[data-path]');
    var settings = {};
    for (var i = 0; i < fields.length; i++) {
        var path = fields[i].getAttribute('data-path');
        var input = fields[i].querySelector('input,select');
        if (input && path) {
            settings[path] = input.value;
            // Update the display value
            var valEl = fields[i].querySelector('.cs-val');
            if (valEl) {
                var maskedSpan = valEl.querySelector('span[data-cs-masked]');
                var linkEl     = valEl.querySelector('a');
                if (maskedSpan) {
                    // Secret field — preserve the masked pill structure.
                    // Stash the new plaintext in data-cs-plain so the eye
                    // button reveals the latest saved value next time,
                    // but render the mask text now.
                    maskedSpan.setAttribute('data-cs-plain', input.value);
                    maskedSpan.setAttribute('data-cs-revealed', '0');
                    maskedSpan.textContent = maskedSpan.getAttribute('data-cs-masked') || '';
                } else if (linkEl) {
                    linkEl.textContent = input.value; linkEl.href = input.value;
                } else if (valEl.querySelector('.cs-masked')) {
                    /* keep masked */
                } else {
                    valEl.textContent = input.value;
                }
            }
        }
    }
    // Also collect toggle values
    var toggles = body.querySelectorAll('.cs-toggle input[data-path]');
    for (var j = 0; j < toggles.length; j++) {
        settings[toggles[j].getAttribute('data-path')] = toggles[j].checked ? '1' : '0';
    }
    // Send AJAX save
    new Ajax.Request('<?php echo $_csUrl ?>', {
        method: 'post',
        parameters: { settings: JSON.stringify(settings) },
        onSuccess: function(t) {
            try {
                var r = JSON.parse(t.responseText);
                if (r.success) {
                    csCancelSection(section);
                }
            } catch(e) {}
        }
    });
};
</script>
