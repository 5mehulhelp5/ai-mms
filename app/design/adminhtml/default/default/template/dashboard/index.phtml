                        // form submission already reads.
                        window._cncTrainerOpts = <?php echo json_encode(array_map(function ($oid, $name) {
                            return array('id' => (int) $oid, 'name' => $name);
                        }, array_keys($_cncTrainers), array_values($_cncTrainers))) ?>;
                        window.cncFilterTrainers = function(inp) {
                            var q = (inp.value || '').toLowerCase().trim();
                            // Drop "(you)" suffix when matching so the
                            // pre-selected label stays valid as a query.
                            var qClean = q.replace(/\s*\(you\)\s*$/, '');
                            var box = document.getElementById('cnc-trainer-list');
                            box.innerHTML = '';
                            var matches = [];
                            for (var i = 0; i < window._cncTrainerOpts.length; i++) {
                                var o = window._cncTrainerOpts[i];
                                if (qClean === '' || o.name.toLowerCase().indexOf(qClean) !== -1) matches.push(o);
                                // Cap at 500 — covers the full current
                                // ~270 trainer roster with room to grow,
                                // while still preventing runaway DOM
                                // builds if the list ever explodes.
                                if (matches.length >= 500) break;
                            }
                            if (matches.length === 0) {
                                var n = document.createElement('div');
                                n.className = 'cnc-trainer-empty';
                                n.textContent = 'No matching trainers';
                                box.appendChild(n);
                            } else {
                                for (var k = 0; k < matches.length; k++) {
                                    var m = matches[k];
                                    var d = document.createElement('div');
                                    d.className = 'cnc-trainer-row';
                                    d.textContent = m.name;
                                    (function(id, name){
                                        d.onclick = function() {
                                            inp.value = name;
                                            document.getElementById('cnc-trainer-id').value = String(id);
                                            box.style.display = 'none';
                                        };
                                    })(m.id, m.name);
                                    box.appendChild(d);
                                }
                            }
                            box.style.display = '';
                        };
                        // Hide list when clicking outside.
                        document.addEventListener('click', function(e){
                            var w = document.querySelector('.cnc-trainer-wrap');
                            var box = document.getElementById('cnc-trainer-list');
                            if (w && box && !w.contains(e.target)) box.style.display = 'none';
                        });
                        </script>
