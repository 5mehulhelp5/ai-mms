<script type="text/javascript">
var RM_PAGE_SIZE = 50;
var rmCurrentPage = 1;
var CLS_SEND_INVITE_URL  = '<?php echo $this->jsQuoteEscape($_sendInviteUrl) ?>';
var CLS_UPDATE_FLAGS_URL = '<?php echo $this->jsQuoteEscape($_updateFlagsUrl) ?>';

function clsToggleExpand(runId) {
    var row = document.getElementById('cls-expand-' + runId);
    if (!row) return;
    row.style.display = (row.style.display === 'none') ? '' : 'none';
}

function clsUpdateInviteBtn(runId) {
    var sel = document.getElementById('cls-sel-' + runId);
    var btn = document.getElementById('cls-invite-btn-' + runId);
    if (!sel || !btn) return;
    var firstName = sel.value ? sel.value.split(' ')[0] : '';
    btn.textContent = firstName ? ('Invite: ' + firstName + '…') : 'Invite Next';
}

function clsSendInvitation(runId, btn) {
    var sel = document.getElementById('cls-sel-' + runId);
    var statusEl = document.getElementById('cls-inv-status-' + runId);
    var orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    if (statusEl) statusEl.textContent = '';
    var fd = new FormData();
    fd.append('run_id', runId);
    fd.append('trainer_name', sel ? sel.value : '');
    fd.append('form_key', window.FORM_KEY || '');
    fetch(CLS_SEND_INVITE_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            btn.disabled = false;
            btn.textContent = orig;
            if (statusEl) {
                statusEl.style.color = d.success ? '#10b981' : '#f87171';
                statusEl.textContent = (d.success ? '✓ ' : '✗ ') + (d.message || '');
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = orig;
            if (statusEl) { statusEl.style.color = '#f87171'; statusEl.textContent = '✗ Network error'; }
        });
}

function clsToggleFlag(runId, flag, btn) {
    var cur = parseInt(btn.getAttribute('data-value') || '0', 10);
    var val = cur ? 0 : 1;
    btn.disabled = true;
    var fd = new FormData();
    fd.append('run_id', runId);
    fd.append('flag', flag);
    fd.append('value', val);
    fd.append('form_key', window.FORM_KEY || '');
    fetch(CLS_UPDATE_FLAGS_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            btn.disabled = false;
            if (!d.success) return;
            btn.setAttribute('data-value', val);
            if (flag === 'invitation_paused') {
                btn.textContent      = val ? 'Unpause Invite' : 'Pause Invite';
                btn.style.background = val ? 'rgba(245,158,11,.15)' : 'transparent';
                btn.style.color      = val ? '#f59e0b' : '#64748b';
                btn.style.borderColor = val ? 'rgba(245,158,11,.4)' : '#334155';
            } else {
                btn.textContent      = val ? 'Unblock Reply' : 'Block Reply';
                btn.style.background = val ? 'rgba(239,68,68,.15)' : 'transparent';
                btn.style.color      = val ? '#f87171' : '#64748b';
                btn.style.borderColor = val ? 'rgba(239,68,68,.4)' : '#334155';
            }
        })
        .catch(function() { btn.disabled = false; });
}

function rmFilter(resetPage) {
    if (resetPage !== false) rmCurrentPage = 1;
    var q  = document.getElementById('rm-search').value.toLowerCase();
    var sf = document.getElementById('rm-state-filter').value;
    var rows = document.querySelectorAll('.rm-row');
    var matched = [];
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        var hay = (r.getAttribute('data-class-id') || '') + ' ' +
                  (r.getAttribute('data-sku') || '') + ' ' +
                  (r.getAttribute('data-title') || '');
        var matchQ = !q || hay.indexOf(q) >= 0;
        var matchS = !sf || r.getAttribute('data-state') === sf;
        if (matchQ && matchS) matched.push(r);
        else r.style.display = 'none';
    }
    var total  = matched.length;
    var pages  = Math.max(1, Math.ceil(total / RM_PAGE_SIZE));
    if (rmCurrentPage > pages) rmCurrentPage = pages;
    var start = (rmCurrentPage - 1) * RM_PAGE_SIZE;
    var end   = start + RM_PAGE_SIZE;
    for (var k = 0; k < matched.length; k++) {
        matched[k].style.display = (k >= start && k < end) ? '' : 'none';
    }
    rmRenderPagination(total, pages);
    // Keep expansion rows in sync: hide when their parent row is hidden.
    var expRows = document.querySelectorAll('[data-expand-for]');
    for (var ei = 0; ei < expRows.length; ei++) {
        var runId   = expRows[ei].getAttribute('data-expand-for');
        var parent  = document.querySelector('[data-run-id="' + runId + '"]');
        if (parent && parent.style.display === 'none') {
            expRows[ei].style.display = 'none';
        }
    }
}

function rmGoToPage(p) { rmCurrentPage = p; rmFilter(false); }

function rmRenderPagination(total, pages) {
    var sum = document.getElementById('rm-pagination-summary');
    var ctl = document.getElementById('rm-pagination-controls');
    if (!sum || !ctl) return;
    if (total === 0) { sum.textContent = 'No classes'; ctl.innerHTML = ''; return; }
    var firstOfPage = (rmCurrentPage - 1) * RM_PAGE_SIZE + 1;
    var lastOfPage  = Math.min(rmCurrentPage * RM_PAGE_SIZE, total);
    sum.textContent = 'Showing ' + firstOfPage + '–' + lastOfPage + ' of ' + total;
    var html = '';
    var prevDisabled = rmCurrentPage <= 1     ? ' disabled' : '';
    var nextDisabled = rmCurrentPage >= pages ? ' disabled' : '';
    html += '<button class="rm-pagination-btn" onclick="rmGoToPage(' + (rmCurrentPage - 1) + ')"' + prevDisabled + '>&#8249;</button>';
    var shown = {};
    var toShow = [1, pages, rmCurrentPage, rmCurrentPage - 1, rmCurrentPage + 1].filter(function(n){ return n >= 1 && n <= pages; });
    toShow.sort(function(a, b){ return a - b; });
    var last = 0;
    for (var i = 0; i < toShow.length; i++) {
        var n = toShow[i];
        if (shown[n]) continue;
        if (last && n - last > 1) html += '<span class="rm-pagination-ellipsis">…</span>';
        var active = n === rmCurrentPage ? ' active' : '';
        html += '<button class="rm-pagination-btn' + active + '" onclick="rmGoToPage(' + n + ')">' + n + '</button>';
        shown[n] = true; last = n;
    }
    html += '<button class="rm-pagination-btn" onclick="rmGoToPage(' + (rmCurrentPage + 1) + ')"' + nextDisabled + '>&#8250;</button>';
    ctl.innerHTML = html;
}

(function() { rmFilter(); })();
</script>
