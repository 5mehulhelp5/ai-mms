<?php
/**
 * Admin "Classes" grid — first-class view over course_runs.
 *
 * Supports four buckets via the 'bucket' block data key:
 *   all       — every class with a start date (default)
 *   ongoing   — start_date <= today AND (end_date IS NULL OR end_date >= today)
 *   upcoming  — start_date > today, sorted nearest first
 *   completed — end_date < today, sorted newest first
 *
 * Drill-in (Edit) deep-links to the existing dashboard ?panel=assignlearner
 * panel where roster CRUD already lives.
 */
$_bucket = (string) $this->getData('bucket');
if (!in_array($_bucket, array('all', 'ongoing', 'upcoming', 'completed'), true)) {
    $_bucket = 'all';
}

$resource   = Mage::getSingleton('core/resource');
$read       = $resource->getConnection('core_read');
$runsTbl    = $resource->getTableName('course_runs');
$enrolTbl   = $resource->getTableName('course_run_enrolments');
$pVarchar   = $resource->getTableName('catalog_product_entity_varchar');

$nameAttrId = (int) $read->fetchOne("
    SELECT a.attribute_id
      FROM " . $resource->getTableName('eav_attribute') . " a
      INNER JOIN " . $resource->getTableName('eav_entity_type') . " t ON t.entity_type_id = a.entity_type_id
     WHERE t.entity_type_code = 'catalog_product' AND a.attribute_code = 'name'
");

$today = Mage::getModel('core/date')->date('Y-m-d');

switch ($_bucket) {
    case 'ongoing':
        $_whereBucket = "cr.course_start_date <= '$today'
            AND (cr.course_end_date IS NULL OR cr.course_end_date >= '$today')";
        $_orderBy   = 'cr.course_start_date ASC, cr.course_start_time ASC';
        $_pageTitle = 'Ongoing Classes';
        $_emptyMsg  = 'No classes are currently ongoing.';
        break;
    case 'upcoming':
        $_whereBucket = "cr.course_start_date > '$today'";
        $_orderBy   = 'cr.course_start_date ASC, cr.course_start_time ASC';
        $_pageTitle = 'Upcoming Classes';
        $_emptyMsg  = 'No upcoming classes scheduled.';
        break;
    case 'completed':
        $_whereBucket = "cr.course_end_date < '$today'";
        $_orderBy   = 'cr.course_end_date DESC, cr.course_start_date DESC';
        $_pageTitle = 'Completed Classes';
        $_emptyMsg  = 'No completed classes found.';
        break;
    default:
        $_whereBucket = 'cr.course_start_date IS NOT NULL';
        $_orderBy   = 'cr.course_start_date DESC, cr.course_start_time DESC';
        $_pageTitle = 'All Classes';
        $_emptyMsg  = 'No classes found.';
        break;
}

// Store View filter — map active store_id to class_id prefix (SG/MY/GH/NG/BT/IN/TI)
$_branchHelper  = Mage::helper('branchscope');
$_activeStoreId = $_branchHelper ? (int) $_branchHelper->getActiveStoreId() : 1;
$_storePrefixMap = array(1=>'SG', 2=>'MY', 3=>'GH', 4=>'NG', 5=>'BT', 6=>'IN', 7=>'TI');
$_activePrefix  = isset($_storePrefixMap[$_activeStoreId]) ? $_storePrefixMap[$_activeStoreId] : null;
$_whereStore    = $_activePrefix ? "AND cr.class_id LIKE '{$_activePrefix}%'" : '';

$rows = array();
if ($nameAttrId) {
    $rows = $read->fetchAll("
        SELECT cr.run_id, cr.class_id, cr.course_sku, cr.product_id,
               cr.course_start_date, cr.course_end_date,
               cr.course_start_time, cr.course_end_time,
               cr.vacancy, cr.trainer_option_id, cr.created_by,
               COALESCE(pn.value, '(deleted product)') AS course_title,
               COALESCE(en.enrolled, 0) AS enrolled
          FROM `$runsTbl` cr
          LEFT JOIN `$pVarchar` pn
               ON pn.entity_id = cr.product_id
              AND pn.attribute_id = $nameAttrId
              AND pn.store_id = 0
          LEFT JOIN (
              SELECT run_id, COUNT(*) AS enrolled
                FROM `$enrolTbl`
               GROUP BY run_id
          ) en ON en.run_id = cr.run_id
         WHERE cr.course_start_date IS NOT NULL
           AND $_whereBucket
           $_whereStore
         ORDER BY $_orderBy
    ");
}

$trainerMap = array();
try {
    $trainerRows = $read->fetchAll("
        SELECT eov.option_id, eov.value AS label
          FROM " . $resource->getTableName('eav_attribute_option_value') . " eov
         WHERE eov.store_id = 0
    ");
    foreach ($trainerRows as $tr) {
        $trainerMap[(int)$tr['option_id']] = $tr['label'];
    }
} catch (Exception $e) { /* non-fatal */ }

$storeColors = array(
    'SG' => array('bg' => 'rgba(59,130,246,.12)',  'color' => '#60a5fa'),
    'MY' => array('bg' => 'rgba(245,158,11,.12)',  'color' => '#f59e0b'),
    'GH' => array('bg' => 'rgba(16,185,129,.12)',  'color' => '#10b981'),
    'NG' => array('bg' => 'rgba(34,197,94,.12)',   'color' => '#22c55e'),
    'IN' => array('bg' => 'rgba(168,85,247,.12)',  'color' => '#a855f7'),
    'BT' => array('bg' => 'rgba(236,72,153,.12)',  'color' => '#ec4899'),
);

$assignBase = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('_query' => array('panel' => 'assign_learner')));
?>
<div class="rm-wrap">
    <!-- Page header -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h2 class="rm-title" style="margin:0"><?php echo $this->__($_pageTitle) ?></h2>
        <a href="<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('_query' => array('panel' => 'create_class'))) ?>"
           style="padding:8px 18px;background:#2563eb;color:#fff !important;border:none;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none !important;white-space:nowrap;">+ Create Class</a>
    </div>

    <!-- Bucket tabs -->
    <div style="display:flex;gap:0;margin-bottom:20px;border-bottom:1px solid #1e293b;">
        <?php
        $tabs = array(
            'all'       => 'All Classes',
            'ongoing'   => 'Ongoing',
            'upcoming'  => 'Upcoming',
            'completed' => 'Completed',
        );
        foreach ($tabs as $_tb => $_tl):
            $_isActive = ($_tb === $_bucket);
        ?>
        <a href="<?php echo Mage::helper('adminhtml')->getUrl('adminhtml/classes/index', array('bucket' => $_tb)) ?>"
           style="padding:8px 16px;font-size:13px;font-weight:<?php echo $_isActive ? '600' : '400' ?>;color:<?php echo $_isActive ? '#60a5fa' : '#64748b' ?>;border-bottom:2px solid <?php echo $_isActive ? '#60a5fa' : 'transparent' ?>;text-decoration:none;margin-bottom:-1px;display:inline-block;"><?php echo $this->__($_tl) ?></a>
        <?php endforeach; ?>
    </div>

    <!-- Filters -->
    <div class="rm-filters">
        <div class="rm-search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" id="rm-search" placeholder="Search class ID, SKU, or course title..." oninput="rmFilter()" />
        </div>
        <select class="rm-select" id="rm-state-filter" onchange="rmFilter()">
            <option value="" <?php echo ($_bucket !== 'ongoing') ? 'selected' : '' ?>>All States</option>
            <option value="pending">Pending</option>
            <option value="confirmed" <?php echo ($_bucket === 'ongoing') ? 'selected' : '' ?>>Confirmed</option>
        </select>
    </div>

    <div style="overflow-x:auto;">
    <table class="rm-table" id="rm-table">
        <thead>
            <tr>
                <th>Class ID</th>
                <th>Course</th>
                <th>SKU</th>
                <th>Store</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Time</th>
                <th>Trainer</th>
                <th>Enrolled</th>
                <th>State</th>
                <th>Created By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        <?php foreach ($rows as $r):
            $classId   = (string) $r['class_id'];
            $storeCode = substr($classId, 0, 2);
            $sStyle    = isset($storeColors[$storeCode]) ? $storeColors[$storeCode] : array('bg'=>'rgba(100,116,139,.12)','color'=>'#94a3b8');
            $startStr  = $r['course_start_date'] ? date('d M Y', strtotime($r['course_start_date'])) : '—';
            $endStr    = $r['course_end_date']   ? date('d M Y', strtotime($r['course_end_date']))   : '—';
            $timeStr   = '';
            if (!empty($r['course_start_time']) && !empty($r['course_end_time'])) {
                $timeStr = date('H:i', strtotime($r['course_start_time'])) . '–' . date('H:i', strtotime($r['course_end_time']));
            }
            $trainerName = isset($trainerMap[(int)$r['trainer_option_id']]) ? $trainerMap[(int)$r['trainer_option_id']] : '';
            $state = ((int)$r['trainer_option_id'] > 0) ? 'confirmed' : 'pending';
            $stateColor = array(
                'pending'   => array('bg'=>'rgba(245,158,11,.15)', 'color'=>'#f59e0b'),
                'confirmed' => array('bg'=>'rgba(34,197,94,.15)',  'color'=>'#22c55e'),
            );
            $sc      = $stateColor[$state];
            $editUrl = $assignBase . '#class-' . $classId;
        ?>
            <tr class="rm-row"
                data-class-id="<?php echo strtolower($classId) ?>"
                data-sku="<?php echo strtolower(htmlspecialchars($r['course_sku'])) ?>"
                data-title="<?php echo strtolower(htmlspecialchars($r['course_title'])) ?>"
                data-store="<?php echo $storeCode ?>"
                data-state="<?php echo $state ?>">
                <td><span class="rm-name" style="font-variant-numeric:tabular-nums"><?php echo htmlspecialchars($classId) ?></span></td>
                <td><span class="rm-name"><?php echo htmlspecialchars($r['course_title']) ?></span></td>
                <td><span class="rm-email" style="font-variant-numeric:tabular-nums"><?php echo htmlspecialchars($r['course_sku']) ?></span></td>
                <td>
                    <?php if ($storeCode !== ''): ?>
                        <span class="rm-badge" style="background:<?php echo $sStyle['bg'] ?>;color:<?php echo $sStyle['color'] ?>;"><?php echo $storeCode ?></span>
                    <?php else: ?>
                        <span style="color:#475569">—</span>
                    <?php endif; ?>
                </td>
                <td><span class="rm-email" style="font-variant-numeric:tabular-nums"><?php echo $startStr ?></span></td>
                <td><span class="rm-email" style="font-variant-numeric:tabular-nums"><?php echo $endStr ?></span></td>
                <td><span class="rm-email" style="font-variant-numeric:tabular-nums"><?php echo $timeStr ?: '—' ?></span></td>
                <td><span class="rm-email"><?php echo $trainerName !== '' ? htmlspecialchars($trainerName) : '<span style="color:#475569">—</span>' ?></span></td>
                <td><span class="rm-name" style="font-variant-numeric:tabular-nums"><?php echo (int)$r['enrolled'] ?></span></td>
                <td><span class="rm-badge" style="background:<?php echo $sc['bg'] ?>;color:<?php echo $sc['color'] ?>;"><?php echo ucfirst($state) ?></span></td>
                <td><span class="rm-email" style="font-size:11px;"><?php echo !empty($r['created_by']) ? htmlspecialchars($r['created_by']) : '<span style="color:#475569">—</span>' ?></span></td>
                <td>
                    <div class="rm-actions">
                        <a href="<?php echo htmlspecialchars($editUrl) ?>" class="rm-icon rm-icon-edit" title="View roster" aria-label="View roster">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                    </div>
                </td>
            </tr>
        <?php endforeach; ?>
        <?php if (empty($rows)): ?>
            <tr><td colspan="12" style="padding:48px 12px;text-align:center;color:#64748b">
                <?php echo htmlspecialchars($_emptyMsg) ?>
            </td></tr>
        <?php endif; ?>
        </tbody>
    </table>
    </div>

    <div class="rm-pagination" id="rm-pagination">
        <div class="rm-pagination-summary" id="rm-pagination-summary"></div>
        <div class="rm-pagination-controls" id="rm-pagination-controls"></div>
    </div>
</div>

<script type="text/javascript">
var RM_PAGE_SIZE = 50;
var rmCurrentPage = 1;

function rmFilter(resetPage) {
    if (resetPage !== false) rmCurrentPage = 1;
    var q  = document.getElementById('rm-search').value.toLowerCase();
    var sf = document.getElementById('rm-state-filter').value;
    var rows = document.querySelectorAll('.rm-row');
    var matched = [];
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        var hay = (r.getAttribute('data-class-id') || '') + ' ' +
                  (r.getAttribute('data-sku') || '') + ' ' +
                  (r.getAttribute('data-title') || '');
        var matchQ = !q || hay.indexOf(q) >= 0;
        var matchS = !sf || r.getAttribute('data-state') === sf;
        if (matchQ && matchS) matched.push(r);
        else r.style.display = 'none';
    }
    var total  = matched.length;
    var pages  = Math.max(1, Math.ceil(total / RM_PAGE_SIZE));
    if (rmCurrentPage > pages) rmCurrentPage = pages;
    var start = (rmCurrentPage - 1) * RM_PAGE_SIZE;
    var end   = start + RM_PAGE_SIZE;
    for (var k = 0; k < matched.length; k++) {
        matched[k].style.display = (k >= start && k < end) ? '' : 'none';
    }
    rmRenderPagination(total, pages);
}

function rmGoToPage(p) { rmCurrentPage = p; rmFilter(false); }

function rmRenderPagination(total, pages) {
    var sum = document.getElementById('rm-pagination-summary');
    var ctl = document.getElementById('rm-pagination-controls');
    if (!sum || !ctl) return;
    if (total === 0) { sum.textContent = 'No classes'; ctl.innerHTML = ''; return; }
    var firstOfPage = (rmCurrentPage - 1) * RM_PAGE_SIZE + 1;
    var lastOfPage  = Math.min(rmCurrentPage * RM_PAGE_SIZE, total);
    sum.textContent = 'Showing ' + firstOfPage + '–' + lastOfPage + ' of ' + total;
    var html = '';
    var prevDisabled = rmCurrentPage <= 1     ? ' disabled' : '';
    var nextDisabled = rmCurrentPage >= pages ? ' disabled' : '';
    html += '<button class="rm-pagination-btn" onclick="rmGoToPage(' + (rmCurrentPage - 1) + ')"' + prevDisabled + '>&#8249;</button>';
    var shown = {};
    var toShow = [1, pages, rmCurrentPage, rmCurrentPage - 1, rmCurrentPage + 1].filter(function(n){ return n >= 1 && n <= pages; });
    toShow.sort(function(a, b){ return a - b; });
    var last = 0;
    for (var i = 0; i < toShow.length; i++) {
        var n = toShow[i];
        if (shown[n]) continue;
        if (last && n - last > 1) html += '<span class="rm-pagination-ellipsis">…</span>';
        var active = n === rmCurrentPage ? ' active' : '';
        html += '<button class="rm-pagination-btn' + active + '" onclick="rmGoToPage(' + n + ')">' + n + '</button>';
        shown[n] = true; last = n;
    }
    html += '<button class="rm-pagination-btn" onclick="rmGoToPage(' + (rmCurrentPage + 1) + ')"' + nextDisabled + '>&#8250;</button>';
    ctl.innerHTML = html;
}

(function() { rmFilter(); })();
</script>
