 * Links directly to set/4/type/simple to bypass the type-selection wizard.
 * Only visible in MMS country mode (GH/MY/NG etc.) for M-prefix courses;
 * on the SG instance it is suppressed because courses come from the catalog.
 */
$_isSg = strtolower((string) getenv('MMS_MODE')) !== 'country';
?>
