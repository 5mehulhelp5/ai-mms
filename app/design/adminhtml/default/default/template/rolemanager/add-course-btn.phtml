    <button class="scalable add" type="button"
            onclick="setLocation('<?php echo $this->getUrl('adminhtml/catalog_product/new', array('set' => 4, 'type' => 'simple')) ?>')">
        <span><span><span><?php echo $this->__('Add Course') ?></span></span></span>
    </button>
</div>
