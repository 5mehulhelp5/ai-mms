    <script>
    var TI_PULL_URL='<?php echo $this->jsQuoteEscape($_tiPullUrl) ?>';
    var TI_TOGGLE_URL='<?php echo $this->jsQuoteEscape($_tiToggleUrl) ?>';
    var TI_CFG_URL='<?php echo $this->jsQuoteEscape($_tiCfgUrl) ?>';
    var TI_FORM_KEY='<?php echo $this->jsQuoteEscape($formKey) ?>';
    function tiStatus(msg, ok){ var s=document.getElementById('ti-status'); if(!s)return; s.style.color = ok===true?'#22c55e':(ok===false?'#f87171':'#64748b'); s.textContent=msg||''; }
    function tiSaveConfig(btn){
        var url=document.getElementById('ti-url').value.trim();
        var key=document.getElementById('ti-key').value;
        btn.disabled=true; tiStatus('Saving…');
        var fd=new FormData(); fd.append('lms_url',url); fd.append('api_key',key); fd.append('form_key',TI_FORM_KEY);
        fetch(TI_CFG_URL,{method:'POST',body:fd,credentials:'same-origin'}).then(function(r){return r.json();}).then(function(d){
            btn.disabled=false; tiStatus((d.success?'✓ ':'✗ ')+(d.message||''), d.success);
            if(d.success){ document.getElementById('ti-key').value=''; }
        }).catch(function(){ btn.disabled=false; tiStatus('✗ Network error', false); });
    }
    function tiPull(btn){
        if(!confirm('Pull trainers from LMS now? This creates/updates accounts and roles in MMS.')) return;
        btn.disabled=true; var orig=btn.textContent; btn.textContent='Pulling…'; tiStatus('Contacting LMS…');
        var fd=new FormData(); fd.append('form_key',TI_FORM_KEY);
        fetch(TI_PULL_URL,{method:'POST',body:fd,credentials:'same-origin'}).then(function(r){return r.json();}).then(function(d){
            btn.disabled=false; btn.textContent=orig;
            tiStatus((d.success?'✓ ':'✗ ')+(d.message||''), d.success);
        }).catch(function(){ btn.disabled=false; btn.textContent=orig; tiStatus('✗ Network error', false); });
    }
    var _tiSpin=null,_tiRes=null;
    function tiSpinStart(){var el=document.getElementById('ti-spinner');if(!el)return;if(_tiRes){clearTimeout(_tiRes);_tiRes=null;}el.style.color='#60a5fa';var f=['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'],i=0;el.textContent=f[0];_tiSpin=setInterval(function(){i=(i+1)%f.length;el.textContent=f[i];},80);}
    function tiSpinStop(){if(_tiSpin){clearInterval(_tiSpin);_tiSpin=null;}}
    function tiSpinResult(ok){var el=document.getElementById('ti-spinner');if(!el)return;el.textContent=ok?'✓':'✗';el.style.color=ok?'#22c55e':'#ef4444';_tiRes=setTimeout(function(){el.textContent='';el.style.color='#60a5fa';},2500);}
    function tiToggle(cb){
        var val=cb.checked?1:0; cb.checked=(val===0);
        if(val===1 && !confirm('Enable the daily automatic trainer pull from LMS?')) return;
        cb.disabled=true; tiSpinStart();
        var fd=new FormData(); fd.append('value',val); fd.append('form_key',TI_FORM_KEY);
        fetch(TI_TOGGLE_URL,{method:'POST',body:fd,credentials:'same-origin'}).then(function(r){return r.json();}).then(function(d){
            cb.disabled=false; tiSpinStop();
            if(!d.success){ tiSpinResult(false); tiStatus('✗ '+(d.message||'Failed'),false); return; }
            cb.checked=(d.value===1); cb.closest('.dcf-toggle-sw').setAttribute('title', d.value===1?'Auto-pull ON':'Auto-pull OFF');
            tiSpinResult(true);
        }).catch(function(){ cb.disabled=false; tiSpinStop(); tiSpinResult(false); });
    }
    </script>
