$rows = $read->fetchAll("
    SELECT u.user_id, u.firstname, u.lastname, u.email, u.tel, u.is_active, u.created,
           GROUP_CONCAT(r.role_code ORDER BY r.role_code) as roles
    FROM {$userTable} u
    LEFT JOIN {$roleTable} r ON u.user_id = r.user_id
    GROUP BY u.user_id
    ORDER BY u.firstname
");

// Storefront-registered customers also surface here as learners. They live in
// customer_entity (EAV) — pull firstname/lastname via the two customer_entity_varchar
// rows whose attribute_codes are 'firstname'/'lastname'. Sorted by created_at DESC
// so the most recent learners appear first; pagination handles the long tail.
// Use literal table names — customer EAV doesn't expose a 'customer/entity_varchar'
// model alias in this OpenMage install (only 'customer/entity'). getTableName()
// passes literal strings through unchanged so this is portable and prefix-safe.
$customerTable = $resource->getTableName('customer_entity');
$customerVarchar = $resource->getTableName('customer_entity_varchar');
$eavAttr = $resource->getTableName('eav_attribute');
$eavType = $resource->getTableName('eav_entity_type');
$attrFirstId = (int) $read->fetchOne(
    "SELECT a.attribute_id FROM {$eavAttr} a INNER JOIN {$eavType} t ON t.entity_type_id=a.entity_type_id WHERE t.entity_type_code='customer' AND a.attribute_code='firstname'"
);
$attrLastId = (int) $read->fetchOne(
    "SELECT a.attribute_id FROM {$eavAttr} a INNER JOIN {$eavType} t ON t.entity_type_id=a.entity_type_id WHERE t.entity_type_code='customer' AND a.attribute_code='lastname'"
);
$customers = array();
if ($attrFirstId && $attrLastId) {
    $customers = $read->fetchAll("
        SELECT ce.entity_id AS customer_id,
               fn.value AS firstname,
               ln.value AS lastname,
               ce.email,
               ce.created_at,
               ce.is_active,
               ce.store_id
        FROM {$customerTable} ce
        LEFT JOIN {$customerVarchar} fn ON fn.entity_id = ce.entity_id AND fn.attribute_id = {$attrFirstId}
        LEFT JOIN {$customerVarchar} ln ON ln.entity_id = ce.entity_id AND ln.attribute_id = {$attrLastId}
        ORDER BY ce.created_at DESC
    ");
}

// Map store_id → country code in one shot so the per-row lookup stays cheap.
$storeRows = $read->fetchAll("SELECT store_id, code FROM " . $resource->getTableName('core/store'));
$storeIdToCode = array();
foreach ($storeRows as $sr) {
    // Magento store codes here are like 'default','sg','my','gh','ng','bt','in'.
    // Normalise to upper-case 2-letter country code. The default SG store is
    // commonly code='default' in this install.
    $c = strtoupper((string)$sr['code']);
    if ($c === 'DEFAULT' || $c === 'SG') $c = 'SG';
    if (in_array($c, array('SG','MY','GH','NG','BT','IN'), true)) {
        $storeIdToCode[(int)$sr['store_id']] = $c;
    }
}
