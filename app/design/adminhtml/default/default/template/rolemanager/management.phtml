<?php
$resource = Mage::getSingleton('core/resource');
$read = $resource->getConnection('core_read');
$userTable = $resource->getTableName('admin/user');
$roleTable = $resource->getTableName('mmd_user_role_map');
$currentUserId = Mage::getSingleton('admin/session')->getUser()->getId();
$formKey = Mage::getSingleton('core/session')->getFormKey();

$rows = $read->fetchAll("
    SELECT u.user_id, u.firstname, u.lastname, u.email, u.is_active, u.created,
           GROUP_CONCAT(r.role_code ORDER BY r.role_code) as roles
    FROM {$userTable} u
    LEFT JOIN {$roleTable} r ON u.user_id = r.user_id
    GROUP BY u.user_id
    ORDER BY u.firstname
");

$totalUsers = count($rows);
$activeUsers = 0;
$multiRoleUsers = 0;
foreach ($rows as $r) {
    if ($r['is_active']) $activeUsers++;
    $rc = $r['roles'] ? explode(',', $r['roles']) : array();
    if (count($rc) >= 3) $multiRoleUsers++;
}

$helper = Mage::helper('mmd_rolemanager');
$allRoles = $helper->getAllRoles();
$saveUrl = Mage::helper('adminhtml')->getUrl('adminhtml/rolemanagement/save');
