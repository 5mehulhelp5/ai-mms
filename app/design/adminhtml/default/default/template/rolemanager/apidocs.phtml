<script>
function apiDocsToggleKey() {
    var el = document.getElementById('apikey-value');
    var btn = el.parentElement.querySelector('.reveal-toggle');
    if (el.getAttribute('data-revealed') === '1') {
        el.textContent = '<?php echo addslashes($apiKeyMasked); ?>';
        el.setAttribute('data-revealed', '0');
        btn.textContent = 'Reveal';
    } else {
        el.textContent = el.getAttribute('data-full');
        el.setAttribute('data-revealed', '1');
        btn.textContent = 'Hide';
    }
}
function apiDocsCopyKey() {
    var el = document.getElementById('apikey-value');
    var full = el.getAttribute('data-full');
    if (!full) return;
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(full).then(function () {
            var btn = el.parentElement.querySelectorAll('button')[1];
            var orig = btn.textContent;
            btn.textContent = 'Copied ✓';
            setTimeout(function () { btn.textContent = orig; }, 1500);
        });
    } else {
        var ta = document.createElement('textarea');
        ta.value = full;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (e) {}
        document.body.removeChild(ta);
    }
}
</script>
