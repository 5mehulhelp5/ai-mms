<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Select Role - Tertiary Infotech Academy</title>
    <link rel="icon" href="<?php echo $logoUrl ?>" type="image/png" />
</head>
<body>
    <div class="role-select-card">
        <div class="rs-logo">
            <img src="<?php echo $logoUrl ?>" alt="Tertiary Infotech Academy" />
        </div>
        <h1 class="rs-title">Tertiary Infotech Academy</h1>
        <p class="rs-subtitle">Magento Management System</p>

        <p class="rs-welcome">Welcome back, <?php echo htmlspecialchars($fullName) ?>!</p>
        <p class="rs-instruction">You have access to multiple roles. Please select one to continue:</p>

        <?php foreach ($roles as $roleCode): ?>
