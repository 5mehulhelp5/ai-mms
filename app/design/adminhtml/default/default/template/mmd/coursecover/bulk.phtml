<script>
(function () {
    var listUrl    = <?php echo json_encode($_listUrl) ?>;
    var runUrl     = <?php echo json_encode($_runUrl) ?>;
    var refreshUrl = <?php echo json_encode($_refreshUrl) ?>;
    var formKey = (window.FORM_KEY || '');
    var badgeDefaultsByWebsite = <?php echo json_encode($_badgeDefaultsByWebsite, JSON_UNESCAPED_SLASHES) ?>;

    var els = {
        store:    document.getElementById('bac-store'),
        wsq:      document.getElementById('bac-wsq'),
        missing:  document.getElementById('bac-missing'),
        skuPref:  document.getElementById('bac-sku-prefix'),
        keyword:  document.getElementById('bac-keyword'),
        findBtn:  document.getElementById('bac-find-btn'),
        runBtn:   document.getElementById('bac-run-btn'),
        stopBtn:  document.getElementById('bac-stop-btn'),
        summary:  document.getElementById('bac-summary'),
        card:     document.getElementById('bac-results-card'),
        tbody:    document.getElementById('bac-tbody'),
        selAll:   document.getElementById('bac-select-all'),
    };

    var state = { items: [], running: false, stopRequested: false };

    function badges() {
        var out = [];
        document.querySelectorAll('.bac-badge:checked').forEach(function (cb) { out.push(cb.value); });
        return out;
    }

    // When the store dropdown changes, re-check the badges that match the
    // selected website's country defaults (SG → WSQ/MCES/UTAP, MY → HRDF,
    // others → none). Avoids the admin having to retick by hand.
    function applyBadgeDefaultsForCurrentStore() {
        var opt = els.store.options[els.store.selectedIndex];
        var code = opt ? (opt.getAttribute('data-website-code') || '') : '';
        var defaults = badgeDefaultsByWebsite[code] || [];
        document.querySelectorAll('.bac-badge').forEach(function (cb) {
            cb.checked = defaults.indexOf(cb.value) !== -1;
        });
    }
    els.store.addEventListener('change', applyBadgeDefaultsForCurrentStore);

    // Refresh storefront button — POST to /coursecover/refreshStorefront.
    // Fire-and-await: button stays disabled while the reindex runs so the
    // admin can't queue a second concurrent flat rebuild.
    var refreshBtn = document.getElementById('bac-refresh-btn');
    var refreshMsg = document.getElementById('bac-refresh-msg');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', function () {
            if (!confirm('Rebuild the catalog flat index and flush block/FPC caches?\nThis publishes any pending course_image_url changes to the storefront.')) return;
            var origLabel = refreshBtn.textContent;
            refreshBtn.disabled = true;
            refreshBtn.textContent = 'Refreshing…';
            refreshMsg.textContent = 'Reindexing flat catalog (this may take 30–60s)…';

            var fd = new FormData();
            fd.append('form_key', formKey);

            fetch(refreshUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d.ok) {
                        refreshMsg.textContent = 'Done. ' + (d.messages || []).join(' · ');
                    } else {
                        refreshMsg.textContent = 'Failed: ' + (d.error || 'unknown error');
                    }
                })
                .catch(function (e) { refreshMsg.textContent = 'Network error: ' + e.message; })
                .then(function () {
                    refreshBtn.disabled = false;
                    refreshBtn.textContent = origLabel;
                });
        });
    }

    function updateRunBtn() {
        var n = document.querySelectorAll('.bac-row-check:checked').length;
        els.runBtn.disabled = (n === 0 || state.running);
        els.runBtn.textContent = 'Run on selected (' + n + ')';
    }

    els.findBtn.addEventListener('click', function () {
        var url = listUrl
            + (listUrl.indexOf('?') === -1 ? '?' : '&')
            + 'store_id=' + encodeURIComponent(els.store.value)
            + '&wsq_only=' + (els.wsq.checked ? 1 : 0)
            + '&missing_only=' + (els.missing.checked ? 1 : 0)
            + '&sku_prefix=' + encodeURIComponent(els.skuPref.value.trim())
            + '&keyword=' + encodeURIComponent(els.keyword.value.trim());

        els.findBtn.disabled = true;
        els.summary.textContent = 'Searching…';

        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.ok) throw new Error(d.error || 'unknown error');
                state.items = d.items;
                renderRows();
                els.summary.textContent = 'Found ' + d.count + ' product' + (d.count === 1 ? '' : 's') + '.';
                els.card.style.display = d.count > 0 ? '' : 'none';
            })
            .catch(function (e) { els.summary.textContent = 'Error: ' + e.message; })
            .then(function () { els.findBtn.disabled = false; });
    });

    function renderRows() {
        els.tbody.innerHTML = '';
        state.items.forEach(function (it) {
            var tr = document.createElement('tr');
            tr.dataset.id = String(it.id);
            tr.innerHTML =
                '<td><input type="checkbox" class="bac-row-check" checked /></td>' +
                '<td>' + it.id + '</td>' +
                '<td><code>' + escapeHtml(it.sku) + '</code></td>' +
                '<td>' + escapeHtml(it.name) + '</td>' +
                '<td><span class="bac-status pending">pending</span></td>';
            els.tbody.appendChild(tr);
        });
        updateRunBtn();
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
            return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
        });
    }

    els.selAll.addEventListener('change', function () {
        document.querySelectorAll('.bac-row-check').forEach(function (cb) { cb.checked = els.selAll.checked; });
        updateRunBtn();
    });
    els.tbody.addEventListener('change', function (e) {
        if (e.target.classList.contains('bac-row-check')) updateRunBtn();
    });

    els.stopBtn.addEventListener('click', function () {
        state.stopRequested = true;
        els.stopBtn.disabled = true;
        els.stopBtn.textContent = 'Stopping…';
    });

    els.runBtn.addEventListener('click', function () {
        if (state.running) return;
        var selected = [];
        document.querySelectorAll('.bac-row-check:checked').forEach(function (cb) {
            selected.push(parseInt(cb.closest('tr').dataset.id, 10));
        });
        if (!selected.length) return;
        if (!confirm('Generate covers for ' + selected.length + ' product' + (selected.length === 1 ? '' : 's') + '? This writes course_image_url on each.')) return;

        state.running = true;
        state.stopRequested = false;
        els.runBtn.disabled = true;
        els.findBtn.disabled = true;
        els.stopBtn.style.display = '';
        els.stopBtn.disabled = false;
        els.stopBtn.textContent = 'Stop';

        var b = badges();
        var ok = 0, fail = 0, i = 0;

        function next() {
            if (state.stopRequested || i >= selected.length) return finish();
            var id = selected[i++];
            var row = els.tbody.querySelector('tr[data-id="' + id + '"]');
            var statusEl = row ? row.querySelector('.bac-status') : null;
            if (statusEl) { statusEl.className = 'bac-status running'; statusEl.textContent = 'rendering…'; }

            var fd = new FormData();
            fd.append('product_id', String(id));
            fd.append('store_id', String(els.store.value));
            fd.append('form_key', formKey);
            b.forEach(function (v) { fd.append('badges[]', v); });

            fetch(runUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d.ok) {
                        ok++;
                        if (row) row.classList.add('done');
                        if (statusEl) { statusEl.className = 'bac-status done'; statusEl.textContent = 'done'; }
                    } else {
                        fail++;
                        if (row) row.classList.add('fail');
                        if (statusEl) { statusEl.className = 'bac-status fail'; statusEl.textContent = (d.error || 'failed').slice(0, 60); }
                    }
                })
                .catch(function (e) {
                    fail++;
                    if (row) row.classList.add('fail');
                    if (statusEl) { statusEl.className = 'bac-status fail'; statusEl.textContent = e.message.slice(0, 60); }
                })
                .then(function () {
                    els.summary.textContent = 'Progress: ' + (ok + fail) + ' / ' + selected.length
                        + '  (ok ' + ok + ', fail ' + fail + ')';
                    next();
                });
        }

        function finish() {
            state.running = false;
            els.runBtn.disabled = false;
            els.findBtn.disabled = false;
            els.stopBtn.style.display = 'none';
            updateRunBtn();
            var note = state.stopRequested ? ' — stopped by user' : '';
            els.summary.textContent = 'Finished: ok ' + ok + ', fail ' + fail + note + '.';
        }

        next();
    });
})();
</script>
