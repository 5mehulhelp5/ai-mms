<?php
/**
 * Bulk AI Course Cover Generator
 *
 * Super-admin tool: regenerate course-cover PNGs for many products at once,
 * scoped to a single Magento store. Nothing runs automatically — the admin
 * picks the store + filters, clicks "Find matches" to see the candidate
 * list, then "Run on selected" to process row-by-row via AJAX so the user
 * can watch progress and abort.
 *
 * Endpoints used:
 *   GET  tigerdragon/coursecover/bulkList   — return candidate products as JSON
 *   POST tigerdragon/coursecover/bulkRun    — render+upload+save ONE product
 */
$_listUrl    = Mage::helper('adminhtml')->getUrl('adminhtml/coursecover/bulkList');
$_runUrl     = Mage::helper('adminhtml')->getUrl('adminhtml/coursecover/bulkRun');
$_refreshUrl = Mage::helper('adminhtml')->getUrl('adminhtml/coursecover/refreshStorefront');

$_ciHelper = Mage::helper('mmd_courseimage');
$_stores   = [];
foreach (Mage::app()->getStores() as $_s) {
    $_stores[] = [
        'id'           => (int) $_s->getId(),
        'website'      => $_s->getWebsite()->getName(),
        'website_code' => $_s->getWebsite()->getCode(),
        'code'         => $_s->getCode(),
        'name'         => $_s->getName(),
    ];
}
// Singapore = base website default store view. Pre-select it.
$_defaultStoreId = 1;

$_badges = $_ciHelper->getAllBadges();

// Per-website defaults exported to JS so toggling the store dropdown
// re-checks the appropriate badges client-side.
$_badgeDefaultsByWebsite = [];
foreach ($_stores as $_st) {
    $_badgeDefaultsByWebsite[$_st['website_code']] = $_ciHelper->getDefaultBadgesForWebsite($_st['website_code']);
}
$_defaultChecked = $_ciHelper->getDefaultBadgesForWebsite('base');
?>
