                        <label class="bac-check" for="<?php echo $_id ?>">
                            <input type="checkbox" id="<?php echo $_id ?>" class="bac-badge" value="<?php echo htmlspecialchars($_b) ?>" <?php echo in_array($_b, $_defaultChecked, true) ? 'checked' : '' ?> />
