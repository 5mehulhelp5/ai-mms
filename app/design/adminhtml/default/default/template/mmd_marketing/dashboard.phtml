/**
 * Marketing Dashboard — relocated from the admin master dashboard.
 *
 * Hosts four marketing-relevant cards: Most Popular Courses (by views),
 * Top Revenue Courses, Latest 20 Search Terms, Top 20 Popular Search Terms.
 * Phase C will add MailerLite KPIs and the subscriber growth chart.
 *
 * Phase A intentionally DUPLICATES the SQL + markup from the admin
 * dashboard (template/dashboard/index.phtml lines 575-675 + 1865-1953)
 * so this page can ship without touching the admin dashboard at all.
 * Phase B removes the duplicates from index.phtml once this page is
 * verified live.
 *
 * The CSS classes (.dash-summary-*) are defined in
 * skin/adminhtml/default/default/admin-dashboard.css and loaded by our
 * layout XML on the adminhtml_mmd_marketing_dashboard_index handle.
 */

$resource = Mage::getSingleton('core/resource');
$read     = $resource->getConnection('core_read');
$write    = $resource->getConnection('core_write');

// product_name attribute_id (admin store fallback). 71 is the historical
// Magento default; verified live in this project.
$nameAid = 71;

// External-link icon (clicks through to the admin product / search-term edit page).
$_extIcon = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';

// Phase A decision: no per-country scoping yet — show all-store totals.
// Phase C can wire the country chip row.
$_adminWid = 0;
$_admStoreWhere = '';
$_admSearchStoreWhere = '';
$_viewStoreWhere = '';
$_admSalesStoreWhere = 'WHERE';

// ---- Latest 20 Search Terms ----
$_admDashRecentSearches = $read->fetchAll("
    SELECT query_id, query_text, num_results, popularity, updated_at, store_id
    FROM catalogsearch_query
    {$_admSearchStoreWhere}
    ORDER BY updated_at DESC
    LIMIT 20
");

// ---- Top 20 Popular Search Terms ----
$_admDashTopSearches = $read->fetchAll("
    SELECT query_id, query_text, popularity, num_results, store_id
    FROM catalogsearch_query
    {$_admSearchStoreWhere}
    ORDER BY popularity DESC, query_text ASC
    LIMIT 20
");

// ---- Most Popular Courses (by views) — from report_event event_type_id=1 ----
$_admDashTopCourses = $read->fetchAll("
    SELECT re.object_id AS product_id, p.sku,
           COALESCE(vname.value, CONCAT('Product #', re.object_id)) AS name,
           COUNT(*) AS views
    FROM report_event re
    LEFT JOIN catalog_product_entity p ON p.entity_id=re.object_id
    LEFT JOIN catalog_product_entity_varchar vname
           ON vname.entity_id=re.object_id
          AND vname.attribute_id={$nameAid}
          AND vname.store_id=0
    WHERE re.event_type_id=1
    GROUP BY re.object_id
    ORDER BY views DESC
    LIMIT 10
");

// ---- Top Revenue Courses — SUM(row_total) per product, all-time, non-cancelled ----
$_admDashTopRevenue = $read->fetchAll("
    SELECT oi.product_id, MAX(oi.name) AS name,
           SUM(oi.row_total) AS revenue, SUM(oi.qty_ordered) AS qty
    FROM sales_flat_order_item oi
    INNER JOIN sales_flat_order o ON oi.order_id=o.entity_id AND o.state NOT IN ('canceled','holded')
    WHERE (oi.parent_item_id IS NULL)
    GROUP BY oi.product_id
    ORDER BY revenue DESC
    LIMIT 10
");

// ---- MailerLite KPIs (cached 5 min in core/cache) ----
$_mlSubsSG    = null;
$_mlSubsMY    = null;
$_mlCampSent  = null;
$_mlNextCamp  = null;
$_mlConfigured = false;
try {
    /** @var MMD_Marketing_Helper_Mailerlite $ml */
    $ml = Mage::helper('mmd_marketing/mailerlite');
    if ($ml->isConfigured()) {
        $_mlConfigured = true;
        $_mlSubsSG    = $ml->getSubscribersSG();
        $_mlSubsMY    = $ml->getSubscribersMY();
        $_mlCampSent  = $ml->getCampaignsSentLast30Days();
        $_mlNextCamp  = $ml->getNextCampaign();
    }
} catch (Exception $e) {
    Mage::logException($e);
}

// ---- Auto-Newsletter schedule + recent campaigns (SG-scoped for v1) ----
// Reads from `core_config_data` for the schedule + the `newsletters` table
// for the campaign list. Analytics (open / click rate) are served from
// cached columns; rows older than 10 min trigger a live MailerLite fetch
// inline so the dashboard stays fresh without a manual refresh.
$_anSched = array(
    'enabled'          => (int)    Mage::getStoreConfig('mmd_marketing/auto_newsletter/enabled'),
    'day_of_week'      => (int)    Mage::getStoreConfig('mmd_marketing/auto_newsletter/day_of_week'),
    'hour'             => (int)    Mage::getStoreConfig('mmd_marketing/auto_newsletter/hour'),
    'send_delay_hours' => (int)    Mage::getStoreConfig('mmd_marketing/auto_newsletter/send_delay_hours'),
    'country_code'     => (string) Mage::getStoreConfig('mmd_marketing/auto_newsletter/country_code'),
);
$_anDayLabels  = array(1=>'Monday',2=>'Tuesday',3=>'Wednesday',4=>'Thursday',5=>'Friday',6=>'Saturday',7=>'Sunday');
$_anDayLabel   = isset($_anDayLabels[$_anSched['day_of_week']]) ? $_anDayLabels[$_anSched['day_of_week']] : '—';
$_anHourLabel  = sprintf('%02d:00', $_anSched['hour']);
$_anNextDelta  = '';
try {
    $now    = new DateTime('now');
    $target = new DateTime('now');
    $target->setTime($_anSched['hour'], 0);
    $todayIso  = (int) $now->format('N');
    $daysAhead = ($_anSched['day_of_week'] - $todayIso + 7) % 7;
    if ($daysAhead === 0 && $now > $target) $daysAhead = 7;
    $target->modify('+' . $daysAhead . ' days');
    $diff = $now->diff($target);
    $bits = array();
    if ($diff->d > 0) $bits[] = $diff->d . 'd';
    if ($diff->h > 0) $bits[] = $diff->h . 'h';
    if (!$bits)       $bits[] = max(1, $diff->i) . 'm';
    $_anNextDelta = 'in ' . implode(' ', array_slice($bits, 0, 2));
} catch (Exception $e) {
    $_anNextDelta = '';
}

$_anCampaigns = array();
try {
    $_newsletterTable = $resource->getTableName('newsletters');
    $_anCampaigns = $read->fetchAll(
        "SELECT newsletter_id, title, subject, status, mailerlite_id, is_auto, "
      . "       scheduled_send_at, analytics_open_rate, analytics_click_rate, "
      . "       analytics_synced_at, created_at "
      . "FROM {$_newsletterTable} "
      . "WHERE country_code = 'SG' "
      . "ORDER BY created_at DESC LIMIT 10"
    );
    // Lazy-sync rows whose analytics are stale (>10 min) or missing. Only
    // touches MailerLite when we actually need to refresh — costs at most
    // 1 round-trip per stale row, throttled by the helper's own cache.
    if ($_mlConfigured) {
        $now = time();
        foreach ($_anCampaigns as $i => $row) {
            $mlid = (string) $row['mailerlite_id'];
            if ($mlid === '' || strpos($mlid, 'STUB-') === 0) continue;
            $syncedTs = $row['analytics_synced_at'] ? strtotime($row['analytics_synced_at']) : 0;
            if ($syncedTs && ($now - $syncedTs) < 600) continue;
            $stats = $ml->getCampaignAnalytics($mlid);
            if (!$stats) continue;
            $write->update($_newsletterTable, array(
                'analytics_opens'      => $stats['opens'],
                'analytics_clicks'     => $stats['clicks'],
                'analytics_open_rate'  => $stats['open_rate'],
                'analytics_click_rate' => $stats['click_rate'],
                'analytics_synced_at'  => date('Y-m-d H:i:s'),
            ), array('newsletter_id = ?' => (int) $row['newsletter_id']));
            $_anCampaigns[$i]['analytics_open_rate']  = $stats['open_rate'];
            $_anCampaigns[$i]['analytics_click_rate'] = $stats['click_rate'];
        }
    }
} catch (Exception $e) {
    Mage::logException($e);
}

// ---- Leads KPIs (real data from mmd_lead) ----
// Wrapped so the dashboard never fatals if the leads module isn't installed
// (e.g. on a fresh DB before migrations 114 land).
$_mktLeadsTotal     = 0;
$_mktLeadsLast30d   = 0;
$_mktLeadsByStore   = array();
try {
    $_leadsTable = $resource->getTableName('mmd_leads/lead');
    $_mktLeadsTotal   = (int) $read->fetchOne("SELECT COUNT(*) FROM {$_leadsTable}");
    $_mktLeadsLast30d = (int) $read->fetchOne("SELECT COUNT(*) FROM {$_leadsTable} WHERE created_at >= (NOW() - INTERVAL 30 DAY)");
    $_mktLeadsByStore = $read->fetchAll("SELECT COALESCE(NULLIF(store_code,''),'admin') AS store_code, COUNT(*) AS n FROM {$_leadsTable} GROUP BY store_code ORDER BY n DESC");
} catch (Exception $e) {
    // mmd_lead table not present yet — leave KPIs at zero.
}
