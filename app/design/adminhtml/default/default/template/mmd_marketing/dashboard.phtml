/**
 * Marketing Dashboard — relocated from the admin master dashboard.
 *
 * Hosts four marketing-relevant cards: Most Popular Courses (by views),
 * Top Revenue Courses, Latest 20 Search Terms, Top 20 Popular Search Terms.
 * Phase C will add MailerLite KPIs and the subscriber growth chart.
 *
 * Phase A intentionally DUPLICATES the SQL + markup from the admin
 * dashboard (template/dashboard/index.phtml lines 575-675 + 1865-1953)
 * so this page can ship without touching the admin dashboard at all.
 * Phase B removes the duplicates from index.phtml once this page is
 * verified live.
 *
 * The CSS classes (.dash-summary-*) are defined in
 * skin/adminhtml/default/default/admin-dashboard.css and loaded by our
 * layout XML on the adminhtml_mmd_marketing_dashboard_index handle.
 */

$resource = Mage::getSingleton('core/resource');
$read     = $resource->getConnection('core_read');

// product_name attribute_id (admin store fallback). 71 is the historical
// Magento default; verified live in this project.
$nameAid = 71;

// External-link icon (clicks through to the admin product / search-term edit page).
$_extIcon = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';

// Phase A decision: no per-country scoping yet — show all-store totals.
// Phase C can wire the country chip row.
$_adminWid = 0;
$_admStoreWhere = '';
$_admSearchStoreWhere = '';
$_viewStoreWhere = '';
$_admSalesStoreWhere = 'WHERE';

// ---- Latest 20 Search Terms ----
$_admDashRecentSearches = $read->fetchAll("
    SELECT query_id, query_text, num_results, popularity, updated_at, store_id
    FROM catalogsearch_query
    {$_admSearchStoreWhere}
    ORDER BY updated_at DESC
    LIMIT 20
");

// ---- Top 20 Popular Search Terms ----
$_admDashTopSearches = $read->fetchAll("
    SELECT query_id, query_text, popularity, num_results, store_id
    FROM catalogsearch_query
    {$_admSearchStoreWhere}
    ORDER BY popularity DESC, query_text ASC
    LIMIT 20
");

// ---- Most Popular Courses (by views) — from report_event event_type_id=1 ----
$_admDashTopCourses = $read->fetchAll("
    SELECT re.object_id AS product_id, p.sku,
           COALESCE(vname.value, CONCAT('Product #', re.object_id)) AS name,
           COUNT(*) AS views
    FROM report_event re
    LEFT JOIN catalog_product_entity p ON p.entity_id=re.object_id
    LEFT JOIN catalog_product_entity_varchar vname
           ON vname.entity_id=re.object_id
          AND vname.attribute_id={$nameAid}
          AND vname.store_id=0
    WHERE re.event_type_id=1
    GROUP BY re.object_id
    ORDER BY views DESC
    LIMIT 10
");

// ---- Top Revenue Courses — SUM(row_total) per product, all-time, non-cancelled ----
$_admDashTopRevenue = $read->fetchAll("
    SELECT oi.product_id, MAX(oi.name) AS name,
           SUM(oi.row_total) AS revenue, SUM(oi.qty_ordered) AS qty
    FROM sales_flat_order_item oi
    INNER JOIN sales_flat_order o ON oi.order_id=o.entity_id AND o.state NOT IN ('canceled','holded')
    WHERE (oi.parent_item_id IS NULL)
    GROUP BY oi.product_id
    ORDER BY revenue DESC
    LIMIT 10
");
?>
