    <script>
    (function(){
        var fireBtn = document.getElementById('mmd-mkt-fire-btn');
        var refBtn  = document.getElementById('mmd-mkt-refresh-btn');
        function busy(btn, on, label) {
            btn.disabled = on;
            btn.style.opacity = on ? '.55' : '1';
            btn.style.cursor  = on ? 'wait' : 'pointer';
            if (label) btn.textContent = label;
        }
        function post(url, onDone) {
            var fd = new FormData();
            fd.append('form_key', window.FORM_KEY || '<?php echo Mage::getSingleton('core/session')->getFormKey() ?>');
            return fetch(url, { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function(r){ return r.json().catch(function(){ return { success:false, message:'invalid response' }; }); });
        }
        if (fireBtn) {
            fireBtn.addEventListener('click', function(){
                if (!confirm('Fire the auto-newsletter scheduler now? This picks a random SG course, generates a draft, and pushes to MailerLite. Skip the day/hour gate.')) return;
                var orig = fireBtn.textContent;
                busy(fireBtn, true, 'Firing…');
                post('<?php echo $_fireUrl ?>').then(function(j){
                    busy(fireBtn, false, orig);
                    if (j && j.success) {
                        alert('Scheduler fired. Newsletter ID: ' + (j.newsletter_id || '?') + '\nReload the page to see it in the table.');
                        setTimeout(function(){ window.location.reload(); }, 600);
                    } else {
                        alert('Failed: ' + ((j && j.message) || 'unknown error'));
                    }
                }).catch(function(err){
                    busy(fireBtn, false, orig);
                    alert('Network error: ' + err.message);
                });
            });
        }
        if (refBtn) {
            refBtn.addEventListener('click', function(){
                var orig = refBtn.textContent;
                busy(refBtn, true, 'Refreshing…');
                post('<?php echo $_refUrl ?>').then(function(j){
                    busy(refBtn, false, orig);
                    if (j && j.success) {
                        alert('Analytics refreshed. Synced ' + (j.synced || 0) + ' of ' + (j.total || 0) + ' campaigns.');
                        setTimeout(function(){ window.location.reload(); }, 400);
                    } else {
                        alert('Failed: ' + ((j && j.message) || 'unknown error'));
                    }
                }).catch(function(err){
                    busy(refBtn, false, orig);
                    alert('Network error: ' + err.message);
                });
            });
        }
    })();
    </script>

