<script>
var FB_SAVE_URL  = '<?php echo $this->jsQuoteEscape($saveUrl) ?>';
var FB_LOAD_URL  = '<?php echo $this->jsQuoteEscape($loadUrl) ?>';
var FB_FORM_KEY  = window.FORM_KEY || '';
var fbState      = { title: '', sections: [] };
var fbPreviewOn  = true;
var FB_TYPES     = <?php echo json_encode($fieldTypes) ?>;
var FB_AUTOFILLS = <?php echo json_encode($autofills) ?>;
var FB_SAMPLES   = {
    course_title: 'Sample Course Title',
    course_code:  'TGS-XXXXXXXX',
    trainer_name: 'Dr. Trainer Name',
    start_date:   '15/01/2026',
    end_date:     '16/01/2026'
};

// ── Boot ────────────────────────────────────────────────────────────────────
fetch(FB_LOAD_URL, { credentials: 'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(d){
        if (d.success && d.template) {
            fbState = { title: d.template.title || '', sections: d.template.sections || [] };
            document.getElementById('fb-title').value = fbState.title;
        }
        fbRender(); // always render; fbPreviewOn=true so preview also renders
    });

document.getElementById('fb-title').addEventListener('input', function(){
    fbState.title = this.value;
    fbMaybeUpdatePreview();
});

// ── Section operations ───────────────────────────────────────────────────────
function fbAddSection() {
    fbState.sections.push({ id: 's'+Date.now(), title: 'New Section', fields: [] });
    fbRender();
}
function fbDeleteSection(si) {
    if (!confirm('Delete this section and all its fields?')) return;
    fbState.sections.splice(si, 1);
    fbRender();
}
function fbMoveSec(si, dir) {
    var ni = si + dir;
    if (ni < 0 || ni >= fbState.sections.length) return;
    var tmp = fbState.sections[ni]; fbState.sections[ni] = fbState.sections[si]; fbState.sections[si] = tmp;
    fbRender();
}
function fbSecTitle(si, val) { fbState.sections[si].title = val; fbMaybeUpdatePreview(); }

// ── Field operations ─────────────────────────────────────────────────────────
function fbAddField(si) {
    fbState.sections[si].fields.push({ id:'f'+Date.now(), label:'New Field', type:'text', autofill:'', readonly:false, required:false, options:'' });
    fbRender();
}
function fbDeleteField(si, fi) {
    fbState.sections[si].fields.splice(fi, 1);
    fbRender();
}
function fbMoveField(si, fi, dir) {
    var fields = fbState.sections[si].fields, ni = fi + dir;
    if (ni < 0 || ni >= fields.length) return;
    var tmp = fields[ni]; fields[ni] = fields[fi]; fields[fi] = tmp;
    fbRender();
}
function fbFieldProp(si, fi, key, val) {
    fbState.sections[si].fields[fi][key] = val;
    if (key === 'type' || key === 'autofill' || key === 'required' || key === 'readonly' || key === 'label') fbMaybeUpdatePreview();
}

// ── Render editor ────────────────────────────────────────────────────────────
function fbRender() {
    var html = '';
    fbState.sections.forEach(function(sec, si) {
        html += '<div class="fbb-section">'
            + '<div class="fbb-section-hdr">'
            + '<input class="fbb-section-title" value="'+e(sec.title)+'" oninput="fbSecTitle('+si+',this.value)" placeholder="Section title">'
            + '<button class="fbb-btn-icon" onclick="fbMoveSec('+si+',-1)" title="Move up">↑</button>'
            + '<button class="fbb-btn-icon" onclick="fbMoveSec('+si+',1)" title="Move down">↓</button>'
            + '<button class="fbb-btn-icon fbb-btn-icon-danger" onclick="fbDeleteSection('+si+')" title="Delete section">'
            + svgDelete(16) + '</button></div>';

        if (sec.fields.length === 0) {
            html += '<p style="font-size:12px;color:#475569;font-style:italic;margin-bottom:8px;">No fields. Click "+ Add Field" below.</p>';
        }
        sec.fields.forEach(function(f, fi) {
            var typeOpts = '', afOpts = '';
            for (var k in FB_TYPES) typeOpts += '<option value="'+k+'"'+(f.type===k?' selected':'')+'>'+FB_TYPES[k]+'</option>';
            for (var ak in FB_AUTOFILLS) afOpts  += '<option value="'+ak+'"'+((f.autofill||'')===ak?' selected':'')+'>'+FB_AUTOFILLS[ak]+'</option>';

            html += '<div class="fbb-field">'
                + '<div class="fbb-field-grid">'
                + '<div><label class="fbb-label">Label</label>'
                +   '<input class="fbb-input-sm" value="'+e(f.label)+'" oninput="fbFieldProp('+si+','+fi+',\'label\',this.value)"></div>'
                + '<div><label class="fbb-label">Type</label>'
                +   '<select class="fbb-select-sm" onchange="fbFieldProp('+si+','+fi+',\'type\',this.value)">'+typeOpts+'</select></div>'
                + '<div><label class="fbb-label">Autofill</label>'
                +   '<select class="fbb-select-sm" onchange="fbFieldProp('+si+','+fi+',\'autofill\',this.value)">'+afOpts+'</select></div>'
                + '<div class="fbb-req-wrap"><label>'
                +   '<input type="checkbox"'+(f.required?' checked':'')+' onchange="fbFieldProp('+si+','+fi+',\'required\',this.checked)"> Req'
                + '</label></div>'
                + '<div style="display:flex;align-items:flex-end;gap:4px;padding-bottom:1px;">'
                +   '<button class="fbb-btn-icon" onclick="fbMoveField('+si+','+fi+',-1)" title="Move up">↑</button>'
                +   '<button class="fbb-btn-icon" onclick="fbMoveField('+si+','+fi+',1)" title="Move down">↓</button>'
                +   '<button class="fbb-btn-icon fbb-btn-icon-danger" onclick="fbDeleteField('+si+','+fi+')" title="Delete">'+svgDelete(14)+'</button>'
                + '</div></div>';

            if (f.type === 'select') {
                html += '<div class="fbb-field-options">'
                    + '<label class="fbb-label">Options (comma-separated)</label>'
                    + '<input class="fbb-input-sm" value="'+e(f.options||'')+'" placeholder="Option A, Option B" oninput="fbFieldProp('+si+','+fi+',\'options\',this.value)">'
                    + '</div>';
            }
            html += '</div>';
        });

        html += '<button type="button" class="fbb-add-field-btn" onclick="fbAddField('+si+')">+ Add Field</button>';
        html += '</div>';
    });
    document.getElementById('fb-sections').innerHTML = html;
    fbMaybeUpdatePreview();
}

// ── Render preview ────────────────────────────────────────────────────────────
function fbMaybeUpdatePreview() { if (fbPreviewOn) fbRenderPreview(); }

function fbRenderPreview() {
    document.getElementById('fbp-form-title').textContent = fbState.title || '(untitled form)';
    var html = '';
    fbState.sections.forEach(function(sec) {
        html += '<div class="fbb-preview-section">'
            + '<div class="fbb-preview-section-title">'+e(sec.title)+'</div>';
        if (!sec.fields.length) {
            html += '<p class="fbb-preview-empty">No fields in this section.</p>';
        }
        sec.fields.forEach(function(f) {
            var req = f.required && !f.readonly;
            html += '<div class="fbb-preview-field">'
                + '<label class="fbb-preview-label">'+e(f.label)+(req?'<span style="color:#ef4444"> *</span>':'')+'</label>';
            if (f.type === 'rating1to5') {
                html += '<div style="display:flex;align-items:center;justify-content:space-between;max-width:320px;margin-top:6px;">'
                    + [1,2,3,4,5].map(function(n){
                        return '<div style="display:flex;flex-direction:column;align-items:center;gap:4px;">'
                            + '<span style="color:#334155;">'+svgStar(36)+'</span>'
                            + '<span style="font-size:11px;font-weight:500;color:#475569;">'+n+'</span>'
                            + '</div>';
                    }).join('')
                    + '</div>'
                    + '<p class="fbb-preview-star-legend" style="margin-top:6px;">1 = Poor, 5 = Best</p>';
            } else if (f.type === 'textarea') {
                html += '<textarea class="fbb-preview-input" rows="3" disabled placeholder="'+e(f.label)+'"></textarea>';
            } else if (f.type === 'select') {
                html += '<select class="fbb-preview-input" disabled><option>— Select —</option></select>';
            } else {
                var sampleVal = (f.autofill && FB_SAMPLES[f.autofill]) ? FB_SAMPLES[f.autofill] : '';
                var ph = sampleVal ? '' : e(f.label);
                html += '<input type="'+(f.type||'text')+'" class="fbb-preview-input" disabled value="'+e(sampleVal)+'" placeholder="'+ph+'">';
            }
            html += '</div>';
        });
        html += '</div>';
    });
    if (!fbState.sections.length) html = '<p class="fbb-preview-empty" style="text-align:center;padding:24px 0;">Add sections and fields on the left to see a preview.</p>';
    document.getElementById('fbp-sections').innerHTML = html;
}

// ── Toggle preview ────────────────────────────────────────────────────────────
function fbTogglePreview() {
    fbPreviewOn = !fbPreviewOn;
    var layout  = document.getElementById('fbb-layout');
    var preview = document.getElementById('fbb-preview');
    var btn     = document.getElementById('fb-preview-btn');
    if (fbPreviewOn) {
        layout.classList.add('with-preview');
        preview.style.display = '';
        btn.classList.add('active');
        btn.textContent = 'Hide Preview';
        fbRenderPreview();
    } else {
        layout.classList.remove('with-preview');
        preview.style.display = 'none';
        btn.classList.remove('active');
        btn.textContent = 'Show Preview';
    }
}

// ── Save ─────────────────────────────────────────────────────────────────────
function fbSave() {
    var btn = document.getElementById('fb-save-btn');
    var st  = document.getElementById('fb-save-status');
    btn.disabled = true; btn.textContent = 'Saving…';
    st.style.color = '#64748b'; st.textContent = '';
    fbState.title = document.getElementById('fb-title').value;
    fetch(FB_SAVE_URL + '?form_key=' + encodeURIComponent(FB_FORM_KEY), {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(fbState)
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        btn.disabled = false; btn.textContent = 'Save';
        st.style.color = d.success ? '#10b981' : '#ef4444';
        st.textContent = d.success ? '✓ Saved' : '✗ '+(d.message||'Error');
        setTimeout(function(){ st.textContent=''; }, 3000);
    })
    .catch(function(){
        btn.disabled = false; btn.textContent = 'Save';
        st.style.color = '#ef4444'; st.textContent = '✗ Network error';
    });
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function e(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

function svgDelete(size) {
    return '<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'
        + '<polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>'
        + '<path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>';
}

function svgStar(size) {
    return '<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">'
        + '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
}
</script>
