    <div style="margin-bottom:16px;">
        <label class="fbb-label" for="fb-title">Form Title</label>
        <input type="text" id="fb-title" class="fbb-input" placeholder="Course Feedback Form"
               oninput="fbState.title=this.value;fbMaybeUpdatePreview();">
    </div>

    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <button type="button" id="fb-save-btn" class="fbb-btn-primary" onclick="fbSave()">Save</button>
        <button type="button" class="fbb-btn-secondary" onclick="fbAddSection()">+ Add Section</button>
        <button type="button" id="fb-preview-btn" class="fbb-btn-outline active" onclick="fbTogglePreview()">Hide Preview</button>
        <span id="fb-save-status" class="fbb-save-status"></span>
    </div>
</div>

<!-- Two-column layout (preview open by default) -->
