    <div id="fbb-preview">
        <div class="fbb-card" style="position:sticky;top:16px;">
            <div class="fbb-preview-hdr">
                <div>
                    <p class="fbb-preview-title">Live Preview</p>
                    <p class="fbb-preview-sub">As the learner sees it</p>
                </div>
            </div>
            <p class="fbb-preview-form-title" id="fbp-form-title"></p>
