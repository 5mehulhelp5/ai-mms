<script>
var FBR_LIST_URL   = '<?php echo $this->jsQuoteEscape($listUrl) ?>';
var FBR_UPDATE_URL = '<?php echo $this->jsQuoteEscape($updateUrl) ?>';
var FBR_DELETE_URL = '<?php echo $this->jsQuoteEscape($deleteUrl) ?>';
var FBR_FORM_KEY   = window.FORM_KEY || '';
var fbrPage  = 1;
var fbrPages = 1;
var fbrTotal = 0;
var fbrRows  = {};
var fbrSel   = {};

// ── Close modals on backdrop click ─────────────────────────────────────────
['fbr-view-modal','fbr-edit-modal'].forEach(function(id){
    document.getElementById(id).addEventListener('click', function(e){ if(e.target===this) this.style.display='none'; });
});

// ── Enter key triggers search ──────────────────────────────────────────────
document.getElementById('fbr-q').addEventListener('keydown', function(e){ if(e.key==='Enter') fbrLoad(1); });

// ── Load ───────────────────────────────────────────────────────────────────
fbrLoad(1);

function fbrLoad(page) {
    fbrPage = Math.max(1, page || 1);
    var q    = document.getElementById('fbr-q').value;
    var from = document.getElementById('fbr-from').value;
    var to   = document.getElementById('fbr-to').value;
    var url  = FBR_LIST_URL + '?page=' + fbrPage
             + (q    ? '&q='    + encodeURIComponent(q)    : '')
             + (from ? '&from=' + encodeURIComponent(from) : '')
             + (to   ? '&to='   + encodeURIComponent(to)   : '');

    document.getElementById('fbr-loading').style.display = '';
    document.getElementById('fbr-empty').style.display   = 'none';
    document.getElementById('fbr-table-wrap').style.display = 'none';
    document.getElementById('fbr-pagination').style.display = 'none';

    fetch(url, { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(d){
            document.getElementById('fbr-loading').style.display = 'none';
            if (!d.success) { document.getElementById('fbr-empty').textContent = 'Error: '+(d.message||'Unknown error'); document.getElementById('fbr-empty').style.display=''; return; }
            fbrTotal = d.total || 0; fbrPages = d.pages || 1;
            if (!d.rows || !d.rows.length) { document.getElementById('fbr-empty').style.display = ''; return; }
            fbrRenderRows(d.rows);
            fbrRenderPagination();
            document.getElementById('fbr-table-wrap').style.display = '';
            document.getElementById('fbr-pagination').style.display = '';
        })
        .catch(function(){ document.getElementById('fbr-loading').textContent = '✗ Network error'; });
}

function fbrReset() {
    document.getElementById('fbr-q').value = '';
    document.getElementById('fbr-from').value = '';
    document.getElementById('fbr-to').value = '';
    fbrLoad(1);
}

// ── Render rows ────────────────────────────────────────────────────────────
function fbrRenderRows(rows) {
    fbrRows = {}; fbrSel = {};
    fbrUpdateSelBar();
    var tbody = document.getElementById('fbr-tbody');
    var html = '';
    rows.forEach(function(r) {
        fbrRows[r.response_id] = r;
        var ans = r.answers || {};
        // Ratings: first three non-autofill rating1to5 fields saved in order.
        // _message: reserved key written by RespondController for the textarea.
        var ratingVals = [];
        for (var k in ans) {
            if (k.charAt(0) !== '_') {
                var v = ans[k];
                var n = parseFloat(String(v));
                if (!isNaN(n) && n >= 1 && n <= 5) ratingVals.push(v);
            }
        }
        var outcome = ratingVals[0] || '—';
        var trainerQ= ratingVals[1] || '—';
        var env     = ratingVals[2] || '—';
        var msg = ans['_message'] || '';

        var dt = r.submitted_at ? r.submitted_at.replace('T',' ').substr(0,16) : '—';
        var sel = fbrSel[r.response_id] ? ' selected' : '';
        html += '<tr data-id="'+r.response_id+'" class="'+sel+'">'
            + '<td><input type="checkbox" class="fbr-row-chk" value="'+r.response_id+'" onchange="fbrToggleRow(this)" style="accent-color:#2563eb;"'+(fbrSel[r.response_id]?' checked':'')+' ></td>'
            + '<td class="muted" style="white-space:nowrap;font-size:11px;">'+esc(dt)+'</td>'
            + '<td class="mono" style="font-size:11px;">'+esc(r.class_id||'—')+'</td>'
            + '<td><div class="fbr-cell-trunc" title="'+esc(r.course_title||'')+'">'+esc(r.course_title||'—')+'</div></td>'
            + '<td class="mono" style="font-size:11px;">'+esc(r.course_sku||'—')+'</td>'
            + '<td style="font-size:12px;">'+esc(r.trainer_name||'—')+'</td>'
            + '<td style="font-size:12px;">'+esc(r.learner_name||'—')+'<br><span style="color:#64748b;font-size:10px;">'+esc(r.learner_email||'')+'</span></td>'
            + '<td style="text-align:center;">'+fbrRating(outcome)+'</td>'
            + '<td style="text-align:center;">'+fbrRating(trainerQ)+'</td>'
            + '<td style="text-align:center;">'+fbrRating(env)+'</td>'
            + '<td><div class="fbr-cell-trunc" style="max-width:160px;" title="'+esc(msg||'')+'">'+esc(msg||'—')+'</div></td>'
            + '<td><div style="display:flex;align-items:center;gap:2px;">'
            + '<button type="button" class="fbr-btn-icon fbr-btn-icon-view" onclick="fbrOpenView('+r.response_id+')" title="View JSON">'+svgEye()+'</button>'
            + '<button type="button" class="fbr-btn-icon fbr-btn-icon-edit" onclick="fbrOpenEdit('+r.response_id+')" title="Edit">'+svgPencil()+'</button>'
            + '<button type="button" class="fbr-btn-icon fbr-btn-icon-del"  onclick="fbrDeleteOne('+r.response_id+')" title="Delete">'+svgTrash()+'</button>'
            + '</div></td></tr>';
    });
    tbody.innerHTML = html;
    document.getElementById('fbr-chk-all').checked = false;
}

function fbrRating(v) {
    var n = parseInt(v, 10);
    if (isNaN(n)) return '<span style="color:#475569">—</span>';
    return '<span style="color:#f59e0b;font-size:13px;">★</span><span style="font-size:11px;color:#94a3b8;">'+n+'/5</span>';
}

// ── Pagination ─────────────────────────────────────────────────────────────
function fbrRenderPagination() {
    var s = (fbrPage-1)*30+1, e2 = Math.min(fbrPage*30, fbrTotal);
    document.getElementById('fbr-pag-info').textContent = 'Showing '+s+'–'+e2+' of '+fbrTotal;
    document.getElementById('fbr-pag-page').textContent = 'Page '+fbrPage+' of '+fbrPages;
    document.getElementById('fbr-first-btn').disabled = fbrPage <= 1;
    document.getElementById('fbr-prev-btn').disabled  = fbrPage <= 1;
    document.getElementById('fbr-next-btn').disabled  = fbrPage >= fbrPages;
    document.getElementById('fbr-last-btn').disabled  = fbrPage >= fbrPages;
}

// ── Selection ──────────────────────────────────────────────────────────────
function fbrToggleAll(chk) {
    document.querySelectorAll('.fbr-row-chk').forEach(function(el){
        el.checked = chk.checked;
        var row = el.closest('tr');
        if (chk.checked) { fbrSel[el.value]=true; row.classList.add('selected'); }
        else { delete fbrSel[el.value]; row.classList.remove('selected'); }
    });
    fbrUpdateSelBar();
}
function fbrToggleRow(chk) {
    var row = chk.closest('tr');
    if (chk.checked) { fbrSel[chk.value]=true; row.classList.add('selected'); }
    else { delete fbrSel[chk.value]; row.classList.remove('selected'); }
    fbrUpdateSelBar();
}
function fbrClearSelection() {
    fbrSel = {};
    document.querySelectorAll('.fbr-row-chk').forEach(function(el){ el.checked=false; el.closest('tr').classList.remove('selected'); });
    document.getElementById('fbr-chk-all').checked = false;
    fbrUpdateSelBar();
}
function fbrUpdateSelBar() {
    var n = Object.keys(fbrSel).length;
    var bar = document.getElementById('fbr-selection-bar');
    bar.style.display = n ? 'flex' : 'none';
    if (n) document.getElementById('fbr-sel-count').textContent = n+' selected';
}

// ── View modal ─────────────────────────────────────────────────────────────
function fbrOpenView(id) {
    var r = fbrRows[id]; if (!r) return;
    var meta = (r.course_sku||'') + (r.course_title ? ' — '+r.course_title : '') + (r.class_id ? ' ('+r.class_id+')' : '');
    document.getElementById('fbr-view-meta').textContent = meta + (r.submitted_at ? '  ·  '+r.submitted_at.replace('T',' ').substr(0,16) : '');
    document.getElementById('fbr-view-json').textContent = JSON.stringify(r, null, 2);
    document.getElementById('fbr-view-modal').style.display = 'flex';
}

// ── Edit modal ─────────────────────────────────────────────────────────────
function fbrOpenEdit(id) {
    var r = fbrRows[id]; if (!r) return;
    var meta = (r.course_sku||'') + (r.course_title ? ' — '+r.course_title : '') + (r.class_id ? ' ('+r.class_id+')' : '');
    document.getElementById('fbr-edit-meta').textContent  = meta;
    document.getElementById('fbr-edit-id').value          = id;
    document.getElementById('fbr-edit-name').value        = r.learner_name  || '';
    document.getElementById('fbr-edit-email').value       = r.learner_email || '';
    var ans = r.answers || {}, html = '';
    for (var k in ans) {
        var v = String(ans[k]);
        var isLong = v.length > 60;
        html += '<div class="fbr-answer-grid">'
            + '<div class="fbr-answer-key" title="'+esc(k)+'">'+esc(k)+'</div>'
            + (isLong
                ? '<textarea class="fbr-answer-textarea" rows="3" data-ans-key="'+esc(k)+'">'+esc(v)+'</textarea>'
                : '<input type="text" class="fbr-answer-input" data-ans-key="'+esc(k)+'" value="'+esc(v)+'">')
            + '</div>';
    }
    document.getElementById('fbr-edit-answers').innerHTML = html;
    document.getElementById('fbr-edit-save-btn').textContent = 'Save';
    document.getElementById('fbr-edit-save-btn').disabled  = false;
    document.getElementById('fbr-edit-modal').style.display = 'flex';
}

function fbrSaveEdit() {
    var id    = parseInt(document.getElementById('fbr-edit-id').value, 10);
    var name  = document.getElementById('fbr-edit-name').value;
    var email = document.getElementById('fbr-edit-email').value;
    var answers = {};
    document.querySelectorAll('[data-ans-key]').forEach(function(el){ answers[el.getAttribute('data-ans-key')] = el.value; });
    var btn = document.getElementById('fbr-edit-save-btn');
    btn.disabled = true; btn.textContent = 'Saving…';
    fetch(FBR_UPDATE_URL + '?form_key=' + encodeURIComponent(FBR_FORM_KEY), {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ response_id: id, learner_name: name, learner_email: email, answers: answers })
    }).then(function(r){ return r.json(); }).then(function(d){
        btn.disabled = false; btn.textContent = 'Save';
        if (d.success) { document.getElementById('fbr-edit-modal').style.display = 'none'; fbrLoad(fbrPage); }
        else alert('Error: '+(d.message||'Unknown'));
    }).catch(function(){ btn.disabled=false; btn.textContent='Save'; alert('Network error'); });
}

// ── Delete ─────────────────────────────────────────────────────────────────
function fbrDeleteOne(id) {
    if (!confirm('Delete this response?')) return;
    fbrDoDelete([id]);
}
function fbrBulkDelete() {
    var ids = Object.keys(fbrSel).map(Number);
    if (!ids.length) return;
    if (!confirm('Delete '+ids.length+' response(s)?')) return;
    fbrDoDelete(ids);
}
function fbrDoDelete(ids) {
    fetch(FBR_DELETE_URL + '?form_key=' + encodeURIComponent(FBR_FORM_KEY), {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: ids })
    }).then(function(r){ return r.json(); }).then(function(d){
        if (d.success) { fbrSel={}; fbrUpdateSelBar(); fbrLoad(fbrPage); }
        else alert('Error: '+(d.message||'Unknown'));
    });
}

// ── Helpers ────────────────────────────────────────────────────────────────
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

function svgEye(){ return '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>'; }
function svgPencil(){ return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>'; }
function svgTrash(){ return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>'; }
</script>
