<?xml version="1.0"?>
<layout>
    <adminhtml_sales_order_grid>
        <remove name="root"/>

        <reference name="content">
            <block type="enhancedsalesgrid/sales_order_grid" name="sales_order.grid"></block>
        </reference>
    </adminhtml_sales_order_grid>

    <adminhtml_sales_order_index>
        <remove name="sales_order.grid.container"/>

        <reference name="content">
            <block type="enhancedsalesgrid/sales_order" name="enhancedsalesgrid.sales_order.grid.container"></block>
        </reference>
    </adminhtml_sales_order_index>

    <!-- Drop Credit Memos and Comments History tabs on the View Registration page -->
    <adminhtml_sales_order_view>
        <reference name="sales_order_tabs">
            <action method="removeTab"><name>order_creditmemos</name></action>
            <action method="removeTab"><name>order_history</name></action>
        </reference>
    </adminhtml_sales_order_view>
</layout>
