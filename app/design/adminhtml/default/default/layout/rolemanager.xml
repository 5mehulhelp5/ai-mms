<?xml version="1.0"?>
<layout>
    <default>
        <reference name="header">
            <block type="mmd_rolemanager/page_header_roleSwitcher"
                   name="role_switcher"
                   template="rolemanager/role-switcher.phtml" />
        </reference>
    </default>

    <!-- RoleManager pages — load the extracted page-specific stylesheet
         only on the screens that actually need it. MMD routes use
         before="Mage_Adminhtml" so the handle is adminhtml_<ctrl>_<act>. -->
    <!-- Add Course button above the Manage Courses product grid -->
    <adminhtml_catalog_product_index>
        <reference name="content">
            <block type="core/template" name="add.course.btn" before="products_list"
                   template="rolemanager/add-course-btn.phtml" />
        </reference>
    </adminhtml_catalog_product_index>

    <adminhtml_rolemanagement_index>
        <reference name="head">
            <action method="addCss"><name>rolemanager.css</name></action>
        </reference>
    </adminhtml_rolemanagement_index>
    <adminhtml_classes_index>
        <reference name="head">
            <action method="addCss"><name>rolemanager.css</name></action>
        </reference>
    </adminhtml_classes_index>
    <adminhtml_roleselect_index>
        <reference name="head">
            <action method="addCss"><name>rolemanager.css</name></action>
        </reference>
    </adminhtml_roleselect_index>
    <adminhtml_cpgenerator_index>
        <reference name="head">
            <action method="addCss"><name>rolemanager.css</name></action>
        </reference>
    </adminhtml_cpgenerator_index>
    <adminhtml_seometadata_index>
        <reference name="head">
            <action method="addCss"><name>rolemanager.css</name></action>
        </reference>
    </adminhtml_seometadata_index>
</layout>
