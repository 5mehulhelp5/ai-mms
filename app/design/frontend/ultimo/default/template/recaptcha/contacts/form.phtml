<script type="text/javascript">
    function onSubmit(token) {
        var error = "";
        var name = document.forms["contactForm"]["name"].value;
        if (name == "") { error += "Please enter your name<br/>"; }
        var email = document.forms["contactForm"]["email"].value;
        if (!/^\w+([\.-]?\w+)*@\w+([\.-]?\w+)*(\.\w{2,})+$/.test(email)) {
            error += "Please enter a valid email<br/>";
        }
        var telephone = document.forms["contactForm"]["telephone"].value;
        if (telephone == "") { error += "Please enter your telephone<br/>"; }
        var comment = document.forms["contactForm"]["comment"].value;
        if (comment == "") { error += "Please enter a message<br/>"; }
        if (error == "") {
            document.getElementById("error").innerHTML = "";
            document.getElementById("contactForm").submit();
            return true;
        } else {
            document.getElementById("error").innerHTML = error;
            return false;
        }
    }

    if ('NodeList' in window) {
        if (!NodeList.prototype.each && NodeList.prototype.forEach) {
            NodeList.prototype.each = NodeList.prototype.forEach;
        }
    }
</script>
