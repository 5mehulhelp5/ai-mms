<script type="text/javascript">
    /* Client-side validation + Turnstile gating.
       Flow:
         1. User clicks Send.
         2. validateForm() runs; on failure shows errors, blocks submit.
         3. On success, if Turnstile is configured, call turnstile.execute()
            and wait for onTurnstileSuccess to actually submit. If Turnstile
            isn't loaded (no key or script blocked), submit immediately —
            backend fails open in that case.
    */
    (function () {
        var TURNSTILE_ENABLED = <?php echo $tsSiteKey ? 'true' : 'false'; ?>;
        var pendingSubmit = false;

        function validateForm() {
            var error = "";
            var f = document.forms["contactForm"];
            if (!f["name"].value) { error += "Please enter your name<br/>"; }
            if (!/^\w+([\.-]?\w+)*@\w+([\.-]?\w+)*(\.\w{2,})+$/.test(f["email"].value)) {
                error += "Please enter a valid email<br/>";
            }
            if (!f["telephone"].value) { error += "Please enter your telephone<br/>"; }
            if (!f["comment"].value) { error += "Please enter a message<br/>"; }
            document.getElementById("error").innerHTML = error;
            return error === "";
        }

        function doSubmit() {
            // Mark submitting to avoid double-fire; release the button afterward
            // in case the navigation is cancelled by the browser.
            var btn = document.getElementById("tc-submit-btn");
            if (btn) { btn.disabled = true; }
            document.forms["contactForm"].submit();
        }

        // Exposed for Turnstile callbacks (declared globally as required by data-callback).
        window.onTurnstileSuccess = function (token) {
            var input = document.getElementById("cf-turnstile-response");
            if (input) { input.value = token; }
            if (pendingSubmit) {
                pendingSubmit = false;
                doSubmit();
            }
        };
        window.onTurnstileError = function () {
            pendingSubmit = false;
            document.getElementById("error").innerHTML =
                "Spam check could not run. Please refresh the page and try again.";
        };
        window.onTurnstileExpired = function () {
            var input = document.getElementById("cf-turnstile-response");
            if (input) { input.value = ""; }
        };

        document.addEventListener("DOMContentLoaded", function () {
            var form = document.getElementById("contactForm");
            if (!form) { return; }
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                if (!validateForm()) { return; }

                if (!TURNSTILE_ENABLED || typeof window.turnstile === "undefined") {
                    doSubmit();
                    return;
                }

                // If invisible widget already has a fresh token in the hidden input, just submit.
                var input = document.getElementById("cf-turnstile-response");
                if (input && input.value) { doSubmit(); return; }

                // Otherwise trigger execution; submission happens in onTurnstileSuccess.
                pendingSubmit = true;
                try {
                    window.turnstile.execute(); // executes the first invisible widget on page
                } catch (err) {
                    // Fallback: let the browser submit anyway; backend will reject if needed.
                    pendingSubmit = false;
                    doSubmit();
                }
            });
        });

        if ('NodeList' in window) {
            if (!NodeList.prototype.each && NodeList.prototype.forEach) {
                NodeList.prototype.each = NodeList.prototype.forEach;
            }
        }
    })();
</script>
