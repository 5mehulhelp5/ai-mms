        <script type="text/javascript">
            //<![CDATA[
            var code = "";
            var temp = 0;
            Validation.addAllThese(
                [
                    ['validate-rating', '<?php echo $this->__('Please select one of each of the ratings above') ?>', function (v) {
                        var trs = $('product-review-table').select('tr');
                        var inputs;
                        var error = 1;

                        for (var j = 0; j < trs.length; j++) {
                            var tr = trs[j];
                            if (j > 0) {
                                inputs = tr.select('input');

                                for (i in inputs) {
                                    if (inputs[i].checked == true) {
                                        error = 0;
                                    }
                                }
                                if (error == 1) {
                                    return false;
                                } else {
                                    error = 1;
                                }
                            }
                        }
                        return true;
                    }]
                ]
            );
        </script>
        <script type="text/javascript">
            var dataForm = new VarienForm('review-form', true);

            /* Turnstile gating for review submissions. The widget runs
               invisibly on page load; if a token is already present we let
               the form submit immediately. Otherwise we call execute() and
               submit from the success callback. */
            (function () {
                var TURNSTILE_ENABLED = <?php echo $tsSiteKey ? 'true' : 'false'; ?>;
                var pendingSubmit = false;

                window.onTurnstileSuccessReview = function (token) {
                    var input = document.getElementById("cf-turnstile-response");
                    if (input) { input.value = token; }
                    if (pendingSubmit) {
                        pendingSubmit = false;
                        document.getElementById("review-form").submit();
                    }
                };
                window.onTurnstileErrorReview = function () {
                    pendingSubmit = false;
                    var box = document.getElementById("captcha-required");
                    if (box) { box.style.display = "block"; }
                };
                window.onTurnstileExpiredReview = function () {
                    var input = document.getElementById("cf-turnstile-response");
                    if (input) { input.value = ""; }
                };

                window.validateRecaptcha = function () {
                    if (!TURNSTILE_ENABLED || typeof window.turnstile === "undefined") {
                        return true;
                    }
                    var input = document.getElementById("cf-turnstile-response");
                    if (input && input.value) {
                        var box = document.getElementById("captcha-required");
                        if (box) { box.style.display = "none"; }
                        return true;
                    }
                    pendingSubmit = true;
                    try { window.turnstile.execute(); } catch (e) { return true; }
                    return false; // wait for callback
                };
            })();
        </script>
