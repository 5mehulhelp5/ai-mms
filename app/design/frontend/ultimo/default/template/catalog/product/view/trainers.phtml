<?php
$trainers = trim((string) $this->getProduct()->getTrainerprofile());
if ($trainers === '') { return; }

// Parse trainer EAV HTML into discrete cards. Source shape is typically:
//   <p><strong>Name</strong> - bio sentence...</p>
//   <p>continuation paragraph for same trainer...</p>
//   <p><strong>Next Name</strong> - bio...</p>
// A paragraph that opens with <strong>X</strong> followed by a dash starts a
// new card; subsequent paragraphs without that prefix attach to the current
// card. If parsing yields zero cards, fall back to raw render so nothing
// ever disappears silently.
$cards = [];
$current = null;
$pPattern = '#<p\b[^>]*>(.*?)</p>#siu';
$dashRe   = '#^\s*<strong[^>]*>\s*(.+?)\s*</strong>\s*(?:[-–—:]\s*)(.*)$#siu';
if (preg_match_all($pPattern, $trainers, $pm)) {
    foreach ($pm[1] as $body) {
        if (preg_match($dashRe, $body, $hm)) {
            if ($current !== null) { $cards[] = $current; }
            $current = [
                'name' => trim(strip_tags($hm[1])),
                'body' => [trim($hm[2])],
            ];
        } else {
            $clean = trim($body);
            if ($clean === '') { continue; }
            if ($current === null) {
                $current = ['name' => '', 'body' => [$clean]];
            } else {
                $current['body'][] = $clean;
            }
        }
    }
    if ($current !== null) { $cards[] = $current; }
}

$initial = function ($name) {
    $name = trim((string) $name);
    if ($name === '') return '?';
    $parts = preg_split('#\s+#u', $name);
    $first = mb_substr($parts[0], 0, 1, 'UTF-8');
    $last  = isset($parts[count($parts) - 1]) && count($parts) > 1
        ? mb_substr($parts[count($parts) - 1], 0, 1, 'UTF-8') : '';
    return mb_strtoupper($first . $last, 'UTF-8');
};
?>
<h2><?php echo $this->__('Trainers') ?></h2>
<div class="std course-trainers" id="trainers">
<?php if (!empty($cards) && !(count($cards) === 1 && $cards[0]['name'] === '')): ?>
    <div class="course-trainers__grid">
    <?php foreach ($cards as $c): ?>
        <article class="trainer-card">
            <div class="trainer-card__head">
                <div class="trainer-card__avatar" aria-hidden="true"><?php echo htmlspecialchars($initial($c['name']), ENT_QUOTES, 'UTF-8'); ?></div>
                <div class="trainer-card__name"><?php echo htmlspecialchars($c['name'], ENT_QUOTES, 'UTF-8'); ?></div>
            </div>
            <div class="trainer-card__body">
                <?php foreach ($c['body'] as $para): ?>
                    <p><?php echo $para; ?></p>
                <?php endforeach; ?>
            </div>
        </article>
    <?php endforeach; ?>
    </div>
<?php else: ?>
    <?php echo $trainers; ?>
<?php endif; ?>
</div>
