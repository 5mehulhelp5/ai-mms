<?php
	$_helper = $this->helper('catalog/output');
	$_product = $this->getProduct();
    $_storeId = $_product->getStoreId();
	$productType = $_product->getTypeId(); 
	$theme = $this->helper('ultimo');
	$helperThis = $this->helper('ultimo/template_catalog_product_view');
	$helperSnippets = $this->helper('ultimo/rsnippets');
    $attributeSetId = $_product->getAttributeSetId();

	//CSS classes based on product type
	$productTypeId = $_product->getTypeId();
	$productTypeClasses = '';
	if ($productTypeId === 'grouped') {
		$productTypeClasses .= ' is-type-grouped';
	}

	//
	$shortDescription = $_helper->productAttribute($_product, $_product->getShortDescription(), 'short_description');

	// ---------------------------------------------------------------------
	// Carve dynamic sections out of $shortDescription so they can render as
	// their own styled cards in the left column. Order matters: extract WSQ
	// first (it wraps SFC/UTAP/PSEA in a rounded <div>), then Certification.
	//
	// Primary source for each section is a per-course Magento cms/block with
	// identifier `course_<sku>_<section>`. Editable via Course Edit dashboard
	// or CMS → Static Blocks. Regex extraction from short_description is
	// kept as a permanent fallback (belt and braces — if a course's block
	// is empty, we still render whatever was in short_description, so
	// nothing ever disappears silently).
	// ---------------------------------------------------------------------
	$_WS = '(?:\s|&nbsp;|\x{00A0}|\x{2007}|\x{202F})';
	$_courseSku = (string) $_product->getSku();
	$_courseSectionHtml = function (string $code) use ($_courseSku): string {
		if ($_courseSku === '') return '';
		$id = 'course_' . $_courseSku . '_' . $code;
		return trim(Mage::app()->getLayout()->createBlock('cms/block')->setBlockId($id)->toHtml());
	};

	// (1) WSQ Funding wrapper — raw inner HTML of the SFC/UTAP/PSEA narrative.
	// Per-course cms/block is primary; if empty, fall back to regex extract
	// (the legacy <div style="border-radius:25px"> wrapper, or an
	// <h2>WSQ Funding</h2> heading variant). The post-processor below (drop
	// fee table / boilerplate, wrap sub-schemes in .wsq-sub) runs on
	// whichever source produced the inner HTML — it's pipeline-stage and
	// independent of source.
	$_wsqNarrativeHtml = '';
	$_hasWsqFunding    = false;
	// Non-WSQ courses in the SG store use SKU prefix "C" (WSQ courses use
	// "TGS-"). For these, the funding card is informational only — no
	// auto-calculated fee tiles, title renamed to "Funding Options", and any
	// in-narrative "Funding and Grant Applications" heading is suppressed
	// (we just want the no-funding sentence + WSQ link to render).
	$_isNonWsqSgCourse = (strncasecmp((string) $_courseSku, 'C', 1) === 0)
		&& (Mage::app()->getStore()->getCode() === 'singapore');
	$_inner            = $_courseSectionHtml('funding_and_grant');
	if ($_inner !== '') {
		$_hasWsqFunding = true;
	}
	if ($shortDescription) {
		$_wsqPattern = '#<div\b[^>]*border-radius\s*:[^>]*>(.*?)</div>#siu';
		$_wsqHeadingPattern = '#<h[1-6][^>]*>' . $_WS . '*WSQ' . $_WS . '+Funding' . $_WS . '*</h[1-6]>(.*?)(?=<h[12]\b|\z)#siu';
		$_wsqStripPattern = null;
		if (preg_match($_wsqPattern, $shortDescription, $_wsqMatch)) {
			$_wsqStripPattern = $_wsqPattern;
			if (!$_hasWsqFunding) { $_hasWsqFunding = true; $_inner = $_wsqMatch[1]; }
		} elseif (preg_match($_wsqHeadingPattern, $shortDescription, $_wsqMatch)) {
			$_wsqStripPattern = $_wsqHeadingPattern;
			if (!$_hasWsqFunding) { $_hasWsqFunding = true; $_inner = $_wsqMatch[1]; }
		}
		if ($_wsqStripPattern !== null) {
			$shortDescription = preg_replace($_wsqStripPattern, '', $shortDescription, 1);
		}
	}
	if ($_hasWsqFunding) {
		{
			$_inner = preg_replace('#<h[1-6][^>]*>' . $_WS . '*WSQ' . $_WS . '+Funding' . $_WS . '*</h[1-6]>#siu', '', $_inner);
			$_inner = preg_replace('#<table\b.*?</table>#siu', '', $_inner);
			$_inner = preg_replace('#<p[^>]*>' . $_WS . '*WSQ' . $_WS . '+funding' . $_WS . '+is' . $_WS . '+only.*?</p>#siu', '', $_inner);
			// Drop redundant tier-explainer / nett-payment lines that the
			// auto-calc tiles already convey.
			$_inner = preg_replace('#<p[^>]*>(?:' . $_WS . '|<[^>]+>)*Baseline\s*:.*?</p>#siu', '', $_inner);
			$_inner = preg_replace('#<p[^>]*>(?:' . $_WS . '|<[^>]+>)*MCES\b.*?</p>#siu', '', $_inner);
			$_inner = preg_replace('#<p[^>]*>(?:' . $_WS . '|<[^>]+>)*Upon\s+registration[^<]*advise[^<]*WSQ.*?</p>#siu', '', $_inner);
			$_inner = preg_replace('#<p[^>]*>(?:' . $_WS . '|<[^>]+>)*You\s+can\s+pay\s+the\s+nett\s+fee.*?</p>#siu', '', $_inner);
			$_inner = preg_replace('#<p[^>]*>' . $_WS . '*</p>#siu', '', $_inner);
			// Drop any <hr> separators inside the narrative — the per-scheme
			// .wsq-sub cards below already supply visual separation.
			$_inner = preg_replace('#<hr\b[^>]*/?>#siu', '', $_inner);

			// Non-WSQ SG courses: strip ALL remaining headings so the
			// preg_replace_callback below doesn't wrap them as .wsq-sub
			// mini-cards (we don't want the "Funding and Grant Applications"
			// pill above the no-funding sentence).
			if ($_isNonWsqSgCourse) {
				$_inner = preg_replace('#<h[1-6][^>]*>.*?</h[1-6]>#siu', '', $_inner);
			}

			// Wrap each remaining <h[1-6]>…(body until next h)…</h> into its
			// own .wsq-sub block so the SFC / UTAP / PSEA / SFEC sub-sections
			// render as visually separated mini-cards instead of flat text.
			// Tag each block with a slug derived from the heading text so the
			// CSS can colour-code by scheme.
			$_inner = preg_replace_callback(
				'#<h[1-6][^>]*>(?P<title>.*?)</h[1-6]>(?P<body>.*?)(?=<h[1-6]|\z)#siu',
				function ($m) {
					$titleText = trim(strip_tags($m['title']));
					if ($titleText === '') { return trim($m['body']); }
					// Prefer the acronym in parentheses ("SkillsFuture Credit (SFC)"
					// → "sfc"); otherwise fall back to a slug of the full title.
					if (preg_match('#\(([A-Z]{2,6})\)#u', $titleText, $am)) {
						$slug = strtolower($am[1]);
					} elseif (preg_match('#^([A-Z]{2,6})\b#u', $titleText, $am)) {
						$slug = strtolower($am[1]);
					} else {
						$slug = strtolower(preg_replace('#[^a-z0-9]+#i', '-', $titleText));
						$slug = trim($slug, '-');
					}
					if ($slug === '') { return trim($m['body']); }
					return '<div class="wsq-sub wsq-sub--' . $slug . '">'
						 . '<div class="wsq-sub__title">' . htmlspecialchars($titleText, ENT_QUOTES, 'UTF-8') . '</div>'
						 . '<div class="wsq-sub__body">' . trim($m['body']) . '</div>'
						 . '</div>';
				},
				$_inner
			);

			$_wsqNarrativeHtml = trim($_inner);
		}
	}

	// Helper: build a "<h[1-6]> Section </h[1-6]>(.*?)" extractor whose
	// lookahead stops before any wrapper opening tag that immediately
	// precedes the next heading. Returns [bodyHtml, descriptionWithSectionRemoved].
	$_extractSection = function ($title, $desc) use ($_WS) {
		$pattern = '#<h[1-6][^>]*>' . $_WS . '*(?:<br\s*/?>' . $_WS . '*)*' . $title . $_WS . '*:?' . $_WS . '*</h[1-6]>(.*?)(?=(?:<[a-z][a-z0-9]*\b[^>]*>' . $_WS . '*)*<h[1-6]|\z)#siu';
		if (preg_match($pattern, $desc, $m)) {
			return [trim($m[1]), preg_replace($pattern, '', $desc)];
		}
		return ['', $desc];
	};

	// (2) Learning Outcomes — per-course cms/block first, regex fallback.
	// Always run the strip so any residual heading in short_description
	// doesn't double-render in the narrative below.
	list($_loExtracted, $shortDescription) = $_extractSection('Learning' . $_WS . '+Outcomes', $shortDescription);
	$_learningOutcomesHtml = $_courseSectionHtml('learning_outcomes');
	if ($_learningOutcomesHtml === '') { $_learningOutcomesHtml = $_loExtracted; }
	unset($_loExtracted);

	// (3) Course Brochure — per-course cms/block first, regex fallback.
	list($_brExtracted, $shortDescription) = $_extractSection('Course' . $_WS . '+Brochure', $shortDescription);
	$_courseBrochureHtml = $_courseSectionHtml('brochure');
	if ($_courseBrochureHtml === '') { $_courseBrochureHtml = $_brExtracted; }
	unset($_brExtracted);
	// Pull the first <a href> out of the brochure block so the CTA button
	// can link to it directly with a clean label.
	$_courseBrochureUrl   = '';
	$_courseBrochureLabel = 'Download Course Brochure';
	if ($_courseBrochureHtml !== '' && preg_match('#<a\s[^>]*href=["\']([^"\']+)["\'][^>]*>(.*?)</a>#siu', $_courseBrochureHtml, $_bm)) {
		$_courseBrochureUrl   = $_bm[1];
		$_clean               = trim(strip_tags($_bm[2]));
		if ($_clean !== '') { $_courseBrochureLabel = $_clean; }
	}

	// (4) Skills Framework — per-course cms/block first, regex fallback.
	// Typical body shape:
	//   <h2>Skills Framework</h2>
	//   <p>This course follows the guideline of <strong>{Title} {Code} TSC</strong> under {Framework} Skills Framework</p>
	// TSC Title / TSC Code are derived from the body below.
	list($_sfExtracted, $shortDescription) = $_extractSection('Skills' . $_WS . '+Framework', $shortDescription);
	$_skillsFrameworkRawHtml = $_courseSectionHtml('skills_framework');
	if ($_skillsFrameworkRawHtml === '') { $_skillsFrameworkRawHtml = $_sfExtracted; }
	unset($_sfExtracted);
	$_skillsTitle = '';
	$_skillsCode  = '';
	if ($_skillsFrameworkRawHtml !== '') {
		// Flatten the whole section body to text — the code may sit in a
		// different <strong> from the title (e.g. Power Apps WSQ course has
		// 3 separate strongs: "{Title}", "{Code}", "TSC"). Looking at only
		// the first strong would miss the code entirely.
		$_haystack = html_entity_decode(strip_tags($_skillsFrameworkRawHtml), ENT_QUOTES | ENT_HTML5, 'UTF-8');
		$_haystack = preg_replace('#[\x{00A0}\x{2007}\x{202F}]#u', ' ', $_haystack);
		$_haystack = preg_replace('#\s+#u', ' ', trim($_haystack));

		// Code lookup — strategy 1: anchor on the " T"/" TSC" marker.
		// Strategy 2: structured uppercase-dash-digits pattern.
		$_codeFull = '';
		if (preg_match('#([A-Z]{2,}(?:-[A-Z][A-Z0-9]*)+(?:[-.][0-9][0-9.\-]*)?)\s+(T(?:SC)?)\b#u', $_haystack, $_cm)) {
			$_skillsCode = trim($_cm[1] . ' ' . $_cm[2]);
			$_codeFull   = $_cm[0];
		} elseif (preg_match('#([A-Z]{2,}(?:-[A-Z][A-Z0-9]*)+(?:[-.][0-9][0-9.\-]*))#u', $_haystack, $_cm)) {
			$_skillsCode = trim($_cm[1]);
			$_codeFull   = $_cm[0];
		}

		// Title — start from the haystack, slice the code out, then trim the
		// surrounding boilerplate prefix/suffix ("This course follows the
		// guideline of … under … Skills Framework"). What's left is the
		// human-readable framework title.
		$_titleSrc = $_haystack;
		if ($_codeFull !== '') {
			$_titleSrc = preg_replace('#\s*' . preg_quote($_codeFull, '#') . '\s*#u', ' ', $_titleSrc);
		}
		$_titleSrc = preg_replace('#^.*?follows\s+the\s+guideline\s+of\s+#iu', '', $_titleSrc);
		$_titleSrc = preg_replace('#\s+under\s+.*?Skills\s+Framework\s*\.?\s*$#iu', '', $_titleSrc);
		$_skillsTitle = trim($_titleSrc);
	}

	// (5) Certification section.
	// SG store: ALWAYS render a standardised writeup keyed off the SKU
	// prefix, regardless of whatever heading variant ("Certificate" /
	// "Certification" / "Certifications") the legacy description used.
	// - TGS-* SKUs (WSQ courses) → Certificate of Completion + OpenCert
	// - All other SG SKUs (C-prefix etc.) → Certificate of Completion only
	// Other stores keep the original per-course extraction.
	if (Mage::app()->getStore()->getId() == 1) {
		// Strip whatever heading variant the description carries so it
		// doesn't double-render inside the course narrative below.
		list($_certIgnored, $shortDescription) = $_extractSection('(?:Certifications?|Certificate)', $shortDescription);
		unset($_certIgnored);

		$_isWsqCert = (stripos((string) $_product->getSku(), 'TGS-') === 0);
		$_certificationHtml  = '<ul class="cert-bullets">';
		$_certificationHtml .= '<li><strong>Certificate of Completion from Tertiary Infotech</strong> - Upon meeting at least 75% attendance and passing the assessment(s), participants will receive a Certificate of Completion from Tertiary Infotech.</li>';
		if ($_isWsqCert) {
			$_certificationHtml .= '<li><strong>OpenCerts from SkillsFuture Singapore</strong> - After passing the assessment(s) and achieving at least 75% attendance, participants will receive a OpenCert (aka Statement of Achievement) from SkillsFuture Singapore, certifying that they have achieved the Competency Standard(s) in the above Skills Framework.</li>';
		}
		$_certificationHtml .= '</ul>';

		// Append per-course certification supplement from the cms_block
		// `course_<sku>_certification`. Carries vendor-specific copy like
		// "Certification Exam at Pearson Vue" for CompTIA courses (migration
		// 151). The SG baseline bullets above are hardcoded and the
		// per-course block ALSO has its own baseline (migration 143), so we
		// can't append the whole block or we'd double the bullets — extract
		// just the Pearson-Vue-and-after suffix and append that.
		$_certBlock = $_courseSectionHtml('certification');
		if ($_certBlock !== '' && preg_match('#<p>\s*<strong>\s*Certification Exam at Pearson Vue\s*</strong>\s*</p>.*$#siu', $_certBlock, $_pvMatch)) {
			$_certificationHtml .= $_pvMatch[0];
		}
	} else {
		// Other stores (MY/GH/NG/BT/IN/Infotech): strip the heading variant
		// from short_description so it doesn't double-render, then resolve
		// the cert body in priority order:
		//   1. per-course cms/block `course_<sku>_certification`
		//   2. per-store global cms/block `course_certification` (migration 143)
		//   3. whatever the regex extracted from short_description
		list($_certExtracted, $shortDescription) = $_extractSection('(?:Certifications?|Certificate)', $shortDescription);
		$_certificationHtml = $_courseSectionHtml('certification');
		if ($_certificationHtml === '') {
			$_certificationHtml = trim($this->getLayout()->createBlock('cms/block')->setBlockId('course_certification')->toHtml());
		}
		if ($_certificationHtml === '') {
			$_certificationHtml = $_certExtracted;
		}
		unset($_certExtracted);
	}

	// (6) Funding and Grant — MY-side pattern. Per-course cms/block first,
	// regex fallback for legacy content still in short_description.
	// SG/GH/NG/BT/IN typically don't carry this section, so block + regex
	// both return empty and no card renders.
	list($_fgExtracted, $shortDescription) = $_extractSection('Funding' . $_WS . '+(?:and|&amp;|&)' . $_WS . '+Grant', $shortDescription);
	// Merged single block: funding_and_grant cms/block holds either WSQ
	// narrative (SG WSQ) or HRD Corp content (MY) per course. When the WSQ
	// card has ALREADY consumed it ($_hasWsqFunding == true), suppress the
	// separate Funding and Grant card to avoid rendering the same content
	// twice. Otherwise (non-WSQ products), this card renders the block.
	if ($_hasWsqFunding) {
		$_fundingAndGrantHtml = '';
	} else {
		$_fundingAndGrantHtml = $_courseSectionHtml('funding_and_grant');
		if ($_fundingAndGrantHtml === '') { $_fundingAndGrantHtml = $_fgExtracted; }
	}
	unset($_fgExtracted);

	//Rich snippets
	$useRichSnippets = ($helperSnippets->isEnabledOnProductPage() && $productTypeId !== 'grouped');
	$priceProperties = '';
	if ($useRichSnippets)
	{
		$priceProperties = $helperSnippets->getPriceProperties($_product); //Has to be called before getOfferItemscope
	}

	//Get grid classes for product page sections
	$grid = $helperThis->getGridClasses();

	//Product collaterals
	//--------------------------------------------------------------
	$section = array();
	$relatedProductsHtml = '';
	$upsellProductsHtml = '';
	
	//Related products.
	//If related products not assigned to collateral data container.
	if (!$theme->getCfg('product_page/collateral_related'))
	{
		$replaceRelated = $theme->getCfg('product_page/replace_related');
		if ($replaceRelated == 1) //don't replace with static block
		{
			if ($tmpHtml = trim($this->getChildHtml('related_products_wrapper')))
				$relatedProductsHtml = $tmpHtml;
			//$relatedProductsHtml = trim($this->getChildHtml('related_products_wrapper'));
		}
		elseif ($replaceRelated == 2) //if related is empty, replace with static block
		{
			if ($tmpHtml = trim($this->getChildHtml('related_products_wrapper')))
				$relatedProductsHtml = $tmpHtml;
			else //related empty
				if ($tmpHtml = $this->getChildHtml('block_product_replace_related'))
					$relatedProductsHtml = '<div class="block_product_replace_related">'. $tmpHtml .'</div>';
		}
		elseif ($replaceRelated == 3) //replace with static block
		{
			if ($tmpHtml = $this->getChildHtml('block_product_replace_related'))
				$relatedProductsHtml = '<div class="block_product_replace_related">'. $tmpHtml .'</div>';
		}
	}

	//Up-sell products.
	//If up-sell products not assigned to collateral data container.
	if (!$theme->getCfg('product_page/collateral_upsell'))
	{
		$replaceUpsell = $theme->getCfg('product_page/replace_upsell');
		if ($replaceUpsell == 1) //don't replace with static block
		{
			if ($tmpHtml = trim($this->getChildHtml('upsell_products_wrapper')))
				$upsellProductsHtml = $tmpHtml;
			//$upsellProductsHtml = $this->getChildHtml('upsell_products_wrapper');
		}
		elseif ($replaceUpsell == 2) //if upsell is empty, replace with static block
		{
			if ($tmpHtml = trim($this->getChildHtml('upsell_products_wrapper')))
				$upsellProductsHtml = $tmpHtml;
			else //upsell empty
				if ($tmpHtml = $this->getChildHtml('block_product_replace_upsell'))
					$upsellProductsHtml = '<div class="block_product_replace_upsell">'. $tmpHtml .'</div>';
		}
		elseif ($replaceUpsell == 3) //replace with static block
		{
			if ($tmpHtml = $this->getChildHtml('block_product_replace_upsell'))
				$upsellProductsHtml = '<div class="block_product_replace_upsell">'. $tmpHtml .'</div>';
		}
	}

	//Assign blocks to selected position
	$p = array();

	// ----------------------------------------------------------------------
	// Recommended Courses (tabbed) + right-column Photo Gallery
	//
	// Defaults from Ultimo:
	//   related_position = secCol_3   (right column)
	//   upsell_position  = lowerPrimCol_2 (full-width bottom)
	//
	// We override that wiring:
	//   * Bottom of page: ONE block "Recommended Courses" with two tabs —
	//     "You May Be Interested" (upsells) and "Related Courses". Lets the
	//     learner flip between two angles of cross-sell without scrolling
	//     twice. Tabs hidden if either list is empty.
	//   * Right column (was Related): a Photo Gallery sourced from the
	//     product's standard Media Gallery (Manage Images). Skips the base
	//     image so we don't double-show the hero. Renders nothing if the
	//     product has no extra gallery images — no empty wrapper.
	// ----------------------------------------------------------------------

	$relatedTabHtml = trim((string) $relatedProductsHtml);
	$upsellTabHtml  = trim((string) $upsellProductsHtml);
	$recommendedHtml = '';
	if ($relatedTabHtml !== '' || $upsellTabHtml !== '') {
		$tabs = array();
		if ($upsellTabHtml !== '') {
			$tabs['upsell'] = array(
				'label' => $this->__('Recommended Courses'),
				'html'  => $upsellTabHtml,
			);
		}
		if ($relatedTabHtml !== '') {
			$tabs['related'] = array(
				'label' => $this->__('Related Courses'),
				'html'  => $relatedTabHtml,
			);
		}
		$activeKey = array_key_first($tabs);
		$recommendedHtml .= '<div class="box-collateral box-recommended">';
		// Parent heading intentionally omitted — the tab labels carry the
		// section name; an extra "Recommended Courses" h3 above them was
		// visually redundant.
		$recommendedHtml .= '<ul class="recommended-tabs" role="tablist">';
		foreach ($tabs as $k => $tab) {
			$active = ($k === $activeKey) ? ' is-active' : '';
			$recommendedHtml .= '<li class="recommended-tab' . $active . '" role="tab" data-target="recommended-' . $k . '" aria-selected="' . ($k === $activeKey ? 'true' : 'false') . '">' . $tab['label'] . '</li>';
		}
		$recommendedHtml .= '</ul>';
		foreach ($tabs as $k => $tab) {
			$active = ($k === $activeKey) ? ' is-active' : '';
			$recommendedHtml .= '<div class="recommended-panel' . $active . '" id="recommended-' . $k . '" role="tabpanel">';
			// Strip the original block's own h3 — the parent block owns the heading now.
			$panel = preg_replace('#<h3 class="section-title[^"]*">.*?</h3>#s', '', $tab['html'], 1);
			$recommendedHtml .= $panel;
			$recommendedHtml .= '</div>';
		}
		$recommendedHtml .= '</div>';
		// JS tab toggle — vanilla, no jQuery dependency.
		if (count($tabs) > 1) {
			$recommendedHtml .= <<<HTML
<script>
(function(){
	var box = document.currentScript.previousElementSibling;
	if (!box) return;
	var tabs = box.querySelectorAll('.recommended-tab');
	var panels = box.querySelectorAll('.recommended-panel');
	// Owl Carousel 1.x measures width at init time; sliders living inside a
	// display:none tab read width=0 and fall back to a single column. When a
	// tab is activated we trigger an Owl refresh so the carousel re-measures
	// against the now-visible panel.
	function refreshSliders(panel) {
		if (!window.jQuery) return;
		var sliders = panel.querySelectorAll('.itemslider');
		sliders.forEach(function(el){
			var \$el = window.jQuery(el);
			var data = \$el.data('owlCarousel');
			if (data) {
				if (typeof data.reinit === 'function') {
					data.reinit();
				} else if (typeof \$el.trigger === 'function') {
					\$el.trigger('owl.refresh');
				}
			}
		});
	}
	tabs.forEach(function(t){
		t.addEventListener('click', function(){
			tabs.forEach(function(x){ x.classList.remove('is-active'); x.setAttribute('aria-selected','false'); });
			panels.forEach(function(x){ x.classList.remove('is-active'); });
			t.classList.add('is-active');
			t.setAttribute('aria-selected','true');
			var target = document.getElementById(t.getAttribute('data-target'));
			if (target) {
				target.classList.add('is-active');
				refreshSliders(target);
			}
		});
	});
})();
</script>
HTML;
