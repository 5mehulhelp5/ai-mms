document.addEventListener("DOMContentLoaded", function () {
    if (window.location.hash === "#trainers") {
        const tab = document.getElementById("tab-trainers");
        const link = tab ? tab.querySelector("a") : null;

        // click the link if found
        if (link) {
            link.click();
        }

        // scroll to the element smoothly
        if (tab) {
            tab.scrollIntoView({ behavior: "smooth", block: "start" });
        }
    }

    // Date-label shortener for course-date <select> options. iOS Safari
    // renders <select> as a native picker overlay; CSS can't affect option
    // wrapping or font size inside that overlay. The only thing the picker
    // shows is the literal text content of <option>, so we shorten it here
    // — drop the parens around the day-of-week and abbreviate any 4-letter
    // weekday ("Thur"/"Tues") to 3 letters so labels like
    // "22/23 Aug 2026 (Thur/Fri)" become "22/23 Aug 2026 Thu/Fri" and
    // fit on one row on a phone-width picker.
    document.querySelectorAll('select.product-custom-option option').forEach(function (opt) {
        var t = opt.textContent;
        if (!t || !/\d{4}/.test(t)) return; // only touch year-bearing labels
        var shortened = t
            .replace(/\s*\(([A-Za-z]+\/[A-Za-z]+)\)\s*$/, ' $1')
            .replace(/\bThur\b/g, 'Thu')
            .replace(/\bTues\b/g, 'Tue')
            .replace(/\s+/g, ' ')
            .trim();
        if (shortened !== t) opt.textContent = shortened;
    });
});

