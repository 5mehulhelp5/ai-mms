				// no funding option — then no pill renders.
				$_fundingOptId = null;
				if ($productType == 'virtual') {
					foreach ($_product->getOptions() as $_opt) {
						if (stripos($_opt->getTitle(), 'Funding Eligibility') !== false) {
							$_fundingOptId = $_opt->getId();
							break;
						}
					}
				}
				if ($productType == 'simple') {
					echo '<h2>Price</h2>';
				} elseif ($productType == 'virtual') {
					echo '<h2 class="course-fee-heading">Course Fee';
					if ($_fundingOptId) {
						echo '<span class="funding-tag" id="funding-tag" data-funding-opt="' . (int) $_fundingOptId . '">Before Funding</span>';
					}
					echo '</h2>';
				} else {
					echo '<h2>Information</h2>';
				}
				?>
				<?php if ($_fundingOptId): ?>
				<script type="text/javascript">
				/* Dynamic "Before Funding / After Funding" pill beside the Course
				   Fee heading. It registers its OWN change-listener on the
				   Funding Eligibility radios (event delegation on the add-to-cart
				   form) and never touches reloadPrice() — so the existing dynamic
				   price/GST recalculation is completely unaffected. */
				(function () {
					var tag = document.getElementById('funding-tag');
					if (!tag) { return; }
					var optName = 'options[' + tag.getAttribute('data-funding-opt') + ']';
					function sync() {
						var rs = document.querySelectorAll('input[type="radio"][name="' + optName + '"]');
						var picked = false;
						for (var i = 0; i < rs.length; i++) { if (rs[i].checked) { picked = true; break; } }
						tag.textContent = picked ? 'After Funding' : 'Before Funding';
						tag.className = 'funding-tag' + (picked ? ' funding-tag--after' : '');
					}
					function bind() {
						var form = document.getElementById('product_addtocart_form');
						if (form) {
							form.addEventListener('change', function (e) {
								if (e.target && e.target.name === optName) { sync(); }
							});
						}
						sync();
					}
					if (document.readyState === 'loading') {
						document.addEventListener('DOMContentLoaded', bind);
					} else { bind(); }
				})();
				</script>
				<?php endif; ?>

