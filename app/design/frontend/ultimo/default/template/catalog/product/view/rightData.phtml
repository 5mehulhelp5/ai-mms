<?php
/**
 * Course Information card — rendered in the product page LEFT column
 * directly under the product image. Companion templates / blocks:
 *   - cms_block: post_course_support
 *   - cms_block: course_cancellation_policy
 *   - cms_block: grant            (residual "Additional Information")
 * Styled via .course-info-card in skin/.../css/custom.css.
 */
$_product       = $this->getProduct();
$currentStoreId = Mage::app()->getStore()->getId();
$attSetId       = (int) $_product->getAttributeSetId();
$isTour         = ($attSetId === 21);
$sectionTitle   = $isTour ? 'Tour Information' : 'Course Information';

$_rows = array();
if ($_product->getSessions()) {
    $_rows[] = array('label' => 'Sessions',       'value' => $_product->getSessions() . ' day' . ((int) $_product->getSessions() === 1 ? '' : 's'), 'icon' => 'calendar');
}
if ($_product->getDuration()) {
    $_rows[] = array('label' => 'Duration',       'value' => $_product->getDuration() . ' hrs', 'icon' => 'clock');
}
if ($_product->getAttributeText('level')) {
    $_rows[] = array('label' => 'Level',          'value' => $_product->getAttributeText('level'), 'icon' => 'bar');
}
if ($_product->getAdditional_note()) {
    $_rows[] = array('label' => 'Additional Note','value' => $_product->getAdditional_note(), 'icon' => 'note', 'wide' => true);
}

$_icons = array(
    'calendar' => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
    'clock'    => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    'bar'      => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
    'note'     => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>',
    'pin'      => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
);
?>
<section class="course-info-card" aria-labelledby="course-info-heading">
    <header class="course-info-card__header">
        <h3 id="course-info-heading" class="course-info-card__title"><?php echo $this->escapeHtml($sectionTitle); ?></h3>
    </header>

    <?php if (!empty($_rows)): ?>
    <ul class="course-info-grid">
        <?php foreach ($_rows as $_row): ?>
            <li class="course-info-tile<?php echo !empty($_row['wide']) ? ' course-info-tile--wide' : ''; ?>">
                <span class="course-info-tile__icon" aria-hidden="true"><?php echo $_icons[$_row['icon']]; ?></span>
                <span class="course-info-tile__body">
                    <span class="course-info-tile__label"><?php echo $this->escapeHtml($_row['label']); ?></span>
                    <span class="course-info-tile__value"><?php echo $this->escapeHtml($_row['value']); ?></span>
                </span>
            </li>
        <?php endforeach; ?>
    </ul>
    <?php endif; ?>

    <?php if (!$isTour): ?>
    <div class="course-info-venue">
        <div class="course-info-venue__head">
            <span class="course-info-venue__icon" aria-hidden="true"><?php echo $_icons['pin']; ?></span>
            <h4 class="course-info-venue__title">Venue</h4>
        </div>
        <div class="course-info-venue__body">
            <?php
            if ($currentStoreId == 2) {
                $venueBlockId = 'my_venue_address';
            } elseif ($_product->getSku() === 'TGS-2025053916') {
                $venueBlockId = 'sg_venue_address_hydroponics';
            } else {
                $venueBlockId = 'sg_venue_address';
            }
            echo $this->getLayout()->createBlock('cms/block')->setBlockId($venueBlockId)->toHtml();
            ?>
        </div>
    </div>
    <?php endif; ?>
</section>
