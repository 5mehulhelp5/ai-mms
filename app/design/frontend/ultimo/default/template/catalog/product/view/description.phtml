<?php
/**
 * Product description template — renders inside the "Course Details" tab.
 *
 * Layout: two cards.
 *   1. What You'll Learn — wraps the product description (topics/lessons).
 *   2. Assessment        — WSQ courses only (SKU `TGS-`). Reads the
 *                          `assessment_methods` multiselect attribute,
 *                          falling back to Written Exam + Practical Exam.
 *
 * Card chrome matches the `course-policy-card` family used elsewhere on
 * the product page so the tab content reads visually consistent with the
 * primary-column cards.
 *
 * Non-WSQ products simply skip the Assessment card.
 *
 * @see Mage_Catalog_Block_Product_View_Description
 */
$p = $this->getProduct();
$productTypeD = $p->getTypeId();
$txt = ($productTypeD == "virtual") ? "Course Details" : "Book Description";
$_description = $p->getDescription();

// WSQ courses are identified by TGS- SKU prefix.
$_sku   = (string) $p->getSku();
$_isWsq = (stripos($_sku, 'TGS-') === 0);

// Resolve assessment_methods multiselect labels for WSQ courses only.
$_assessmentLabels = [];
if ($_isWsq) {
    $_assessmentRaw = (string) $p->getAssessmentMethods();
    if ($_assessmentRaw === '') {
        // Backfill defaults — read by label so we don't hardcode option IDs.
        $_assessmentLabels = ['Written Exam', 'Practical Exam'];
    } else {
        $_attr   = Mage::getModel('eav/entity_attribute')->loadByCode('catalog_product', 'assessment_methods');
        $_optMap = [];
        if ($_attr->getId()) {
            foreach ($_attr->getSource()->getAllOptions(false) as $_opt) {
                if (!empty($_opt['value'])) {
                    $_optMap[(string) $_opt['value']] = (string) $_opt['label'];
                }
            }
        }
        foreach (explode(',', $_assessmentRaw) as $_id) {
            $_id = trim($_id);
            if ($_id !== '' && isset($_optMap[$_id])) {
                $_assessmentLabels[] = $_optMap[$_id];
            }
        }
        if (empty($_assessmentLabels)) {
            $_assessmentLabels = ['Written Exam', 'Practical Exam'];
        }
    }
}
?>
<?php if ($_description): ?>
    <h2 class="course-details-tab-heading"><?php echo $this->__($txt); ?></h2>

    <section class="course-policy-card course-policy-card--learning course-details-card">
        <header class="course-policy-card__header">
            <span class="course-policy-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.66 4 3 6 3s6-1.34 6-3v-5"/></svg>
            </span>
            <h3 class="course-policy-card__title"><?php echo $this->__("What You'll Learn"); ?></h3>
        </header>
        <div class="course-policy-card__body std">
            <?php echo $this->helper('catalog/output')->productAttribute($p, $_description, 'description'); ?>
        </div>
    </section>

    <?php if ($_isWsq && !empty($_assessmentLabels)): ?>
        <section class="course-policy-card course-policy-card--assessment course-details-card">
            <header class="course-policy-card__header">
                <span class="course-policy-card__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                </span>
                <h3 class="course-policy-card__title"><?php echo $this->__('Assessment'); ?></h3>
            </header>
            <div class="course-policy-card__body">
                <ul class="course-assessment-list">
                    <?php foreach ($_assessmentLabels as $_label): ?>
                        <li><?php echo $this->escapeHtml($_label); ?></li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </section>
    <?php endif; ?>

    <script type="text/javascript">
    /* Promote syllabus topic headings to <h3> for proper heading semantics.
       A topic heading is a <p> whose entire content is a single <strong>
       (e.g. <p><strong>LU1: ...</strong></p>). Italic item rows (<p><em>)
       and list items are deliberately left untouched. Runs synchronously
       right after the card above, so the swap lands before first paint. */
    (function () {
        var s = document.currentScript;
        var card = s ? s.previousElementSibling : null;
        while (card && !(card.classList && card.classList.contains('course-policy-card--learning'))) {
            card = card.previousElementSibling;
        }
        var std = card ? card.querySelector('.course-policy-card__body.std') : null;
        if (!std) {
            std = document.querySelector('#acctab-description + .panel .course-policy-card--learning .std');
        }
        if (!std) { return; }
        var ps = std.querySelectorAll('p');
        for (var i = 0; i < ps.length; i++) {
            var p = ps[i], strong = p.querySelector('strong');
            if (strong
                && strong.textContent.trim() !== ''
                && p.textContent.trim() === strong.textContent.trim()) {
                var h3 = document.createElement('h3');
                h3.className = 'course-topic-h3';
                h3.innerHTML = strong.innerHTML;
                p.parentNode.replaceChild(h3, p);
            }
        }

        /* Legacy descriptions use <p>• …</p> (often wrapped in <em>) instead
           of <ul><li>…</li></ul>, which bypasses the green-bullet card CSS.
           Group consecutive bullet <p>s into a single <ul>, strip the leading
           bullet glyph, and unwrap a surrounding <em>/<i> so the text isn't
           italic. */
        var BULLET_RE = /^\s*[•·●◦⁃∙]\s*/;
        var children = Array.prototype.slice.call(std.children);
        var run = null;
        function flush() {
            if (!run || run.items.length === 0) { run = null; return; }
            var ul = document.createElement('ul');
            for (var k = 0; k < run.items.length; k++) {
                var li = document.createElement('li');
                li.innerHTML = run.items[k];
                ul.appendChild(li);
            }
            run.anchor.parentNode.insertBefore(ul, run.anchor);
            for (var k = 0; k < run.nodes.length; k++) {
                run.nodes[k].parentNode.removeChild(run.nodes[k]);
            }
            run = null;
        }
        for (var i = 0; i < children.length; i++) {
            var node = children[i];
            if (node.tagName !== 'P') { flush(); continue; }
            var inner = node.innerHTML;
            var unwrap = inner.match(/^\s*<(em|i)>([\s\S]*)<\/\1>\s*$/i);
            if (unwrap) { inner = unwrap[2]; }
            if (!BULLET_RE.test(node.textContent) && !BULLET_RE.test(inner)) {
                flush(); continue;
            }
            inner = inner.replace(BULLET_RE, '');
            if (!run) { run = { anchor: node, items: [], nodes: [] }; }
            run.items.push(inner);
            run.nodes.push(node);
        }
        flush();
    })();
    </script>
    <script type="text/javascript">
    /* Two post-tab-render shims, run on DOMContentLoaded so the tab block
       (rendered later in the page) is already in the DOM.

       1) Mobile accordion label filler: tabs.phtml emits <h2 class="acctab">
          with empty text content; only the desktop <li id="tab-X"><a> carries
          the visible label. Copy the desktop label across so the mobile
          accordion headers are tappable.

       2) No-comment review compactor: tag review <dd>s whose body between
          the ratings table and the date is empty / "N/A" / "-" so CSS can
          drop the dashed divider and tighten spacing. */
    document.addEventListener('DOMContentLoaded', function () {
        var acctabs = document.querySelectorAll('#product-tabs .acctab');
        for (var i = 0; i < acctabs.length; i++) {
            var acc = acctabs[i];
            if (acc.textContent.trim() !== '') continue;
            var alias = acc.id.replace(/^acctab-/, '');
            var src = document.querySelector('#tab-' + alias + ' a');
            if (src) acc.textContent = src.textContent.trim();
        }

        var dds = document.querySelectorAll('.box-reviews dl dd');
        for (var j = 0; j < dds.length; j++) {
            var dd = dds[j];
            var table = dd.querySelector('.ratings-table');
            var date  = dd.querySelector('.date');
            if (!date) continue;
            var startFrom = table || dd.firstChild;
            var node = startFrom.nextSibling, txt = '';
            while (node && node !== date) {
                txt += node.nodeType === 3 ? node.nodeValue
                     : (node.nodeType === 1 ? node.textContent : '');
                node = node.nextSibling;
            }
            var norm = txt.replace(/[\s ]+/g, '').toLowerCase();
            if (!norm || norm === 'n/a' || norm === 'na' || norm === '-' || norm === '--') {
                dd.classList.add('review-no-comment');
            }
        }
    });
    </script>
<?php endif; ?>
