/**
 * Product description template
 *
 * @see Mage_Catalog_Block_Product_View_Description
 */
 $p = $this->getProduct(); $productTypeD = $p->getTypeId();
 if($productTypeD=="virtual") { $txt = "Course Details"; } else { $txt = "Book Description"; }
?>
<?php $_description = $p->getDescription(); ?>
<?php if ($_description): ?>
    <h2><?php echo $txt; ?></h2>
    <div class="std">
        <?php echo $this->helper('catalog/output')->productAttribute($this->getProduct(), $_description, 'description') ?>
    </div>
    <script type="text/javascript">
    /* Promote syllabus topic headings to <h3> for proper heading semantics.
       A topic heading is a <p> whose entire content is a single <strong>
       (e.g. <p><strong>LU1: ...</strong></p>). Italic item rows (<p><em>)
       and list items are deliberately left untouched. Runs synchronously
       right after the .std above, so the swap lands before first paint. */
    (function () {
        var s = document.currentScript;
        var std = s ? s.previousElementSibling : null;
        if (!std || !std.classList || !std.classList.contains('std')) {
            std = document.querySelector('#acctab-description + .panel .std');
        }
        if (!std) { return; }
        var ps = std.querySelectorAll('p');
        for (var i = 0; i < ps.length; i++) {
            var p = ps[i], strong = p.querySelector('strong');
            if (strong
                && strong.textContent.trim() !== ''
                && p.textContent.trim() === strong.textContent.trim()) {
                var h3 = document.createElement('h3');
                h3.className = 'course-topic-h3';
                h3.innerHTML = strong.innerHTML;
                p.parentNode.replaceChild(h3, p);
            }
        }
    })();
    </script>
    <script type="text/javascript">
    /* Two post-tab-render shims, run on DOMContentLoaded so the tab block
       (rendered later in the page) is already in the DOM.

       1) Mobile accordion label filler: tabs.phtml emits <h2 class="acctab">
          with empty text content; only the desktop <li id="tab-X"><a> carries
          the visible label. Copy the desktop label across so the mobile
          accordion headers are tappable.

       2) No-comment review compactor: tag review <dd>s whose body between
          the ratings table and the date is empty / "N/A" / "-" so CSS can
          drop the dashed divider and tighten spacing. */
    document.addEventListener('DOMContentLoaded', function () {
        // (1) acctab labels
        var acctabs = document.querySelectorAll('#product-tabs .acctab');
        for (var i = 0; i < acctabs.length; i++) {
            var acc = acctabs[i];
            if (acc.textContent.trim() !== '') continue;
            var alias = acc.id.replace(/^acctab-/, '');
            var src = document.querySelector('#tab-' + alias + ' a');
            if (src) acc.textContent = src.textContent.trim();
        }

        // (2) compact no-comment reviews
        var dds = document.querySelectorAll('.box-reviews dl dd');
        for (var j = 0; j < dds.length; j++) {
            var dd = dds[j];
            var table = dd.querySelector('.ratings-table');
            var date  = dd.querySelector('.date');
            if (!date) continue;
            var startFrom = table || dd.firstChild;
            var node = startFrom.nextSibling, txt = '';
            while (node && node !== date) {
                txt += node.nodeType === 3 ? node.nodeValue
                     : (node.nodeType === 1 ? node.textContent : '');
                node = node.nextSibling;
            }
            var norm = txt.replace(/[\s ]+/g, '').toLowerCase();
            if (!norm || norm === 'n/a' || norm === 'na' || norm === '-' || norm === '--') {
                dd.classList.add('review-no-comment');
            }
        }
    });
    </script>
<?php endif; ?>
