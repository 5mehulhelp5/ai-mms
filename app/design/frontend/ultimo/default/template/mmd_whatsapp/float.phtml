<script type="text/javascript">
//<![CDATA[
(function () {
    var root = document.getElementById('mmd-wa');
    if (!root) { return; }
    var launcher = document.getElementById('mmd-wa-launcher');
    var popup    = document.getElementById('mmd-wa-popup');
    var closeBtn = document.getElementById('mmd-wa-close');

    function open() {
        root.classList.add('is-open');
        popup.hidden = false;
        launcher.setAttribute('aria-expanded', 'true');
    }
    function close() {
        root.classList.remove('is-open');
        popup.hidden = true;
        launcher.setAttribute('aria-expanded', 'false');
    }
    function toggle() {
        if (root.classList.contains('is-open')) { close(); } else { open(); }
    }

    launcher.addEventListener('click', toggle);
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' || e.keyCode === 27) { close(); }
    });
})();
//]]>
</script>
