<?php
/* ----------------------------------------------------------------------
 * SEO: self-canonical + cross-store hreflang cluster.
 *
 * Without this, every country domain (.com.my / .com.ng / .com.gh / .com.sg)
 * looks like a duplicate of the others to Google, and ~6,450 pages end up in
 * "Crawled - currently not indexed" (Search Console, 2026-05).
 *
 * Per-page strategy:
 *   - Product/category pages: per-store URL is resolved from core_url_rewrite
 *     so different per-store url_keys (e.g. /…-malaysia.html) are honoured.
 *   - Everything else (homepage, CMS, search): swap the host on the current path.
 *
 * Infotech (store_id=7) is excluded from the hreflang cluster because it is
 * a different brand (Tertiary Infotech Academy), not a country variant of
 * the Tertiary Courses storefront. It still gets a self-canonical.
 * ---------------------------------------------------------------------- */
$_curStore = Mage::app()->getStore();
$_curStoreId = (int) $_curStore->getId();
$_curBase = rtrim($_curStore->getBaseUrl(Mage_Core_Model_Store::URL_TYPE_LINK), '/');

// Use the public-facing URL (post-rewrite) for canonical/hreflang. Request URI
// reflects the internal route (/catalog/category/view/id/3), not what the user typed.
$_curFullUrl = $this->helper('core/url')->getCurrentUrl();
$_curPath = parse_url($_curFullUrl, PHP_URL_PATH) ?: '/';
$_selfCanonical = $_curBase . $_curPath;

// hreflang map. Only stores with a live DNS-pointed domain. Adding a store here
// before its DNS is cut over makes Google crawl URLs that 404 — actively harmful.
// To enable a reserved store: confirm DNS resolves to this hosting, then add the
// store_id => 'en-XX' line and the matching .htaccess sitemap rewrite + robots
// Sitemap directive.
// Reserved (not yet live): 5 = bhutan, 6 = india. Infotech (7) is intentionally
// outside the cluster — it's a different brand, not a country variant.
$_hreflangMap = [
    1 => 'en-SG', // singapore
    2 => 'en-MY', // malaysia
    3 => 'en-GH', // ghana
    4 => 'en-NG', // nigeria
];

// Resolve per-store paths for the current page.
$_perStorePath = [];
$_product  = Mage::registry('current_product');
$_category = Mage::registry('current_category');
try {
    if ($_product && $_product->getId()) {
        $_db = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_rewriteTable = Mage::getSingleton('core/resource')->getTableName('core/url_rewrite');
        $_select = $_db->select()
            ->from($_rewriteTable, ['store_id', 'request_path'])
            ->where('product_id = ?', (int) $_product->getId())
            ->where('category_id IS NULL OR category_id = 0')
            ->where('is_system = ?', 1)
            ->where('store_id IN (?)', array_keys($_hreflangMap));
        foreach ($_db->fetchAll($_select) as $_row) {
            $_perStorePath[(int) $_row['store_id']] = '/' . ltrim($_row['request_path'], '/');
        }
    } elseif ($_category && $_category->getId()) {
        $_db = Mage::getSingleton('core/resource')->getConnection('core_read');
        $_rewriteTable = Mage::getSingleton('core/resource')->getTableName('core/url_rewrite');
        $_select = $_db->select()
            ->from($_rewriteTable, ['store_id', 'request_path'])
            ->where('category_id = ?', (int) $_category->getId())
            ->where('product_id IS NULL OR product_id = 0')
            ->where('is_system = ?', 1)
            ->where('store_id IN (?)', array_keys($_hreflangMap));
        foreach ($_db->fetchAll($_select) as $_row) {
            $_perStorePath[(int) $_row['store_id']] = '/' . ltrim($_row['request_path'], '/');
        }
    }
} catch (Exception $_e) {
    Mage::logException($_e);
}
// Magento's built-in catalog canonical (controlled by web/seo/use_canonical_for_*)
// already emits <link rel="canonical"> for product/category pages. Don't duplicate
// it — only emit our self-canonical when no product/category is in the registry
// (homepage, CMS pages, search, custom routes).
$_emitOurCanonical = (!$_product || !$_product->getId()) && (!$_category || !$_category->getId());
?>
<?php if ($_emitOurCanonical): ?>
<link rel="canonical" href="<?php echo htmlspecialchars($_selfCanonical, ENT_QUOTES, 'UTF-8'); ?>" />
<?php endif; ?>
<?php
$_stores = Mage::app()->getStores();
foreach ($_hreflangMap as $_storeId => $_lang):
    if (!isset($_stores[$_storeId]) || !$_stores[$_storeId]->getIsActive()) continue;
    $_storeBase = rtrim($_stores[$_storeId]->getBaseUrl(Mage_Core_Model_Store::URL_TYPE_LINK), '/');
    $_storePath = $_perStorePath[$_storeId] ?? $_curPath;
    $_storeUrl  = $_storeBase . $_storePath;
?>
<link rel="alternate" hreflang="<?php echo $_lang; ?>" href="<?php echo htmlspecialchars($_storeUrl, ENT_QUOTES, 'UTF-8'); ?>" />
<?php endforeach; ?>
<?php // x-default points at SG (store_id=1), the primary commercial market.
$_xdBase = isset($_stores[1]) ? rtrim($_stores[1]->getBaseUrl(Mage_Core_Model_Store::URL_TYPE_LINK), '/') : $_curBase;
$_xdPath = $_perStorePath[1] ?? $_curPath;
?>
<link rel="alternate" hreflang="x-default" href="<?php echo htmlspecialchars($_xdBase . $_xdPath, ENT_QUOTES, 'UTF-8'); ?>" />

<?php
/* ----------------------------------------------------------------------
 * Open Graph + Twitter card. Restores rich previews on Facebook, LinkedIn,
 * WhatsApp, Slack, X — without these the share preview shows a blank/random
 * image picked by each crawler.
 *
 * og:image: product page → product main image; otherwise → store logo.
 * og:type:  product page → "product"; otherwise → "website".
 * ---------------------------------------------------------------------- */
$_ogTitle = strip_tags((string) $this->getTitle());
$_ogDesc  = strip_tags((string) $this->getDescription());
$_ogUrl   = $_selfCanonical;
$_ogType  = ($_product && $_product->getId()) ? 'product' : 'website';
$_ogImage = '';
if ($_product && $_product->getId()) {
    try {
        $_imgFile = $_product->getImage();
        if ($_imgFile && $_imgFile !== 'no_selection') {
            $_ogImage = (string) Mage::helper('catalog/image')->init($_product, 'image');
        }
    } catch (Exception $_e) { /* no-op */ }
}
if (!$_ogImage) {
    $_ogImage = $_curBase . '/skin/frontend/ultimo/default/images/TertiaryCoursesSingapore.png';
}
$_ogSiteName = (string) Mage::getStoreConfig('general/store_information/name') ?: 'Tertiary Courses';
?>
<meta property="og:title" content="<?php echo htmlspecialchars($_ogTitle, ENT_QUOTES, 'UTF-8'); ?>" />
<meta property="og:description" content="<?php echo htmlspecialchars($_ogDesc, ENT_QUOTES, 'UTF-8'); ?>" />
<meta property="og:url" content="<?php echo htmlspecialchars($_ogUrl, ENT_QUOTES, 'UTF-8'); ?>" />
<meta property="og:type" content="<?php echo $_ogType; ?>" />
<meta property="og:image" content="<?php echo htmlspecialchars($_ogImage, ENT_QUOTES, 'UTF-8'); ?>" />
<meta property="og:site_name" content="<?php echo htmlspecialchars($_ogSiteName, ENT_QUOTES, 'UTF-8'); ?>" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<?php echo htmlspecialchars($_ogTitle, ENT_QUOTES, 'UTF-8'); ?>" />
<meta name="twitter:description" content="<?php echo htmlspecialchars($_ogDesc, ENT_QUOTES, 'UTF-8'); ?>" />
<meta name="twitter:image" content="<?php echo htmlspecialchars($_ogImage, ENT_QUOTES, 'UTF-8'); ?>" />

<?php
/* ----------------------------------------------------------------------
 * Course JSON-LD schema (product pages only). Unlocks Google's "Course"
 * rich result — the carousel with provider/duration/price that
 * competitors get and we don't. Per Google docs, required fields are
 * name/description/provider; everything else is recommended.
 * https://developers.google.com/search/docs/appearance/structured-data/course
 * ---------------------------------------------------------------------- */
if ($_product && $_product->getId()):
    $_jsonLd = [
        '@context' => 'https://schema.org',
        '@type'    => 'Course',
        'name'     => (string) $_product->getName(),
        'description' => trim((string) ($_product->getMetaDescription()
            ?: strip_tags((string) $_product->getShortDescription())
            ?: strip_tags((string) $_product->getDescription()))),
        'url'      => $_selfCanonical,
        'provider' => [
            '@type' => 'Organization',
            'name'  => (string) (Mage::getStoreConfig('general/store_information/name') ?: 'Tertiary Courses'),
            'sameAs'=> $_curBase,
        ],
    ];
    if ($_ogImage) {
        $_jsonLd['image'] = $_ogImage;
    }
    // hasCourseInstance — required by Google as of 2023 for the Course
    // rich result to show. courseMode defaults to Blended (we offer
    // classroom + live online for every course).
    $_courseInstance = [
        '@type'      => 'CourseInstance',
        'courseMode' => 'Blended',
    ];
    $_durationHours = $_product->getResource()->getAttributeRawValue(
        $_product->getId(), 'duration', $_curStoreId
    );
    if (is_numeric($_durationHours) && (float) $_durationHours > 0) {
        // ISO 8601 duration. Course schema expects an ISO 8601 string.
        // 7.5 hours → PT7H30M; whole hours → PTnH.
        $_h = (int) floor((float) $_durationHours);
        $_m = (int) round((((float) $_durationHours) - $_h) * 60);
        $_iso = 'PT' . $_h . 'H' . ($_m > 0 ? $_m . 'M' : '');
        $_courseInstance['courseWorkload'] = $_iso;
    }
    $_jsonLd['hasCourseInstance'] = $_courseInstance;
    // Offers — price + currency from the current store.
    $_price = (float) $_product->getFinalPrice();
    if ($_price > 0) {
        $_jsonLd['offers'] = [
            '@type'         => 'Offer',
            'price'         => number_format($_price, 2, '.', ''),
            'priceCurrency' => (string) Mage::app()->getStore()->getCurrentCurrencyCode(),
            'url'           => $_selfCanonical,
            'category'      => 'Paid',
            'availability'  => 'https://schema.org/InStock',
        ];
    }
?>
<script type="application/ld+json"><?php echo json_encode($_jsonLd, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE); ?></script>
<?php endif; ?>

