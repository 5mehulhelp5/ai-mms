# Country-instance Coolify environment variables template.
# Copy this into Coolify's "Environment Variables" panel for each new country deployment.
# Replace every <placeholder> with a real value — nothing here is a working secret.
#
# Generation helpers:
#   Crypt key:          php -r "echo bin2hex(random_bytes(16));"
#   Strong password:    openssl rand -base64 24
#   API key:            openssl rand -hex 32

# ── Required: instance identity ─────────────────────────────────────────────
MMS_MODE=country
MMS_COUNTRY_CODE=GH                         # GH | MY | NG | BT | IN
MMS_BASE_URL=https://<country-domain>/      # trailing slash required
MMS_ADMIN_FRONTNAME=tigerdragon            # keep same as SG unless you want isolation

# Crypt key — generate once, pin forever (if lost, all encrypted DB values become
# undecryptable; the seed has no encrypted values, so first-boot is safe without it,
# but you must pin it before writing any encrypted config values).
MMS_CRYPT_KEY=<32-char-hex-from-php>

# ── Required: MySQL (bundled in compose stack) ───────────────────────────────
MYSQL_ROOT_PASSWORD=<strong-root-password>
MYSQL_DATABASE=mms_gh                       # e.g. mms_gh, mms_my, mms_ng
MYSQL_USER=magento
MYSQL_PASSWORD=<strong-magento-password>

# ── Required: course sync (SG → country) ────────────────────────────────────
# SG_SYNC_URL: the public URL of the SG MMS admin (trailing slash).
# SG_SYNC_API_KEY: the shared secret — must match `mmd/course_sync/api_key`
#   in SG's core_config_data (set via SG Coolify env SG_SYNC_API_KEY).
SG_SYNC_URL=https://ai-mms.tertiaryinfo.tech/
SG_SYNC_API_KEY=<shared-secret-32-char-hex>

# ── Optional: Cloudflare Turnstile (leave blank to disable captcha) ──────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Optional: Google OAuth admin login (leave blank to disable) ──────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: SMTP fallback password ─────────────────────────────────────────
SMTPPRO_SG_FALLBACK_PASSWORD=

# ── NOT set on country instances ─────────────────────────────────────────────
# R2_* vars: country instances use local-disk media (no Cloudflare R2).
# Leave all R2_* vars blank / unset. The MMD_CourseImage module switches to the
# local-disk driver automatically when MMS_MODE=country.
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
