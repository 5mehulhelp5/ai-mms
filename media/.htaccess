Options All -Indexes
Options -ExecCGI

# Disable PHP execution under every loader: classic mod_php5, modern mod_php,
# and PHP-FPM via SetHandler / proxy.
<IfModule mod_php5.c>
    php_flag engine 0
</IfModule>
<IfModule mod_php.c>
    php_flag engine 0
</IfModule>
<IfModule mod_php7.c>
    php_flag engine 0
</IfModule>
<IfModule mod_php8.c>
    php_flag engine 0
</IfModule>

# Strip every Apache handler / AddType that could route a file to PHP, then
# block direct requests to any PHP-ish extension. Defense in depth: even if a
# handler survives, the FilesMatch rule still denies the request.
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8 .phps .phar
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8 .phps .phar

<FilesMatch "(?i)\.(php[0-9s]?|phtml|phar|inc|hta(ccess|sswd))$">
    Require all denied
</FilesMatch>

# Belt and suspenders: if PHP-FPM is wired via SetHandler / proxy:fcgi, force
# the request back to the default static handler instead.
<FilesMatch "\.ph(p[0-9]?|tml|ar)$">
    SetHandler default-handler
    ForceType text/plain
</FilesMatch>

<IfModule mod_rewrite.c>
    Options +FollowSymLinks
    RewriteEngine on

    # Category banners are NOT shipped in the Docker image (media/catalog/category
    # is excluded in .dockerignore to keep the build context small) — they live on
    # Cloudflare R2, uploaded by scripts/maintenance/upload-category-images-to-r2.php.
    # When the original isn't on disk (i.e. on prod), redirect to its R2 public URL
    # instead of falling through to get.php, which 500s for an absent original and
    # breaks every category banner. On localhost the file IS present, so !-f is
    # false and this rule never fires — local dev still serves the real file.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^catalog/category/(.+)$ https://pub-77c0dec029944b0386e40673ce81081f.r2.dev/catalog/category/$1 [R=302,L]

    # never rewrite for existing files
    RewriteCond %{REQUEST_FILENAME} !-f
    # rewrite everything else to Magento's media-resize entrypoint
    RewriteRule .* ../get.php [L]
</IfModule>
