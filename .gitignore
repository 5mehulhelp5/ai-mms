# Environment secrets
.env

# Node tooling — the admin theme is pure PHP + plain CSS; no node build.
node_modules/

# Database dumps
*.sql
*.sql.gz
*.sql.gz.zip

# Site backups
*.zip
*.tar.gz

# Precompressed static asset siblings (generated at Docker build time)
skin/**/*.br
skin/**/*.gz
js/**/*.br
js/**/*.gz

# Local developer overrides (not committed — use docker-compose.override.yml)
scripts/local-dev/my-*

# Media cache (auto-generated thumbnails, regenerated by Magento)
/media/catalog/product/cache/
/media/tmp/
/media/captcha/
/media/css/
/media/js/
/media/migrations-status.json

# Var directory (cache, sessions, logs, reports)
/var/*
!/var/.htaccess

# Composer vendor
/vendor/

# Docker volumes
mysql_data/
postgres_data/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Lock files
*.LCK

# Playwright/screenshots
.playwright-mcp/
localhost-*.png

# Backup files
*-bkp-*
*.bkp
*_backup_*
*_clone.*
*_Original/
*_OLD/
*_old/
*_BACKUP/

# PHP info / test / disabled files
info.php*
*.phpdisabled

# Magento downloader
/tertiarydownloader/

# Test directories
/test/
/testing/

# Backup local Mage overrides
/app/code/local/Mage_BACKUP/
/app/code/local/Mage/

# Environment-specific config (contains credentials)
/app/etc/local.xml
/app/etc/google-drive-key.json
/docker-compose.override.yml

# Composer cache (composer.lock is tracked for reproducible builds)

# SSL/hosting/cPanel files
.well-known/
.ftpquota
.user.ini
/cgi-bin/

# Legacy/hosting directories
/tertiarycourses.sg/
/malaysia/
/includes/
/shell/
/pdf/

# Sub-migrations with SQL filename exception (override *.sql rule)
!migrations/*.sql

# Skills CLI artifacts (other editors)
.agents/
.trae/
.windsurf/
skills-lock.json

# Local backup snapshots
.site_courses_*/
site_courses_*/

# Local implementation plans
/docs/tgs-class-enrolment-implementation-plan.md

# Local-only one-off debug and dev scripts
scripts/local-dev/check-date-formats.php
scripts/local-dev/check-upcoming-runs.php
scripts/local-dev/patch-dashboard-pipeline.php
scripts/maintenance/backfill-tgs-course-run-enrolments.php

# Hitpay CSS (bundled with the extension, not committed)
skin/frontend/base/default/hitpay/css/

# Windows null-device artifact
/nul

# Magento backup files — never push (large, may contain credentials/PII)
.magento/
