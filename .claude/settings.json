{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$(jq -r '.tool_input.file_path // empty')\"; case \"$f\" in *app/code/local/MMD/MagentoCaptcha/*|*app/code/local/MMD/Leads/*|*recaptcha/contacts/form.phtml) .claude/hooks/verify-leads-capture.sh ;; esac"
          }
        ]
      }
    ]
  }
}
