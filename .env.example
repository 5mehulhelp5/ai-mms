# Docker MySQL Configuration
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=courses_backupDB
MYSQL_USER=magento
MYSQL_PASSWORD=change_me

# API Keys
KAEL_REVIEW_API_KEY=change_me
RECAPTCHA_SECRET_KEY=change_me

# SG Singapore SMTPPro fallback password (Gmail App Password for the
# sales@tertiarycourses.com.sg mailbox). Primary transport for SG is
# Gmail OAuth2; this only kicks in when OAuth is unconfigured/revoked.
# Read at container start by scripts/maintenance/ensure-smtp-fallback-passwords.php,
# encrypted, and written to smtppro/general/smtp_password @ website=1.
# Spaces are stripped, so "abcd efgh ijkl mnop" and "abcdefghijklmnop"
# are equivalent. Leave blank/unset to take no action.
SMTPPRO_SG_FALLBACK_PASSWORD=

# Google OAuth2 for admin sign-in (MMD_GoogleLogin).
# Get values from Google Cloud Console > APIs & Services > Credentials.
# The redirect URI registered there MUST exactly match:
#   https://<your-admin-domain>/tigerdragon/googlelogin/callback
# (one entry per admin domain — production AND any preview/staging).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
